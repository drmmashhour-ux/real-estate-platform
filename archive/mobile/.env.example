# Copy to `.env` in this folder (never commit `.env`):
#   cp .env.example .env
#
# Expo only exposes variables that start with EXPO_PUBLIC_ (must be UPPERCASE).
# Do not use lowercase names like expo_public_supabase_anon_key — they will not load.

# iOS Simulator: `http://localhost:3001` matches apps/web default `pnpm dev` (port 3001).
# Physical phone: use your machine's LAN IP, e.g. http://10.0.0.230:3001
# Android emulator: localhost is mapped to 10.0.2.2 automatically in dev.
# Local dev only. Store / EAS production builds MUST use HTTPS (never localhost).
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001

# Production / physical devices: deployed Next.js origin (includes `/api/*`), e.g.:
# EXPO_PUBLIC_API_BASE_URL=https://lecipm.com

# Optional Socket.IO bridge (apps/web: `pnpm run realtime:socket`, needs REDIS_URL), e.g.:
# EXPO_PUBLIC_REALTIME_URL=http://192.168.1.10:4010

# EAS production: set `EXPO_PUBLIC_API_BASE_URL` in Expo dashboard → Project → Secrets
# to your deployed API origin, e.g. https://lecipm.com (same host as Next.js `/api/*`).

# EAS / Expo Application Services (after `npm i -g eas-cli` && `eas login` && `eas init` in apps/mobile)
# EAS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Optional native build counters (else defaults in app.config.ts)
# IOS_BUILD_NUMBER=1
# ANDROID_VERSION_CODE=1
# APP_VERSION=1.0.0

# Deep link scheme (must match apps/web NEXT_PUBLIC_MOBILE_*_SCHEME for Stripe return URLs). Default: lecipm
# EXPO_PUBLIC_MOBILE_DEEP_LINK_SCHEME=lecipm

# Legal URLs (defaults in app.config.ts; override if you host policies elsewhere)
# EXPO_PUBLIC_PRIVACY_POLICY_URL=https://lecipm.com/legal/privacy
# EXPO_PUBLIC_TERMS_OF_SERVICE_URL=https://lecipm.com/legal/terms

# --- Supabase (browser-safe anon key only; never service role in the app) ---
# Same project as apps/web if you share auth: Dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: Mapbox when switching from react-native-maps (@rnmapbox/maps + prebuild)
# EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk...

# Soft launch: feedback, events, “Become a host” (does not block booking)
# EXPO_PUBLIC_SOFT_LAUNCH=true

# Splash: set to 0 to skip the elite gold-pulse transition (native splash.png unchanged).
# EXPO_PUBLIC_SPLASH_ANIMATION=0
