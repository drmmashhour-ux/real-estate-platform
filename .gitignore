# BNHub / LECIPM — global ignores (apply in all subfolders; no leading slash = recursive)

node_modules/

# Prisma generated (never commit; regenerate on install/build — Linux on Vercel)
node_modules/.prisma
src/generated/prisma
**/generated/prisma
.prisma

# Prisma engines (OS-specific)
*.dylib
*.so.node
query-engine*

.expo/
# Regenerate: cd apps/mobile && pnpm run app-icon:export
apps/mobile/assets/icon-exports/
.next/
.vercel/
dist/
out/
coverage/
.tmp/
.cache/
.env
.env.*
!.env.example
!**/.env.example
*.log
.DS_Store
apps/web/e2e-report/
apps/web/playwright-report/
apps/web/test-results/
apps/web/.integrity-report.json
apps/web/.stabilization-report.json
debug_git_status.txt
debug_missing.txt
missing_files.txt

# Local tooling / decks (do not ship to production repo)
.venv-pitch/
.venv-pitch-build/
*.pptx
.vercel
.env*.local
