generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Property {
  id              String   @id @default(uuid())
  price           Int
  city            String
  address         String
  beds            Int
  baths           Float
  sqft            Int
  propertyType    String
  createdAt       DateTime @default(now())
  ownerId         String
}