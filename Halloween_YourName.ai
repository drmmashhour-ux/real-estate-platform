%!PS-Adobe-3.0 EPSF-3.0
%%Creator: Cursor Cloud Agent
%%Title: Halloween_YourName.ai
%%BoundingBox: 0 0 800 800
%%HiResBoundingBox: 0 0 800 800
%%LanguageLevel: 2
%%Pages: 1
