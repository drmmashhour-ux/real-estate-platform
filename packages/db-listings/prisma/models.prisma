  esgProfile                       EsgProfile?
  esgEvents                        EsgEvent[]
  esgDocuments                     EsgDocument[]
  esgEvidences                     EsgEvidence[]
  esgActions                       EsgAction[]
  esgActionSnapshots               EsgActionSnapshot[]
  esgRetrofitPlans                 EsgRetrofitPlan[]
  esgRetrofitScenarios             EsgRetrofitScenario[]
  esgFinancingOptions              EsgFinancingOption[]
  esgOptimizationPlans             EsgOptimizationPlan[]
  esgOptimizationActions           EsgOptimizationAction[]
  esgOptimizationRuns              EsgOptimizationRun[]
  esgOutcomeEvents                 EsgOutcomeEvent[]
  esgOptimizationPolicies          EsgOptimizationPolicy[]
  investorMemos                    InvestorMemo[]
  investorIcPacks                  InvestorIcPack[]
  investorDecisionLogs             InvestorDecisionLog[]
  investmentPipelineDeals          InvestmentPipelineDeal[]
  postCloseAssets                  PostCloseAsset[]
