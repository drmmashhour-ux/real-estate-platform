  isIncluded         Boolean                             @default(false) @map("is_included")
  requiresApproval   Boolean                             @default(false) @map("requires_approval")
  capacityLimit      Int?                                @map("capacity_limit")
  advanceNoticeHours Int?                                @map("advance_notice_hours")
  availabilityRules  Json?                               @map("availability_rules")
  notes              String?                             @map("notes") @db.Text
  moderationStatus   BnhubListingServiceModerationStatus @default(APPROVED) @map("moderation_status")
  /// Admin hard-offer for risky listings (host cannot override).
  adminDisabled      Boolean                             @default(false) @map("admin_disabled")
  createdAt          DateTime                            @default(now()) @map("created_at")
  updatedAt          DateTime                            @updatedAt @map("updated_at")

  bookingLines BnhubBookingService[]

  @@unique([listingId, serviceId], map: "bnhub_listing_services_listing_service_key")
  @@index([listingId])
  @@index([serviceId])
  @@index([hostUserId])
  @@map("bnhub_listing_services")
}

