  brokerageSplitLinesAsPayee               BrokerageCommissionSplitLine[]           @relation("BrokerageSplitPayee")
  officeInvoicesIssuedBy                   OfficeInvoice[]                          @relation("OfficeInvoiceIssuedBy")
  officeInvoicesMarkedPaidBy               OfficeInvoice[]                          @relation("OfficeInvoiceMarkedPaidBy")
  officePayoutsApprovedBy                  OfficePayout[]                           @relation("OfficePayoutApprovedBy")
  officePayoutsPaidRecordedBy              OfficePayout[]                           @relation("OfficePayoutPaidRecordedBy")
  officeReconciliationRecordedBy           OfficeReconciliationRecord[]             @relation("OfficeReconciliationActor")
  lecipmFormInstancesAuthored              LecipmFormInstance[]                     @relation("LecipmFormInstanceAuthor")
  growthEvents                             GrowthEvent[]
  bnhubInquiryThreadsAsGuest               BnhubInquiryThread[]                     @relation("BnhubInquiryThreadGuest")
  bnhubInquiryThreadsAsHost                BnhubInquiryThread[]                     @relation("BnhubInquiryThreadHost")
  bnhubInquiryMessagesSent                 BnhubInquiryMessage[]                    @relation("BnhubInquiryMessageSender")
  autonomousActionQueuesAsBroker           AutonomousActionQueue[]                  @relation("AutonomousQueueBroker")
  autonomousApprovalDecisions              AutonomousApprovalEvent[]                @relation("AutonomousApprovalDecider")
  esgDocumentsUploaded                     EsgDocument[]                            @relation("EsgDocumentUploader")
  esgActionsAssigned                       EsgAction[]                              @relation("EsgActionAssignee")
  esgActionActivitiesLogged                EsgActionActivity[]                      @relation("EsgActionActivityActor")
  esgPortfolioActionSummaries              EsgPortfolioActionSummary[]
  esgOptimizationPoliciesOwned             EsgOptimizationPolicy[]                  @relation("EsgOptimizationPolicyOwner")
  evolutionExperimentsCreated              EvolutionSafeExperiment[]                @relation("EvolutionExperimentAuthor")
  evolutionExperimentsApproved             EvolutionSafeExperiment[]                @relation("EvolutionExperimentApprover")
  evolutionPolicyAdjustmentsReviewed       EvolutionPolicyAdjustment[]              @relation("EvolutionAdjustmentReviewer")
  /**
   * Signup / policy acceptance audit (QUÉBEC Law 25–aligned records).
   */
  userConsents                             UserConsent[]
  lecipmRegulatoryConsents                 LecipmRegulatoryConsent[]                @relation("LecipmRegulatoryConsentUser")
  lecipmRegulatoryAuditLogs                LecipmRegulatoryAuditLog[]               @relation("LecipmRegulatoryAuditActor")
  lecipmRiskDisclosureAcceptances          LecipmUserRiskDisclosureAcceptance[]     @relation("LecipmRiskDisclosureAcceptanceUser")
  /// Field demo specialist hiring (`/admin/team`) — linked when a candidate is onboarded.
  fieldTeamCandidatesLinked                FieldTeamCandidate[]                     @relation("FieldTeamCandidateLinkedUser")
  fieldSpecialistPerformance               FieldSpecialistPerformance?
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("Session")
}
