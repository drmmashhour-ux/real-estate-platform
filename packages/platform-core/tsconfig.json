{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": false,
    "noEmit": true,
    "rootDir": ".",
    "outDir": "dist"
  },
  "include": ["src/**/*.ts"]
}
