# PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/carrefour_prestige?schema=public"

# Supabase (Auth + Storage)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE

# App
NEXT_PUBLIC_APP_URL=http://localhost:3040

# External prop-tech app (same origin in dev, separate deploy in prod)
NEXT_PUBLIC_PLATFORM_APP_URL=http://localhost:3040
# Optional: full URL to investor / analyzer workspace (defaults to PLATFORM + /dashboard/investor)
# NEXT_PUBLIC_ANALYZER_APP_URL=http://localhost:3040/dashboard/investor

# Stripe (server-only)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# OpenAI (server-only)
OPENAI_API_KEY=sk-xxx

