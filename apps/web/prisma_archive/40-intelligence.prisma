model Review {
  id                    String                   @id @default(uuid())
  propertyRating        Int // 1-5 overall
  hostRating            Int? // 1-5 optional
  cleanlinessRating     Int? // 1-5 BNHub category
  accuracyRating        Int?                     @map("accuracy_rating")
  communicationRating   Int? // 1-5
  locationRating        Int? // 1-5
  valueRating           Int? // 1-5
  checkinRating         Int?                     @map("check_in_rating")
  comment               String?
  /// Guest post-stay checklist (kitchen, beds, amenities accurate, etc.)
  stayChecklistJson     Json?                    @map("stay_checklist_json")
  /// Whether advertised amenities matched reality (guest attestation).
  amenitiesAsAdvertised Boolean?                 @map("amenities_as_advertised")
  /// AI-assisted composite 0–100 for reputation / monthly medians.
  aiCompositeScore      Float?                   @map("ai_composite_score")
  aiSummary             String?                  @map("ai_summary") @db.Text
  /// When true, review is hidden from public until moderation clears.
  moderationHeld        Boolean                  @default(false) @map("moderation_held")
  /// Heuristic 0–1; higher = more spam-like (optional moderation queue).
  spamScore             Float?                   @map("spam_score")
  createdAt             DateTime
  updatedAt             DateTime                 @updatedAt
  guestId               String
  guest                 User                     @relation(fields: [guestId], references: [id], onDelete: Cascade)
  listingId             String
  listing               ShortTermListing         @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bookingId             String                   @unique
  booking               Booking                  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bnhubModeration       BnhubReviewModeration?
  bnhubAbuseReports     BnhubReviewAbuseReport[]

  @@index([listingId])
  @@index([guestId])
}

