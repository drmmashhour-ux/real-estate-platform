}

// @domain: analytics
model AutonomyOutcome {
  id          String         @id @default(cuid())
  actionId    String         @unique @map("action_id")
  action      AutonomyAction @relation(fields: [actionId], references: [id], onDelete: Cascade)
  scopeType   String         @map("scope_type") @db.VarChar(24)
  scopeId     String         @map("scope_id")
  evaluatedAt DateTime       @default(now()) @map("evaluated_at")

  baselineRevenue   Float? @map("baseline_revenue")
  baselineOccupancy Float? @map("baseline_occupancy")
  baselineBookings  Int?   @map("baseline_bookings")
  baselineAdr       Float? @map("baseline_adr")
  baselineRevpar    Float? @map("baseline_revpar")

  observedRevenue   Float? @map("observed_revenue")
  observedOccupancy Float? @map("observed_occupancy")
  observedBookings  Int?   @map("observed_bookings")
  observedAdr       Float? @map("observed_adr")
  observedRevpar    Float? @map("observed_revpar")

  revenueDelta   Float? @map("revenue_delta")
  occupancyDelta Float? @map("occupancy_delta")
  bookingDelta   Float? @map("booking_delta")
  adrDelta       Float? @map("adr_delta")
  revparDelta    Float? @map("revpar_delta")

  rewardScore          Float?                    @map("reward_score")
  /// Counterfactual baseline expectation for reward (estimate; not causal proof).
  expectedRewardScore  Float?                    @map("expected_reward_score")
  /// Learning signal blending raw outcome reward with uplift estimate (deterministic).
  upliftAdjustedReward Float?                    @map("uplift_adjusted_reward")
  counterfactualEvalId String?                   @unique @map("counterfactual_eval_id")
  counterfactualEval   CounterfactualEvaluation? @relation(fields: [counterfactualEvalId], references: [id], onDelete: SetNull)
  outcomeLabel         String?                   @map("outcome_label") @db.VarChar(24)
  outcomeWindowDays    Int                       @default(7) @map("outcome_window_days")
  notes                String?
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")

  @@index([scopeType, scopeId, createdAt])
  @@map("autonomy_outcomes")
}

// @domain: analytics
model CounterfactualEvaluation {
  id        String         @id @default(cuid())
  actionId  String         @unique @map("action_id")
  action    AutonomyAction @relation(fields: [actionId], references: [id], onDelete: Cascade)
  scopeType String         @map("scope_type") @db.VarChar(24)
  scopeId   String         @map("scope_id")

  baselineWindowDays Int @default(14) @map("baseline_window_days")
  outcomeWindowDays  Int @default(7) @map("outcome_window_days")

  observedRevenue   Float? @map("observed_revenue")
  observedOccupancy Float? @map("observed_occupancy")
  observedBookings  Int?   @map("observed_bookings")
  observedAdr       Float? @map("observed_adr")
  observedRevpar    Float? @map("observed_revpar")

  expectedRevenue   Float? @map("expected_revenue")
  expectedOccupancy Float? @map("expected_occupancy")
  expectedBookings  Float? @map("expected_bookings")
  expectedAdr       Float? @map("expected_adr")
  expectedRevpar    Float? @map("expected_revpar")

  upliftRevenue   Float? @map("uplift_revenue")
  upliftOccupancy Float? @map("uplift_occupancy")
  upliftBookings  Float? @map("uplift_bookings")
  upliftAdr       Float? @map("uplift_adr")
  upliftRevpar    Float? @map("uplift_revpar")

  upliftScore     Float?   @map("uplift_score")
  confidenceScore Float?   @map("confidence_score")
  estimateMethod  String?  @map("estimate_method") @db.VarChar(32)
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  outcome AutonomyOutcome?

  @@index([scopeType, scopeId, createdAt])
