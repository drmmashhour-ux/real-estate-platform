model PlatformInvoice {
  id                String                @id @default(uuid())
  paymentId         String                @map("payment_id")
  payment           PlatformPayment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoiceIssuer     InvoiceIssuer         @default(PLATFORM) @map("invoice_issuer")
  /**
   * Payer (PLATFORM invoice) or broker recipient (BROKER invoice).
   */
  userId            String                @map("user_id")
  user              User                  @relation("PlatformInvoiceParty", fields: [userId], references: [id], onDelete: Cascade)
  /// Unique human-facing invoice number (e.g. INV-2026-000001). Immutable once issued; tax lines are frozen at issuance.
  invoiceNumber     String                @unique @map("invoice_number")
  status            PlatformInvoiceStatus @default(ISSUED) @map("status")
  /// Product / hub attribution (mirrors `PlatformPayment.paymentType` or finer label).
  hubSource         String?               @map("hub_source")
  amountCents       Int                   @map("amount_cents")
  currency          String                @default("cad")
  pdfUrl            String?               @map("pdf_url")
  invoiceLabel      String?               @map("invoice_label") // Human-readable: Platform service invoice | Broker commission invoice
  invoiceTaxDetails Json?                 @map("invoice_tax_details") // issuer-specific; never merge both issuers in one row
  subtotalCents     Int?                  @map("subtotal_cents")
  gstCents          Int?                  @map("gst_cents")
  qstCents          Int?                  @map("qst_cents")
  totalCents        Int?                  @map("total_cents")
  invoiceLines      Json?                 @map("invoice_lines") // line items with party + tax — snapshot at issuance
  taxMode           String?               @map("tax_mode") // EXCLUSIVE | INCLUSIVE
  issuedAt          DateTime              @default(now()) @map("issued_at")
  dueAt             DateTime?             @map("due_at")
  paidAt            DateTime?             @map("paid_at")
  notes             String?               @map("notes") @db.Text
  linkedContractId  String?               @map("linked_contract_id")
  createdAt         DateTime              @default(now()) @map("created_at")

  @@unique([paymentId, invoiceIssuer])
  @@index([userId])
  @@index([paymentId])
  @@index([invoiceIssuer])
  @@index([status])
  @@map("platform_invoices")
}

