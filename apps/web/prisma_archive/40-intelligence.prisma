// @domain: analytics
model AutonomyConfig {
  id                      String   @id @default(cuid())
  scopeType               String   @map("scope_type") @db.VarChar(24)
  scopeId                 String   @map("scope_id")
  /// OFF | ASSIST | SAFE_AUTOPILOT | FULL_AUTOPILOT_APPROVAL
  mode                    String   @default("ASSIST") @db.VarChar(32)
  autoPricing             Boolean  @default(true) @map("auto_pricing")
  autoPromotions          Boolean  @default(false) @map("auto_promotions")
  autoMessaging           Boolean  @default(false) @map("auto_messaging")
  autoListingOptimization Boolean  @default(true) @map("auto_listing_optimization")
  maxPriceChangePct       Float?   @map("max_price_change_pct")
  maxDiscountPct          Float?   @map("max_discount_pct")
  minOccupancyThreshold   Float?   @map("min_occupancy_threshold")
  anomalyDropThreshold    Float?   @map("anomaly_drop_threshold")
  quietHoursStartUtc      Int?     @map("quiet_hours_start_utc")
  quietHoursEndUtc        Int?     @map("quiet_hours_end_utc")
  isEnabled               Boolean  @default(true) @map("is_enabled")
  /// Days to wait before evaluating outcomes vs current metrics (deterministic window).
  learningWindowDays      Int?     @default(7) @map("learning_window_days")
  /// Max candidate actions passed to execution per autonomy cycle (UCB1 bandit ranks candidates first).
  maxActionsPerCycle      Int?     @default(2) @map("max_actions_per_cycle")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@unique([scopeType, scopeId])
  @@index([scopeType, scopeId])
  @@map("autonomy_configs")
}

// @domain: analytics
model AutonomyAction {
  id                       String                    @id @default(cuid())
  scopeType                String                    @map("scope_type") @db.VarChar(24)
  scopeId                  String                    @map("scope_id")
  domain                   String                    @db.VarChar(32)
  actionType               String                    @map("action_type") @db.VarChar(48)
  signalKey                String?                   @map("signal_key") @db.VarChar(48)
  baselineMetricsJson      Json?                     @map("baseline_metrics_json")
  learningEligible         Boolean                   @default(true) @map("learning_eligible")
  /// Deterministic context feature buckets at selection time (Contextual Bandit audit trail).
  contextFeaturesJson      Json?                     @map("context_features_json")
  payloadJson              Json                      @map("payload_json")
  status                   String                    @db.VarChar(24)
  reason                   String?
  confidence               Float?
  createdAt                DateTime                  @default(now()) @map("created_at")
  executedAt               DateTime?                 @map("executed_at")
  outcome                  AutonomyOutcome?
  counterfactualEvaluation CounterfactualEvaluation?

  @@index([scopeType, scopeId, createdAt])
