// @domain: intelligence
model MarketingContent {
  id          String                 @id @default(cuid())
  type        MarketingContentType
  /// Primary copy: post/caption text, flattened growth ideas, or email body mirror
  content     String                 @db.Text
  /// Structured payload: ideas[], emailKind, generation context, etc.
  contentJson Json?                  @map("content_json")
  platform    String?
  topic       String?
  tone        String?
  audience    String?
  theme       String?
  status      MarketingContentStatus @default(DRAFT)
  /// Intended publish/send time — worker picks up when due
  scheduledAt DateTime?              @map("scheduled_at")
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")
  /// "openai" | "fallback" (stored as plain string)
  aiSource    String?                @map("ai_source")

  emailSubject    String? @map("email_subject")
  emailBody       String? @map("email_body") @db.Text
  emailCta        String? @map("email_cta")
  isEmailCampaign Boolean @default(false) @map("is_email_campaign")

  createdByUserId String? @map("created_by_user_id")

  /// Publish destination (set before schedule / publish now).
  publishChannel  MarketingPublishChannel? @map("publish_channel")
  publishTargetId String?                  @map("publish_target_id")
  /// When true, providers must not call live APIs (default safe).
  publishDryRun   Boolean                  @default(true) @map("publish_dry_run")

  /// A/B parent row (variant A lives here; B/C are separate rows pointing to this id).
  parentContentId String?            @map("parent_content_id")
  parentContent   MarketingContent?  @relation("MarketingContentVariants", fields: [parentContentId], references: [id], onDelete: SetNull)
  childVariants   MarketingContent[] @relation("MarketingContentVariants")
  variantLabel    String?            @map("variant_label")
  isVariant       Boolean            @default(false) @map("is_variant")
  isWinnerVariant Boolean            @default(false) @map("is_winner_variant")

  metrics     MarketingMetric[]
  publishJobs MarketingPublishJob[]

  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([scheduledAt])
  @@index([parentContentId])
  @@map("marketing_content")
}

