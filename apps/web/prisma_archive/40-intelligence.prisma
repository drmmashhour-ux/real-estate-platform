// @domain: intelligence
model Project {
  id                     String               @id @default(cuid())
  name                   String
  description            String
  city                   String
  address                String
  developer              String
  deliveryDate           DateTime
  startingPrice          Float
  status                 String // upcoming, under-construction, delivered
  propertyType           String? // family-house | condo | loft-studio | plex | intergenerational | mobile-house | fermette | chalet | land (Centris-style)
  category               String? // residential | commercial (Centris-style)
  listingType            String? // for-sale | for-rent (Centris-style)
  // Caractéristiques (filterable)
  bedroomsMin            Int? // number of rooms (bedrooms) min
  bathroomsMin           Int? // number of bathrooms min
  garageCount            Int? // number of inside garages
  parkingOutside         Int? // outside parking spaces
  storageUnit            Boolean? // storage unit or cabano
  pool                   Boolean? // piscine
  elevator               Boolean? // ascenseur
  adaptedMobility        Boolean? // adapté mobilité réduite
  waterfront             Boolean? // bord à l'eau
  waterAccess            Boolean? // accès à l'eau
  navigableWater         Boolean? // plan d'eau navigable
  resort                 Boolean? // villégiature
  petsAllowed            Boolean? // animaux acceptés
  smokingAllowed         Boolean? // fumeurs acceptés
  // Building (Superficie, Année, type)
  livingAreaMin          Int? // superficie habitable min (sqft)
  livingAreaMax          Int? // superficie habitable max (sqft)
  constructionYearMin    Int? // année de construction min
  constructionYearMax    Int? // année de construction max
  newConstruction        Boolean? // nouvelle construction
  centuryHistoric        Boolean? // centenaire/historique
  bungalow               Boolean? // plain-pied
  multiStorey            Boolean? // à étages
  splitLevel             Boolean? // paliers multiples
  detached               Boolean? // détaché
  semiDetached           Boolean? // jumelé
  attached               Boolean? // en rangée
  plexType               String? // duplex | triplex | quadruplex | quintuplex
  // Autres critères
  landAreaMin            Int? // superficie du terrain min (sqft)
  landAreaMax            Int? // superficie du terrain max (sqft)
  newSince               DateTime? // nouveau depuis (date)
  moveInDate             DateTime? // date d'emménagement
  openHouses             Boolean? // visites libres
  repossession           Boolean? // reprise de finance
  // Style de vie (Lifestyle - Centris)
  pedestrianFriendly     Boolean? // pratique piétons
  transitFriendly        Boolean? // transport en commun
  carFriendly            Boolean? // convivial automobile
  groceryNearby          Boolean? // épiceries
  primarySchoolsNearby   Boolean? // écoles primaires
  secondarySchoolsNearby Boolean? // écoles secondaires
  daycaresNearby         Boolean? // garderies
  restaurantsNearby      Boolean? // restaurants
  cafesNearby            Boolean? // cafés
  nightlifeNearby        Boolean? // nightlife
  shoppingNearby         Boolean? // magasinage
  quiet                  Boolean? // silencieux
  vibrant                Boolean? // dynamique
  heroImage              String?
  featured               Boolean              @default(false)
  featuredUntil          DateTime?
  latitude               Float?
  longitude              Float?
  createdAt              DateTime             @default(now())
  units                  ProjectUnit[]
  subscription           ProjectSubscription?
  leadPayments           ProjectLeadPayment[]
  favoriteBy             FavoriteProject[]
  reservations           ProjectReservation[]
}

