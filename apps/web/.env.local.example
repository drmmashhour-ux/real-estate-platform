# Dual DB: resolver writes DATABASE_URL (run: pnpm db:resolve) — do not set DATABASE_URL by hand in auto mode.
# Production (Vercel): set DATABASE_URL or DB_MODE=neon + PRIMARY_DATABASE_URL; do not run resolve-db-url on the server.
DB_MODE=auto
PRIMARY_DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.neon.tech:5432/neondb?sslmode=require"
LOCAL_DATABASE_URL="postgresql://postgres:postgres@localhost:5433/lecipm_dev?schema=public"
