# Copy to `.env.local` (gitignored). Replace USER/PASSWORD/host with values from Neon Dashboard → Connection.

# --- Neon (recommended for Vercel + Prisma) ---
# Pooled connection for the app (hostname usually contains `-pooler`):
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech:5432/neondb?sslmode=require"
# Optional: non-pooled “direct” URI from Neon for migrations if you use directUrl in Prisma schema elsewhere.
# DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech:5432/neondb?sslmode=require"

# Public URL — must match how you open the app (`pnpm dev` uses port 3001; `pnpm dev:3000` uses 3000).
NEXT_PUBLIC_APP_URL=http://localhost:3001

# --- Dual-DB resolver (only if you use scripts that expect DB_MODE) ---
# Production on Vercel: prefer setting DATABASE_URL directly in the dashboard instead of resolver scripts.
# DB_MODE=neon
# PRIMARY_DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech:5432/neondb?sslmode=require"
# LOCAL_DATABASE_URL="postgresql://postgres:postgres@localhost:5433/lecipm_dev?schema=public"
