# VALIDATION_PAGE_MODE=full               # Default smoke; full = all discovered example URLs (slow)
# VALIDATION_RUN_STRIPE_E2E=1             # Run BNHub Stripe script (needs server + Stripe test keys)
# VALIDATION_SKIP_DATA_INTEGRITY=1        # Skip Supabase guest booking integrity
# VALIDATION_SAMPLE_LISTING_ID=           # For dynamic route probes in full mode
# LECIPM_PLATFORM_VALIDATION_V1_REPORT_PATH=   # Admin dashboard JSON override
