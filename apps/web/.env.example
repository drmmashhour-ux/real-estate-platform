# Database (required for Prisma migrations and BNHub)
# Sanity checks (no secrets printed):
#   pnpm db:check       — warns if DATABASE_URL is not localhost / 127.0.0.1
#   DB_CHECK_STRICT=1 pnpm db:check — exit 1 if DB is remote
#   pnpm prelaunch      — db:check + validate:flows + build:web → "Ready for launch" or fail
#   pnpm validate:flows — Prisma integration pass; run after db:seed
#   ./scripts/setup-local-db.sh — create lecipm_dev, set DATABASE_URL in apps/web/.env, migrate reset + seed
#
# DEV_SAFE_MODE=true — blocks `pnpm db:migrate:reset` when DATABASE_URL is remote (use with local DB only).
# NODE_ENV=production — blocks `pnpm db:push` and `pnpm db:migrate:reset` (use migrate deploy in prod pipelines).
#
# DATABASE_URL — single source for Prisma (no Supabase Postgres fallback in app code).
# To match production (Neon), copy your pooled connection string from Neon and set locally:
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
#
# LOCAL DEV (Docker / Homebrew Postgres alternative):
# DATABASE_URL="postgresql://user:password@localhost:5432/real_estate_platform"
DATABASE_URL="postgresql://user:password@localhost:5432/real_estate_platform"
#
# PRODUCTION / SERVERLESS (Neon — Prisma + Vercel): pooled host usually contains `-pooler` and `neon.tech`.
# Password URL-encoded if it contains special chars.
# After switching (this repo has prisma/migrations): on an EMPTY Neon DB run `pnpm prisma migrate deploy` — it applies every migration.
# Use `pnpm prisma db push` only for quick local experiments (skips migration history; not recommended for prod).
# Supabase Auth / Storage: keep NEXT_PUBLIC_SUPABASE_* and SUPABASE_SERVICE_ROLE_KEY — only Postgres moves to Neon.

# --- AI / autopilot rollout (optional; see docs/ai/AUTOPILOT_ROLLOUT_PLAN.md) ---
# LECIPM_AI_AUTONOMY_KILL_SWITCH=1  — hard-off: no DB read; all autonomy reads return safe defaults (automations off, kill switch on).
# LECIPM_HOST_AUTOPILOT_API_ENABLED=0 — blocks POST /api/ai/host-autopilot/run (emergency brake; unset = enabled).
# LECIPM_AI_LEARNING_ENABLED=0 — optional gate for learning surfaces (unset = enabled).
# LECIPM_AI_DECISION_RANKING_ENABLED=0 — optional gate for ranking (unset = enabled).

# Public browse uses real DB only. If /listings is empty locally, run:
#   pnpm seed:demo          — 10 published BNHub stays + insurance partner/sample lead (see scripts/seed-demo-data.ts)
#   pnpm seed:qa-blockers   — minimal FSBO + BNHub stay for QA
#   pnpm db:seed            — full simulation seed (includes guest@demo.com for booking tests)

# Playwright admin smoke (matches prisma seed admin@demo.com when using full seed):
# E2E_ADMIN_EMAIL=admin@demo.com
# E2E_ADMIN_PASSWORD=AdminDemo2024!

# --- Environment label (client) — use "staging" on the staging Vercel project only ---
# NEXT_PUBLIC_ENV=production
# NEXT_PUBLIC_ENV=staging

# --- Staging: ranking → fraud → scale (apply all web Prisma migrations to staging DB first) ---
# Executive daily cycle (KPI snapshot, entity scores, bottlenecks, recommendations). Keep auto-actions off until reviewed.
# AI_EXECUTIVE_CONTROL_ENABLED=1
# AI_EXECUTIVE_AUTO_ACTIONS_ENABLED=0
# Discovery / conversion: explainable listing ranking + ranking-linked executive recs when enabled.
# AI_RANKING_ENGINE_ENABLED=1
# Trust: LECIPM rule-based fraud (score/flag/admin queue). Soft penalty & review hold default off.
# AI_FRAUD_DETECTION_ENABLED=1
# AI_FRAUD_SOFT_RANKING_PENALTY_ENABLED=0
# AI_FRAUD_REVIEW_HOLD_ENABLED=0
# After deploy, inspect the latest recommendation set (uses DATABASE_URL from this .env):
#   pnpm --filter @lecipm/web run inspect:executive-daily
#   pnpm --filter @lecipm/web run inspect:executive-daily -- --query-only
# Full staging validation pass (stops at first failure if DB is behind schema):
#   pnpm validate:staging-stack

# Staging-only middleware (only when NEXT_PUBLIC_ENV=staging): optional login wall + role allowlist
# NEXT_PUBLIC_STAGING_REQUIRE_LOGIN=1
# NEXT_PUBLIC_STAGING_ROLE_GATE=1
# NEXT_PUBLIC_STAGING_ALLOWED_ROLES=USER,CLIENT,TESTER,ADMIN,ACCOUNTANT

# Staging demo login button + POST /api/auth/staging-demo-login
# STAGING_DEMO_LOGIN=1
# NEXT_PUBLIC_SHOW_STAGING_DEMO_LOGIN=1
# DEMO_LOGIN_EMAIL=demo@platform.com

# --- E2E / QA test mode (Stripe test keys + banner + stricter checkout guard) ---
# Client + server: enables TestModeBanner, extra structured logs, blocks live Stripe secrets on checkout.
# NEXT_PUBLIC_APP_MODE=test
# Seed deterministic @test.com users + listings (from apps/web): pnpm seed:test
# Password for all four: TestMode2026!  (admin / host / broker / user @test.com)
# Optional: while dev server is up, HTTP smoke for key routes:
# TEST_E2E_BASE_URL=http://127.0.0.1:3001 pnpm test:e2e:checklist

# --- Investor / live demo presentation (safe browsing) ---
# Set both so server + client agree: Stripe mocked, emails logged, risky API writes blocked (see proxy.ts).
# DEMO_MODE=1
# NEXT_PUBLIC_DEMO_MODE=1
# After seed (npm run demo:full), use login page "Investor demo" quick buttons (Demo123!) or POST /api/auth/demo-login.
# Safe demo mode (legacy aliases): mock email, disable Stripe in lib/stripe.ts, write guards via allowlist
# DEMO_MODE=false
# NEXT_PUBLIC_DEMO_MODE=0
# Enables POST /api/auth/demo-login + login-page quick buttons (with NEXT_PUBLIC_DEMO_MODE or staging).

# --- Staging daily reset (see docs/DEMO_RESET_AND_ANALYTICS.md) ---
# CRON_SECRET=...   # Vercel Cron + /api/cron/* + internal demo-event; must match Authorization: Bearer
# Behavior-learning ranking (BNHub stays): set to 1 to blend cached behavior scores into recommended/AI sort. POST /api/internal/learning/run aggregates events (same Bearer).
# BEHAVIOR_LEARNING_RANK_ENABLED=0
# POST /api/cron/growth-seo-daily — refreshes `SeoPageContent` for all growth cities (programmatic SEO mesh).
# Optional: create one rotating weekly `SeoBlogPost` when set to 1.
# GROWTH_WEEKLY_BLOG=0
# AI marketing engine daily cron: /api/cron/ai-marketing-engine-daily (also in vercel.json). Optional weekly SEO blog row + Instagram queue.
# MARKETING_ENGINE_WEEKLY_BLOG=0
# MARKETING_ENGINE_INSTAGRAM=0
# POST /api/marketing-engine/track — Bearer secret for incrementing clicks/engagements/conversions on generated rows
# MARKETING_ENGINE_TRACK_SECRET=...

# --- Admin marketing publish pipeline (see docs/marketing/auto-posting.md) ---
# Internal/test email sends via existing Resend (RESEND_API_KEY + EMAIL_FROM). No mass consumer mail.
# MARKETING_EMAIL_LIVE_SEND=1          # required for real sends; otherwise email adapter dry-runs
# MARKETING_EMAIL_TO=ops@a.com,qa@b.com   # comma-separated; else falls back to BROKER_EMAIL / notification path
# MARKETING_SOCIAL_LIVE_SEND=1         # reserved; social adapters are stubs until OAuth — leave unset
# Cron: /api/cron/marketing-publish-due (vercel.json) uses CRON_SECRET; processes only publishDryRun=false rows

# --- Insurance leads (POST /api/insurance/leads) ---
# Partners live in `insurance_partners` (Prisma). First active partner receives lead emails via Resend/SendGrid (same as EMAIL_FROM).
# If no active partner exists, optional fallback notify inbox (internal ops — not shown to end users):
# INSURANCE_OPS_EMAIL=ops@yourcompany.com
# Optional salt for hashing IPs on funnel events (`insurance_lead_funnel_events.ip_hash`):
# INSURANCE_FUNNEL_IP_SALT=long-random-string

# Safe auto-close (hourly /api/cron/auto-close-worker): both must be 1 to execute. Admin can pause in /admin/autoclose.
# AI_AUTOCLOSE_ENABLED=0
# AI_AUTOCLOSE_SAFE_MODE=1
# Optional tuning: AI_AUTOCLOSE_STALE_USER_HOURS=36  AI_AUTOCLOSE_LEAD_INTENT_MIN=55  AI_AUTOCLOSE_INACTIVITY_DEDUPE_HOURS=72
# Investor metrics CAC (30d): optional marketing spend CAD for /admin/investor KPI display
# INVESTOR_MARKETING_SPEND_30D=0
# DEMO_RESET_KEEP_EMAILS=demo@platform.com
# Default includes canonical demo emails from lib/demo/demo-account-constants.ts (sarah@prestige.demo, …)

# Design Studio: price per saved design in cents (e.g. 500 = $5). Income is recorded as BillingEvent DESIGN_SAVED.
# DESIGN_STUDIO_PRICE_CENTS=500
# Design Studio: free trial length in days for all visitors, brokers, clients, partners (default 7).
# DESIGN_STUDIO_TRIAL_DAYS=7

# --- LECIPM system validation (admin CLI + /admin/system-validation) ---
# Never set TEST_MODE on production web traffic. Use a dedicated QA database.
# TEST_MODE=true
# SYSTEM_VALIDATION_USER_PASSWORD=min-12-chars-strong-password
# Optional: allow runner on staging with NODE_ENV=production (rare)
# LECIPM_ALLOW_SYSTEM_VALIDATION_IN_PRODUCTION=true
# Optional: npm run test:system-validation skips 50-user probe when set
# SKIP_SCALING=1
# Refuses automated billing simulation if set (use Playwright + Stripe test cards instead)
# LECIPM_E2E_REAL_STRIPE_CHECKOUT=true

# -----------------------------------------------------------------------------
# Stripe — test vs live (strict alignment)
# -----------------------------------------------------------------------------
# Use ONLY apps/web/.env for these (no .env.local overrides). All three keys must
# be from the SAME Stripe account and SAME mode (all test, or all live). Never commit real values.
# BNHub booking uses Stripe Connect (destination charges). See docs/STRIPE_CONNECT_VALIDATION.md
#
# --- Recommended: local / QA (test mode, real money OFF) ---
# Dashboard toggle: Test mode. Developers → API keys → Secret key starts sk_test_
# STRIPE_SECRET_KEY=sk_test_xxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# Buyer listing paywall: hide FSBO/CRM representative phone & email until Stripe lead checkout completes (`listing_contact_lead`).
# LISTING_CONTACT_PAYWALL_ENABLED=true
# Local forward: stripe listen --forward-to http://127.0.0.1:3001/api/stripe/webhook (paste the NEW whsec each listen session; restart Next).
# If CLI never shows "--> checkout.session.completed": stripe logout && stripe login (same Dashboard account as sk_test_*). If CLI shows the event but logs say Invalid signature: whsec mismatch.
# Prove Connect is on for this key: from apps/web run  pnpm run verify:stripe-connect
#
# --- Optional: pilot / production (live mode, real money ON) ---
# Dashboard toggle: Live mode. Secret must be sk_live_… — never put pk_live_ in STRIPE_SECRET_KEY.
# STRIPE_SECRET_KEY=sk_live_xxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# Create a Live webhook endpoint pointing to https://YOUR_DOMAIN/api/stripe/webhook and copy its signing secret.
# Enable Connect in Live: Dashboard → Connect (same account). Onboard hosts with real Connect Express + bank details.
# If keys were ever pasted in chat or screenshots, roll the secret key in Dashboard before going live.
#
# Other Stripe dashboard tokens (e.g. ids starting with mk_) are not read by this app unless Stripe docs say to wire them.
#
# Optional: Price lookup_keys for POST /api/stripe/subscription-by-lookup (subscription Checkout demo).
# STRIPE_SUBSCRIPTION_LOOKUP_KEYS_ALLOWLIST=starter_monthly
# Default unit price (CAD dollars) for assigned CRM leads when using broker billing (`BrokerMonetizationProfile.leadPrice`).
# BROKER_ASSIGNED_LEAD_DEFAULT_PRICE=100
# LECIPM workspace SaaS (Checkout paymentType lecipm_workspace_subscription) — Price id from Products.
# STRIPE_PRICE_LECIPM_PRO=price_xxx
# Optional: Stripe Price lookup_key for workspace subscription checkout (orchestrated + AdminHub billing)
# STRIPE_SUBSCRIPTION_CHECKOUT_LOOKUP_KEY=lecipm_pro_monthly
# Staging only: allow QA seed admin login in prod-like env (default: blocked for admin@test.com)
# ALLOW_SEED_ADMIN_LOGIN=1
# Allow pnpm seed:qa-blockers against production DB (strongly discouraged)
# ALLOW_QA_SEED_IN_PRODUCTION=1
# Optional: Customer Portal configuration id from Stripe Dashboard → Settings → Customer portal
# STRIPE_BILLING_PORTAL_CONFIGURATION_ID=bpc_xxx
# Clover Hosted Checkout (orchestrator / office_payment) — set merchant + private token for real sessions
# CLOVER_MERCHANT_ID=
# CLOVER_PRIVATE_TOKEN=           # Ecommerce API token (Bearer added automatically if omitted)
# CLOVER_API_BASE_URL=            # default: api.clover.com or apisandbox.dev.clover.com when CLOVER_SANDBOX=1
# CLOVER_SANDBOX=1
# CLOVER_STRICT=1                 # if set, do not fall back to placeholder when API fails
# CLOVER_WEBHOOK_SIGNING_SECRET=  # Hosted Checkout webhook HMAC (Dashboard → Hosted Checkout → Webhook)
# Legacy placeholder (dev only when creds unset):
# CLOVER_CHECKOUT_BASE_URL=http://localhost:3001
# CLOVER_CHECKOUT_PATH=/payments/clover-placeholder
# Base URL for success/cancel redirects (default `pnpm dev` in apps/web uses port 3001)
NEXT_PUBLIC_APP_URL=http://localhost:3001
#
# Mobile guest BNHub: Stripe Checkout for Supabase `bookings` via POST /api/stripe/checkout with body `{ "bookingId": "<uuid>" }` only.
# Requires NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY so the server can read/verify booking totals.
# Optional: Stripe currency for guest Supabase mobile checkout (default cad).
# STRIPE_GUEST_SUPABASE_BOOKING_CURRENCY=cad
# BNHub guest checkout — itemized platform fee + upsells (separate Stripe line items + webhook v2 metadata). When unset, legacy single-line checkout (accommodation only).
# BNHUB_CHECKOUT_ITEMIZED_FEES=1
# BNHUB_SERVICE_FEE_BASE_BPS=800
# BNHUB_SERVICE_FEE_PEAK_EXTRA_BPS=200
# BNHUB_UPSELL_INSURANCE_CENTS=1999
# BNHUB_UPSELL_EARLY_CHECKIN_CENTS=2500
# BNHUB_UPSELL_LATE_CHECKOUT_CENTS=2500
#
# Smart marketplace — city landing AI strip (template; uses OpenAI when OPENAI_API_KEY is set)
# MARKETPLACE_AI_CITY_COPY=1
# MARKETPLACE_CITY_COPY_MODEL=gpt-4o-mini
#
# Cron: GET /api/cron/bnhub-marketplace-loop with Authorization: Bearer <secret>
# BNHUB_MARKETPLACE_CRON_SECRET=...
#
# Soft launch — GET /api/ready/soft-launch (or `pnpm run validate:soft-launch-status`)
# SOFT_LAUNCH_MIN_LISTINGS=10
# SOFT_LAUNCH_STRICT=1   # exit 1 unless webhook + inventory + sample quality pass
# For anonymous guest booking during pilot, leave identity gate off or at zero:
# BNHUB_BOOKING_IDENTITY_VERIFICATION_MIN_TOTAL_USD=0
#
# Seed Supabase listings: apps/mobile/docs/supabase-soft-launch-seed.sql
# Smoke test booking: BNHUB_SMOKE_LISTING_ID=b1111111-1111-4111-8111-111111111101
# Deep link scheme for /payment-success and /payment-cancel “open app” buttons (matches Expo `scheme` in apps/mobile/app.config.ts)
# NEXT_PUBLIC_MOBILE_APP_SCHEME=lecipm
# Alias for the same scheme (either may be set):
# NEXT_PUBLIC_MOBILE_DEEP_LINK_SCHEME=lecipm

# Copilot: optional OpenAI Responses API layer for summarization only (deterministic data computed first).
# COPILOT_USE_RESPONSES_API=false
# COPILOT_RESPONSES_MODEL=gpt-4.1-mini

# Google Analytics 4 (optional — loads only when set; pairs with client events in lib/tracking.ts)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Mortgage experts: Stripe Price IDs (Dashboard → Products → Price API id price_...)
# STRIPE_PRICE_MORTGAGE_BASIC_MONTHLY=price_xxx
# STRIPE_PRICE_MORTGAGE_PRO_MONTHLY=price_xxx
# STRIPE_PRICE_MORTGAGE_PREMIUM_MONTHLY=price_xxx
# One unit = one pay-per-lead credit (Checkout quantity = pack size).
# STRIPE_PRICE_MORTGAGE_LEAD_CREDIT_UNIT=price_xxx
# Optional: after closing a deal, transfer expert share to their Connect account (requires available Stripe balance).
# STRIPE_ENABLE_MORTGAGE_EXPERT_TRANSFERS=false

# BNHub short-term rentals: platform commission rate (decimal). Default 0.15 = 15% platform, 85% host share before Stripe fees.
# BNHUB_COMMISSION_RATE=0.15

# BNHub Growth / Autopilot safety (optional — unset caps = no aggregate daily budget enforcement)
# BNHUB_GROWTH_DEFAULT_DAILY_SPEND_CAP_CENTS=50000
# BNHUB_GROWTH_LAUNCH_COOLDOWN_MINUTES=360
# BNHUB_GROWTH_PUBLISH_MAX_ATTEMPTS=5
# BNHUB_GROWTH_PUBLISH_LOCK_BASE_SECONDS=60
# Optional Expo push access token for BNHub mobile guest notifications.
# EXPO_ACCESS_TOKEN=your_expo_access_token
# Cron + internal automation: use header `x-bnhub-growth-secret` (Next /api/internal/bnhub-growth/*, Supabase Edge).
# Legacy admin cron routes may still send `x-cron-secret` — same secret value, compared with timing-safe equality server-side.
# BNHUB_GROWTH_CRON_SECRET=...
# Base URL for Supabase Edge Functions invoking LECIPM (no trailing slash)
# LECIPM_API_BASE_URL=https://your-deployment.example.com

# BNHub marketplace engine: internal cron `POST /api/internal/bnhub-marketplace/daily-payout-scan` header `x-bnhub-marketplace-cron`
# Supabase: `supabase/functions/bnhub-daily-payout-release-scan`
# BNHUB_MARKETPLACE_CRON_SECRET=...

# Webhooks & connectors (server-only — never NEXT_PUBLIC_*)
# META_APP_SECRET=...
# GOOGLE_LEAD_WEBHOOK_TOKEN=...
# TIKTOK_WEBHOOK_SECRET=...
# WHATSAPP_BUSINESS_TOKEN=...

# Optional: demo user IDs for testing BNHub without full auth
# Create users via seed or sign-up, then set these to their IDs.
# NEXT_PUBLIC_DEMO_GUEST_ID=
# NEXT_PUBLIC_DEMO_HOST_ID=

# Platform tax registration (server-only — do NOT use NEXT_PUBLIC_*).
# Used when building invoices; merged with Admin → Finance → Platform settings (DB wins when set).
# PLATFORM_LEGAL_NAME="Your Legal Entity Inc."
# PLATFORM_GST_NUMBER="123456789RT0001"
# PLATFORM_QST_NUMBER="1234567890TQ0001"
# Optional note printed on invoices (e.g. small supplier wording — confirm with your accountant).
# PLATFORM_TAX_REGISTRATION_NOTE=
# Invoice line tax interpretation: EXCLUSIVE (default) or INCLUSIVE
# INVOICE_TAX_MODE=EXCLUSIVE

# Investment hub / valuation APIs (AMF risk) — default off. Also toggle in Admin → Platform financial settings.
# INVESTMENT_FEATURES_ENABLED=false

# FSBO publish: premium tier default $199 (overrides Basic $99 via FSBO_PUBLISH_PRICE_CENTS)
# FSBO_PREMIUM_PUBLISH_PRICE_CENTS=19900

# --- FSBO listing photos ---
# Client (already used elsewhere): NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY
# Server uploads: create a public bucket (default name `fsbo-media`) and service role key (Dashboard → Settings → API).
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Required for `/api/mobile/v1/me` and other mobile JWT verification (server-only).
# Optional bucket override:
# FSBO_SUPABASE_BUCKET=fsbo-media
# Private bucket for seller supporting documents (PDF, ID, invoices). Path: userId/listingId/file.
# SELLER_DOCUMENTS_SUPABASE_BUCKET=seller-documents
#
# BNHub listing gallery uploads (POST /api/bnhub/listing-media/upload). Create Storage bucket `listing-media` (public read).
# BNHUB_LISTING_MEDIA_UPLOAD_SECRET=...
# Optional: require government ID verification for guest bookings when total (USD) is >= this amount (0 = off).
# BNHUB_BOOKING_IDENTITY_VERIFICATION_MIN_TOTAL_USD=1500
# BNHub escrow: hours after check-in before host payout is scheduled (default 240 ≈ 10 days). Range e.g. 168–336 for 7–14d.
# BNHUB_ESCROW_RELEASE_HOURS_AFTER_CHECKIN=240
#
# Absolute URLs for locally stored files under public/uploads (optional; path-absolute URLs work without this):
# NEXT_PUBLIC_APP_ORIGIN=http://localhost:3001

# --- Mortgage: single primary broker (all /api/mortgage/request leads route here) ---
# Set real partner contact; DB row is synced on each new lead (plan pro, isPrimary true).
# MORTGAGE_PRIMARY_BROKER_NAME=Partner Name
# MORTGAGE_PRIMARY_BROKER_EMAIL=partner@example.com
# MORTGAGE_PRIMARY_BROKER_PHONE=+1 514 555 0100
# MORTGAGE_PRIMARY_BROKER_COMPANY=Your brokerage name
# Fallback if MORTGAGE_PRIMARY_BROKER_EMAIL unset:
# BROKER_EMAIL=partner@example.com

# --- Broker CRM: assign /evaluate leads to primary broker (optional) ---
# PRIMARY_BROKER_USER_ID=cuid_of_verified_broker_user
# PRIMARY_BROKER_EMAIL=mohamed@example.com

