# --- Platform assistant (voice + chat; in-app search & help) — public flags, default on ---
# Set to 0 or false to disable. See lib/ai/assistant-config.ts
# NEXT_PUBLIC_PLATFORM_ASSISTANT_ENABLED=1
# NEXT_PUBLIC_PLATFORM_ASSISTANT_VOICE=1
# NEXT_PUBLIC_PLATFORM_ASSISTANT_TTS=1
