# Database (required for Prisma migrations and BNHub)
# Sanity checks (no secrets printed):
#   pnpm db:check       — warns if DATABASE_URL is not localhost / 127.0.0.1
#   DB_CHECK_STRICT=1 pnpm db:check — exit 1 if DB is remote
#   pnpm prelaunch      — db:check + validate:flows + build:web → "Ready for launch" or fail
#   pnpm validate:flows — Prisma integration pass; run after db:seed
#   ./scripts/setup-local-db.sh — create lecipm_dev, set DATABASE_URL in apps/web/.env, migrate reset + seed
#
# DEV_SAFE_MODE=true — blocks `pnpm db:migrate:reset` when DATABASE_URL is remote (use with local DB only).
# NODE_ENV=production — blocks `pnpm db:push` and `pnpm db:migrate:reset` (use migrate deploy in prod pipelines).
#
# LOCAL DEV (recommended): use Docker Postgres or `brew services start postgresql@16` and point here.
# Prefer `pnpm db:migrate:reset` from repo root (guarded) instead of raw `prisma migrate reset`.
DATABASE_URL="postgresql://user:password@localhost:5432/real_estate_platform"

# --- Environment label (client) — use "staging" on the staging Vercel project only ---
# NEXT_PUBLIC_ENV=production
# NEXT_PUBLIC_ENV=staging

# --- Staging: ranking → fraud → scale (apply all web Prisma migrations to staging DB first) ---
# Executive daily cycle (KPI snapshot, entity scores, bottlenecks, recommendations). Keep auto-actions off until reviewed.
# AI_EXECUTIVE_CONTROL_ENABLED=1
# AI_EXECUTIVE_AUTO_ACTIONS_ENABLED=0
# Discovery / conversion: explainable listing ranking + ranking-linked executive recs when enabled.
# AI_RANKING_ENGINE_ENABLED=1
# Trust: LECIPM rule-based fraud (score/flag/admin queue). Soft penalty & review hold default off.
# AI_FRAUD_DETECTION_ENABLED=1
# AI_FRAUD_SOFT_RANKING_PENALTY_ENABLED=0
# AI_FRAUD_REVIEW_HOLD_ENABLED=0
# After deploy, inspect the latest recommendation set (uses DATABASE_URL from this .env):
#   pnpm --filter @lecipm/web run inspect:executive-daily
#   pnpm --filter @lecipm/web run inspect:executive-daily -- --query-only
# Full staging validation pass (stops at first failure if DB is behind schema):
#   pnpm validate:staging-stack

# Staging-only middleware (only when NEXT_PUBLIC_ENV=staging): optional login wall + role allowlist
# NEXT_PUBLIC_STAGING_REQUIRE_LOGIN=1
# NEXT_PUBLIC_STAGING_ROLE_GATE=1
# NEXT_PUBLIC_STAGING_ALLOWED_ROLES=USER,CLIENT,TESTER,ADMIN,ACCOUNTANT

# Staging demo login button + POST /api/auth/staging-demo-login
# STAGING_DEMO_LOGIN=1
# NEXT_PUBLIC_SHOW_STAGING_DEMO_LOGIN=1
# DEMO_LOGIN_EMAIL=demo@platform.com

# --- Investor / live demo presentation (safe browsing) ---
# Set both so server + client agree: Stripe mocked, emails logged, risky API writes blocked (see proxy.ts).
# DEMO_MODE=1
# NEXT_PUBLIC_DEMO_MODE=1
# After seed (npm run demo:full), use login page "Investor demo" quick buttons (Demo123!) or POST /api/auth/demo-login.
# Safe demo mode (legacy aliases): mock email, disable Stripe in lib/stripe.ts, write guards via allowlist
# DEMO_MODE=false
# NEXT_PUBLIC_DEMO_MODE=0
# Enables POST /api/auth/demo-login + login-page quick buttons (with NEXT_PUBLIC_DEMO_MODE or staging).

# --- Staging daily reset (see docs/DEMO_RESET_AND_ANALYTICS.md) ---
# CRON_SECRET=...   # Vercel Cron + /api/cron/* + internal demo-event; must match Authorization: Bearer
# DEMO_RESET_KEEP_EMAILS=demo@platform.com
# Default includes canonical demo emails from lib/demo/demo-account-constants.ts (sarah@prestige.demo, …)

# Design Studio: price per saved design in cents (e.g. 500 = $5). Income is recorded as BillingEvent DESIGN_SAVED.
# DESIGN_STUDIO_PRICE_CENTS=500
# Design Studio: free trial length in days for all visitors, brokers, clients, partners (default 7).
# DESIGN_STUDIO_TRIAL_DAYS=7

# --- LECIPM system validation (admin CLI + /admin/system-validation) ---
# Never set TEST_MODE on production web traffic. Use a dedicated QA database.
# TEST_MODE=true
# SYSTEM_VALIDATION_USER_PASSWORD=min-12-chars-strong-password
# Optional: allow runner on staging with NODE_ENV=production (rare)
# LECIPM_ALLOW_SYSTEM_VALIDATION_IN_PRODUCTION=true
# Optional: npm run test:system-validation skips 50-user probe when set
# SKIP_SCALING=1
# Refuses automated billing simulation if set (use Playwright + Stripe test cards instead)
# LECIPM_E2E_REAL_STRIPE_CHECKOUT=true

# Stripe: Checkout + webhook (test mode). Get keys from Stripe Dashboard → API keys.
# STRIPE_SECRET_KEY must be the Secret key (starts with sk_test_). Never put pk_test_ here.
# STRIPE_SECRET_KEY=sk_test_xxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Webhook signing secret (Developers → Webhooks → Add endpoint → signing secret). Required to confirm payment and unlock.
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# LECIPM workspace SaaS (Checkout paymentType lecipm_workspace_subscription) — Price id from Products.
# STRIPE_PRICE_LECIPM_PRO=price_xxx
# Base URL for success/cancel redirects (use port 3000 with default `npm run dev`)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Copilot: optional OpenAI Responses API layer for summarization only (deterministic data computed first).
# COPILOT_USE_RESPONSES_API=false
# COPILOT_RESPONSES_MODEL=gpt-4.1-mini

# Google Analytics 4 (optional — loads only when set; pairs with client events in lib/tracking.ts)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Mortgage experts: Stripe Price IDs (Dashboard → Products → Price API id price_...)
# STRIPE_PRICE_MORTGAGE_BASIC_MONTHLY=price_xxx
# STRIPE_PRICE_MORTGAGE_PRO_MONTHLY=price_xxx
# STRIPE_PRICE_MORTGAGE_PREMIUM_MONTHLY=price_xxx
# One unit = one pay-per-lead credit (Checkout quantity = pack size).
# STRIPE_PRICE_MORTGAGE_LEAD_CREDIT_UNIT=price_xxx
# Optional: after closing a deal, transfer expert share to their Connect account (requires available Stripe balance).
# STRIPE_ENABLE_MORTGAGE_EXPERT_TRANSFERS=false

# BNHub short-term rentals: platform commission rate (decimal). Default 0.15 = 15% platform, 85% host share before Stripe fees.
# BNHUB_COMMISSION_RATE=0.15

# BNHub Growth / Autopilot safety (optional — unset caps = no aggregate daily budget enforcement)
# BNHUB_GROWTH_DEFAULT_DAILY_SPEND_CAP_CENTS=50000
# BNHUB_GROWTH_LAUNCH_COOLDOWN_MINUTES=360
# BNHUB_GROWTH_PUBLISH_MAX_ATTEMPTS=5
# BNHUB_GROWTH_PUBLISH_LOCK_BASE_SECONDS=60
# Cron + internal automation: use header `x-bnhub-growth-secret` (Next /api/internal/bnhub-growth/*, Supabase Edge).
# Legacy admin cron routes may still send `x-cron-secret` — same secret value, compared with timing-safe equality server-side.
# BNHUB_GROWTH_CRON_SECRET=...
# Base URL for Supabase Edge Functions invoking LECIPM (no trailing slash)
# LECIPM_API_BASE_URL=https://your-deployment.example.com

# BNHub marketplace engine: internal cron `POST /api/internal/bnhub-marketplace/daily-payout-scan` header `x-bnhub-marketplace-cron`
# Supabase: `supabase/functions/bnhub-daily-payout-release-scan`
# BNHUB_MARKETPLACE_CRON_SECRET=...

# Webhooks & connectors (server-only — never NEXT_PUBLIC_*)
# META_APP_SECRET=...
# GOOGLE_LEAD_WEBHOOK_TOKEN=...
# TIKTOK_WEBHOOK_SECRET=...
# WHATSAPP_BUSINESS_TOKEN=...

# Optional: demo user IDs for testing BNHub without full auth
# Create users via seed or sign-up, then set these to their IDs.
# NEXT_PUBLIC_DEMO_GUEST_ID=
# NEXT_PUBLIC_DEMO_HOST_ID=

# Platform tax registration (server-only — do NOT use NEXT_PUBLIC_*).
# Used when building invoices; merged with Admin → Finance → Platform settings (DB wins when set).
# PLATFORM_LEGAL_NAME="Your Legal Entity Inc."
# PLATFORM_GST_NUMBER="123456789RT0001"
# PLATFORM_QST_NUMBER="1234567890TQ0001"
# Optional note printed on invoices (e.g. small supplier wording — confirm with your accountant).
# PLATFORM_TAX_REGISTRATION_NOTE=
# Invoice line tax interpretation: EXCLUSIVE (default) or INCLUSIVE
# INVOICE_TAX_MODE=EXCLUSIVE

# Investment hub / valuation APIs (AMF risk) — default off. Also toggle in Admin → Platform financial settings.
# INVESTMENT_FEATURES_ENABLED=false

# FSBO publish: premium tier default $199 (overrides Basic $99 via FSBO_PUBLISH_PRICE_CENTS)
# FSBO_PREMIUM_PUBLISH_PRICE_CENTS=19900

# --- FSBO listing photos ---
# Client (already used elsewhere): NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY
# Server uploads: create a public bucket (default name `fsbo-media`) and service role key (Dashboard → Settings → API).
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Required for `/api/mobile/v1/me` and other mobile JWT verification (server-only).
# Optional bucket override:
# FSBO_SUPABASE_BUCKET=fsbo-media
# Private bucket for seller supporting documents (PDF, ID, invoices). Path: userId/listingId/file.
# SELLER_DOCUMENTS_SUPABASE_BUCKET=seller-documents
# Absolute URLs for locally stored files under public/uploads (optional; path-absolute URLs work without this):
# NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000

# --- Mortgage: single primary broker (all /api/mortgage/request leads route here) ---
# Set real partner contact; DB row is synced on each new lead (plan pro, isPrimary true).
# MORTGAGE_PRIMARY_BROKER_NAME=Partner Name
# MORTGAGE_PRIMARY_BROKER_EMAIL=partner@example.com
# MORTGAGE_PRIMARY_BROKER_PHONE=+1 514 555 0100
# MORTGAGE_PRIMARY_BROKER_COMPANY=Your brokerage name
# Fallback if MORTGAGE_PRIMARY_BROKER_EMAIL unset:
# BROKER_EMAIL=partner@example.com

# --- Broker CRM: assign /evaluate leads to primary broker (optional) ---
# PRIMARY_BROKER_USER_ID=cuid_of_verified_broker_user
# PRIMARY_BROKER_EMAIL=mohamed@example.com

# --- TrustGraph Autopilot (verification engine + admin queue) ---
# Master switch. When true, sub-flags below default ON unless explicitly set to false.
# TRUSTGRAPH_ENABLED=true
# Optional overrides (unset = on when TRUSTGRAPH_ENABLED=true):
# TRUSTGRAPH_ADMIN_QUEUE_ENABLED=false
# TRUSTGRAPH_LISTING_BADGE_ENABLED=false
# TRUSTGRAPH_BROKER_BADGE_ENABLED=false
# TRUSTGRAPH_DECLARATION_WIDGET_ENABLED=false

# --- AI Deal Analyzer (deterministic; Phase 1+2) ---
# DEAL_ANALYZER_ENABLED=true
# Phase 2 feature flags (require DEAL_ANALYZER_ENABLED=true):
# DEAL_ANALYZER_COMPS_ENABLED=true
# DEAL_ANALYZER_SCENARIOS_ENABLED=true
# DEAL_ANALYZER_PORTFOLIO_ENABLED=true
# DEAL_ANALYZER_BNHUB_MODE_ENABLED=true
# Optional tuning (see config/dealAnalyzer.ts):
# DEAL_ANALYZER_COMP_RADIUS_KM=35
# DEAL_ANALYZER_MIN_COMP_COUNT=3
# DEAL_ANALYZER_BNHUB_DEFAULT_OCCUPANCY=0.55
# Phase 3 — decision + action layer (require DEAL_ANALYZER_ENABLED=true):
# DEAL_ANALYZER_OFFER_ASSISTANT_ENABLED=true
# DEAL_ANALYZER_MORTGAGE_MODE_ENABLED=true
# DEAL_ANALYZER_ALERTS_ENABLED=true
# DEAL_ANALYZER_PRICING_ADVISOR_ENABLED=true
# DEAL_ANALYZER_STRATEGY_MODES_ENABLED=true
# Optional Phase 3 tuning (see config/dealAnalyzer.ts):
# DEAL_ANALYZER_OFFER_MIN_PCT=0.92
# DEAL_ANALYZER_AFFORD_LIKELY_MAX=0.28
# DEAL_ANALYZER_ALERT_SCORE_DELTA=5
#
# Phase 4 — automation + market adaptation (require DEAL_ANALYZER_ENABLED=true):
# DEAL_ANALYZER_AUTO_REFRESH_ENABLED=true
# DEAL_ANALYZER_REGION_RULES_ENABLED=true
# DEAL_ANALYZER_NEGOTIATION_PLAYBOOKS_ENABLED=true
# DEAL_ANALYZER_REPRICING_TRIGGERS_ENABLED=true
# DEAL_ANALYZER_PORTFOLIO_MONITORING_ENABLED=true
# Optional Phase 4 tuning (see config/dealAnalyzer.ts phase4):
# DEAL_ANALYZER_REFRESH_STALE_HOURS=72
# DEAL_ANALYZER_REFRESH_MIN_HOURS=24
# DEAL_ANALYZER_REFRESH_PRICE_CHANGE_PCT=0.02
# DEAL_ANALYZER_REGION_DENSE_RADIUS_KM=12
# DEAL_ANALYZER_REGION_SPARSE_RADIUS_KM=45
# DEAL_ANALYZER_MC_SELLER_MIN_COMPS=5
# DEAL_ANALYZER_MC_STALE_DAYS=45
# DEAL_ANALYZER_REPRICE_STALE_DAYS=60
# DEAL_ANALYZER_MONITOR_OPP_DELTA=5
# DEAL_ANALYZER_MONITOR_TRUST_DELTA=6
#
# --- Real estate Copilot (Phase 5 — routes to Deal Analyzer + TrustGraph; suggests only) ---
# COPILOT_ENABLED=true
# COPILOT_INVESTOR_ENABLED=true
# COPILOT_BROKER_ENABLED=true
# COPILOT_SELLER_ENABLED=true
# COPILOT_PORTFOLIO_ENABLED=true
# Optional: reserved for future hosted intent classifier (strict JSON schema only)
# COPILOT_INTENT_LLM_ENABLED=false

# --- LECIPM Growth Automation (OAuth + encrypted tokens + review-first publish) ---
# AES-256-GCM key for oauth_access_token_encrypted / oauth_refresh_token_encrypted (64 hex chars = 32 bytes).
# GROWTH_TOKEN_ENCRYPTION_KEY=
# Dev-only fallback (16+ chars); prefer GROWTH_TOKEN_ENCRYPTION_KEY in production.
# GROWTH_TOKEN_ENCRYPTION_SECRET=
# Human review: new drafts default to PENDING_REVIEW unless GROWTH_HUMAN_REVIEW=0
# GROWTH_HUMAN_REVIEW=1
# Block bulk auto-publish until explicitly enabled
# GROWTH_AUTO_PUBLISH_ALL_CHANNELS=0
# GROWTH_PUBLISH_MAX_RETRIES=3
# Email adapter: default recipient when draft.metadata.emailTo is missing
# GROWTH_EMAIL_DEFAULT_TO=
# Blog adapter: HTTPS webhook for CMS publish (optional Bearer via GROWTH_BLOG_PUBLISH_TOKEN)
# GROWTH_BLOG_PUBLISH_URL=
# GROWTH_BLOG_PUBLISH_TOKEN=
# OAuth refresh (set per provider you use): GOOGLE_OAUTH_CLIENT_ID, GOOGLE_OAUTH_CLIENT_SECRET,
# LINKEDIN_CLIENT_ID, LINKEDIN_CLIENT_SECRET, META_APP_ID, META_APP_SECRET, TIKTOK_CLIENT_KEY, TIKTOK_CLIENT_SECRET

# --- Growth funnel (LECIPM) — first-value sim, paywall, analytics ---
# Optional: force demo listing for /growth/first-value (otherwise first published FSBO is used).
# GROWTH_FIRST_VALUE_LISTING_ID=
# Free-tier caps (pro/basic bypass in app).
# GROWTH_FREE_SIMULATOR_RUNS=8
# GROWTH_FREE_AI_DRAFTS=15
# Closing / paywall overrides (optional — take precedence over GROWTH_* when set)
# CLOSING_SIMULATIONS_LIMIT=3
# CLOSING_DRAFTS_LIMIT=10
# USAGE_RESET_PERIOD=lifetime
# USAGE_RESET_PERIOD=monthly

# --- LECIPM AI avatar explainer (production) — HeyGen / D-ID video + ElevenLabs voice ---
# Video face: upload or record in HeyGen/D-ID, then drive with API text. Do not present as a real human.
# LECIPM_AVATAR_VIDEO_PROVIDER=none
# LECIPM_AVATAR_VIDEO_PROVIDER=heygen
# LECIPM_AVATAR_VIDEO_PROVIDER=did
# Optional: block request until MP4 URL ready (dev only; use webhooks in prod)
# LECIPM_AVATAR_VIDEO_SYNC_POLL=0
# LECIPM_AVATAR_VIDEO_SYNC_POLL_MS=45000
#
# HeyGen — https://docs.heygen.com/ (x-api-key, v2/video/generate)
# HEYGEN_API_KEY=
# HEYGEN_AVATAR_ID=
# HEYGEN_VOICE_ID=
#
# D-ID — https://docs.d-id.com/ (Basic auth, POST /talks)
# DID_API_KEY=
# DID_SOURCE_IMAGE_URL=https://cdn.example.com/your-face.jpg
# DID_SCRIPT_TTS_TYPE=microsoft
# DID_SCRIPT_VOICE_ID=en-US-JennyNeural
#
# ElevenLabs — voice clone or stock (server-side TTS; keep keys server-only)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
#
# DB `avatar_profiles.style_config` JSON overrides (optional): heygenAvatarId, heygenVoiceId, didSourceImageUrl
