# Growth autonomy — bounded learning loop (ranking / advisory visibility only; see docs/growth/growth-autonomy-learning-loop.md)
# FEATURE_GROWTH_AUTONOMY_LEARNING_V1=1              # Observe outcomes + adjust suggestion ordering within guardrails
# FEATURE_GROWTH_AUTONOMY_LEARNING_PANEL_V1=1        # Operator panel for effectiveness + controls (internal)
# GROWTH_AUTONOMY_LEARNING_MAX_UP=0.06               # Max positive weight delta per category (clamped)
# GROWTH_AUTONOMY_LEARNING_MAX_DOWN=0.08             # Max negative weight delta per category (clamped)
# GROWTH_AUTONOMY_LEARNING_MIN_OBS=12                # Min impressions before effectiveness / learning moves (sparse => insufficient_data)
# GROWTH_AUTONOMY_LEARNING_IGNORE_SUPPRESS=0.72      # Ignored/shown rate to trigger temporary soft-hide (with poor effectiveness)
# GROWTH_AUTONOMY_LEARNING_NEG_SUPPRESS=0.45         # Negative feedback rate threshold for down-weight (needs enough feedback volume)
# GROWTH_AUTONOMY_LEARNING_COOLDOWN_MS=86400000      # Suppression duration (ms) before category can resurface in advisory tier
# GROWTH_AUTONOMY_LEARNING_STEP_UP=0.015             # Increment on positive signals (bounded by MAX_UP)
# GROWTH_AUTONOMY_LEARNING_STEP_DOWN=0.02            # Decrement on weak/poor signals (bounded by MAX_DOWN)
#
