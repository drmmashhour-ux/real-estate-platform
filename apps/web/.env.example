# --- Host conversion & revenue intelligence (LECIPM web — default off) ---
# Maps to `config/feature-flags.ts` — enable per environment for gradual rollout.
# FEATURE_PRICING_ENGINE_V1=1          # unified pricing snapshot + /api/pricing/calculate + transparency UI
# FEATURE_MONETIZATION_ENGINE_V1=1     # monetization block on GET /api/pricing (revenue streams)
# FEATURE_GTM_ENGINE_V1=1              # POST /api/gtm/script, /api/gtm/pitch + founder/broker sales surfaces
# Short aliases (also enable v1 surfaces — see `lecipmMonetizationSystemV1` in config/feature-flags.ts):
# FEATURE_PRICING_V1=1
# FEATURE_MONETIZATION_V1=1
# FEATURE_ROI_V1=1
# FEATURE_GTM_V1=1
# FEATURE_LECIPM_STRIPE_MONETIZATION_API_V1=1   # POST /api/stripe/create-checkout-session + create-subscription
# FEATURE_PRICING_ENGINE_V2=1          # pricing v2 recommendPriceV2 (recommendation-only; internal signals)
# FEATURE_ROI_CALCULATOR_V1=1          # POST /api/roi/calculate, /api/roi/host, /api/roi/broker + ROI UI
# FEATURE_PRICING_MODEL_V1=1          # GET /api/pricing/plans + host pricing copy
# FEATURE_HOST_ONBOARDING_FUNNEL_V1=1 # POST /api/hosts/* sessions, leads, import queue
# FEATURE_HOST_CONVERSION_SURFACES_V1 # /hosts landing + conversion CTAs (often paired with onboarding)
# Optional LECIPM plan fee overrides (see modules/business/pricing-model.constants.ts):
# LECIPM_FREE_BOOKING_FEE_PERCENT=0.03
# LECIPM_PRO_BOOKING_FEE_PERCENT=0.07
# LECIPM_GROWTH_BOOKING_FEE_PERCENT=0.05
# LECIPM_GROWTH_MONTHLY_SUBSCRIPTION_CENTS=9900

