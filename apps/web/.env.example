# FEATURE_REGION_ADAPTERS_V1=1
# FEATURE_REGION_AWARE_AUTONOMY_V1=1
# FEATURE_GLOBAL_DOMINATION_V1=1

# =============================================================================
# LECIPM phased rollout — institutional stack (see docs/LECIPM-ROLLOUT.md)
# Default unset/false = gated APIs return safe empty payloads + rollout metadata.
# For full local stack during development, set all to 1 after prior phases validated.
# =============================================================================
# FEATURE_ESG_V1=1
# FEATURE_INVESTOR_V1=1
# FEATURE_DEALS_V1=1
# FEATURE_CAPITAL_V1=1
# FEATURE_CLOSING_V1=1
# FEATURE_PORTFOLIO_V1=1
# FEATURE_EXECUTIVE_V1=1
# Smoke scripts: VALIDATION_BASE_URL=http://127.0.0.1:3001 pnpm exec tsx scripts/phase-all-validation.ts

# --- Legal documents engine (versioned templates, broker approval before dispatch) ---
# LECIPM_LEGAL_DOCUMENTS_ENGINE=0 — set to 0/false to disable /api/documents/* (default: enabled when unset).
# LECIPM_INVESTMENT_LEGAL_DOC_COMPLIANCE_STRICT=1 — investment-domain dispatch also requires admin POST .../investment-compliance.
# LECIPM_REQUIRE_DIGITAL_SIGNATURE_FOR_APPROVAL=0 — disable broker hash-matched e-sign gate before document approval (default: required when unset).

# --- Multi-App Production Deployment ---
NEXT_PUBLIC_APP_URL=https://lecipm.com
NEXT_PUBLIC_BNHUB_URL=https://bnhub.lecipm.com
NEXT_PUBLIC_BROKER_URL=https://broker.lecipm.com
NEXT_PUBLIC_ADMIN_URL=https://admin.lecipm.com
NEXT_PUBLIC_COOKIE_DOMAIN=.lecipm.com
