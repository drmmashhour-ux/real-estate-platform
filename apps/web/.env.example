# DEV_AUTO_LOGIN=true                      # Bypass session guard for dashboard validation (requires NODE_ENV=development)
# DEV_AUTO_LOGIN_USER_ID=                  # Optional: force which User.id the bypass uses (must exist; ADMIN for requireAdminSession)
# DEV_LOGIN_USER_ID=                       # Optional: which admin /api/dev-login signs in as
