# FEATURE_DEAL_EXECUTION_V1=1
# FEATURE_SIGNATURE_SYSTEM_V1=1
# FEATURE_CONDITION_TRACKING_V1=1
# FEATURE_EXECUTION_AUTOPILOT_V1=1
# FEATURE_CLIENT_DEAL_VIEW_V1=1
#
# Production pipeline — real e-sign providers, Québec notary coordination, closing readiness (default off).
# FEATURE_SIGNATURE_REAL_PROVIDERS_V1=1
# FEATURE_NOTARY_SYSTEM_V1=1
# FEATURE_CLOSING_PIPELINE_V1=1
#
# DocuSign (JWT): DOCUSIGN_INTEGRATION_KEY, DOCUSIGN_USER_ID, DOCUSIGN_PRIVATE_KEY (PEM or base64),
# DOCUSIGN_REST_BASE (e.g. https://demo.docusign.net/restapi), DOCUSIGN_ACCOUNT_ID
# Optional: DOCUSIGN_OAUTH_BASE, DOCUSIGN_OAUTH_AUDIENCE
# Webhooks: DOCUSIGN_CONNECT_HMAC_SECRET — Connect sends raw JSON; verify HMAC header x-docusign-signature-1
#
# PandaDoc: PANDADOC_API_KEY, PANDADOC_API_BASE (default https://api.pandadoc.com/public/v1)
# PANDADOC_WEBHOOK_SECRET — compared to header from PANDADOC_WEBHOOK_SIGNATURE_HEADER (default pandadoc-signature)
#
# --- Escrow / trust workflow + deal ledger + negotiation copilot (broker-gated) ---
# FEATURE_TRUST_WORKFLOW_V1=1
# FEATURE_PAYMENT_AUTOMATION_V1=1
# FEATURE_DEAL_LEDGER_V1=1
# FEATURE_NEGOTIATION_COPILOT_V1=1
# FEATURE_PP_CP_NEGOTIATION_BRIDGE_V1=1
# Optional: STRIPE_PAYMENT_REQUEST_ENABLED=1 (future Stripe payment-request wiring)

# --- Global multi-region (shared `@lecipm/platform-core` + regional adapters) — default off ---
