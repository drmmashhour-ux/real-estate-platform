# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
#
# DB `avatar_profiles.style_config` JSON overrides (optional): heygenAvatarId, heygenVoiceId, didSourceImageUrl

