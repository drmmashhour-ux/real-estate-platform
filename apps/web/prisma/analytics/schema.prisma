  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("field_specialist_performance")
}

model DemoBooking {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  city        String?
  experience  String?
  status      String   @default("scheduled") // scheduled, completed, no_show, cancelled
  refId       String?  @map("ref_id")
  scheduledAt DateTime @default(now()) @map("scheduled_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([email])
  @@map("demo_bookings")
}

model BrokerActivation {
  id             String   @id @default(cuid())
  brokerId       String   @unique @map("broker_id")
  createdDraft   Boolean  @default(false) @map("created_draft")
  usedAI         Boolean  @default(false) @map("used_ai")
  completedDraft Boolean  @default(false) @map("completed_draft")
  firstPayment   Boolean  @default(false) @map("first_payment")
  assistMode     Boolean  @default(false) @map("assist_mode")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([brokerId])
  @@map("broker_activations")
}

model ExecutiveReport {
  id           String                @id @default(cuid())
  createdAt    DateTime              @default(now()) @map("created_at")
  periodKey    String                @map("period_key") @db.VarChar(32)
  generatedAt  DateTime              @default(now()) @map("generated_at")
  reportJson   Json                  @map("report_json") @db.JsonB
  summaryText  String                @map("summary_text") @db.Text
  status       ExecutiveReportStatus @default(GENERATED)
  errorMessage String?               @map("error_message") @db.Text

  @@index([periodKey, generatedAt(sort: Desc)])
  @@map("executive_reports")
}

model ExecutiveReportSchedule {
  id             String                           @id @default(cuid())
  createdAt      DateTime                         @default(now()) @map("created_at")
  frequency      ExecutiveReportScheduleFrequency
  recipientsJson Json                             @map("recipients_json") @db.JsonB
  lastRunAt      DateTime?                        @map("last_run_at") @db.Timestamptz(6)
  isActive       Boolean                          @default(true) @map("is_active")

  @@index([isActive])
  @@map("executive_report_schedules")
}

model SystemAuditLog {
  id          String   @id @default(cuid())
  userId      String?  @map("user_id")
  action      String // DRAFT_CREATE | NOTICE_ACK | AI_CORRECT | AUTOPILOT_ACT | SIGN_ATTEMPT | SIGN_BLOCK
  entityType  String   @map("entity_type") // DRAFT | DEAL | LEAD | NOTICE
  entityId    String?  @map("entity_id")
  payloadJson Json?    @map("payload_json") @db.JsonB
  traceId     String?  @map("trace_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@map("system_audit_logs")
}

model DocumentHash {
  id         String   @id @default(cuid())
  entityType String   @map("entity_type") // DRAFT_PDF | DEAL_PDF
  entityId   String   @map("entity_id")
  hash       String // SHA-256
  version    Int      @default(1)
  metadata   Json?    @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([entityType, entityId, version])
  @@map("document_hashes")
}