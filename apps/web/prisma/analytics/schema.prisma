model Lead {
  id                            String                         @id @default(cuid())
  name                          String
  email                         String
  phone                         String
  message                       String
  listingId                     String? // listing or project context
  /**
   * When inquiry originates from FSBO Buyer Hub — links to `FsboListing`.
   */
  fsboListingId                 String?                        @map("fsbo_listing_id")
  /**
   * BNHub short-term listing when the CRM lead is tied to a stay (distinct from broker CRM `listingId`).
   */
  shortTermListingId            String?                        @map("short_term_listing_id")
  /**
   * Denormalized LEC code when lead is tied to a ShortTermListing.
   */
  listingCode                   String?                        @map("listing_code")
  projectId                     String?
  status                        String
  /**
   * Combined / form + behavior AI score 0–100 (rule-based; not ML).
   */
  score                         Int
  /**
   * Traffic / marketing attribution (URL ?source= / UTM, or "direct").
   */
  source                        String?
  /**
   * Campaign name from ?campaign= or utm_campaign.
   */
  campaign                      String?
  /**
   * Medium from ?medium= or utm_medium (e.g. cpc, social).
   */
  medium                        String?
  utmTerm                       String?                        @map("utm_term") @db.VarChar(256)
  utmContent                    String?                        @map("utm_content") @db.VarChar(256)
  /**
   * Single acquisition tag (e.g. broker_interest) — distinct from marketing `source`.
   */
  growthTag                     String?                        @map("growth_tag") @db.VarChar(64)
  referrerUrl                   String?                        @map("referrer_url") @db.Text
  /**
   * Capture channel: listing, contact, ai_chat, form, ad, referral, other, mortgage_inquiry
   */
  leadSource                    String?                        @map("lead_source")
  /**
   * Distribution attribution: LECIPM (platform) vs CENTRIS (syndicated) when known.
   */
  distributionChannel           String?                        @map("distribution_channel") @db.VarChar(32)
  /**
   * Funnel label: mortgage | null for legacy CRM rows
   */
  leadType                      String?                        @map("lead_type")
  assignedExpertId              String?                        @map("assigned_expert_id")
  /**
   * mortgage marketplace: open = unclaimed pool; null = normal flow
   */
  mortgageMarketplaceStatus     String?                        @map("mortgage_marketplace_status")
  /**
   * Mortgage form payload: amount, timeline, propertyType, etc.
   */
  mortgageInquiry               Json?                          @map("mortgage_inquiry")
  /**
   * Last known AI tier snapshot: hot | warm | cold
   */
  aiTier                        String?                        @map("ai_tier")
  /**
   * Linked platform user for behavior scoring when known.
   */
  userId                        String?                        @map("user_id")
  /**
   * Structured explainability: { formReasons[], behaviorPoints, mergedScore }.
   */
  aiExplanation                 Json?                          @map("ai_explanation")
  /**
   * Autopilot leads layer (optional; gated; does not replace legacy `score` / CRM priority fields).
   */
  aiScore                       Float?                         @map("lead_ai_score")
  aiPriority                    String?                        @map("lead_ai_priority") @db.VarChar(16)
  aiTags                        Json?                          @map("lead_ai_tags")
  aiLastUpdated                 DateTime?                      @map("lead_ai_last_updated")
  aiExecutionVersion            String?                        @map("lead_ai_execution_version") @db.VarChar(16)
  contactUnlockedAt             DateTime?                      @map("contact_unlocked_at")
  /// Broker/user who paid to unlock contact (Stripe `lead_unlock`); distinct from `introducedByBrokerId`.
  contactUnlockedByUserId       String?                        @map("contact_unlocked_by_user_id")
  introducedByBrokerId          String?                        @map("introduced_by_broker_id")
  lastFollowUpByBrokerId        String?                        @map("last_follow_up_by_broker_id")
  lastFollowUpAt                DateTime?                      @map("last_follow_up_at")
  createdAt                     DateTime                       @default(now())
  updatedAt                     DateTime                       @updatedAt @map("updated_at")
  leadStatus                    String                         @default("NEW") @map("lead_status")
  purchasedByBrokerId           String?                        @map("purchased_by_broker_id")
  /**
   * Sales pipeline: new | contacted | qualified | meeting | negotiation | won | lost (legacy: follow_up)
   */
  pipelineStatus                String                         @default("new") @map("pipeline_status")
  /**
   * Duplicate of stage label for reporting / future split from legacy status strings
   */
  pipelineStage                 String                         @default("new") @map("pipeline_stage")
  optedOutOfFollowUp            Boolean                        @default(false) @map("opted_out_of_follow_up")
  /**
   * Denormalized deal value (e.g. from evaluation estimate), dollars CAD.
   */
  dealValue                     Int?                           @map("deal_value")
  /**
   * Revenue optimization: estimated opportunity value (CAD), often from purchase price.
   */
  estimatedValue                Int?                           @map("estimated_value")
  /**
   * Heuristic 0–1 close probability from tiering model.
   */
  conversionProbability         Float?                         @map("conversion_probability")
  /**
   * How estimated value / tier was derived (mortgage_form, ai_rule, admin).
   * Note: traffic attribution remains in `source` / UTM fields.
   */
  valueSource                   String?                        @map("value_source")
  /**
   * HIGH | MEDIUM | LOW — monetization & expert routing tier.
   */
  revenueTier                   String?                        @map("revenue_tier")
  /**
   * Credits charged when this lead is assigned (auto-assign or marketplace claim).
   */
  mortgageCreditCost            Int                            @default(1) @map("mortgage_credit_cost")
  /**
   * Dynamic internal price for this lead (cents CAD) — reporting / future billing.
   */
  dynamicLeadPriceCents         Int?                           @map("dynamic_lead_price_cents")
  /**
   * Per-service platform commission at close (0–1). Mortgage leads default 0.30.
   */
  serviceCommissionRate         Float?                         @map("service_commission_rate")
  /**
   * When assigned to a mortgage expert (auto or claim).
   */
  mortgageAssignedAt            DateTime?                      @map("mortgage_assigned_at")
  /**
   * After first SLA nudge for uncontacted assigned leads.
   */
  mortgageSlaReminderAt         DateTime?                      @map("mortgage_sla_reminder_at")
  /**
   * Mortgage funnel A/B variant (e.g. A | B).
   */
  revenueAbVariant              String?                        @map("revenue_ab_variant")
  /**
   * Client-indicated city/region for demand pricing & city reports.
   */
  purchaseRegion                String?                        @map("purchase_region")
  /**
   * Estimated broker commission in dollars (dealValue × configurable rate).
   */
  commissionEstimate            Int?                           @map("commission_estimate")
  /**
   * Last time broker contacted this lead (outreach / follow-up logged).
   */
