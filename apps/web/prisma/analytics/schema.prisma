model SeoPageOpportunity {
  id                 String    @id @default(cuid())
  slug               String    @unique @db.VarChar(256)
  pageType           String    @map("page_type") @db.VarChar(64)
  city               String?   @db.VarChar(128)
  neighborhood       String?   @db.VarChar(128)
  propertyType       String?   @map("property_type") @db.VarChar(64)
  /// SALE | RENT | SHORT_TERM | etc.
  transactionType    String?   @map("transaction_type") @db.VarChar(24)
  budgetMinCents     Int?      @map("budget_min_cents")
  budgetMaxCents     Int?      @map("budget_max_cents")
  bedroomCount       Int?      @map("bedroom_count")
  /// e.g. city_property | neighborhood_budget | bnhub_destination
  pageFamily         String?   @map("page_family") @db.VarChar(64)
  inventoryCount     Int       @default(0) @map("inventory_count")
  opportunityScore   Float     @default(0) @map("opportunity_score")
  /// Sub-scores + notes (inventoryStrength, uniqueness, freshness, …)
  seoScoresJson      Json?     @map("seo_scores_json")
  duplicateRiskScore Float?    @map("duplicate_risk_score")
  lastEvaluatedAt    DateTime? @map("last_evaluated_at")
  status             String    @default("candidate") @db.VarChar(24)
  metadataJson       Json      @default("{}") @map("metadata_json")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  draft       SeoPageDraft?
  publishLogs SeoPagePublishLog[]
  refreshJobs SeoPageRefreshJob[]

  @@index([inventoryCount])
  @@index([opportunityScore])
  @@index([pageFamily])
  @@map("seo_page_opportunities")
}

