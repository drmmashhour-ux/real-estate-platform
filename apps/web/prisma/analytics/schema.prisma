model Booking {
  id                              String                          @id @default(uuid())
  /**
   * Immutable internal reference (e.g. BKG-000001) for admin, finance, support — distinct from guest `confirmationCode`.
   */
  bookingCode                     String?                         @unique @map("booking_code")
  /**
   * Guest-facing confirmation code (e.g. BNH-ABC123), unique when set.
   */
  confirmationCode                String?                         @unique @map("confirmation_code")
  checkIn                         DateTime
  checkOut                        DateTime
  /// Number of occupied nights; equals row count in `BookingNight` when synced. `checkOut` is exclusive (see docs).
  nights                          Int
  totalCents                      Int // Total price in cents (before fees)
  guestFeeCents                   Int                             @default(0)
  hostFeeCents                    Int                             @default(0)
  /**
   * Immutable guest-quote snapshots (minor units / cents) captured at booking creation — do not recompute from listing.
   * subtotal = pre-tax, pre-guest-service-fee stay + add-ons; fees = guest service fee; taxes = lodging taxes; total = full charge.
   */
  priceSnapshotSubtotalCents      Int?                            @map("price_snapshot_subtotal_cents")
  priceSnapshotFeesCents          Int?                            @map("price_snapshot_fees_cents")
  priceSnapshotTaxesCents         Int?                            @map("price_snapshot_taxes_cents")
  priceSnapshotTotalCents         Int?                            @map("price_snapshot_total_cents")
  status                          BookingStatus                   @default(PENDING)
  guestNotes                      String?
  /**
   * Optional guest asks (airport pickup, late check-in, etc.) — shown to host in calendar / booking UI.
   */
  specialRequest                  String?                         @map("special_request")
  /**
   * Structured special requests (airport pickup, parking, shuttle, extras).
   */
  specialRequestsJson             Json?                           @map("special_requests_json")
  /// Host confirmed arrival checklist items are ready before guest check-in.
  checklistDeclaredByHostAt       DateTime?                       @map("checklist_declared_by_host_at")
  checkedInAt                     DateTime? // actual check-in time (booking-service)
  checkedOutAt                    DateTime? // actual check-out time (booking-service)
  refunded                        Boolean                         @default(false) @map("refunded")
  refundedAt                      DateTime?                       @map("refunded_at")
  createdAt                       DateTime                        @default(now())
  updatedAt                       DateTime                        @updatedAt
  guestId                         String
  listingId                       String
  /// Origin channel — BNHub remains source of truth; external = imported or mirrored from OTA
  bookingSource                   BnhubBookingSource              @default(LOCAL) @map("booking_source")
  payment                         Payment?
  review                          Review?
  ledgerEntries                   LedgerEntry[]
  payoutHolds                     PayoutHold[]
  contracts                       Contract[]
  platformCommissionRecords       PlatformCommissionRecord[]
  platformLegalDisputes           PlatformLegalDispute[]
  /**
   * Transactional email tracking (BNHub); failures do not block booking.
   */
  guestConfirmationEmailSentAt    DateTime?                       @map("guest_confirmation_email_sent_at")
  guestInvoiceEmailSentAt         DateTime?                       @map("guest_invoice_email_sent_at")
  hostBookingAlertEmailSentAt     DateTime?                       @map("host_booking_alert_email_sent_at")
  internalCrmTelemetryEvents      InternalCrmEvent[]              @relation("CrmEventBooking")
  insuranceLeads                  InsuranceLead[]
  shareSessions                   ShareSession[]
  manualPaymentSettlement         ManualPaymentSettlement         @default(NOT_APPLICABLE) @map("manual_payment_settlement")
  manualPaymentUpdatedAt          DateTime?                       @map("manual_payment_updated_at")
  manualPaymentUpdatedByUserId    String?                         @map("manual_payment_updated_by_user_id")
  aiDisputeRiskLogs               AiDisputeRiskLog[]
  /// Guest count for the stay (distinct from `User` account).
  guestsCount                     Int?                            @map("guests_count")
  guestContactEmail               String?                         @map("guest_contact_email")
  guestContactName                String?                         @map("guest_contact_name")
  guestContactPhone               String?                         @map("guest_contact_phone")
  cancellationReason              String?                         @map("cancellation_reason") @db.Text
  canceledAt                      DateTime?                       @map("canceled_at")
  /// When set, unpaid `PENDING` bookings past this instant are expired for overlap + checkout.
  pendingCheckoutExpiresAt        DateTime?                       @map("pending_checkout_expires_at")
  /// Optional first-touch UTM snapshot when set from verified server flows (e.g. post-payment).
  growthAttributionJson           Json?                           @map("growth_attribution_json")
  /// BNHub messaging read receipts + host response stats (see migration `20260422140000_bnhub_inquiry_threads`).
  guestLastReadBookingMessagesAt  DateTime?                       @map("guest_last_read_booking_messages_at")
  hostLastReadBookingMessagesAt   DateTime?                       @map("host_last_read_booking_messages_at")
  bnhubHostAvgBookingResponseMs   Int?                            @map("bnhub_host_avg_booking_response_ms")
  bnhubHostBookingResponseSamples Int                             @default(0) @map("bnhub_host_booking_response_samples")
  /// Optional LECIPM workspace tenant (multi-tenant / white-label).
  tenantId                        String?                         @map("tenant_id") @db.VarChar(36)
  tenant                          Tenant?                         @relation("BnhubBookingWorkspaceTenant", fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([guestId])
  @@index([listingId])
  @@index([tenantId])
  @@index([status])
  @@index([checkIn])
  @@index([listingId, checkIn, checkOut])
  @@index([bookingSource])
  @@index([pendingCheckoutExpiresAt])
}

