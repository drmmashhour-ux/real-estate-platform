   * Scheduled client meeting.
   */
  meetingAt                     DateTime?                      @map("meeting_at")
  meetingCompleted              Boolean                        @default(false) @map("meeting_completed")
  /**
   * When marked won: final sale price & commission (dollars).
   */
  finalSalePrice                Int?                           @map("final_sale_price")
  finalCommission               Int?                           @map("final_commission")
  dealClosedAt                  DateTime?                      @map("deal_closed_at")
  /**
   * Strong engagement: call/WhatsApp click, repeat visits, etc.
   */
  highIntent                    Boolean                        @default(false) @map("high_intent")
  /**
   * Direct-message lifecycle: none | sent | replied
   */
  dmStatus                      String                         @default("none") @map("dm_status")
  /**
   * Daily execution / outreach coaching: contacted | replied | follow_up_sent | demo_booked
   */
  outreachCoachingStage         String?                        @map("outreach_coaching_stage")
  lastDmAt                      DateTime?                      @map("last_dm_at")
  /**
   * Rule-based engagement points (CTA clicks, automation).
   */
  engagementScore               Int                            @default(0) @map("engagement_score")
  /**
   * LECIPM elite CRM — composite 0–100 (Trust + Deal + urgency + legacy score).
   */
  lecipmLeadScore               Int?                           @map("lecipm_lead_score")
  lecipmDealQualityScore        Int?                           @map("lecipm_deal_quality_score")
  lecipmTrustScore              Int?                           @map("lecipm_trust_score")
  lecipmUrgencyScore            Int?                           @map("lecipm_urgency_score")
  /**
   * Elite pipeline: new_lead | contacted | qualified | visit_scheduled | offer_made | closed
   */
  lecipmCrmStage                String?                        @default("new_lead") @map("lecipm_crm_stage")
  /**
   * Action-driven CRM execution layer (0–100 sub-scores; refreshed from telemetry + behavior).
   */
  intentScore                   Int                            @default(0) @map("crm_intent_score")
  urgencyScore                  Int                            @default(0) @map("crm_urgency_score")
  trustScore                    Int                            @default(0) @map("crm_trust_score")
  frictionScore                 Int                            @default(0) @map("crm_friction_score")
  lastActivityAt                DateTime?                      @map("crm_last_activity_at")
  nextBestAction                String?                        @map("crm_next_best_action")
  priorityScore                 Int                            @default(0) @map("crm_priority_score")
  /**
   * Real-time close pipeline: browsing | viewing_property | inquiry_sent | broker_connected | booking_started | negotiation | closed | lost
   */
  executionStage                String                         @default("browsing") @map("crm_execution_stage")
  lecipmScoresComputedAt        DateTime?                      @map("lecipm_scores_computed_at")
  /**
   * Denormalized: HOT | WARM | COLD (synced with score + engagement).
   */
  scoreLevel                    String?                        @map("score_level")
  /**
   * Eval drip: none | drip_scheduled | followup_24h_sent | followup_72h_sent
   */
