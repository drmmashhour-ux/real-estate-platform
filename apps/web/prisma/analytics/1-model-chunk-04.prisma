model NotificationPreference {
  id        String @id @default(cuid())
  ownerType String @map("owner_type")
  ownerId   String @map("owner_id")

  emailEnabled Boolean @default(true) @map("email_enabled")
  smsEnabled   Boolean @default(false) @map("sms_enabled")
  pushEnabled  Boolean @default(true) @map("push_enabled")

  emailAddress String? @map("email_address")
  phoneNumber  String? @map("phone_number")

  alertNewDeals    Boolean @default(true) @map("alert_new_deals")
  alertPriceDrop   Boolean @default(true) @map("alert_price_drop")
  alertScoreChange Boolean @default(true) @map("alert_score_change")
  alertBuyBox      Boolean @default(true) @map("alert_buy_box")

  quietHoursStart Int? @map("quiet_hours_start")
  quietHoursEnd   Int? @map("quiet_hours_end")

