  sentAt         DateTime? @map("sent_at")
  confirmationAt DateTime? @map("confirmation_at")

  documentIdsJson Json? @map("document_ids_json")
  payloadJson     Json? @map("payload_json")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("lecipm_sd_notary_packages")
}

model LecipmDealNumberSequence {
  year    Int @id @map("year")
  lastSeq Int @default(0) @map("last_seq")

  @@map("lecipm_deal_number_sequences")
}

model LecipmPipelineDeal {
  id            String               @id @default(cuid())
  transactionId String?              @unique @map("transaction_id") @db.VarChar(36)
  transaction   LecipmSdTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  listingId     String?              @map("listing_id") @db.VarChar(36)

  brokerId                   String    @map("broker_id") @db.VarChar(36)
  brokerDecisionApprovedById String?   @map("broker_decision_approved_by_id") @db.VarChar(36)
  brokerDecisionApprovedAt   DateTime? @map("broker_decision_approved_at")

  dealNumber String @unique @map("deal_number") @db.VarChar(48)
  title      String @db.VarChar(512)
  dealType   String @map("deal_type") @db.VarChar(32)

  pipelineStage  String @default("SCREENING") @map("pipeline_stage") @db.VarChar(40)
  decisionStatus String @default("PENDING") @map("decision_status") @db.VarChar(40)

  priority      String? @db.VarChar(16)
  ownerUserId   String? @map("owner_user_id") @db.VarChar(36)
  sponsorUserId String? @map("sponsor_user_id") @db.VarChar(36)

  latestTransactionNumber String?   @map("latest_transaction_number") @db.VarChar(48)
  latestMemoRef           String?   @map("latest_memo_ref") @db.VarChar(512)
  latestSummary           String?   @map("latest_summary") @db.Text
  /// Set when `compareOffers` runs with ≥2 offers (required before selecting a lender offer).
  lastOfferComparedAt     DateTime? @map("last_offer_compared_at")

  capitalStack        LecipmPipelineDealCapitalStack?
  lenders             LecipmPipelineDealLender[]
  lenderOffers        LecipmPipelineDealLenderOffer[]
  financingConditions LecipmPipelineDealFinancingCondition[]
  closingReadiness    LecipmPipelineDealClosingReadiness?
  closingRoom         LecipmPipelineDealClosing?
  portfolioAssets     LecipmPortfolioAsset[]

  stageHistories       LecipmPipelineDealStageHistory[]
  committeeSubmissions LecipmPipelineDealCommitteeSubmission[]
  committeeDecisions   LecipmPipelineDealCommitteeDecision[]
  conditions           LecipmPipelineDealCondition[]
  diligenceTasks       LecipmPipelineDealDiligenceTask[]
  auditEvents          LecipmPipelineDealAuditEvent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([brokerId, pipelineStage])
  @@index([brokerId, updatedAt(sort: Desc)])
  @@index([listingId])
  @@map("lecipm_pipeline_deals")
}

model LecipmPipelineDealStageHistory {
  id     String             @id @default(cuid())
  dealId String             @map("deal_id") @db.VarChar(36)
  deal   LecipmPipelineDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  fromStage       String? @map("from_stage") @db.VarChar(40)
  toStage         String  @map("to_stage") @db.VarChar(40)
  changedByUserId String? @map("changed_by_user_id") @db.VarChar(36)
  reason          String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  @@index([dealId, createdAt])
  @@map("lecipm_pipeline_deal_stage_histories")
}

model LecipmPipelineDealCommitteeSubmission {
  id     String             @id @default(cuid())
  dealId String             @map("deal_id") @db.VarChar(36)
  deal   LecipmPipelineDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  submittedByUserId String? @map("submitted_by_user_id") @db.VarChar(36)

  status      String    @default("SUBMITTED") @db.VarChar(24)
  summary     String?   @db.Text
  submittedAt DateTime  @default(now()) @map("submitted_at")
  decidedAt   DateTime? @map("decided_at")

  decisions LecipmPipelineDealCommitteeDecision[]

  @@index([dealId, status])
  @@map("lecipm_pipeline_deal_committee_submissions")
}

model LecipmPipelineDealCommitteeDecision {
  id     String             @id @default(cuid())
  dealId String             @map("deal_id") @db.VarChar(36)
  deal   LecipmPipelineDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  submissionId String?                                @map("submission_id") @db.VarChar(36)
  submission   LecipmPipelineDealCommitteeSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)

  decidedByUserId String? @map("decided_by_user_id") @db.VarChar(36)

  recommendation  String  @db.VarChar(40)
  rationale       String  @db.Text
  confidenceLevel String? @map("confidence_level") @db.VarChar(16)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([dealId])
  @@map("lecipm_pipeline_deal_committee_decisions")
}

model LecipmPipelineDealCondition {
  id     String             @id @default(cuid())
  dealId String             @map("deal_id") @db.VarChar(36)
  deal   LecipmPipelineDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  title       String  @db.VarChar(512)
  description String? @db.Text
  category    String  @db.VarChar(24)
  priority    String  @db.VarChar(16)

  status String @default("OPEN") @db.VarChar(16)

  ownerUserId String?   @map("owner_user_id") @db.VarChar(36)
  dueDate     DateTime? @map("due_date")
  notes       String?   @db.Text

  satisfiedAt DateTime? @map("satisfied_at")

  diligenceTasks LecipmPipelineDealDiligenceTask[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([dealId, status])
  @@map("lecipm_pipeline_deal_conditions")
}

model LecipmPipelineDealDiligenceTask {
  id     String             @id @default(cuid())
  dealId String             @map("deal_id") @db.VarChar(36)
  deal   LecipmPipelineDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  linkedConditionId String?                      @map("linked_condition_id") @db.VarChar(36)
  linkedCondition   LecipmPipelineDealCondition? @relation(fields: [linkedConditionId], references: [id], onDelete: SetNull)

  title       String  @db.VarChar(512)
  description String? @db.Text
  category    String  @db.VarChar(24)
  priority    String? @db.VarChar(16)

  status String @default("OPEN") @db.VarChar(16)

  ownerUserId String?   @map("owner_user_id") @db.VarChar(36)
  dueDate     DateTime? @map("due_date")

  completedAt DateTime? @map("completed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([dealId, status])
  @@map("lecipm_pipeline_deal_diligence_tasks")
}

model LecipmPipelineDealAuditEvent {
  id     String             @id @default(cuid())
  dealId String             @map("deal_id") @db.VarChar(36)
  deal   LecipmPipelineDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  eventType    String  @map("event_type") @db.VarChar(64)
  actorUserId  String? @map("actor_user_id") @db.VarChar(36)
  summary      String  @db.Text
  metadataJson Json?   @map("metadata_json")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([dealId, createdAt])
  @@map("lecipm_pipeline_deal_audit_events")
}

model LecipmPipelineDealCapitalStack {
  id     String             @id @default(cuid())
  dealId String             @unique @map("deal_id") @db.VarChar(36)
  deal   LecipmPipelineDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  totalPurchasePrice  Float  @map("total_purchase_price")
  equityAmount        Float? @map("equity_amount")
  debtAmount          Float? @map("debt_amount")
  loanToValue         Float? @map("loan_to_value")
  debtServiceCoverage Float? @map("debt_service_coverage")
  /// Annual NOI — optional input for DSCR when debt service is known.
  noiAnnual           Float? @map("noi_annual")
  annualDebtService   Float? @map("annual_debt_service")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("lecipm_pipeline_deal_capital_stacks")
}

model LecipmPipelineDealLender {
  id     String             @id @default(cuid())
  dealId String             @map("deal_id") @db.VarChar(36)
  deal   LecipmPipelineDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  lenderName   String  @map("lender_name") @db.VarChar(512)
  contactName  String? @map("contact_name") @db.VarChar(256)
  contactEmail String? @map("contact_email") @db.VarChar(320)

  status String  @default("TARGET") @db.VarChar(24)
  notes  String? @db.Text

  offers LecipmPipelineDealLenderOffer[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([dealId, status])
  @@map("lecipm_pipeline_deal_lenders")
}

model LecipmPipelineDealLenderOffer {
  id       String                   @id @default(cuid())
  dealId   String                   @map("deal_id") @db.VarChar(36)
  deal     LecipmPipelineDeal       @relation(fields: [dealId], references: [id], onDelete: Cascade)
  lenderId String                   @map("lender_id") @db.VarChar(36)
  lender   LecipmPipelineDealLender @relation(fields: [lenderId], references: [id], onDelete: Cascade)

  offeredAmount     Float @map("offered_amount")
  interestRate      Float @map("interest_rate")
  amortizationYears Int?  @map("amortization_years")
  termYears         Int?  @map("term_years")

  conditionsJson Json? @map("conditions_json")

  status String @default("RECEIVED") @db.VarChar(24)

  financingConditions LecipmPipelineDealFinancingCondition[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([dealId])
  @@index([lenderId])
  @@map("lecipm_pipeline_deal_lender_offers")
}

model LecipmPipelineDealFinancingCondition {
  id            String                         @id @default(cuid())
  dealId        String                         @map("deal_id") @db.VarChar(36)
  deal          LecipmPipelineDeal             @relation(fields: [dealId], references: [id], onDelete: Cascade)
  lenderOfferId String?                        @map("lender_offer_id") @db.VarChar(36)
  lenderOffer   LecipmPipelineDealLenderOffer? @relation(fields: [lenderOfferId], references: [id], onDelete: SetNull)

  title       String  @db.VarChar(512)
  description String? @db.Text

  status     String  @default("OPEN") @db.VarChar(16)
  isCritical Boolean @default(true) @map("is_critical")
  waiverNote String? @map("waiver_note") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([dealId, status])
  @@map("lecipm_pipeline_deal_financing_conditions")
}

model LecipmPipelineDealClosingReadiness {
  id     String             @id @default(cuid())
  dealId String             @unique @map("deal_id") @db.VarChar(36)
  deal   LecipmPipelineDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  readinessStatus   String   @default("BLOCKED") @map("readiness_status") @db.VarChar(24)
  blockingItemsJson Json?    @map("blocking_items_json")
  lastEvaluatedAt   DateTime @default(now()) @map("last_evaluated_at")

  @@map("lecipm_pipeline_deal_closing_readiness")
}

model LecipmPipelineDealClosing {
  id     String             @id @default(cuid())
  dealId String             @unique @map("deal_id") @db.VarChar(36)
  deal   LecipmPipelineDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  transactionId String?              @unique @map("transaction_id") @db.VarChar(36)
  transaction   LecipmSdTransaction? @relation("ClosingRoomTransaction", fields: [transactionId], references: [id], onDelete: SetNull)

  closingStatus   String    @default("PREPARING") @map("closing_status") @db.VarChar(24)
  closingDate     DateTime? @map("closing_date")
  closingLocation String?   @map("closing_location") @db.VarChar(512)
  notaryName      String?   @map("notary_name") @db.VarChar(256)
  notaryEmail     String?   @map("notary_email") @db.VarChar(320)

  closingDocuments LecipmPipelineDealClosingDocument[]
  checklistItems   LecipmPipelineDealClosingChecklistItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("lecipm_pipeline_deal_closings")
}
