model Experiment {
  id                 String           @id @default(uuid())
  name               String
  slug               String           @unique
  status             ExperimentStatus @default(draft)
  targetSurface      String           @map("target_surface")
  hypothesis         String?
  /// Short objective line (e.g. “Improve LP CTA CTR”) — additive to hypothesis.
  objective          String?          @db.Text
  primaryMetric      String           @map("primary_metric")
  metricSecondary    Json?            @map("metric_secondary")
  audienceScope      Json?            @map("audience_scope")
  notes              Json?
  trafficSplitJson   Json             @map("traffic_split_json")
  startAt            DateTime?        @map("start_at")
  endAt              DateTime?        @map("end_at")
  winnerVariantKey   String?          @map("winner_variant_key")
  stoppedVariantKeys Json             @default("[]") @map("stopped_variant_keys")
  archivedAt         DateTime?        @map("archived_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  variants         ExperimentVariant[]
  assignments      ExperimentAssignment[]
  events           ExperimentEvent[]
  resultSnapshots  ExperimentResultSnapshot[]
  metricSnapshots  ExperimentMetricSnapshot[]
  outcomeDecisions ExperimentOutcomeDecision[]

  @@index([status])
  @@index([targetSurface])
  @@map("experiments")
}

model ExperimentVariant {
  id            String   @id @default(uuid())
  experimentId  String   @map("experiment_id")
  variantKey    String   @map("variant_key")
  name          String
  configJson    Json     @map("config_json")
  /// active | winner | loser | inconclusive — recommendation layer; not auto-applied UX.
  outcomeStatus String?  @map("outcome_status") @db.VarChar(24)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  experiment              Experiment                  @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  assignments             ExperimentAssignment[]
  events                  ExperimentEvent[]
  metricSnapshots         ExperimentMetricSnapshot[]
  winningOutcomeDecisions ExperimentOutcomeDecision[] @relation("ExperimentWinningVariant")

  @@unique([experimentId, variantKey])
  @@index([experimentId])
  @@map("experiment_variants")
}

model ExperimentAssignment {
  id           String   @id @default(uuid())
  experimentId String   @map("experiment_id")
  variantId    String   @map("variant_id")
  userId       String?  @map("user_id")
  sessionId    String   @map("session_id") @db.VarChar(128)
  assignedAt   DateTime @default(now()) @map("assigned_at")

  experiment Experiment        @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  variant    ExperimentVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([experimentId, sessionId])
  @@index([experimentId])
  @@index([variantId])
  @@index([userId])
  @@index([sessionId])
  @@map("experiment_assignments")
}

model ExperimentEvent {
  id           String   @id @default(uuid())
  experimentId String   @map("experiment_id")
  variantId    String   @map("variant_id")
  userId       String?  @map("user_id")
  sessionId    String   @map("session_id") @db.VarChar(128)
  eventName    String   @map("event_name") @db.VarChar(64)
  metadataJson Json     @default("{}") @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")

  experiment Experiment        @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  variant    ExperimentVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([experimentId])
  @@index([variantId])
  @@index([eventName])
  @@index([sessionId])
  @@map("experiment_events")
}

model ExperimentMetricSnapshot {
  id           String   @id @default(cuid())
  experimentId String   @map("experiment_id")
  variantId    String   @map("variant_id")
  metricKey    String   @map("metric_key") @db.VarChar(64)
  metricValue  Float    @map("metric_value")
  measuredAt   DateTime @default(now()) @map("measured_at") @db.Timestamptz(6)

  experiment Experiment        @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  variant    ExperimentVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([experimentId, metricKey, measuredAt])
  @@index([variantId, measuredAt])
  @@map("experiment_metric_snapshots")
}

model ExperimentOutcomeDecision {
  id               String   @id @default(cuid())
  experimentId     String   @map("experiment_id")
  decisionType     String   @map("decision_type") @db.VarChar(32)
  winningVariantId String?  @map("winning_variant_id")
  losingVariantIds Json     @map("losing_variant_ids")
  confidence       Float
  rationale        Json
  recommendation   String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")

  experiment     Experiment         @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  winningVariant ExperimentVariant? @relation("ExperimentWinningVariant", fields: [winningVariantId], references: [id], onDelete: SetNull)

  @@index([experimentId, createdAt])
  @@map("experiment_outcome_decisions")
}

