  id                    String  @id @default(cuid())
  listingId             String? @map("listing_id")
  offerId               String? @map("offer_id")
  contractId            String? @map("contract_id")
  payerUserId           String? @map("payer_user_id")
  brokerId              String? @map("broker_id")
  agencyId              String? @map("agency_id")
  trustAccountProfileId String? @map("trust_account_profile_id")
  dealId                String? @map("deal_id")

  depositType String @map("deposit_type") // earnest_money | security_deposit_vacation_resort | other_trust_funds
  contextType String @map("context_type") // sale | purchase | lease_vacation_resort | other
  amountCents Int    @map("amount_cents")
  currency    String @default("CAD")

  paymentMethod     String? @map("payment_method")
  externalReference String? @map("external_reference")
  receiptNumber     String? @map("receipt_number")

  /// pending_receipt | received | held_in_trust | release_requested | released | refunded | disputed | frozen | cancelled
  status          String  @default("pending_receipt")
  releaseRuleType String? @map("release_rule_type")
  releaseRuleText String? @map("release_rule_text") @db.Text

  receivedAt DateTime? @map("received_at")
  heldAt     DateTime? @map("held_at")
  releasedAt DateTime? @map("released_at")
  refundedAt DateTime? @map("refunded_at")

  requiresManualReview Boolean @default(true) @map("requires_manual_review")
  complianceFlags      Json?   @map("compliance_flags")
  notes                String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trustAccountProfile    TrustAccountProfile?    @relation(fields: [trustAccountProfileId], references: [id], onDelete: SetNull)
  ledgerEntries          TrustLedgerEntry[]
  events                 TrustDepositEvent[]
  financialLedgerEntries FinancialLedgerEntry[]
  financialRegisterLinks FinancialRegisterLink[]

  @@index([brokerId], map: "idx_trust_deposits_broker")
  @@index([agencyId], map: "idx_trust_deposits_agency")
  @@index([listingId], map: "idx_trust_deposits_listing")
  @@index([dealId], map: "idx_trust_deposits_deal")
  @@index([offerId], map: "idx_trust_deposits_offer")
  @@index([contractId], map: "idx_trust_deposits_contract")
  @@index([trustAccountProfileId], map: "idx_trust_deposits_profile")
  @@index([status], map: "idx_trust_deposits_status")
  @@map("trust_deposits")
}

model TrustDepositEvent {
  id             String   @id @default(cuid())
  trustDepositId String   @map("trust_deposit_id")
  eventType      String   @map("event_type")
  performedById  String?  @map("performed_by_id")
  aiAssisted     Boolean  @default(false) @map("ai_assisted")
  details        Json?    @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at")

  trustDeposit TrustDeposit @relation(fields: [trustDepositId], references: [id], onDelete: Cascade)

  @@index([trustDepositId], map: "idx_trust_deposit_events_deposit")
  @@index([eventType], map: "idx_trust_deposit_events_type")
  @@map("trust_deposit_events")
}
