model DealAnalysis {
  id                           String                        @id @default(cuid())
  /// Optional link to canonical `properties.id` (bigint blueprint) without removing FSBO `propertyId`.
  canonicalPropertyId          BigInt?                       @map("canonical_property_id")
  /// FSBO listing id when analysis targets a sale/long-term listing (nullable for BNHub-only rows).
  propertyId                   String?                       @map("property_id")
  /// BNHub short-term listing id when analysis targets BNHub revenue mode.
  shortTermListingId           String?                       @unique @map("short_term_listing_id")
  analysisType                 String                        @map("analysis_type") // listing | investor | rental | bnhub
  investmentScore              Int                           @map("investment_score")
  riskScore                    Int                           @map("risk_score")
  confidenceScore              Int?                          @map("confidence_score")
  recommendation               String
  opportunityType              String                        @map("opportunity_type")
  summary                      Json?                         @db.JsonB
  explanation                  String?                       @db.Text
  createdAt                    DateTime                      @default(now()) @map("created_at")
  updatedAt                    DateTime                      @updatedAt @map("updated_at")
  factors                      DealAnalysisFactor[]
  scenarios                    DealAnalysisScenario[]
  comparables                  DealAnalysisComparable[]
  offerStrategies              DealOfferStrategy[]
  refreshJobs                  DealAnalysisRefreshJob[]
  refreshEvents                DealAnalysisRefreshEvent[]
  negotiationPlaybooks         DealNegotiationPlaybook[]
  appraisalAdjustmentProposals AppraisalAdjustmentProposal[]
  appraisalAdjustments         AppraisalAdjustment[]

  @@index([propertyId], map: "idx_deal_analyses_property_id")
  @@index([canonicalPropertyId], map: "idx_deal_analyses_canonical_property_id")
  @@index([shortTermListingId], map: "idx_deal_analyses_short_term_listing_id")
  @@index([createdAt(sort: Desc)], map: "idx_deal_analyses_created_at_desc")
  @@map("deal_analyses")
}

model DealAnalysisFactor {
  id             String       @id @default(cuid())
  analysisId     String       @map("analysis_id")
  analysis       DealAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  factorCode     String       @map("factor_code")
  factorCategory String       @map("factor_category")
  factorValue    Int          @map("factor_value")
  weight         Decimal      @db.Decimal(5, 4)
  impact         String
  details        Json?        @db.JsonB
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([analysisId], map: "idx_deal_analysis_factors_analysis_id")
  @@map("deal_analysis_factors")
}

model DealAnalysisScenario {
  id              String       @id @default(cuid())
  analysisId      String       @map("analysis_id")
  analysis        DealAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  scenarioType    String       @map("scenario_type") // conservative | expected | aggressive
  /// rental | bnhub — Phase 2 extended modes
  scenarioMode    String?      @map("scenario_mode")
  monthlyRent     Int?         @map("monthly_rent")
  occupancyRate   Decimal?     @map("occupancy_rate") @db.Decimal(5, 4)
  operatingCost   Int?         @map("operating_cost")
  mortgageCost    Int?         @map("mortgage_cost")
  monthlyCashFlow Int?         @map("monthly_cash_flow")
  annualRoi       Decimal?     @map("annual_roi") @db.Decimal(7, 4)
  capRate         Decimal?     @map("cap_rate") @db.Decimal(7, 4)
  /// Phase 2: BNHub nightly metrics, fee breakdowns, confidence flags (sanitized for API via DTO).
  details         Json?        @db.JsonB
  createdAt       DateTime     @default(now()) @map("created_at")

  @@index([analysisId], map: "idx_deal_analysis_scenarios_analysis_id")
  @@map("deal_analysis_scenarios")
}

model DealAnalysisComparable {
  id                           String                        @id @default(cuid())
  analysisId                   String                        @map("analysis_id")
  analysis                     DealAnalysis                  @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  comparablePropertyId         String                        @map("comparable_property_id")
  distanceKm                   Float?                        @map("distance_km")
  similarityScore              Float                         @map("similarity_score")
  sourceType                   String                        @map("source_type")
  priceCents                   Int                           @map("price_cents")
  pricePerSqft                 Float?                        @map("price_per_sqft")
  propertyType                 String?                       @map("property_type")
  bedrooms                     Int?
  bathrooms                    Float?
  areaSqft                     Int?                          @map("area_sqft")
  listingStatus                String?                       @map("listing_status")
  details                      Json?                         @db.JsonB
  createdAt                    DateTime                      @default(now()) @map("created_at")
  appraisalAdjustmentProposals AppraisalAdjustmentProposal[]
  appraisalAdjustments         AppraisalAdjustment[]

  @@index([analysisId], map: "idx_deal_analysis_comparables_analysis_id")
  @@map("deal_analysis_comparables")
}

model AppraisalAdjustmentProposal {
  id              String                  @id @default(cuid())
  appraisalCaseId String                  @map("appraisal_case_id")
  appraisalCase   DealAnalysis            @relation(fields: [appraisalCaseId], references: [id], onDelete: Cascade)
  comparableId    String?                 @map("comparable_id")
  comparable      DealAnalysisComparable? @relation(fields: [comparableId], references: [id], onDelete: SetNull)

  adjustmentType       String @map("adjustment_type")
  label                String
  suggestedAmountCents Int    @map("suggested_amount_cents")
  direction            String

  rationale  String? @db.Text
  confidence Float?

  sourceType    String? @map("source_type")
  sourceSummary Json?   @map("source_summary") @db.JsonB

  reviewed     Boolean @default(false)
  approved     Boolean @default(false)
  reviewedById String? @map("reviewed_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  appliedAdjustment AppraisalAdjustment?

  @@index([appraisalCaseId], map: "idx_appraisal_adj_props_case")
  @@index([comparableId], map: "idx_appraisal_adj_props_comp")
  @@map("appraisal_adjustment_proposals")
}

model AppraisalAdjustment {
  id         String                       @id @default(cuid())
  proposalId String?                      @unique @map("proposal_id")
  proposal   AppraisalAdjustmentProposal? @relation(fields: [proposalId], references: [id], onDelete: SetNull)

