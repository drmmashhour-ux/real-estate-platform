  listingId                        String?                           @map("listing_id") // ShortTermListing or sale listing
  /**
   * Denormalized LEC code when deal references a ShortTermListing.
   */
  listingCode                      String?                           @map("listing_code")
  buyerId                          String                            @map("buyer_id")
  sellerId                         String                            @map("seller_id")
  brokerId                         String?                           @map("broker_id")
  priceCents                       Int                               @map("price_cents")
  status                           String                            @default("initiated") // initiated | offer_submitted | accepted | inspection | financing | closing_scheduled | closed | cancelled | CONFLICT_REQUIRES_DISCLOSURE
  /**
   * Broker CRM pipeline stage (UI / reminders); separate from legal deal status.
   */
  crmStage                         String?                           @map("crm_stage")
  createdAt                        DateTime                          @default(now()) @map("created_at")
  updatedAt                        DateTime                          @updatedAt @map("updated_at")
  /// Broker execution profile — assists official workflows; does not replace mandatory OACIQ forms.
  dealExecutionType                DealExecutionType?                @map("deal_execution_type")
