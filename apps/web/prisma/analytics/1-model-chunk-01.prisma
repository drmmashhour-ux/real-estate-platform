  assignedFormPackageKey           String?                           @map("assigned_form_package_key") @db.VarChar(160)
  propertyReferenceId              String?                           @map("property_reference_id") @db.VarChar(160)
  executionMetadata                Json                              @default("{}") @map("execution_metadata")
  milestones                       DealMilestone[]
  documents                        DealDocument[]
  crmInteractions                  CrmInteraction[]
  contracts                        Contract[]
  /**
   * Optional link to originating CRM lead (e.g. ImmoContact).
   */
  leadId                           String?                           @unique @map("lead_id")
  lead                             Lead?                             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  /**
   * LECIPM enterprise workspace (organization) — optional; null = legacy unscoped rows.
   */
  workspaceId                      String?                           @map("workspace_id") @db.Uuid
  /**
   * Snapshot of lead origin at deal creation (reporting / disputes).
   */
  leadContactOrigin                LeadContactOrigin?                @map("lead_contact_origin")
  /**
