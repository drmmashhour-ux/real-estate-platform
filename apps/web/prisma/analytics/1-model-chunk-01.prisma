model Payment {
  id                                 String                   @id @default(uuid())
  amountCents                        Int // Total charged to guest
  guestFeeCents                      Int
  hostFeeCents                       Int
  /**
   * Host transfer amount in minor units; may be finalized at payment completion (e.g. webhook).
   */
  hostPayoutCents                    Int?
  /**
   * BNHub Stripe Connect application fee (platform commission) in minor units — set at webhook from PaymentIntent.
   */
  platformFeeCents                   Int?                     @map("platform_fee_cents")
  status                             PaymentStatus            @default(PENDING)
  stripePaymentId                    String? // PaymentIntent id (or fallback)
  /**
   * Stripe Checkout Session id (cs_...) for receipts / invoices.
   */
  stripeCheckoutSessionId            String?                  @map("stripe_checkout_session_id")
  /**
   * Stripe-hosted receipt / invoice PDF link (from Charge after Checkout).
   */
  stripeReceiptUrl                   String?                  @map("stripe_receipt_url") @db.Text
  /**
   * Checkout Session amount_total (minor units), for reconciliation.
   */
  stripeCheckoutAmountCents          Int?                     @map("stripe_checkout_amount_cents")
  /**
   * Checkout Session currency (lowercase ISO).
   */
  stripeCheckoutCurrency             String?                  @map("stripe_checkout_currency")
  /**
   * Last Stripe refund id (re_…) for support / idempotency notes.
   */
  stripeLastRefundId                 String?                  @map("stripe_last_refund_id")
  /**
   * Stripe Connect destination account (acct_…) on this charge; for admin reconciliation.
   */
  stripeConnectAccountId             String?                  @map("stripe_connect_account_id")
  hostPayoutReleasedAt               DateTime?                @map("host_payout_released_at") // Escrow: release 24-48h after check-in unless held
  /**
   * Scheduled host payout (e.g. check-in + 7 days) — BNHub money layer.
   */
  scheduledHostPayoutAt              DateTime?                @map("scheduled_host_payout_at")
  payoutHoldReason                   String?                  @map("payout_hold_reason") // fraud_investigation | dispute | escrow_window
  /**
   * Linked enforceable / booking agreement referenced on payment capture.
   */
  linkedContractId                   String?                  @map("linked_contract_id")
  linkedContractType                 String?                  @map("linked_contract_type")
  linkedContract                     Contract?                @relation("PaymentLegalLink", fields: [linkedContractId], references: [id], onDelete: SetNull)
  /**
   * Canonical BNHub money breakdown (subtotal, taxes, fees, host payout) — cents only, JSON shape from `BookingMoneyBreakdown`.
   */
  moneyBreakdownJson                 Json?                    @map("money_breakdown_json")
  paidAt                             DateTime?                @map("paid_at")
  createdAt                          DateTime                 @default(now())
  updatedAt                          DateTime                 @updatedAt
  bookingId                          String                   @unique
  booking                            Booking                  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([payoutHoldReason])
  @@index([linkedContractId])
  @@index([stripePaymentId])
  @@index([status])
  @@map("payments")
}

