  @@index([bookingId, createdAt])
  @@index([hostId, createdAt])
  @@index([guestId, createdAt])
  @@map("bnhub_automated_host_message_logs")
}

model MarketplaceAutonomyApproval {
  id                String    @id @default(cuid())
  /// pending | approved | rejected | executed
  status            String    @default("pending") @db.VarChar(20)
  actionType        String    @map("action_type") @db.VarChar(64)
  riskTier          String    @map("risk_tier") @db.VarChar(16)
  payload           Json      @default("{}")
  summary           String?   @db.VarChar(512)
  requestedByUserId String?   @map("requested_by_user_id")
  reviewedByUserId  String?   @map("reviewed_by_user_id")
  reviewNote        String?   @map("review_note") @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  executedAt        DateTime? @map("executed_at")

  @@index([status, createdAt])
  @@index([actionType, status])
  @@map("marketplace_autonomy_approvals")
}

model ListingAnalytics {
  id                      String               @id @default(cuid())
  kind                    ListingAnalyticsKind @map("listing_kind")
  listingId               String               @map("listing_id")
  viewsTotal              Int                  @default(0) @map("views_total")
  saves                   Int                  @default(0)
  contactClicks           Int                  @default(0) @map("contact_clicks")
  bookingAttempts         Int                  @default(0) @map("booking_attempts")
  bookings                Int                  @default(0)
  demandScore             Int                  @default(0) @map("demand_score")
  demandScoreComputedAt   DateTime?            @map("demand_score_computed_at")
  views24hCached          Int                  @default(0) @map("views_24h_cached")
  uniqueViews24hCached    Int                  @default(0) @map("unique_views_24h_cached")
  shareCount              Int                  @default(0) @map("share_count")
  unlockCheckoutStarts    Int                  @default(0) @map("unlock_checkout_starts")
  unlockCheckoutSuccesses Int                  @default(0) @map("unlock_checkout_successes")
  createdAt               DateTime             @default(now()) @map("created_at")
  updatedAt               DateTime             @updatedAt @map("updated_at")

  @@unique([kind, listingId])
  @@index([kind, listingId])
  @@index([demandScore])
  @@map("listing_analytics")
}

model ListingPriceHistory {
  id                 String               @id @default(cuid())
  kind               ListingAnalyticsKind @map("listing_kind")
  listingId          String               @map("listing_id")
  /// New price after change (major unit: cents).
  priceCents         Int                  @map("price_cents")
  /// Previous price when this row records a change (optional for legacy snapshot-only rows).
  previousPriceCents Int?                 @map("previous_price_cents")
  changedByUserId    String?              @map("changed_by_user_id")
  changeReason       String?              @map("change_reason") @db.VarChar(128)
  recordedAt         DateTime             @default(now()) @map("recorded_at")

  @@index([kind, listingId, recordedAt])
  @@map("listing_price_history")
}

model PropertyLegalProfile {
  id                    String    @id @default(cuid())
  listingScope          String    @map("listing_scope")
  listingId             String    @map("listing_id")
  latentDefectRiskScore Float     @default(0) @map("latent_defect_risk_score")
  disclosureRiskScore   Float     @default(0) @map("disclosure_risk_score")
  fraudRiskScore        Float     @default(0) @map("fraud_risk_score")
  overallLegalRiskScore Float     @default(0) @map("overall_legal_risk_score")
  latestRiskLevel       String    @default("MEDIUM") @map("latest_risk_level")
  lastEvaluatedAt       DateTime? @map("last_evaluated_at")
  signals               Json      @default("{}")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@unique([listingScope, listingId])
  @@index([overallLegalRiskScore])
  @@map("property_legal_profiles")
}

model OutreachDailyStat {
  id          String   @id @default(cuid())
  date        DateTime @unique @default(now()) @db.Date
  callsMade   Int      @default(0) @map("calls_made")
  dmsSent     Int      @default(0) @map("dms_sent")
  demosBooked Int      @default(0) @map("demos_booked")
  demosDone   Int      @default(0) @map("demos_done")
  loomsSent   Int      @default(0) @map("looms_sent")
  conversions Int      @default(0)
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("outreach_daily_stats")
}

model OutreachDailyTask {
  id        String   @id @default(cuid())
  date      DateTime @default(now()) @db.Date
  label     String
  category  String // outreach, follow_up, demo, product
  completed Boolean  @default(false)
  quota     Int      @default(1)
  progress  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([date])
  @@map("outreach_daily_tasks")
}
