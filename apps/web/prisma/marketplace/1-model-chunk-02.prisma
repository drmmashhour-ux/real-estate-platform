model BnhubService {
  id                      String                      @id @default(uuid()) @map("id")
  serviceCode             String                      @unique @map("service_code")
  name                    String                      @map("name")
  category                BnhubAddonServiceCategory   @map("category")
  description             String?                     @map("description") @db.Text
  shortDescription        String?                     @map("short_description") @db.Text
  fullDescription         String?                     @map("full_description") @db.Text
  icon                    String?                     @map("icon")
  iconKey                 String?                     @map("icon_key")
  serviceScope            BnhubServiceScope           @default(LISTING_HOSTED) @map("service_scope")
  catalogPricingBehavior  BnhubCatalogPricingBehavior @default(FIXED) @map("pricing_behavior")
  defaultRequiresApproval Boolean                     @default(false) @map("default_requires_approval")
  isActive                Boolean                     @default(true) @map("is_active")
  /// Premium add-ons are hidden for listings with HIGH/CRITICAL trust risk.
  isPremiumTier           Boolean                     @default(false) @map("is_premium_tier")
  /// Minimum listing `BnhubTrustProfile.trustScore` required for this service to be offered (null = no minimum).
  minListingTrustScore    Int?                        @map("min_listing_trust_score")
  createdAt               DateTime                    @default(now()) @map("created_at")
  updatedAt               DateTime                    @updatedAt @map("updated_at")

  listingOffers BnhubListingService[]
  bookingLines  BnhubBookingService[]
  requests      BnhubServiceRequest[]
  bundleItems   BnhubBundleItem[]

  @@index([category])
  @@index([isActive])
  @@map("bnhub_services")
}

model BnhubListingService {
  id                 String                              @id @default(uuid()) @map("id")
  listingId          String                              @map("listing_id")
  listing            ShortTermListing                    @relation(fields: [listingId], references: [id], onDelete: Cascade)
  hostUserId         String?                             @map("host_user_id")
  serviceId          String                              @map("service_id")
  service            BnhubService                        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  isEnabled          Boolean                             @default(true) @map("is_enabled")
  pricingType        BnhubListingServicePricingType      @map("pricing_type")
  /// Price in minor units (cents); meaning depends on `pricingType` (per unit / per night / per guest / per booking).
  priceCents         Int                                 @default(0) @map("price_cents")
  currency           String                              @default("USD") @map("currency")
  /// Complimentary / bundled — shown clearly to guests, not charged.
  isIncluded         Boolean                             @default(false) @map("is_included")
  requiresApproval   Boolean                             @default(false) @map("requires_approval")
  capacityLimit      Int?                                @map("capacity_limit")
  advanceNoticeHours Int?                                @map("advance_notice_hours")
  availabilityRules  Json?                               @map("availability_rules")
  notes              String?                             @map("notes") @db.Text
  moderationStatus   BnhubListingServiceModerationStatus @default(APPROVED) @map("moderation_status")
  /// Admin hard-offer for risky listings (host cannot override).
  adminDisabled      Boolean                             @default(false) @map("admin_disabled")
  createdAt          DateTime                            @default(now()) @map("created_at")
  updatedAt          DateTime                            @updatedAt @map("updated_at")

  bookingLines BnhubBookingService[]

  @@unique([listingId, serviceId], map: "bnhub_listing_services_listing_service_key")
  @@index([listingId])
  @@index([serviceId])
  @@index([hostUserId])
  @@map("bnhub_listing_services")
}

model BnhubBookingService {
  id               String                          @id @default(uuid()) @map("id")
  bookingId        String                          @map("booking_id")
  listingId        String                          @map("listing_id")
  listing          ShortTermListing                @relation(fields: [listingId], references: [id], onDelete: Cascade)
  guestUserId      String?                         @map("guest_user_id")
  hostUserId       String?                         @map("host_user_id")
  listingServiceId String                          @map("listing_service_id")
  listingService   BnhubListingService             @relation(fields: [listingServiceId], references: [id], onDelete: Restrict)
  serviceId        String                          @map("service_id")
  service          BnhubService                    @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  quantity         Int                             @default(1) @map("quantity")
  linePricingType  BnhubListingServicePricingType? @map("line_pricing_type")
  unitPriceCents   Int                             @map("unit_price_cents")
  totalPriceCents  Int                             @map("total_price_cents")
  serviceDate      DateTime?                       @map("service_date") @db.Date
  status           BnhubBookingServiceLineStatus   @default(CONFIRMED) @map("status")
  selectedFrom     BnhubServiceSelectedFrom        @default(BOOKING_FLOW) @map("selected_from")
  notes            String?                         @map("notes") @db.Text
  selectedAt       DateTime                        @default(now()) @map("selected_at")
  createdAt        DateTime                        @default(now()) @map("created_at")
  updatedAt        DateTime                        @updatedAt @map("updated_at")

  @@index([bookingId])
  @@index([listingId])
  @@index([serviceId])
  @@index([guestUserId])
  @@index([hostUserId])
  @@map("bnhub_booking_services")
}

model BnhubServiceRequest {
  id                  String                    @id @default(uuid()) @map("id")
  bookingId           String                    @map("booking_id")
