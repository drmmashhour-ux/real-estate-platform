model MortgageBroker {
  id                     String                        @id @default(cuid())
  userId                 String?                       @unique @map("user_id")
  user                   User?                         @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// Display name (legacy + signup)
  name                   String
  /// Full legal name (signup / profile)
  fullName               String?                       @map("full_name")
  email                  String
  phone                  String?
  company                String?
  licenseNumber          String                        @default("") @map("license_number")
  yearsExperience        Int?                          @map("years_experience")
  /// e.g. residential, commercial (free text)
  specialties            String?                       @db.Text
  profilePhotoUrl        String?                       @map("profile_photo_url")
  /// Government ID (passport / driver license) — manual review; path under /public
  idDocumentUrl          String?                       @map("id_document_url")
  /// Selfie for identity match — manual review
  selfiePhotoUrl         String?                       @map("selfie_photo_url")
  /// pending | verified | rejected (ID + selfie review; separate from license verificationStatus)
  identityStatus         String                        @default("pending") @map("identity_status")
  insuranceProvider      String?                       @map("insurance_provider")
  insuranceValid         Boolean?                      @map("insurance_valid")
  /// Professional references (text)
  brokerReferences       String?                       @map("broker_references") @db.Text
  /// Admin-approved; required for lead pool + dashboard access
  isVerified             Boolean                       @default(false) @map("is_verified")
  /// pending | verified | rejected
  verificationStatus     String                        @default("pending") @map("verification_status")
  profileCompletedAt     DateTime?                     @map("profile_completed_at")
  /// trial | pro — trial has limited leads + 7-day window; pro is subscription
  plan                   String                        @default("trial")
  trialEndsAt            DateTime?                     @map("trial_ends_at")
  /// Trusted fallback when no eligible trial/pro brokers exist for round-robin
  isPrimary              Boolean                       @default(false) @map("is_primary")
  /// Fair rotation: updated each time a lead is assigned to this broker
  lastAssignedLeadAt     DateTime?                     @map("last_assigned_lead_at")
  /// Optional boost for future weighted distribution (higher = tie-break after lastAssigned)
  priorityScore          Int                           @default(0) @map("priority_score")
  /// Cumulative: incremented by visible (unlocked) lead count on each list fetch
  leadsViewedTotal       Int                           @default(0) @map("leads_viewed_total")
  /// Cumulative upgrade CTA clicks (pricing, dashboard, etc.)
  upgradeClickCount      Int                           @default(0) @map("upgrade_click_count")
  /// Average star rating (1–5) from client reviews
  rating                 Float                         @default(0) @map("rating")
  totalReviews           Int                           @default(0) @map("total_reviews")
  /// Rolling average first-response time (hours); updated when broker marks contacted/approved
  responseTimeAvg        Float?                        @map("response_time_avg")
  /// Number of response-time samples (for rolling average)
  responseTimeSamples    Int                           @default(0) @map("response_time_samples")
  /// Leads where broker first marked contacted or approved (engagement count)
  totalLeadsHandled      Int                           @default(0) @map("total_leads_handled")
  /// Sum of paid contact unlocks (CAD dollars)
  totalLeadUnlockRevenue Float                         @default(0) @map("total_lead_unlock_revenue")
  /// Count of contact unlocks (free weekly + paid)
  totalLeadUnlocks       Int                           @default(0) @map("total_lead_unlocks")
  createdAt              DateTime                      @default(now()) @map("created_at")
  requests               MortgageRequest[]
  leadDistributionLogs   MortgageLeadDistributionLog[]
  leadUnlocks            MortgageLeadUnlock[]

  @@index([userId])
  @@index([plan])
  @@index([isPrimary])
  @@index([lastAssignedLeadAt])
  @@map("mortgage_brokers")
}

model MortgageRequest {
  id                       String                        @id @default(cuid())
  userId                   String                        @map("user_id")
  user                     User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Exactly one broker per lead (exclusive routing).
  brokerId                 String?                       @map("broker_id")
  broker                   MortgageBroker?               @relation(fields: [brokerId], references: [id], onDelete: SetNull)
  propertyPrice            Float                         @map("property_price")
  downPayment              Float                         @map("down_payment")
  income                   Float
  /// pending | contacted | approved
  status                   String                        @default("pending")
  /// low | medium | high — auto-scored from income, down %, timeline, pre-approval
  intentLevel              String                        @default("medium") @map("intent_level")
  /// immediate | 1-3 months | 3+ months
  timeline                 String                        @default("1-3 months") @map("timeline")
  preApproved              Boolean                       @default(false) @map("pre_approved")
  /// Broker paid to unlock full contact on this row (pay-per-lead)
  isPurchasedLead          Boolean                       @default(false) @map("is_purchased_lead")
  /// Pay-per-lead price (CAD) for unlocking borrower contact
  leadValue                Float                         @default(35) @map("lead_value")
  /// Borrower email/phone (and extended financials) visible after unlock
  contactUnlocked          Boolean                       @default(false) @map("contact_unlocked")
  unlockedByBrokerId       String?                       @map("unlocked_by_broker_id")
  contactUnlockedAt        DateTime?                     @map("contact_unlocked_at")
  /// Heuristic pre-approval estimate (informational only)
  estimatedApprovalAmount  Float?                        @map("estimated_approval_amount")
  estimatedMonthlyPayment  Float?                        @map("estimated_monthly_payment")
  /// low | medium | high
  approvalConfidence       String?                       @map("approval_confidence")
  /// When the lead was assigned to `brokerId` (for response-time SLA)
  assignedAt               DateTime?                     @map("assigned_at")
  /// True after first performance stats applied (response time + lead handled count)
  performanceStatsRecorded Boolean                       @default(false) @map("performance_stats_recorded")
  createdAt                DateTime                      @default(now()) @map("created_at")
  /// Optional listing context when request originates from BuyerHub.
  fsboListingId            String?                       @map("fsbo_listing_id")
  employmentStatus         String?                       @map("employment_status")
  creditRange              String?                       @map("credit_range")
  leadDistributionLogs     MortgageLeadDistributionLog[]
  leadUnlock               MortgageLeadUnlock?

  @@index([userId])
  @@index([brokerId])
  @@index([status, createdAt])
  @@index([intentLevel])
  @@index([fsboListingId])
  @@map("mortgage_requests")
}

