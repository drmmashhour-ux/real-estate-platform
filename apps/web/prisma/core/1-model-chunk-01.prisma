model PlatformCodeSequence {
  id        String   @id @default(cuid())
  scope     String   @unique
  nextValue Int      @default(1) @map("next_value")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_code_sequences")
}

model User {
  id                                String             @id @default(uuid())
  email                             String             @unique
  passwordHash                      String?            @map("password_hash") // Optional: demo users may have no password
  role                              PlatformRole       @default(USER)
  brokerStatus                      BrokerStatus       @default(NONE) @map("broker_status")
  accountStatus                     AccountStatus      @default(ACTIVE) @map("account_status")
  /// Public account code for support and admin tracking (e.g. USR-XXXXXX).
  userCode                          String?            @unique @map("user_code")
  /// Optional email-based 2FA after password (sends 6-digit code).
  twoFactorEmailEnabled             Boolean            @default(false) @map("two_factor_email_enabled")
  /// Set when the user verifies via email link (new signups); existing users backfilled in migration.
  emailVerifiedAt                   DateTime?          @map("email_verified_at")
  /// One-time token for /auth/verify-email?token=… (cleared after use).
  emailVerificationToken            String?            @unique @map("email_verification_token")
  emailVerificationExpires          DateTime?          @map("email_verification_expires")
  /// Set when the user confirms their mobile number via SMS OTP (see ContactVerificationCode).
  phoneVerifiedAt                   DateTime?          @map("phone_verified_at")
  name                              String?
  phone                             String?
  /// Optional home / primary market (multi-city expansion; denormalized).
  homeCity                          String?            @map("home_city")
  homeRegion                        String?            @map("home_region")
  homeCountry                       String?            @map("home_country")
  /// UI locale preference (`en` | `fr` | `es` | `ar`); synced with `mi_locale` cookie when the user switches language.
  preferredUiLocale                 String?            @map("preferred_ui_locale") @db.VarChar(8)
  /// Canonical LECIPM market city for dashboards and rollout.
  lecipmCityId                      String?            @map("lecipm_city_id")
  /// Seller Hub: mailing / contact address collected at onboarding (not legal advice).
  sellerProfileAddress              String?            @map("seller_profile_address") @db.Text
  /// Seller Hub wizard: `basicInfo`, `propertyAddress`, `ownershipConfirmed`, `idVerifiedAt` (ISO), etc.
  sellerHubOnboardingJson           Json?              @map("seller_hub_onboarding_json")
  /// FSBO = sell yourself; PLATFORM_BROKER = list with platform broker assistance (`FsboListing.listingOwnerType`).
  sellerSellingMode                 String?            @map("seller_selling_mode")
  sellerOnboardingCompletedAt       DateTime?          @map("seller_onboarding_completed_at")
  /// User-level acknowledgment of listing accuracy (optional; per-listing also on `FsboListing`).
  sellerLegalAccuracyAcceptedAt     DateTime?          @map("seller_legal_accuracy_accepted_at")
  referralCode                      String?            @unique
  plan                              String             @default("free") @map("plan") // free | basic | pro
  /// Marketplace onboarding group — drives default dashboard routes and UX.
  marketplacePersona                MarketplacePersona @default(UNSET) @map("marketplace_persona")
  /// Seller DIY plans: basic | assisted | premium
  sellerPlan                        String?            @map("seller_plan")
  /**
   * Stripe Connect Express account id (acct_...) for BNHub host payouts
   */
  stripeAccountId                   String?            @map("stripe_account_id")
  /**
   * True when Connect onboarding completed (synced from Stripe or return URL).
   */
  stripeOnboardingComplete          Boolean            @default(false) @map("stripe_onboarding_complete")
  /// Last known Stripe Account `charges_enabled` (denormalized; refreshed on status sync).
  stripeChargesEnabled              Boolean?           @map("stripe_charges_enabled")
  /// Last known Stripe Account `payouts_enabled` (denormalized; refreshed on status sync).
  stripePayoutsEnabled              Boolean?           @map("stripe_payouts_enabled")
  /// Outbound growth messaging: warm | buyer | broker | host (manual or automation).
  growthOutreachSegment             String?            @map("growth_outreach_segment")
  growthLastContactAt               DateTime?          @map("growth_last_contact_at")
  growthFollowUpDueAt               DateTime?          @map("growth_follow_up_due_at")
  growthFollowUpSentAt              DateTime?          @map("growth_follow_up_sent_at")
  /// When true, automated follow-ups and triggers skip this user.
  growthMessagingPaused             Boolean            @default(false) @map("growth_messaging_paused")
  /// Launch checklist: persona picker completed (`/onboarding`).
  launchOnboardingCompletedAt       DateTime?          @map("launch_onboarding_completed_at")
  /// Optional: `find` | `list` | `invest`
  launchPersonaChoice               String?            @map("launch_persona_choice") @db.VarChar(32)
  /// First-touch acquisition at signup (channel + UTM + optional `?src=`). See `buildSignupAttributionPayload`.
  signupAttributionJson             Json?              @map("signup_attribution_json")
  /// Until this instant, user sees premium AI insights (deal score, investor views). Set by subscription or one-off Stripe.
  lecipmAiInsightsPremiumUntil      DateTime?          @map("lecipm_ai_insights_premium_until")
  /// BNHub guest trust snapshot (0–100); recomputed from stays, host reviews, disputes.
  bnhubGuestTrustScore              Int                @default(50) @map("bnhub_guest_trust_score")
  /// Completed BNHub stays (paid + COMPLETED) for this guest.
  bnhubGuestTotalStays              Int                @default(0) @map("bnhub_guest_total_stays")
  /// Average of host post-stay ratings (1–5), when at least one exists.
  bnhubGuestRatingAverage           Float?             @map("bnhub_guest_rating_average")
  /// BNHub pilot: founding hosts get badge + ranking tie-breaker (set by ops; never auto-faked).
  bnhubIsFoundingHost               Boolean            @default(false) @map("bnhub_is_founding_host")
  /// Set once when the broker’s first lead unlocks or first CRM outbound message is recorded — testimonial nudge.
  brokerTestimonialPromptEligibleAt DateTime?          @map("broker_testimonial_prompt_eligible_at")
  /// User dismissed the testimonial prompt (optional; stops repeat nudges).
  brokerTestimonialNudgeDismissedAt DateTime?          @map("broker_testimonial_nudge_dismissed_at")

  /// OACIQ License Integration (Phase 1)
  isOaciqLicensed    Boolean   @default(false) @map("is_oaciq_licensed")
  oaciqLicenseNumber String?   @map("oaciq_license_number") @db.VarChar(64)
  brokerageName      String?   @map("brokerage_name") @db.VarChar(512)
  licenseVerifiedAt  DateTime? @map("license_verified_at")

  createdAt                                DateTime                                 @default(now())
  updatedAt                                DateTime                                 @updatedAt
  /// Append-only audit — optional; not read at runtime (see `snapshot-writer.service.ts`).
  brokerActivityScores                     BrokerActivityScore[]
  /**
   * Centris-style broker transaction files (LEC-SD number).
   */
  /// Phase 4 broker deal pipeline (LEC-DEAL-*).
  /// Phase 7 — broker/investor portfolio workspaces (LECIPM Portfolio OS).
  lecipmBrokerPortfolios                   LecipmBrokerPortfolio[]
  /// Launch — Québec-first broker invites (OACIQ / early access).
  lecipmBrokerInvitesSent                  LecipmBrokerInvite[]                     @relation("LecipmBrokerInviteSender")
  lecipmBrokerInviteAccepted               LecipmBrokerInvite[]                     @relation("LecipmBrokerInviteAccept")
  lecipmBrokerLaunchSubscription           LecipmBrokerLaunchSubscription?
  lecipmBrokerUsageEvents                  LecipmBrokerUsageEvent[]
  lecipmBrokerLaunchReferralsGiven         LecipmBrokerLaunchReferral[]             @relation("LecipmBrokerLaunchReferrer")
  brokerProfilesReferred                   BrokerProfile[]                          @relation("BrokerProfileReferredBy")
  /// Soins Hub — residence operator (optional).
  /// Soins Hub — at most one active resident profile per account.
  /// AMF-aligned capital raises — sponsor / issuer.
  /// Linked accredited investor profile (optional).
  userMemoryProfile                        UserMemoryProfile?
  marketplaceMemoryEvents                  UserMemoryEvent[]
  marketplaceMemoryInsights                UserMemoryInsight[]
  marketplaceMemorySessions                UserMemorySession[]
  userIntelligenceProfile                  UserIntelligenceProfile?
  /// Wave 13 — LECIPM auditable user preference memory (playbook + Dream Home; no protected-trait storage).
  userPreferenceProfileW13                 UserPreferenceProfile?                   @relation("UserPreferenceProfileW13")
  userJourneyStateW13                      UserJourneyState?                        @relation("UserJourneyStateW13")
  userPreferenceSignalsW13                 UserPreferenceSignal[]                   @relation("UserPreferenceSignalOwner")
  userBehaviorEvents                       UserBehaviorEvent[]
  socialAccounts                           SocialAccount[]
  brokerProfile                            BrokerProfile?
  brokerActivities                         BrokerActivity[]
  lecipmBrokerageContractsAsBroker         LecipmBrokerageContract[]                @relation("LecipmBrokerageContractBroker")
  lecipmBrokerageIdentityProofsAsSeller    LecipmBrokerageIdentityProof[]           @relation("LecipmBrokerageIdentityProofSeller")
  lecipmBrokerageIdentityProofsVerified    LecipmBrokerageIdentityProof[]           @relation("LecipmBrokerageIdentityProofVerifier")
  /// LECIPM portfolio intelligence (supervised autonomy) — policy + plans scoped to owner.
  brokerApplications                       BrokerApplication[]
  developerApplications                    DeveloperApplication[]
  /// LECIPM First Revenue — balance of paid contract (turbo) export credits.
  /// Multi-provider orchestration ledger (Stripe primary, Clover secondary) — see `lib/payments`.
  brokerCommissions                        BrokerCommission[]
  /// Investor-intelligence / expansion scenarios authored by this user.
  /**
   * Visited evaluate funnel without completing; cleared on evaluation submit (retargeting prep).
   */
  isRetargetCandidate                      Boolean                                  @default(false) @map("is_retarget_candidate")
  /// LECIPM transactional AI Autopilot Layer (drafts/deals) — distinct from BNHub `HostAutopilotSettings`.
  /// TrustGraph Autopilot (reviewer on human review actions)
  mortgageExpertProfile                    MortgageExpert?
  /// First-10-clients / manual acquisition CRM (admin launch dashboard)
  /// Listing supply pipeline rows assigned to this admin/operator.
  /**
   * Public /deal views attributed to this user when share links include ?ru=
   */
  /// Investment MVP: completed analyze runs (server-tracked, logged-in users).
  investmentMvpAnalyzeCount                Int                                      @default(0) @map("investment_mvp_analyze_count")
  investmentMvpFirstAnalyzeAt              DateTime?                                @map("investment_mvp_first_analyze_at")
  mortgageRequests                         MortgageRequest[]
  /// When set, this user can access `/broker/dashboard` for assigned `MortgageRequest` rows.
  mortgageBrokerAccount                    MortgageBroker?
  /// Insurance PROPERTY leads assigned to this broker (`InsuranceLead.assignedBrokerUserId`).
  growthUserEvents                         UserEvent[]                              @relation("GrowthUserEvents")
  twoFactorCodes                           TwoFactorCode[]
  lecipmCrmContacts                        LecipmCrmContact[]                       @relation("LecipmCrmContactBroker")
  lecipmCrmPipelineLeads                   LecipmCrmPipelineLead[]                  @relation("LecipmCrmPipelineBroker")
  lecipmBrokerTasksAuthored                LecipmBrokerTask[]                       @relation("LecipmBrokerTaskBroker")
  lecipmBrokerCrmAuditLogs                 LecipmBrokerCrmAuditLog[]                @relation("LecipmBrokerCrmAuditBroker")
  lecipmBrokerListingThreadsAsBroker       LecipmBrokerListingThread[]              @relation("BrokerListingThreadBroker")
  lecipmBrokerListingThreadsAsCustomer     LecipmBrokerListingThread[]              @relation("BrokerListingThreadCustomer")
  lecipmBrokerListingMessagesSent          LecipmBrokerListingMessage[]             @relation("BrokerListingMessageSender")
  lecipmBrokerListingParticipants          LecipmBrokerListingParticipant[]
  lecipmBrokerCrmLeadsAsBroker             LecipmBrokerCrmLead[]                    @relation("BrokerCrmLeadBroker")
  lecipmBrokerCrmLeadsAsCustomer           LecipmBrokerCrmLead[]                    @relation("BrokerCrmLeadCustomer")
  lecipmBrokerCrmLeadNotesAuthored         LecipmBrokerCrmLeadNote[]                @relation("BrokerCrmLeadNoteAuthor")
  lecipmBrokerAutopilotSettings            LecipmBrokerAutopilotSetting[]           @relation("BrokerAutopilotSettingBroker")
  lecipmBrokerAutopilotActions             LecipmBrokerAutopilotAction[]            @relation("BrokerAutopilotActionBroker")
  lecipmBrokerDailyBriefings               LecipmBrokerDailyBriefing[]              @relation("BrokerDailyBriefingBroker")
  lecipmBrokerClientProfiles               LecipmBrokerClientProfile[]              @relation("LecipmBrokerClientProfileBroker")
  ownedBrokerTeams                         BrokerTeam[]                             @relation("BrokerTeamOwner")
  brokerTeamMemberships                    BrokerTeamMember[]
  brokerInternalNotesAuthored              BrokerInternalNote[]                     @relation("BrokerInternalNoteAuthor")
  savedSearches                            SavedSearch[]
  /// Platform Dispute Room (neutral resolution workflow — distinct from BNHub `Dispute`).
  /// Latest acceptance of the platform Content & Usage License (version checked against `ContentLicensePolicy`).
  contentLicenseAcceptance                 ContentLicenseAcceptance?
  contentLicensePolicyUpdates              ContentLicensePolicy[]                   @relation("ContentLicensePolicyUpdatedBy")
  /// Long-term Rent Hub (landlord listings + tenant applications + leases).
  /// Canonical bigint listing (Supabase blueprint); optional link from FSBO.
  /// FSBO / CRM leads this broker purchased on the lead marketplace.
  enterpriseWorkspaceMemberships           EnterpriseWorkspaceMember[]
  enterpriseWorkspacesCreated              EnterpriseWorkspace[]                    @relation("EnterpriseWorkspaceCreator")
  enterpriseWorkspaceInvitesSent           EnterpriseWorkspaceInvite[]              @relation("EnterpriseWorkspaceInviter")
  workspaceAuditLogsAsActor                WorkspaceAuditLog[]                      @relation("WorkspaceAuditActor")
  /// BNHub monetization — hosts paying for featured / slots / local ads.
  lecipmUserExplainerMedia                 LecipmUserExplainerMedia?
  workspaceBrokerReputations               WorkspaceBrokerReputation[]              @relation("WorkspaceBrokerReputationBroker")
  workspaceDealSharesTarget                WorkspaceDealShare[]                     @relation("WorkspaceDealShareTarget")
  workspaceDealSharesCreated               WorkspaceDealShare[]                     @relation("WorkspaceDealShareCreator")
  workspaceCollaborationMessages           WorkspaceCollaborationMessage[]          @relation("WorkspaceCollabAuthor")
  workspaceReferralsAsReferrer             WorkspaceReferral[]                      @relation("WorkspaceReferralReferrer")
  dailyTasks                               DailyTask[]
  dailyMetrics                             DailyMetric[]
  /// Browser cookie holds `Session.token`; revoked on logout; prior rows revoked on new login (single active session).
  sessions                                 Session[]
  /// Revenue execution CRM — actions logged against this user (outreach / conversion).
  /// FARCIQ-style broker E&O coverage (LECIPM compliance layer — not legal advice).
  userLoyaltyProfile                       UserLoyaltyProfile?
  lecipmBrokerAvailabilities               LecipmBrokerAvailability[]
  lecipmBrokerTimeOffBlocks                LecipmBrokerTimeOff[]
  lecipmBrokerBookingSettings              LecipmBrokerBookingSettings?
  teamTasksAssigned                        TeamTask[]                               @relation("TeamTaskAssignee")
  teamTasksCreated                         TeamTask[]                               @relation("TeamTaskCreator")
  teamDailyReports                         TeamDailyReport[]
  teamDailyTargets                         TeamDailyTarget[]                        @relation("TeamDailyTargetUser")
  teamDailyTargetsCreated                  TeamDailyTarget[]                        @relation("TeamDailyTargetCreator")
  /**
   * Signup / policy acceptance audit (QUÉBEC Law 25–aligned records).
   */
  userConsents                             UserConsent[]
  /// Field demo specialist hiring (`/admin/team`) — linked when a candidate is onboarded.
}

model UserConsent {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// TERMS | PRIVACY | MARKETING
  type       String
  acceptedAt DateTime @default(now())

  @@index([userId])
  @@index([userId, type])
}

model TeamTask {
  id              String           @id @default(cuid())
  title           String           @map("title") @db.VarChar(512)
  description     String?          @map("description") @db.Text
  status          TeamTaskStatus   @default(PENDING) @map("status")
  priority        TeamTaskPriority @default(NORMAL) @map("priority")
  assigneeUserId  String           @map("assignee_user_id")
  assignee        User             @relation("TeamTaskAssignee", fields: [assigneeUserId], references: [id], onDelete: Cascade)
  createdByUserId String           @map("created_by_user_id")
  createdBy       User             @relation("TeamTaskCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  dueAt           DateTime?        @map("due_at")
  startedAt       DateTime?        @map("started_at")
  completedAt     DateTime?        @map("completed_at")
  /// 1–5 impact rating when task is completed (optional).
  impactScore     Int?             @map("impact_score")
  resultNotes     String?          @map("result_notes") @db.Text
  metadata        Json?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@index([assigneeUserId, status])
  @@index([status, createdAt])
  @@map("team_tasks")
}

model TeamDailyReport {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// UTC calendar day `YYYY-MM-DD`.
  reportDay     String   @map("report_day") @db.VarChar(10)
  completedWork String   @map("completed_work") @db.Text
  results       String?  @map("results") @db.Text
  issues        String?  @map("issues") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([userId, reportDay])
  @@index([reportDay])
  @@map("team_daily_reports")
}

model TeamDailyTarget {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation("TeamDailyTargetUser", fields: [userId], references: [id], onDelete: Cascade)
  /// UTC calendar day `YYYY-MM-DD`.
  targetDay   String   @map("target_day") @db.VarChar(10)
  taskGoal    Int      @default(5) @map("task_goal")
  notes       String?  @map("notes") @db.Text
  createdById String?  @map("created_by_id")
  createdBy   User?    @relation("TeamDailyTargetCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([userId, targetDay])
  @@map("team_daily_targets")
}

model PlatformAutonomyEvent {
  id              String                    @id @default(cuid())
  eventType       PlatformAutonomyEventType @map("event_type")
  entityType      String?                   @map("entity_type") @db.VarChar(64)
  entityId        String?                   @map("entity_id") @db.VarChar(64)
  userId          String?                   @map("user_id")
  payload         Json?
  dedupeKey       String?                   @unique @map("dedupe_key")
  processedAt     DateTime?                 @map("processed_at")
  processingError String?                   @map("processing_error") @db.Text
  createdAt       DateTime                  @default(now()) @map("created_at")

  @@index([eventType, createdAt])
  @@index([processedAt])
  @@map("platform_autonomy_events")
}

model PlatformAutomationRule {
  id            String                    @id @default(cuid())
  name          String                    @unique @map("name")
  enabled       Boolean                   @default(true)
  eventType     PlatformAutonomyEventType @map("event_type")
  conditionJson Json?                     @map("condition_json")
  /// e.g. notify_admin | log_only | trigger_automation | queue_listing_content
  actionKind    String                    @map("action_kind") @db.VarChar(64)
  actionPayload Json?                     @map("action_payload")
  priority      Int                       @default(0) @map("priority")
  createdAt     DateTime                  @default(now()) @map("created_at")
  updatedAt     DateTime                  @updatedAt @map("updated_at")

  @@index([eventType, enabled])
  @@map("platform_automation_rules")
}

model UserLoyaltyProfile {
  id                String      @id @default(cuid())
  userId            String      @unique @map("user_id")
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalBookings     Int         @default(0) @map("total_bookings")
  completedBookings Int         @default(0) @map("completed_bookings")
  lastBookingAt     DateTime?   @map("last_booking_at")
  tier              LoyaltyTier @default(NONE)
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  @@map("user_loyalty_profiles")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("Session")
}

model LecipmAvatarProfile {
  id             String   @id @default(cuid())
  name           String
  videoBaseUrl   String   @map("video_base_url") @db.Text
  voiceProfileId String?  @map("voice_profile_id") @db.Text
  styleConfig    Json?    @map("style_config")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([active])
  @@map("avatar_profiles")
}

model LecipmUserExplainerMedia {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoUrl  String?  @map("video_url") @db.Text
  imageUrl  String?  @map("image_url") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("lecipm_user_explainer_media")
}

model EnterpriseWorkspace {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  slug            String?  @unique
  createdByUserId String   @map("created_by_user_id")
  createdBy       User     @relation("EnterpriseWorkspaceCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  settings        Json?    @db.JsonB
  seatLimit       Int      @default(10) @map("seat_limit")
  planTier        String   @default("team") @map("plan_tier")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  members                        EnterpriseWorkspaceMember[]
  invites                        EnterpriseWorkspaceInvite[]
  auditLogs                      WorkspaceAuditLog[]
  lecipmDealHistories            LecipmDealHistory[]
  workspaceBrokerReputations     WorkspaceBrokerReputation[]
  workspaceDealShares            WorkspaceDealShare[]
  workspaceCollaborationMessages WorkspaceCollaborationMessage[]
  workspaceReferrals             WorkspaceReferral[]

  @@index([createdByUserId], map: "idx_enterprise_workspaces_created_by")
  @@map("enterprise_workspaces")
}

model EnterpriseWorkspaceMember {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String              @map("workspace_id") @db.Uuid
  workspace   EnterpriseWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String              @map("user_id")
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        LecipmWorkspaceRole
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([workspaceId, userId], map: "uq_enterprise_workspace_member")
  @@index([userId], map: "idx_enterprise_workspace_member_user")
  @@map("enterprise_workspace_members")
}

model EnterpriseWorkspaceInvite {
  id              String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId     String                      @map("workspace_id") @db.Uuid
  workspace       EnterpriseWorkspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email           String
  role            LecipmWorkspaceRole
  tokenHash       String                      @map("token_hash")
  status          LecipmWorkspaceInviteStatus @default(pending)
  invitedByUserId String                      @map("invited_by_user_id")
  invitedBy       User                        @relation("EnterpriseWorkspaceInviter", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  expiresAt       DateTime                    @map("expires_at") @db.Timestamptz(6)
  createdAt       DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([workspaceId], map: "idx_enterprise_workspace_invites_ws")
  @@index([email], map: "idx_enterprise_workspace_invites_email")
  @@map("enterprise_workspace_invites")
}

model WorkspaceAuditLog {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String              @map("workspace_id") @db.Uuid
  workspace   EnterpriseWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actorUserId String              @map("actor_user_id")
  actor       User                @relation("WorkspaceAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  entityType  String              @map("entity_type")
  entityId    String?             @map("entity_id")
  action      String
  metadata    Json?               @db.JsonB
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([workspaceId, createdAt(sort: Desc)], map: "idx_workspace_audit_ws_created")
  @@index([actorUserId], map: "idx_workspace_audit_actor")
  @@map("workspace_audit_logs")
}

model LecipmDealHistory {
  id          String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String                   @map("workspace_id") @db.Uuid
  workspace   EnterpriseWorkspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dealId      String                   @map("deal_id")
  outcome     LecipmDealHistoryOutcome
  /// Final or best-known price in cents (CAD).
  priceCents  Int                      @map("price_cents")
