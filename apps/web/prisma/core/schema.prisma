  invitedByUserId  String?   @map("invited_by_user_id") @db.VarChar(36)
  invitedBy        User?     @relation("LecipmBrokerInviteSender", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  acceptedByUserId String?   @map("accepted_by_user_id") @db.VarChar(36)
  acceptedBy       User?     @relation("LecipmBrokerInviteAccept", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  status           String    @default("PENDING") @db.VarChar(16)
  createdAt        DateTime  @default(now()) @map("created_at")
  acceptedAt       DateTime? @map("accepted_at")

  @@index([email])
  @@index([status])
  @@map("lecipm_broker_invites")
