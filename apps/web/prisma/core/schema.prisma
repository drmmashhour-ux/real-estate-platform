  brokerUserId  String   @map("broker_user_id")
  broker        User     @relation(fields: [brokerUserId], references: [id], onDelete: Cascade)
  startDateTime DateTime @map("start_date_time")
  endDateTime   DateTime @map("end_date_time")
  reason        String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([brokerUserId])
  @@map("lecipm_broker_time_off")
}

model LecipmBrokerBookingSettings {
  id               String   @id @default(cuid())
  brokerUserId     String   @unique @map("broker_user_id")
  broker           User     @relation(fields: [brokerUserId], references: [id], onDelete: Cascade)
