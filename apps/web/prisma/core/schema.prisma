model LecipmBrokerPortfolio {
  id          String @id @default(cuid())
  ownerUserId String @map("owner_user_id") @db.VarChar(36)
  owner       User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  name        String  @db.VarChar(512)
  description String? @db.Text

  totalValue  Float? @map("total_value")
  totalAssets Int    @default(0) @map("total_assets")

  assetLinks      LecipmBrokerPortfolioAssetLink[]
  decisions       LecipmBrokerPortfolioDecision[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([ownerUserId])
  @@map("lecipm_broker_portfolios")
}

model LecipmBrokerPortfolioAssetLink {
  id          String                @id @default(cuid())
  portfolioId String                @map("portfolio_id") @db.VarChar(36)
  portfolio   LecipmBrokerPortfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  assetId String               @map("asset_id") @db.VarChar(36)

  allocationWeight Float? @map("allocation_weight")

  addedAt DateTime @default(now()) @map("added_at")

  @@unique([portfolioId, assetId])
  @@index([assetId])
  @@map("lecipm_broker_portfolio_asset_links")
}

model LecipmBrokerInvite {
