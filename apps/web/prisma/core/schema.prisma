model LecipmBrokerPortfolioDecision {
  id          String                @id @default(cuid())
  portfolioId String                @map("portfolio_id") @db.VarChar(36)
  portfolio   LecipmBrokerPortfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  assetId String?               @map("asset_id") @db.VarChar(36)

  decisionType    String @map("decision_type") @db.VarChar(24)
  rationale       String @db.Text
  confidenceScore Float? @map("confidence_score")

  requiresApproval Boolean @default(true) @map("requires_approval")
  status           String  @default("PROPOSED") @db.VarChar(16)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([portfolioId])
  @@map("lecipm_broker_portfolio_decisions")
}