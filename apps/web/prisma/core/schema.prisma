  LISTING_OPERATOR
  OUTREACH_OPERATOR
  OPERATOR
  SUPPORT_AGENT
  /// Marketplace — residential buyer hub (`/dashboard/buyer`)
  BUYER
  /// Marketplace — DIY / FSBO seller (`/dashboard/seller`)
  SELLER_DIRECT
  /// Marketplace — mortgage specialist (same product surface as MORTGAGE_EXPERT; prefer one per user long-term)
  MORTGAGE_BROKER
  /// Property & stay insurance partners (`/dashboard/insurance`)
