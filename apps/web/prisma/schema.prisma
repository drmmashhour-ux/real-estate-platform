generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  /// Postgres URL (Neon pooled/direct, RDS, local). Use sslmode=require for hosted providers.
  url      = env("DATABASE_URL")
}

/// Atomic monotonic counters for public codes (LST-, USR-, BKG-, …). Never decremented; never reused.
model PlatformCodeSequence {
  id        String   @id @default(cuid())
  scope     String   @unique
  nextValue Int      @default(1) @map("next_value")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_code_sequences")
}

// Platform ecosystem roles – unified across all hubs
enum PlatformRole {
  VISITOR // Browse only (not logged in)
  USER // Signed-up user: booking, messaging
  CLIENT // Legacy alias for USER (treat as USER in guards)
  TESTER // Staging/UAT demo testers (same product access as USER; use on staging DB only)
  HOST // BNHub: manage listings (must verify + accept hosting terms)
  BROKER // Real estate: CRM + deals (must verify + accept broker terms)
  MORTGAGE_EXPERT // Mortgage specialists: profile, assigned leads
  DEVELOPER // Projects: manage projects (must verify + accept developer terms)
  ACCOUNTANT // Financial dashboard, reports, tax docs — no system config / user deletion
  ADMIN // Full control
  /// Privacy & Compliance Roles (Law 25)
  PRIVACY_OFFICER
  LEGAL_ADMIN
  COMPLIANCE_STAFF
  AGENCY_EXECUTIVE
  UNREPRESENTED_BUYER
  /// Internal ops — team workspace (`/admin/team`): tasks, daily reports, scoped metrics (not full platform admin)
  CONTENT_OPERATOR
  LISTING_OPERATOR
  OUTREACH_OPERATOR
  SUPPORT_AGENT
  /// Marketplace — residential buyer hub (`/dashboard/buyer`)
  BUYER
  /// Marketplace — DIY / FSBO seller (`/dashboard/seller`)
  SELLER_DIRECT
  /// Marketplace — mortgage specialist (same product surface as MORTGAGE_EXPERT; prefer one per user long-term)
  MORTGAGE_BROKER
  /// Property & stay insurance partners (`/dashboard/insurance`)
  INSURANCE_BROKER
  /// Investor relations — pitch + private metrics (`/investor/*`)
  INVESTOR
}

/// Product “persona” for marketplace UX (onboarding + dashboards). Complements `PlatformRole` (permissions).
enum MarketplacePersona {
  UNSET
  BUYER
  SELLER_DIRECT
  BROKER
  MORTGAGE_BROKER
}

// Broker certification status (OACIQ-style)
enum BrokerStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
}

/**
 * Manual broker payout batches (no automated Stripe payouts unless you wire them).
 */
enum BrokerPayoutStatus {
  PENDING
  APPROVED
  PAID
  FAILED
  CANCELLED
}

/**
 * GST/QST profile — format validation only; staff review (not government-verified).
 */
enum BrokerTaxRegistrationStatus {
  SUBMITTED
  FORMAT_VALID
  PENDING_STAFF_REVIEW
  MANUALLY_REVIEWED
  APPROVED
  REJECTED
}

/**
 * Revenue attribution — platform vs broker (separate ledger rows; never mixed).
 */
enum RevenueParty {
  PLATFORM
  BROKER
}

/**
 * Tax document issuer — platform fees vs broker commission invoices must not be merged.
 */
enum InvoiceIssuer {
  PLATFORM
  BROKER
}

/// Platform-generated invoice lifecycle (operational; not a filed tax return).
enum PlatformInvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOID
  OVERDUE
}

// Account status – unified professional verification
enum AccountStatus {
  ACTIVE // Approved; full access
  PENDING_VERIFICATION // Applied; awaiting admin approval
  RESTRICTED // Rejected or limited; cannot use professional features
  SUSPENDED // Temporary suspension
  BANNED // Permanent; cannot use platform
}

// ---------------------------------------------------------------------------
// BNHub (short-term rental) enums
// ---------------------------------------------------------------------------
enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

// FSBO photo verification lifecycle (address consistency + user confirmation).
enum FsboPhotoVerificationStatus {
  PENDING
  VERIFIED
  FLAGGED
}

// Property ownership verification (land register / cadastre)
enum ListingAuthorityType {
  OWNER
  BROKER
}

enum ListingVerificationStatus {
  DRAFT // Not yet submitted for verification
  PENDING_VERIFICATION // Documents submitted, awaiting admin review
  PENDING_DOCUMENTS // Admin requested more documents; lister can resubmit
  VERIFIED // Ownership/broker authorization confirmed (cadastre + identity + location)
  REJECTED // Verification failed
}

enum PropertyDocumentType {
  LAND_REGISTRY_EXTRACT
  BROKER_AUTHORIZATION
}

/// Commission / monetization category for listings (sale vs rental verticals).
enum ListingCommissionCategory {
  SALE
  RENT_LONG
  RENT_SHORT
}

enum BookingStatus {
  PENDING // Awaiting payment
  AWAITING_HOST_APPROVAL // Request sent, host must approve or decline
  CONFIRMED
  DECLINED // Host declined
  CANCELLED_BY_GUEST
  CANCELLED_BY_HOST
  CANCELLED // Legacy / admin cancellation
  COMPLETED
  DISPUTED
  /// Unpaid checkout abandoned past `pendingCheckoutExpiresAt` (or legacy 1h rule) — ignored for overlap.
  EXPIRED
}

/// Offline / manual settlement tracking (Syria-style markets). Does not replace `BookingStatus`; pairs with `PENDING` while host arranges payment outside Stripe.
enum ManualPaymentSettlement {
  NOT_APPLICABLE
  PENDING
  RECEIVED
  FAILED
  WAIVED
}

enum ListingStatus {
  DRAFT // Not visible in search
  PENDING_REVIEW // Submitted; awaiting admin approval (Quebec/OACIQ-style)
  APPROVED // Admin approved; can be published
  PUBLISHED // Live and searchable
  UNLISTED // Temporarily hidden
  SUSPENDED // Admin action
  UNDER_INVESTIGATION // Fraud suspected; removed from public; admin review
  FROZEN // Explicit freeze (same visibility as under_investigation)
  REJECTED_FOR_FRAUD // Fraud confirmed; listing rejected
  PERMANENTLY_REMOVED // Permanently removed for fraud
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

/// Permission-based listing supply (owners / brokers / hosts). Never used for scraped third-party inventory.
enum ListingAcquisitionSourceType {
  OWNER
  BROKER
  HOST
  MANUAL

  @@map("listing_acquisition_source_type")
}

enum ListingAcquisitionPermissionStatus {
  UNKNOWN
  REQUESTED
  GRANTED
  REJECTED

  @@map("listing_acquisition_permission_status")
}

enum ListingAcquisitionIntakeStatus {
  NEW
  CONTACTED
  INTERESTED
  AWAITING_ASSETS
  READY_FOR_REVIEW
  PUBLISHED
  ARCHIVED

  @@map("listing_acquisition_intake_status")
}

model User {
  id                            String             @id @default(uuid())
  email                         String             @unique
  passwordHash                  String?            @map("password_hash") // Optional: demo users may have no password
  role                          PlatformRole       @default(USER)
  brokerStatus                  BrokerStatus       @default(NONE) @map("broker_status")
  accountStatus                 AccountStatus      @default(ACTIVE) @map("account_status")
  /// Public account code for support and admin tracking (e.g. USR-XXXXXX).
  userCode                      String?            @unique @map("user_code")
  /// Optional email-based 2FA after password (sends 6-digit code).
  twoFactorEmailEnabled         Boolean            @default(false) @map("two_factor_email_enabled")
  /// Set when the user verifies via email link (new signups); existing users backfilled in migration.
  emailVerifiedAt               DateTime?          @map("email_verified_at")
  /// One-time token for /auth/verify-email?token=… (cleared after use).
  emailVerificationToken        String?            @unique @map("email_verification_token")
  emailVerificationExpires      DateTime?          @map("email_verification_expires")
  /// Set when the user confirms their mobile number via SMS OTP (see ContactVerificationCode).
  phoneVerifiedAt               DateTime?          @map("phone_verified_at")
  name                          String?
  phone                         String?
  /// Optional home / primary market (multi-city expansion; denormalized).
  homeCity                      String?            @map("home_city")
  homeRegion                    String?            @map("home_region")
  homeCountry                   String?            @map("home_country")
  /// UI locale preference (`en` | `fr` | `es` | `ar`); synced with `mi_locale` cookie when the user switches language.
  preferredUiLocale             String?            @map("preferred_ui_locale") @db.VarChar(8)
  /// Canonical LECIPM market city for dashboards and rollout.
  lecipmCityId                  String?            @map("lecipm_city_id")
  lecipmCity                    City?              @relation(fields: [lecipmCityId], references: [id], onDelete: SetNull)
  /// Seller Hub: mailing / contact address collected at onboarding (not legal advice).
  sellerProfileAddress          String?            @map("seller_profile_address") @db.Text
  /// Seller Hub wizard: `basicInfo`, `propertyAddress`, `ownershipConfirmed`, `idVerifiedAt` (ISO), etc.
  sellerHubOnboardingJson       Json?              @map("seller_hub_onboarding_json")
  /// FSBO = sell yourself; PLATFORM_BROKER = list with platform broker assistance (`FsboListing.listingOwnerType`).
  sellerSellingMode             String?            @map("seller_selling_mode")
  sellerOnboardingCompletedAt   DateTime?          @map("seller_onboarding_completed_at")
  /// User-level acknowledgment of listing accuracy (optional; per-listing also on `FsboListing`).
  sellerLegalAccuracyAcceptedAt DateTime?          @map("seller_legal_accuracy_accepted_at")
  referralCode                  String?            @unique
  plan                          String             @default("free") @map("plan") // free | basic | pro
  /// Marketplace onboarding group — drives default dashboard routes and UX.
  marketplacePersona            MarketplacePersona @default(UNSET) @map("marketplace_persona")
  /// Seller DIY plans: basic | assisted | premium
  sellerPlan                    String?            @map("seller_plan")
  /**
   * Stripe Connect Express account id (acct_...) for BNHub host payouts
   */
  stripeAccountId               String?            @map("stripe_account_id")
  /**
   * True when Connect onboarding completed (synced from Stripe or return URL).
   */
  stripeOnboardingComplete      Boolean            @default(false) @map("stripe_onboarding_complete")
  /// Last known Stripe Account `charges_enabled` (denormalized; refreshed on status sync).
  stripeChargesEnabled          Boolean?           @map("stripe_charges_enabled")
  /// Last known Stripe Account `payouts_enabled` (denormalized; refreshed on status sync).
  stripePayoutsEnabled          Boolean?           @map("stripe_payouts_enabled")
  /// Outbound growth messaging: warm | buyer | broker | host (manual or automation).
  growthOutreachSegment         String?            @map("growth_outreach_segment")
  growthLastContactAt           DateTime?          @map("growth_last_contact_at")
  growthFollowUpDueAt           DateTime?          @map("growth_follow_up_due_at")
  growthFollowUpSentAt          DateTime?          @map("growth_follow_up_sent_at")
  /// When true, automated follow-ups and triggers skip this user.
  growthMessagingPaused         Boolean            @default(false) @map("growth_messaging_paused")
  /// Launch checklist: persona picker completed (`/onboarding`).
  launchOnboardingCompletedAt   DateTime?          @map("launch_onboarding_completed_at")
  /// Optional: `find` | `list` | `invest`
  launchPersonaChoice           String?            @map("launch_persona_choice") @db.VarChar(32)
  /// First-touch acquisition at signup (channel + UTM + optional `?src=`). See `buildSignupAttributionPayload`.
  signupAttributionJson         Json?              @map("signup_attribution_json")
  /// Until this instant, user sees premium AI insights (deal score, investor views). Set by subscription or one-off Stripe.
  lecipmAiInsightsPremiumUntil  DateTime?          @map("lecipm_ai_insights_premium_until")
  /// BNHub guest trust snapshot (0–100); recomputed from stays, host reviews, disputes.
  bnhubGuestTrustScore          Int                @default(50) @map("bnhub_guest_trust_score")
  /// Completed BNHub stays (paid + COMPLETED) for this guest.
  bnhubGuestTotalStays          Int                @default(0) @map("bnhub_guest_total_stays")
  /// Average of host post-stay ratings (1–5), when at least one exists.
  bnhubGuestRatingAverage       Float?             @map("bnhub_guest_rating_average")

  /// OACIQ License Integration (Phase 1)
  isOaciqLicensed    Boolean   @default(false) @map("is_oaciq_licensed")
