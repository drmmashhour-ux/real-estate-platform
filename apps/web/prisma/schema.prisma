  createdAt     DateTime          @default(now()) @map("created_at")

  @@index([userId])
  @@index([fsboListingId])
  @@index([severity])
  @@index([createdAt])
  @@map("risk_alerts")
}

/// Audit-friendly deterministic legal intelligence snapshots (metadata only — no raw file payloads).
model LegalIntelligenceRecord {
