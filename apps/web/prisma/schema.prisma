  broker
  buyer
  host
}

enum GrowthEngineLeadSource {
  form
  csv
  manual
  referral
}

enum GrowthEnginePermissionStatus {
  unknown
  requested
  granted
  rejected
  granted_by_source
}

enum GrowthEngineLeadStage {
  new
  contacted
  interested
  awaiting_assets
  converted
  lost
}

/// Inbound routing for broker resale (Growth CRM — Leads Hub).
enum GrowthEngineBrokerRoute {
  unspecified
  real_estate
  mortgage
  both
}

/// Visitor-stated timeline for ops prioritization (Hot / Mid / Long).
enum GrowthEngineLeadUrgency {
  unspecified
  hot
  mid
  long_term
}

