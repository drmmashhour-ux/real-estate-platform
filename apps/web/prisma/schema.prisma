  effectiveStartDate DateTime         @map("effective_start_date")
  effectiveEndDate   DateTime?        @map("effective_end_date")
  verificationStatus String           @map("verification_status")
  notes              String?
  createdAt          DateTime         @default(now()) @map("created_at")

  @@index([propertyIdentityId])
  @@index([ownerIdentityId])
  @@map("ownership_history")
}

model BrokerAuthorizationHistory {
  id                  String           @id @default(uuid())
  propertyIdentityId  String           @map("property_identity_id")
  propertyIdentity    PropertyIdentity @relation(fields: [propertyIdentityId], references: [id], onDelete: Cascade)
  brokerIdentityId    String           @map("broker_identity_id")
  brokerIdentity      BrokerIdentity   @relation(fields: [brokerIdentityId], references: [id], onDelete: Cascade)
  ownerIdentityId     String?          @map("owner_identity_id")
  ownerIdentity       OwnerIdentity?   @relation(fields: [ownerIdentityId], references: [id], onDelete: SetNull)
  authorizationSource String           @map("authorization_source")
  startDate           DateTime         @map("start_date")
  endDate             DateTime?        @map("end_date")
  verificationStatus  String           @map("verification_status")
