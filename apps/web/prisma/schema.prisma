  /// Route to real-estate broker desk vs mortgage desk vs both (Leads Hub).
  brokerRoute                  GrowthEngineBrokerRoute      @default(unspecified) @map("broker_route")
  /// Visitor-stated service horizon (hot / 1–3 mo / 6+ mo).
  leadUrgency                  GrowthEngineLeadUrgency      @default(unspecified) @map("lead_urgency")
  /// When mortgage is in scope, prefer platform mortgage experts first.
  preferPlatformMortgageExpert Boolean                      @default(false) @map("prefer_platform_mortgage_expert")
  createdAt                    DateTime                     @default(now()) @map("created_at")
  updatedAt                    DateTime                     @updatedAt @map("updated_at")

  @@index([email])
  @@index([stage])
  @@index([source])
  @@index([role])
  @@index([needsFollowUp])
  @@index([createdAt])
  @@index([brokerRoute])
  @@index([leadUrgency])
  @@map("growth_engine_leads")
}

/// AI Growth Brain — recommendations, approvals, outcomes (see lib/growth-brain/).
enum GrowthBrainDomain {
  supply
  demand
  seo
  content
  conversion
  revenue
  retention
}

enum GrowthBrainPriority {
  low
  medium
  high
}

enum GrowthBrainApprovalStatus {
  pending
  approved
  rejected
  executed
}

model GrowthBrainRecommendation {
  id               String              @id @default(cuid())
  type             String              @db.VarChar(96)
  domain           GrowthBrainDomain
  priority         GrowthBrainPriority
  confidence       Float
  title            String              @db.VarChar(400)
  description      String              @db.Text
  reasoning        String              @db.Text
  suggestedAction  String              @map("suggested_action") @db.Text
  autoRunnable     Boolean             @default(false) @map("auto_runnable")
  requiresApproval Boolean             @default(true) @map("requires_approval")
  targetEntityType String?             @map("target_entity_type") @db.VarChar(64)
  targetEntityId   String?             @map("target_entity_id") @db.VarChar(64)
  metadataJson     Json?               @map("metadata_json")
  runId            String              @map("run_id") @db.VarChar(64)
  status           String              @default("active") @db.VarChar(24)
  fingerprint      String              @unique @db.VarChar(160)
  viewedCount      Int                 @default(0) @map("viewed_count")
  dismissedCount   Int                 @default(0) @map("dismissed_count")
  approvedCount    Int                 @default(0) @map("approved_count")
  executedCount    Int                 @default(0) @map("executed_count")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  approvals GrowthBrainApproval[]
  outcomes  GrowthBrainOutcomeEvent[]

  @@index([domain, priority])
  @@index([runId])
  @@index([status, createdAt])
  @@map("growth_brain_recommendations")
}

model GrowthBrainApproval {
  id               String                    @id @default(cuid())
  recommendationId String                    @map("recommendation_id")
  recommendation   GrowthBrainRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  status           GrowthBrainApprovalStatus @default(pending)
  reviewerId       String?                   @map("reviewer_id")
  reviewer         User?                     @relation("GrowthBrainApprovalReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  notes            String?                   @db.Text
  createdAt        DateTime                  @default(now()) @map("created_at")
  executedAt       DateTime?                 @map("executed_at")

  @@index([recommendationId])
  @@index([status, createdAt])
  @@map("growth_brain_approvals")
}

model GrowthBrainOutcomeEvent {
  id               String                    @id @default(cuid())
  recommendationId String                    @map("recommendation_id")
  recommendation   GrowthBrainRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  eventType        String                    @map("event_type") @db.VarChar(32)
  metadataJson     Json?                     @map("metadata_json")
  createdAt        DateTime                  @default(now()) @map("created_at")

  @@index([recommendationId, createdAt])
  @@map("growth_brain_outcome_events")
}

/// B2B / enterprise sales pipeline (property managers, agencies, operators). See docs/enterprise-sales.md
enum EnterpriseLeadSegment {
  PROPERTY_MANAGEMENT
  REAL_ESTATE_AGENCY
  MULTI_PROPERTY_HOST
  STR_OPERATOR
  TRAVEL_BUSINESS
}

enum EnterpriseLeadStage {
  LEAD_IDENTIFIED
  CONTACTED
  INTERESTED
  DEMO_SCHEDULED
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

model EnterpriseLead {
  id                     String                @id @default(cuid())
  companyName            String                @map("company_name") @db.VarChar(320)
  contactName            String?               @map("contact_name") @db.VarChar(160)
  email                  String                @db.VarChar(320)
  phone                  String?               @db.VarChar(64)
  segment                EnterpriseLeadSegment @map("segment")
  stage                  EnterpriseLeadStage   @default(LEAD_IDENTIFIED) @map("stage")
  notes                  String?               @db.Text
  /// Estimated annual or pilot deal value in cents (optional)
  dealValueEstimateCents Int?                  @map("deal_value_estimate_cents")
  /// Light automation: reminder to follow up
  followUpAt             DateTime?             @map("follow_up_at")
  /// 0–100 manual or rule-based (see lib/enterprise/sales-lead-rules.ts)
  leadScore              Int?                  @map("lead_score")
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")

  @@index([stage])
  @@index([segment])
  @@index([followUpAt])
  @@index([createdAt])
  @@map("enterprise_leads")
}

/// Optional product feedback (floating “Give feedback” form)
model ProductFeedback {
  id          String   @id @default(cuid())
  liked       String?  @db.Text
  confusing   String?  @db.Text
  suggestions String?  @db.Text
  path        String?  @db.VarChar(512)
  userAgent   String?  @db.VarChar(512)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("product_feedback")
}

/// Product analytics — normalized event stream (investment funnel + visits)
enum UserEventType {
  ANALYZE
  SAVE_DEAL
  COMPARE
  VISIT_PAGE
  WAITLIST_SIGNUP
  RETURN_VISIT
  /// LECIPM + BNHub product funnel (growth dashboard)
  SIGNUP
  LOGIN
  LISTING_VIEW
  FAVORITE
  INQUIRY
  BOOKING_START
  CHECKOUT_START
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  STRIPE_WEBHOOK
  /// Live funnel / monitoring (search, messaging, AI)
  SEARCH_PERFORMED
  MESSAGE_SENT
  AI_REPLY_SENT
}

/// Email waitlist for product updates (growth / conversion)
model WaitlistUser {
  id                String    @id @default(cuid())
  email             String
  /// JSON array of tags e.g. ["early_user"]
  tags              Json      @default("[]")
  /// When tagged as early_user (first cohort)
  earlyUserTaggedAt DateTime? @map("early_user_tagged_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@unique([email])
  @@index([createdAt])
  @@map("waitlist_users")
}

/// Growth engine: simple marketing waitlist (distinct from `WaitlistUser` tags/cohorts).
model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("growth_waitlist")
}

/// Residence operators applying for limited partnership slots (supply control / exclusivity).
model OperatorWaitlist {
  id               String    @id @default(cuid())
  name             String    @db.VarChar(256)
  email            String    @db.VarChar(320)
  residenceName    String    @map("residence_name") @db.VarChar(512)
  city             String    @db.VarChar(160)
  /// Optional phone / WhatsApp — “contact” from apply form.
  phone            String?   @db.VarChar(64)
  /// PENDING | APPROVED | REJECTED
  status           String    @default("PENDING") @db.VarChar(24)
  /// Higher = reviewed first in dashboard (manual prioritize).
  priority         Int       @default(0)
  reviewedAt       DateTime? @map("reviewed_at")
  onboardingSentAt DateTime? @map("onboarding_sent_at")
  notes            String?   @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([city, status])
  @@index([status, priority(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("operator_waitlist")
}

model UserEvent {
  id        String        @id @default(cuid())
  eventType UserEventType
  metadata  Json?
  sessionId String?       @db.VarChar(64)
  userId    String?       @map("user_id")
  user      User?         @relation("GrowthUserEvents", fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([eventType, createdAt])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([userId, eventType, createdAt])
  @@map("user_events")
}

/// Admin / ops: API, Stripe, and validation failures for live debugging (optional `LIVE_DEBUG_MODE` workflows).
model ErrorEvent {
  id        String   @id @default(cuid())
  errorType String   @map("error_type") @db.VarChar(64)
  message   String   @db.Text
  stack     String?  @db.Text
  userId    String?  @map("user_id")
  user      User?    @relation("LiveDebugErrorEvents", fields: [userId], references: [id], onDelete: SetNull)
  route     String?  @db.VarChar(512)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([errorType, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("error_events")
}

/// Launch / investor validation funnel — discrete events for admin dashboard.
model LaunchEvent {
  id        String   @id @default(cuid())
  event     String
  payload   Json
  timestamp DateTime @default(now())
  createdAt DateTime @default(now()) @map("created_at")
  /// Optional actor for growth metrics (signups, bookings, referrals).
  userId    String?  @map("user_id")
  user      User?    @relation("LaunchEvents", fields: [userId], references: [id], onDelete: SetNull)

  @@index([event, createdAt])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("launch_events")
}

/// Audit log for first-users / manual acquisition daily plans (engine output; additive).
model LaunchActionLog {
  id          String   @id @default(cuid())
  runDate     DateTime @map("run_date") @db.Date
  city        String   @db.VarChar(128)
  /// e.g. organic_manual
  source      String   @db.VarChar(32)
  /// e.g. facebook | tiktok | dm | broker | classified | engine
  channel     String   @db.VarChar(32)
  payloadJson Json     @map("payload_json")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([runDate, city])
  @@index([createdAt])
  @@map("launch_actions_log")
}

/// Idempotent log of Stripe webhook deliveries for growth analytics (one row per `event.id`).
model GrowthStripeWebhookLog {
  id              String   @id @default(cuid())
  stripeEventId   String   @unique @map("stripe_event_id")
  eventType       String   @map("event_type")
  metadata        Json?
  bookingId       String?  @map("booking_id")
  paymentIntentId String?  @map("payment_intent_id")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([eventType, createdAt])
  @@map("growth_stripe_webhook_logs")
}

/// Processed Stripe webhook `event.id` — skip duplicate delivery handling for observability paths.
model StripeWebhookEventDedupe {
  eventId   String   @id @map("event_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("stripe_events")
}

enum GrowthEmailQueueType {
  WELCOME
  REMINDER
  FOLLOWUP
}

enum GrowthEmailQueueStatus {
  PENDING
  SENT
  FAILED
}

model GrowthEmailQueue {
  id          String                 @id @default(cuid())
  userId      String?                @map("user_id")
  user        User?                  @relation("GrowthEmailQueueUser", fields: [userId], references: [id], onDelete: Cascade)
  type        GrowthEmailQueueType
  payload     Json?
  status      GrowthEmailQueueStatus @default(PENDING)
  scheduledAt DateTime               @map("scheduled_at")
  sentAt      DateTime?              @map("sent_at")
  lastError   String?                @map("last_error") @db.Text
  createdAt   DateTime               @default(now()) @map("created_at")

  @@index([status, scheduledAt])
  @@index([userId])
  @@map("growth_email_queue")
}

/// Segmented outbound copy (LECIPM + BNHub growth messaging).
model MessageTemplate {
  id        String   @id @default(cuid())
  segment   String
  type      String
  subject   String?
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  logs MessageLog[]

  @@index([segment, type])
  @@map("message_templates")
}

model MessageLog {
  id           String           @id @default(cuid())
  userId       String           @map("user_id")
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId   String?          @map("template_id")
  template     MessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  channel      String           @default("email")
  status       String           @default("sent")
  subject      String?
  bodyPreview  String?          @map("body_preview") @db.Text
  triggerEvent String?          @map("trigger_event")
  metadata     Json?
  sentAt       DateTime         @default(now()) @map("sent_at")

  @@index([userId, sentAt])
  @@index([status])
  @@map("message_logs")
}

/// LECIPM + BNHub growth AI auto-reply threads (separate from CRM `conversations`).
model GrowthAiConversation {
  id                          String    @id @default(uuid())
  userId                      String?   @map("user_id")
  user                        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  channel                     String    @default("in_app")
  status                      String    @default("open")
  assignedToId                String?   @map("assigned_to_id")
  assignedTo                  User?     @relation("GrowthAiConversationAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  contextJson                 Json?     @map("context_json")
  humanTakeoverAt             DateTime? @map("human_takeover_at")
  aiReplyPending              Boolean   @default(false) @map("ai_reply_pending")
  lastAutomatedAt             DateTime? @map("last_automated_at")
  silentNudgeSentAt           DateTime? @map("silent_nudge_sent_at")
  /// Funnel: new | replied | qualified | booked | call_scheduled | handoff | lost | stale
  outcome                     String?   @map("outcome") @db.VarChar(32)
  highIntent                  Boolean   @default(false) @map("high_intent")
  lastUserMessageAt           DateTime? @map("last_user_message_at")
  lastAiMessageAt             DateTime? @map("last_ai_message_at")
  lastHumanMessageAt          DateTime? @map("last_human_message_at")
  staleMarkedAt               DateTime? @map("stale_marked_at")
  highIntentAssistNudgeSentAt DateTime? @map("high_intent_assist_nudge_sent_at")
  /// Adaptive funnel: new | engaged | considering | high_intent | closing | converted | stale
  stage                       String    @default("new") @map("stage") @db.VarChar(24)
  /// Learning layer: last suggested better template for this thread (optional).
  recommendedTemplateKey      String?   @map("recommended_template_key") @db.VarChar(64)
  learningFlag                String?   @map("learning_flag") @db.VarChar(32)
  /// Milestone: auto_replied | silent_nudge_sent | user_replied_after_auto | user_replied_after_nudge | handoff_pending | resolved | human_takeover
  growthAiOutcome             String?   @map("growth_ai_outcome")
  growthAiOutcomeAt           DateTime? @map("growth_ai_outcome_at")
  createdAt                   DateTime  @default(now()) @map("created_at")
  updatedAt                   DateTime  @updatedAt @map("updated_at")

  messages              GrowthAiConversationMessage[]
  handoffs              GrowthAiConversationHandoff[]
  decisions             GrowthAiConversationDecision[]
  templateOutcomeEvents GrowthAiTemplateOutcomeEvent[]
  orchestration         GrowthAiLeadOrchestration?
  dealAssistantInsights DealAssistantInsight[]

  @@index([userId, status])
  @@index([status, aiReplyPending])
  @@index([assignedToId])
  @@index([growthAiOutcome])
  @@index([outcome])
  @@index([highIntent], map: "growth_ai_conversations_high_intent_idx")
  @@index([stage])
  @@index([lastUserMessageAt])
  @@index([silentNudgeSentAt])
  @@map("growth_ai_conversations")
}

model GrowthAiConversationMessage {
  id                String               @id @default(uuid())
  conversationId    String               @map("conversation_id")
  conversation      GrowthAiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderType        String               @map("sender_type")
  messageText       String               @map("message_text") @db.Text
  detectedIntent    String?              @map("detected_intent")
  detectedObjection String?              @map("detected_objection")
  confidence        Float?
  handoffRequired   Boolean              @default(false) @map("handoff_required")
  templateKey       String?              @map("template_key")
  ctaType           String?              @map("cta_type") @db.VarChar(32)
  isNudge           Boolean              @default(false) @map("is_nudge")
  isAssistClose     Boolean              @default(false) @map("is_assist_close")
  createdAt         DateTime             @default(now()) @map("created_at")

  @@index([conversationId, createdAt])
  @@map("growth_ai_conversation_messages")
}

/// Operator-facing Deal Assistant snapshot (assisted AI — human sends messages).
model DealAssistantInsight {
  id                String               @id @default(uuid())
  conversationId    String               @map("conversation_id")
  conversation      GrowthAiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  detectedIntent    String               @map("detected_intent")
  detectedObjection String               @map("detected_objection")
  urgencyLevel      String               @map("urgency_level")
  recommendedAction String               @map("recommended_action")
  messageSuggestion String               @map("message_suggestion") @db.Text
  confidence        Float
  createdAt         DateTime             @default(now()) @map("created_at")

  @@index([conversationId, createdAt])
  @@map("deal_assistant_insights")
}

model AutoReplyRule {
  id          String   @id @default(uuid())
  intent      String
  objection   String?  @map("objection")
  stage       String?  @map("stage")
  templateKey String   @map("template_key")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([intent, objection, isActive])
  @@map("auto_reply_rules")
}

model AutoReplyTemplate {
  id          String   @id @default(uuid())
  templateKey String   @unique @map("template_key")
  segment     String
  content     String   @db.Text
  ctaType     String   @map("cta_type")
  tone        String   @default("helpful")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("auto_reply_templates")
}

model GrowthAiConversationHandoff {
  id             String               @id @default(uuid())
  conversationId String               @map("conversation_id")
  conversation   GrowthAiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  reason         String               @db.Text
  status         String               @default("pending")
  createdAt      DateTime             @default(now()) @map("created_at")

  @@index([conversationId, status])
  @@map("growth_ai_conversation_handoffs")
}

/// Rollup: template sends and outcomes by routing context (self-learning).
model GrowthAiTemplatePerformance {
  id                String   @id @default(cuid())
  templateKey       String   @map("template_key") @db.VarChar(64)
  /// Empty string = aggregate across all stages for that row key (prefer exact-match rows in queries).
  stage             String   @default("") @map("stage") @db.VarChar(32)
  detectedIntent    String   @default("") @map("detected_intent") @db.VarChar(48)
  detectedObjection String   @default("") @map("detected_objection") @db.VarChar(32)
  highIntent        Boolean  @default(false) @map("high_intent")
  sentCount         Int      @default(0) @map("sent_count")
  replyCount        Int      @default(0) @map("reply_count")
  qualifiedCount    Int      @default(0) @map("qualified_count")
  bookedCount       Int      @default(0) @map("booked_count")
  handoffCount      Int      @default(0) @map("handoff_count")
  staleCount        Int      @default(0) @map("stale_count")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([templateKey, stage, detectedIntent, detectedObjection, highIntent])
  @@index([templateKey])
  @@index([stage, detectedIntent, detectedObjection])
  @@index([highIntent])
  @@map("growth_ai_template_performance")
}

/// A/B routing experiments (safe flows only; gated by env).
model GrowthAiRoutingExperiment {
  id                 String   @id @default(cuid())
  experimentKey      String   @unique @map("experiment_key") @db.VarChar(64)
  isActive           Boolean  @default(false) @map("is_active")
  description        String?  @db.Text
  controlTemplateKey String   @map("control_template_key") @db.VarChar(64)
  variantTemplateKey String   @map("variant_template_key") @db.VarChar(64)
  stage              String?  @map("stage") @db.VarChar(32)
  detectedIntent     String?  @map("detected_intent") @db.VarChar(48)
  detectedObjection  String?  @map("detected_objection") @db.VarChar(32)
  highIntent         Boolean? @map("high_intent")
  allocationPercent  Int      @default(50) @map("allocation_percent")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("growth_ai_routing_experiments")
}

/// One row per AI template selection (explainability + learning attribution).
model GrowthAiConversationDecision {
  id                  String               @id @default(cuid())
  conversationId      String               @map("conversation_id")
  conversation        GrowthAiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  messageId           String?              @map("message_id")
  stage               String?              @map("stage") @db.VarChar(32)
  detectedIntent      String?              @map("detected_intent") @db.VarChar(48)
  detectedObjection   String?              @map("detected_objection") @db.VarChar(32)
  highIntent          Boolean              @default(false) @map("high_intent")
  selectedTemplateKey String               @map("selected_template_key") @db.VarChar(64)
  reasonJson          Json?                @map("reason_json")
  wasExperiment       Boolean              @default(false) @map("was_experiment")
  experimentKey       String?              @map("experiment_key") @db.VarChar(64)
  outcomeAtSelection  String?              @map("outcome_at_selection") @db.VarChar(32)
  createdAt           DateTime             @default(now()) @map("created_at")

  @@index([conversationId])
  @@index([selectedTemplateKey])
  @@index([experimentKey])
  @@map("growth_ai_conversation_decisions")
}

/// Idempotent outcome→metrics attribution (one credit per conversation per outcome milestone).
model GrowthAiTemplateOutcomeEvent {
  id             String               @id @default(cuid())
  conversationId String               @map("conversation_id")
  conversation   GrowthAiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  /// e.g. outcome:replied, outcome:qualified, outcome:booked
  eventKey       String               @map("event_key") @db.VarChar(48)
  decisionId     String?              @map("decision_id")
  createdAt      DateTime             @default(now()) @map("created_at")

  @@unique([conversationId, eventKey])
  @@index([conversationId])
  @@map("growth_ai_template_outcome_events")
}

/// Admin-applied template override for a routing context (optional).
model GrowthAiLearningManualOverride {
  id                  String   @id @default(cuid())
  stage               String   @default("") @map("stage") @db.VarChar(32)
  detectedIntent      String   @default("") @map("detected_intent") @db.VarChar(48)
  detectedObjection   String   @default("") @map("detected_objection") @db.VarChar(32)
  highIntent          Boolean  @default(false) @map("high_intent")
  overrideTemplateKey String   @map("override_template_key") @db.VarChar(64)
  isActive            Boolean  @default(true) @map("is_active")
  note                String?  @db.Text
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@unique([stage, detectedIntent, detectedObjection, highIntent])
  @@index([isActive])
  @@map("growth_ai_learning_manual_overrides")
}

/// Autonomous deal-closer orchestration (one row per growth AI conversation).
model GrowthAiLeadOrchestration {
  id                           String               @id @default(cuid())
  conversationId               String               @unique @map("conversation_id")
  conversation                 GrowthAiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId                       String?              @map("user_id")
  listingId                    String?              @map("listing_id")
  bookingId                    String?              @map("booking_id")
  routeType                    String?              @map("route_type") @db.VarChar(32)
  leadScore                    Int                  @default(0) @map("lead_score")
  urgencyScore                 Int                  @default(0) @map("urgency_score")
  assignmentStatus             String               @default("unassigned") @map("assignment_status") @db.VarChar(32)
  assignedBrokerId             String?              @map("assigned_broker_id")
  assignedHostId               String?              @map("assigned_host_id")
  assignedAdminId              String?              @map("assigned_admin_id")
  nextActionType               String?              @map("next_action_type") @db.VarChar(32)
  nextActionDueAt              DateTime?            @map("next_action_due_at")
  lastActionAt                 DateTime?            @map("last_action_at")
  conversionGoal               String?              @map("conversion_goal") @db.VarChar(32)
  automationPaused             Boolean              @default(false) @map("automation_paused")
  assignedAt                   DateTime?            @map("assigned_at")
  lastOrchestrationTemplateKey String?              @map("last_orchestration_template_key") @db.VarChar(64)
  createdAt                    DateTime             @default(now()) @map("created_at")
  updatedAt                    DateTime             @updatedAt @map("updated_at")

  actions GrowthAiActionLog[]

  @@index([conversationId])
  @@index([assignmentStatus, nextActionDueAt])
  @@index([assignedBrokerId])
  @@index([assignedHostId])
  @@map("growth_ai_lead_orchestrations")
}

model GrowthAiActionLog {
  id              String                    @id @default(cuid())
  orchestrationId String                    @map("orchestration_id")
  orchestration   GrowthAiLeadOrchestration @relation(fields: [orchestrationId], references: [id], onDelete: Cascade)
  conversationId  String                    @map("conversation_id")
  actionType      String                    @map("action_type")
  actionPayload   Json?                     @map("action_payload")
  resultStatus    String                    @map("result_status")
  createdAt       DateTime                  @default(now()) @map("created_at")

  @@index([orchestrationId])
  @@index([conversationId])
  @@map("growth_ai_action_logs")
}

model GrowthAiAssignmentRule {
  id           String   @id @default(cuid())
  routeType    String   @map("route_type") @db.VarChar(32)
  city         String?  @db.VarChar(64)
  propertyType String?  @map("property_type") @db.VarChar(32)
  brokerId     String?  @map("broker_id")
  hostId       String?  @map("host_id")
  priority     Int      @default(0)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([routeType, isActive])
  @@map("growth_ai_assignment_rules")
}

/// AI Executive Control — KPI snapshots (daily / weekly); metrics from real DB aggregates only.
model ExecutiveKpiSnapshot {
  id           String   @id @default(cuid())
  snapshotType String   @map("snapshot_type") @db.VarChar(16)
  snapshotDate DateTime @map("snapshot_date")
  metricsJson  Json     @map("metrics_json")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([snapshotType, snapshotDate])
  @@map("executive_kpi_snapshots")
}

/// Prioritized executive recommendations (review-first; optional safe auto-actions when enabled).
model ExecutiveRecommendation {
  id                 String   @id @default(cuid())
  recommendationType String   @map("recommendation_type") @db.VarChar(64)
  priorityScore      Int      @default(0) @map("priority_score")
  status             String   @default("open") @db.VarChar(24)
  title              String
  summary            String   @db.Text
  detailsJson        Json     @map("details_json")
  evidenceJson       Json?    @map("evidence_json")
  targetEntityType   String?  @map("target_entity_type") @db.VarChar(32)
  targetEntityId     String?  @map("target_entity_id")
  safeAutoActionKey  String?  @map("safe_auto_action_key") @db.VarChar(64)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  actionRuns ExecutiveActionRun[]

  @@index([status, priorityScore])
  @@index([recommendationType])
  @@index([targetEntityType, targetEntityId])
