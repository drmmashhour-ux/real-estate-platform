  scheduledAt        DateTime                     @map("scheduled_at")
  status             ContentMachineScheduleStatus @default(pending)
  externalId         String?                      @map("external_id") @db.VarChar(256)
  /// Provider-specific post / schedule id (Meta, Metricool, Buffer, …)
  externalPlatformId String?                      @map("external_platform_id") @db.VarChar(256)
  externalStatus     String?                      @map("external_status") @db.VarChar(64)
  externalResponse   Json?                        @map("external_response")
  platformAccountId  String?                      @map("platform_account_id") @db.VarChar(256)
  errorMessage       String?                      @map("error_message") @db.Text
  createdAt          DateTime                     @default(now()) @map("created_at")
  updatedAt          DateTime                     @updatedAt @map("updated_at")

  @@index([scheduledAt])
  @@index([contentId])
  @@map("content_schedules")
}

/// OAuth-connected social / scheduler accounts for content automation (tokens encrypted at rest).
