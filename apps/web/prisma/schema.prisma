/// BNHUB listing → TikTok scripts (OpenAI) + video tool payload + scheduler + metrics
model ContentGenerated {
  id        String           @id @default(cuid())
  listingId String           @map("listing_id")
  listing   ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  /// create | update | manual
  trigger String @db.VarChar(32)

  scriptsJson      Json   @map("scripts_json")
  captionsJson     Json   @map("captions_json")
  hashtagsJson     Json   @map("hashtags_json")
  /// openai | deterministic
  generationSource String @default("openai") @map("generation_source") @db.VarChar(32)

  /// runway | pictory | null (stub until API keys wired)
  videoTool         String? @map("video_tool") @db.VarChar(24)
  videoPayloadJson  Json?   @map("video_payload_json")
  videoUrl          String? @map("video_url") @db.Text
  /// short_form_vertical | etc.
  videoStyle        String  @default("short_form_vertical") @map("video_style") @db.VarChar(48)
  /// First script block used for the primary render
  primaryScriptJson Json?   @map("primary_script_json")
  publishedCaption  String? @map("published_caption") @db.Text

  /// metricool | later | null
  schedulerProvider   String?   @map("scheduler_provider") @db.VarChar(24)
  scheduledFor        DateTime? @map("scheduled_for")
  schedulerExternalId String?   @map("scheduler_external_id") @db.VarChar(128)

  metricsViews       Int?      @map("metrics_views")
  metricsClicks      Int?      @map("metrics_clicks")
  metricsConversions Int?      @map("metrics_conversions")
  metricsSyncedAt    DateTime? @map("metrics_synced_at")

  /// pending | generated | video_queued | video_ready | scheduled | published | failed
  pipelineStatus String  @default("pending") @map("pipeline_status") @db.VarChar(32)
  errorMessage   String? @map("error_message") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([listingId, createdAt(sort: Desc)])
  @@index([pipelineStatus])
  @@map("content_generated")
}

