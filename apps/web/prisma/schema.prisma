model Property {
  id                    String                 @id @default(uuid())
  price                 Int
  city                  String
  address               String
  beds                  Int
  baths                 Float
  sqft                  Int
  propertyType          String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  ownerId               String
