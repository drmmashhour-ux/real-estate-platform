/// Global daily rollup for LECIPM launch phase (outreach, content, conversion). Admin-incremented or scripted.
model LaunchPhaseDailyStats {
  id                 String   @id @default(cuid())
  /// UTC calendar day (store at midnight UTC).
  date               DateTime @db.Date
