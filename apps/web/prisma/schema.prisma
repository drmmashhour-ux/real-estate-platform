  referredByUserId             String?                      @map("referred_by_user_id")
  referredBy                   User?                        @relation("GrowthEngineLeadReferrer", fields: [referredByUserId], references: [id], onDelete: SetNull)
  consentAt                    DateTime?                    @map("consent_at")
  needsFollowUp                Boolean                      @default(false) @map("needs_follow_up")
  followUpReason               String?                      @map("follow_up_reason") @db.VarChar(256)
  archivedAt                   DateTime?                    @map("archived_at")
