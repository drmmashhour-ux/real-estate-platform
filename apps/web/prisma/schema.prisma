// -----------------------------------------------------------------------------
// AMF-aligned capital structure (Québec securities compliance primitives)
// SPV per deal, KYC / accreditation gates, disclosures, distributions.
// Legal review required before production marketing or public solicitation.
// -----------------------------------------------------------------------------

/// Capital raise / syndication shell (distinct from ROI `InvestmentDeal`).
model AmfCapitalDeal {
  id            String   @id @default(cuid())
  /// Optional CRM listing anchor.
  listingId     String?  @map("listing_id") @db.VarChar(36)
  listing       Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  sponsorUserId String?  @map("sponsor_user_id") @db.VarChar(36)
  sponsor       User?    @relation("AmfCapitalDealSponsor", fields: [sponsorUserId], references: [id], onDelete: SetNull)

  title                 String  @db.VarChar(512)
  status                String  @default("DRAFT") @db.VarChar(24)
  brokerSnapshot        Json?   @map("broker_snapshot")
  /// PRIVATE_PLACEMENT | PROSPECTUS_EXEMPT — drives solicitation rules in services.
  solicitationMode      String  @default("PRIVATE_PLACEMENT") @map("solicitation_mode") @db.VarChar(40)
  /// When false, subscription endpoints reject broad marketing flows (policy hook).
  allowsPublicMarketing Boolean @default(false) @map("allows_public_marketing")
  /// Issuer-recorded exemption narrative (non-legal placeholder for compliance workflow).
  exemptionNarrative    String? @map("exemption_narrative") @db.Text

  corporateEntity        LecipmLegalEntity?
  investments            AmfInvestment[]
  disclosures            AmfDealDisclosure[]
  disclosureAcks         AmfDisclosureAcknowledgment[]
  distributions          AmfDistributionRecord[]
  investmentPacket       DealInvestmentPacket?
  spvRecord              AmfSpv? // NEW: AMF-aligned SPV record
  fundAllocations        FundAllocation[]
  legalDocumentArtifacts LecipmLegalDocumentArtifact[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([listingId])
  @@index([sponsorUserId, status])
  @@map("amf_capital_deals")
}

model LecipmLegalEntity {
  id                 String   @id @default(cuid())
  name               String   @map("name") @db.VarChar(512)
  type               String   @map("type") @db.VarChar(32) // BROKERAGE | TECH | FUND | HOLDING
  jurisdiction       String   @default("QC") @db.VarChar(8)
  registrationNumber String?  @map("registration_number") @db.VarChar(64)
  regulator          String?  @db.VarChar(16) // OACIQ | AMF | null
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  userRoles     LecipmUserEntityRole[]
  capitalDeal   AmfCapitalDeal?        @relation(fields: [capitalDealId], references: [id], onDelete: SetNull)
  capitalDealId String?                @unique @map("capital_deal_id")

  /// For bridge logic: packets originated by this brokerage entity
  originatedPackets DealInvestmentPacket[] @relation("BrokerageOriginatedPackets")
  /// For bridge logic: SPVs managed by this fund entity
  managedSpvs       AmfSpv[]               @relation("FundManagedSpvs")

  @@map("lecipm_legal_entities")
}

model LecipmUserEntityRole {
  id        String            @id @default(cuid())
  userId    String            @map("user_id") @db.VarChar(36)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityId  String            @map("entity_id") @db.VarChar(36)
  entity    LecipmLegalEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  role      String            @db.VarChar(32) // BROKER | DIRECTOR | SHAREHOLDER | ADMIN | GP | LP
  createdAt DateTime          @default(now()) @map("created_at")

  @@unique([userId, entityId, role])
  @@map("lecipm_user_entity_roles")
}

model AmfInvestor {
  id     String  @id @default(cuid())
  userId String? @unique @map("user_id") @db.VarChar(36)
  user   User?   @relation("AmfInvestorUser", fields: [userId], references: [id], onDelete: SetNull)

  legalName             String  @map("legal_name") @db.VarChar(512)
  email                 String  @unique @db.VarChar(320)
  /// PENDING | ACCREDITED | NOT_ACCREDITED | EXEMPT
  accreditationStatus   String  @default("PENDING") @map("accreditation_status") @db.VarChar(24)
  /// PENDING | VERIFIED | FAILED | REVIEW
  kycStatus             String  @default("PENDING") @map("kyc_status") @db.VarChar(24)
  suitabilityIntakeJson Json?   @map("suitability_intake_json")
  simulationConsent     Boolean @default(false) @map("simulation_consent")

  investments         AmfInvestment[]
  disclosureAcks      AmfDisclosureAcknowledgment[]
  distributionRecords AmfDistributionRecord[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([kycStatus, accreditationStatus])
  @@map("amf_investors")
}

model AmfInvestment {
  id            String         @id @default(cuid())
  capitalDealId String         @map("capital_deal_id") @db.VarChar(36)
  capitalDeal   AmfCapitalDeal @relation(fields: [capitalDealId], references: [id], onDelete: Cascade)
  investorId    String         @map("investor_id") @db.VarChar(36)
  investor      AmfInvestor    @relation(fields: [investorId], references: [id], onDelete: Restrict)

  amount                    Float
  equityPercentage          Float?    @map("equity_percentage")
  status                    String    @default("PENDING") @db.VarChar(24)
  disclosuresAcknowledgedAt DateTime? @map("disclosures_acknowledged_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([capitalDealId, investorId])
  @@index([investorId])
  @@map("amf_investments")
}

model AmfDealDisclosure {
  id            String         @id @default(cuid())
  capitalDealId String         @map("capital_deal_id") @db.VarChar(36)
  capitalDeal   AmfCapitalDeal @relation(fields: [capitalDealId], references: [id], onDelete: Cascade)

  docType    String @map("doc_type") @db.VarChar(40)
  title      String @db.VarChar(512)
  storageUrl String @map("storage_url") @db.Text
  version    Int    @default(1)

  createdAt DateTime @default(now()) @map("created_at")

  acknowledgments AmfDisclosureAcknowledgment[]

  @@index([capitalDealId, docType])
  @@map("amf_deal_disclosures")
}

model AmfDisclosureAcknowledgment {
  id            String            @id @default(cuid())
  capitalDealId String            @map("capital_deal_id") @db.VarChar(36)
  capitalDeal   AmfCapitalDeal    @relation(fields: [capitalDealId], references: [id], onDelete: Cascade)
  investorId    String            @map("investor_id") @db.VarChar(36)
  investor      AmfInvestor       @relation(fields: [investorId], references: [id], onDelete: Cascade)
  disclosureId  String            @map("disclosure_id") @db.VarChar(36)
  disclosure    AmfDealDisclosure @relation(fields: [disclosureId], references: [id], onDelete: Cascade)

  acknowledgedAt DateTime @default(now()) @map("acknowledged_at")

  /// PHASE 4: DISCLOSURE SYSTEM
  riskAccepted        Boolean @default(false) @map("risk_accepted")
  notFinancialAdvice  Boolean @default(false) @map("not_financial_advice")
  independentDecision Boolean @default(false) @map("independent_decision")

  @@unique([investorId, disclosureId])
  @@index([capitalDealId, investorId])
  @@map("amf_disclosure_acknowledgments")
}

model AmfDistributionRecord {
  id            String         @id @default(cuid())
  capitalDealId String         @map("capital_deal_id") @db.VarChar(36)
  capitalDeal   AmfCapitalDeal @relation(fields: [capitalDealId], references: [id], onDelete: Cascade)
  investorId    String?        @map("investor_id") @db.VarChar(36)
  investor      AmfInvestor?   @relation(fields: [investorId], references: [id], onDelete: SetNull)

  /// DISTRIBUTION | RETURN_OF_CAPITAL | INCOME_ALLOCATION | BROKER_COMMISSION | PLATFORM_FEE | REFERRAL_FEE | FUND_MANAGEMENT_FEE
  kind       String   @db.VarChar(40)
  amount     Float
  recordedAt DateTime @default(now()) @map("recorded_at")
  notes      String?  @db.Text

  @@index([capitalDealId, recordedAt])
  @@index([investorId])
  @@map("amf_distribution_records")
}

model DealInvestmentPacket {
  id            String         @id @default(cuid())
  capitalDealId String         @unique @map("capital_deal_id") @db.VarChar(36)
  capitalDeal   AmfCapitalDeal @relation(fields: [capitalDealId], references: [id], onDelete: Cascade)

  /// The BROKERAGE entity that originated the deal
  entityId String?            @map("entity_id") @db.VarChar(36)
  entity   LecipmLegalEntity? @relation("BrokerageOriginatedPackets", fields: [entityId], references: [id], onDelete: SetNull)

  summary                    String  @db.Text
  underwritingRecommendation String? @map("underwriting_recommendation") @db.Text
  risks                      String  @db.Text
  financialProjection        String? @map("financial_projection") @db.Text
  esgRetrofitSnapshot        String? @map("esg_retrofit_snapshot") @db.Text
  financingSnapshot          String? @map("financing_snapshot") @db.Text
  committeeStatus            String? @map("committee_status") @db.VarChar(64)
  complianceBlockers         String? @map("compliance_blockers") @db.Text
  esgScore                   Float?  @map("esg_score")

  createdByBrokerId String @map("created_by_broker_id") @db.VarChar(36)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("deal_investment_packets")
}

enum AmfExemptionCategory {
  ACCREDITED_INVESTOR
  FAMILY_FRIENDS_BUSINESS_ASSOCIATES
}

enum ExemptFilingFormStatus {
  DRAFT
  READY
  FILED
}

enum InvestorCapitalCommitmentStatus {
  PENDING
  PARTIAL
  FUNDED
  CANCELLED
}

/// AMF-ready SPV structure isolating capital from brokerage
model AmfSpv {
  id            String         @id @default(cuid())
  capitalDealId String         @unique @map("capital_deal_id") @db.VarChar(36)
  capitalDeal   AmfCapitalDeal @relation(fields: [capitalDealId], references: [id], onDelete: Cascade)

  /// The FUND entity that manages this SPV
  entityId String            @map("entity_id") @db.VarChar(36)
  entity   LecipmLegalEntity @relation("FundManagedSpvs", fields: [entityId], references: [id], onDelete: Cascade)

  ownershipStructureJson Json? @map("ownership_structure_json")

  /// Default private exempt deal mode — no public offering workflow.
  privateExemptDealMode         Boolean               @default(true) @map("private_exempt_deal_mode")
  exemptionPath                 AmfExemptionCategory? @map("exemption_path")
  /// Counsel-approved additional exemption keys (manual enablement only).
  counselApprovedExemptionsJson Json?                 @map("counsel_approved_exemptions_json")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  exemptDistributionFiles    ExemptDistributionFile[]
  investorCapitalCommitments InvestorCapitalCommitment[]
  crmDealInvestorCommitments CrmDealInvestorCommitment[]
  crmDealCapTableEntries     CrmDealCapTableEntry[]

  @@map("amf_spvs")
}

// --- Finance Admin Hub (brokerage / platform / investment separation) ---

enum FinAdminDomain {
  BROKERAGE
  PLATFORM
  INVESTMENT
}

enum FinAccountType {
  BANK
  RECEIVABLE
  PAYABLE
  TAX
  ESCROW_SIMULATION
}

enum FinLedgerEntryType {
  INVOICE
  PAYMENT
  COMMISSION
  OACIQ_FEE
  INSURANCE
  GST
  QST
  AMF_FEE
  LEGAL
  DISTRIBUTION
  REFUND
}

enum FinCounterpartyKind {
  CLIENT
  BROKER
  INVESTOR
  GOVERNMENT
  VENDOR
  LAWYER
  NOTARY
}

enum TaxFilingFrequency {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum RegulatoryAuthority {
  OACIQ
  REVENU_QUEBEC
  CRA
  FARCIQ
  AMF
}

enum RegulatoryObligationType {
  LICENCE_RENEWAL
  INSURANCE_RENEWAL
  GST_QST_RETURN
  EXEMPT_DISTRIBUTION_REPORT
  FEE_PAYMENT
}

enum RegulatoryObligationStatus {
  OPEN
  DRAFT
  FILED
  PAID
}

/// Finance Admin Hub chart of accounts (distinct from brokerage `FinancialLedgerEntry` trust register).
model ComplianceFinanceAccount {
  id        String         @id @default(cuid())
  name      String         @db.VarChar(256)
  domain    FinAdminDomain @map("domain")
  type      FinAccountType @map("type")
  currency  String         @default("CAD") @db.VarChar(8)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  ledgerEntries ComplianceFinanceLedgerEntry[]

  @@index([domain, type])
  @@map("compliance_finance_accounts")
}

model ComplianceFinanceLedgerEntry {
  id                 String                         @id @default(cuid())
  accountId          String                         @map("account_id")
  account            ComplianceFinanceAccount       @relation(fields: [accountId], references: [id], onDelete: Restrict)
  domain             FinAdminDomain                 @map("domain")
  entryType          FinLedgerEntryType             @map("entry_type")
  referenceType      String                         @map("reference_type") @db.VarChar(64)
  referenceId        String?                        @map("reference_id") @db.VarChar(64)
  amount             Decimal                        @map("amount") @db.Decimal(18, 2)
  taxExclusiveAmount Decimal?                       @map("tax_exclusive_amount") @db.Decimal(18, 2)
  gstAmount          Decimal?                       @map("gst_amount") @db.Decimal(18, 2)
  qstAmount          Decimal?                       @map("qst_amount") @db.Decimal(18, 2)
  effectiveDate      DateTime                       @map("effective_date")
  counterpartyId     String?                        @map("counterparty_id")
  counterparty       ComplianceFinanceCounterparty? @relation(fields: [counterpartyId], references: [id], onDelete: SetNull)
  notesJson          Json?                          @map("notes_json")
  createdAt          DateTime                       @default(now()) @map("created_at")

  @@index([domain, effectiveDate])
  @@index([entryType, effectiveDate])
  @@index([referenceType, referenceId])
  @@map("compliance_finance_ledger_entries")
}

model ComplianceFinanceCounterparty {
  id            String              @id @default(cuid())
  name          String              @db.VarChar(512)
  type          FinCounterpartyKind @map("type")
  taxNumberJson Json?               @map("tax_number_json")
  createdAt     DateTime            @default(now()) @map("created_at")

  ledgerEntries ComplianceFinanceLedgerEntry[]

  @@map("compliance_finance_counterparties")
}

model TaxRegistrationProfile {
  id              String             @id @default(cuid())
  registrantName  String             @map("registrant_name") @db.VarChar(512)
  gstNumber       String?            @map("gst_number") @db.VarChar(64)
  qstNumber       String?            @map("qst_number") @db.VarChar(64)
  filingFrequency TaxFilingFrequency @map("filing_frequency")
  isRegistered    Boolean            @default(true) @map("is_registered")
  effectiveDate   DateTime           @map("effective_date")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@map("tax_registration_profiles")
}

model RegulatoryObligation {
  id             String                     @id @default(cuid())
  authority      RegulatoryAuthority        @map("authority")
  obligationType RegulatoryObligationType   @map("obligation_type")
  dueDate        DateTime                   @map("due_date")
  amountEstimate Decimal?                   @map("amount_estimate") @db.Decimal(18, 2)
  status         RegulatoryObligationStatus @default(OPEN) @map("status")
  referenceJson  Json?                      @map("reference_json")
  createdAt      DateTime                   @default(now()) @map("created_at")
  updatedAt      DateTime                   @updatedAt @map("updated_at")

  @@index([authority, dueDate])
  @@index([status, dueDate])
