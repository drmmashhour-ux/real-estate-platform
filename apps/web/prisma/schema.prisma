  immoContactLogs                      ImmoContactLog[]
  immoContactLogsAsTarget              ImmoContactLog[]                      @relation("ImmoContactLogTargetUser")
  immoContactLogsAsBroker              ImmoContactLog[]                      @relation("ImmoContactLogBroker")
  immoContactLogsAdminNoted            ImmoContactLog[]                      @relation("ImmoContactLogAdminNote")
  legalContractAuditLogs               LegalContractAuditLog[]
  platformLegalDisputesOpened          PlatformLegalDispute[]                @relation("PlatformLegalDisputeOpenedBy")
  platformLegalDisputesTargeted        PlatformLegalDispute[]                @relation("PlatformLegalDisputeTarget")
  /// Latest acceptance of the platform Content & Usage License (version checked against `ContentLicensePolicy`).
  contentLicenseAcceptance             ContentLicenseAcceptance?
  contentLicensePolicyUpdates          ContentLicensePolicy[]                @relation("ContentLicensePolicyUpdatedBy")
  /// Long-term Rent Hub (landlord listings + tenant applications + leases).
  rentalListingsOwned                  RentalListing[]                       @relation("RentalLandlord")
  rentalApplicationsAsTenant           RentalApplication[]                   @relation("RentalTenantApplications")
  rentalLeasesAsTenant                 RentalLease[]                         @relation("RentalLeaseTenant")
  rentalLeasesAsLandlord               RentalLease[]                         @relation("RentalLeaseLandlord")
  /// Canonical bigint listing (Supabase blueprint); optional link from FSBO.
  canonListingPropertiesOwned          ListingProperty[]                     @relation("ListingPropertyOwner")
  canonListingPropertiesBrokered       ListingProperty[]                     @relation("ListingPropertyBroker")
  lecipmSubscriptions                  Subscription[]                        @relation("WorkspaceSubscriptionUser")
  /// FSBO / CRM leads this broker purchased on the lead marketplace.
  leadMarketplacePurchases             LeadMarketplaceListing[]              @relation("LeadMarketplaceBuyer")
  brokerLecipmSubscription             BrokerLecipmSubscription?
  brokerMonetizationProfile            BrokerMonetizationProfile?
  brokerBillingLeadsReceived           BrokerLead[]                          @relation("BrokerLeadBroker")
  brokerBillingLeadsAsBuyer            BrokerLead[]                          @relation("BrokerLeadBuyer")
  brokerInvoices                       BrokerInvoice[]
  brokerPayments                       BrokerPayment[]
  publicShareLinksCreated              PublicShareLink[]                     @relation("ShareLinkCreator")
  crmSalesLeadsOwned                   CrmSalesLead[]                        @relation("CrmSalesLeadOwner")
  copilotConversations                 CopilotConversation[]
  copilotRuns                          CopilotRun[]                          @relation("CopilotRunUser")
  copilotMemoryItems                   CopilotMemoryItem[]
  sellerDeclarationRecords             SellerDeclarationRecord[]
  sellerDeclarationDraftsAsSeller      SellerDeclarationDraft[]              @relation("SellerDeclarationDraftSeller")
  sellerDeclarationDraftsAsAdmin       SellerDeclarationDraft[]              @relation("SellerDeclarationDraftAdmin")
  growthEmailLogs                      GrowthEmailLog[]
  enterpriseWorkspaceMemberships       EnterpriseWorkspaceMember[]
  enterpriseWorkspacesCreated          EnterpriseWorkspace[]                 @relation("EnterpriseWorkspaceCreator")
  enterpriseWorkspaceInvitesSent       EnterpriseWorkspaceInvite[]           @relation("EnterpriseWorkspaceInviter")
  workspaceAuditLogsAsActor            WorkspaceAuditLog[]                   @relation("WorkspaceAuditActor")
  offerStrategyScenarios               OfferStrategyScenario[]
  negotiationVersionsCreated           NegotiationVersion[]                  @relation("NegotiationVersionCreator")
  growthFunnelEvents                   GrowthFunnelEvent[]
  growthUsageCounter                   GrowthUsageCounter?
  lecipmConversionSubscription         LecipmConversionSubscription?
  lecipmConversionUsages               LecipmConversionUsage[]
  /// BNHub monetization — hosts paying for featured / slots / local ads.
  bnhubPromotionOrdersPaid             BnhubPromotionOrder[]                 @relation("BnhubPromotionPayer")
  bnhubSalesAssistAsGuest              BnhubSalesAssistEntry[]               @relation("BnhubSalesGuest")
  bnhubSalesAssistAssigned             BnhubSalesAssistEntry[]               @relation("BnhubSalesAssignee")
  bnhubAutomationEvents                BnhubAutomationEvent[]
  lecipmUserExplainerMedia             LecipmUserExplainerMedia?
  lecipmAiOperatorActions              LecipmAiOperatorAction[]
  lecipmAiOperatorSettings             LecipmAiOperatorSettings?
  workspaceBrokerReputations           WorkspaceBrokerReputation[]           @relation("WorkspaceBrokerReputationBroker")
  workspaceDealSharesTarget            WorkspaceDealShare[]                  @relation("WorkspaceDealShareTarget")
  workspaceDealSharesCreated           WorkspaceDealShare[]                  @relation("WorkspaceDealShareCreator")
  workspaceCollaborationMessages       WorkspaceCollaborationMessage[]       @relation("WorkspaceCollabAuthor")
  workspaceReferralsAsReferrer         WorkspaceReferral[]                   @relation("WorkspaceReferralReferrer")
  dailyTasks                           DailyTask[]
  dailyMetrics                         DailyMetric[]
  bnhubMarketingCampaignsAsHost        BnhubMarketingCampaign[]              @relation("BnhubMarketingHostUser")
  bnhubMarketingCampaignsCreated       BnhubMarketingCampaign[]              @relation("BnhubMarketingCreatedBy")
  bnhubGrowthCampaignsAsHost           BnhubGrowthCampaign[]                 @relation("BnhubGrowthHostUser")
  bnhubGrowthCampaignsCreated          BnhubGrowthCampaign[]                 @relation("BnhubGrowthCreatedBy")
  bnhubLeadsAsHost                     BnhubLead[]                           @relation("BnhubLeadHostUser")
  bnhubLeadsAsOwner                    BnhubLead[]                           @relation("BnhubLeadOwnerUser")
  bnhubHostGrowthPrefs                 BnhubHostGrowthPrefs?
  bnhubTrustProfiles                   BnhubTrustProfile[]
  bnhubFraudFlagsAsSubject             BnhubFraudFlag[]                      @relation("BnhubFraudFlagHost")
  bnhubTrustIdentityVerifications      BnhubTrustIdentityVerification[]
  bnhubListingTrustRiskProfilesHost    BnhubListingTrustRiskProfile[]        @relation("BnhubListingTrustRiskHost")
  bnhubTrustRiskFlagsAsUser            BnhubTrustRiskFlag[]                  @relation("BnhubTrustRiskFlagUser")
  bnhubHostQualityProfile              BnhubHostQualityProfile?
  /// Browser cookie holds `Session.token`; revoked on logout; prior rows revoked on new login (single active session).
  sessions                             Session[]
  playbookExecutions                   PlaybookExecution[]
  revenueEvents                        RevenueEvent[]
  revenueOpportunities                 RevenueOpportunity[]
  /// Revenue execution CRM — actions logged against this user (outreach / conversion).
  executionActionsAsCrmTarget        ExecutionAction[]                     @relation("ExecutionActionCrmUser")
  salesAgentProfile                SalesAgent?
  salesAssignmentsAsProspect       SalesAssignment[]                     @relation("SalesAssignmentProspect")
  insuranceLeads                   InsuranceLead[]
  userLoyaltyProfile               UserLoyaltyProfile?
  loyaltyRewardEvents              LoyaltyRewardEvent[]

  @@index([lecipmCityId])
}

enum LoyaltyTier {
  NONE
  BRONZE
  SILVER
  GOLD
}

/// BNHub guest loyalty — simple tier + counters (no points).
model UserLoyaltyProfile {
  id                String      @id @default(cuid())
  userId            String      @unique @map("user_id")
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalBookings     Int         @default(0) @map("total_bookings")
  completedBookings Int         @default(0) @map("completed_bookings")
  lastBookingAt     DateTime?   @map("last_booking_at")
  tier              LoyaltyTier @default(NONE)
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  @@map("user_loyalty_profiles")
}

/// One row per paid booking — idempotent loyalty credit + audit log.
model LoyaltyRewardEvent {
  id                     String      @id @default(cuid())
  userId                 String      @map("user_id")
  user                   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookingId              String      @unique @map("booking_id")
  tierBefore             LoyaltyTier @map("tier_before")
  tierAfter              LoyaltyTier @map("tier_after")
  discountPercentApplied Float?      @map("discount_percent_applied")
  createdAt              DateTime    @default(now()) @map("created_at")

  @@index([userId])
  @@map("loyalty_reward_events")
}

/// Server-side auth session (`lecipm_guest_id` cookie value = opaque `token`).
model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("Session")
}

/// LECIPM AI Operator — explainable suggested actions; execution only per policy + approval.
enum LecipmAiOperatorActionStatus {
  pending
  suggested
  approved
  executed
  failed
  rejected
}

model LecipmAiOperatorAction {
  id                   String                       @id @default(cuid())
  userId               String                       @map("user_id")
  user                 User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId          String?                      @map("workspace_id") @db.Uuid
  workspace            EnterpriseWorkspace?         @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  type                 String
  context              String
  payload              Json
  status               LecipmAiOperatorActionStatus @default(suggested)
  confidenceScore      Float                        @map("confidence_score")
  title                String
  description          String                       @db.Text
  reason               String                       @db.Text
  dataUsedSummary      String?                      @map("data_used_summary") @db.Text
  expectedOutcome      String?                      @map("expected_outcome") @db.Text
  suggestedExecution   Json?                        @map("suggested_execution")
  resultLog            Json?                        @map("result_log")
  editedPayload        Json?                        @map("edited_payload")
  autonomyModeAtCreate String?                      @map("autonomy_mode_at_create")
  outcomeNotes         String?                      @map("outcome_notes") @db.Text
  createdAt            DateTime                     @default(now()) @map("created_at")
  updatedAt            DateTime                     @updatedAt @map("updated_at")

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([context])
  @@index([workspaceId])
  @@map("ai_actions")
}

model LecipmAiOperatorSettings {
  userId       String   @id @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  autonomyMode String   @default("manual") @map("autonomy_mode")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("lecipm_ai_operator_settings")
}

/// LECIPM AI explainer: configurable synthetic guide (clearly labeled; not a real person).
model LecipmAvatarProfile {
  id             String   @id @default(cuid())
  name           String
  videoBaseUrl   String   @map("video_base_url") @db.Text
  voiceProfileId String?  @map("voice_profile_id") @db.Text
  styleConfig    Json?    @map("style_config")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([active])
  @@map("avatar_profiles")
}

/// Optional user-uploaded explainer loop (CDN URL after upload elsewhere — not identity spoofing).
model LecipmUserExplainerMedia {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoUrl  String?  @map("video_url") @db.Text
  imageUrl  String?  @map("image_url") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("lecipm_user_explainer_media")
}

// ---------------------------------------------------------------------------
// LECIPM Enterprise — team workspaces, RBAC, invites, audit (billing scope uses Subscription.workspace_id UUID)
// ---------------------------------------------------------------------------

enum LecipmWorkspaceRole {
  owner
  admin
  manager
  broker
  analyst
  viewer
  compliance_reviewer

  @@map("lecipm_workspace_role")
}

enum LecipmWorkspaceInviteStatus {
  pending
  accepted
  expired
  revoked

  @@map("lecipm_workspace_invite_status")
}

model EnterpriseWorkspace {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  slug            String?  @unique
  createdByUserId String   @map("created_by_user_id")
  createdBy       User     @relation("EnterpriseWorkspaceCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  settings        Json?    @db.JsonB
  seatLimit       Int      @default(10) @map("seat_limit")
  planTier        String   @default("team") @map("plan_tier")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  members                        EnterpriseWorkspaceMember[]
  invites                        EnterpriseWorkspaceInvite[]
  auditLogs                      WorkspaceAuditLog[]
  deals                          Deal[]
  leads                          Lead[]
  documentFiles                  DocumentFile[]
  lecipmAiOperatorActions        LecipmAiOperatorAction[]
  lecipmDealHistories            LecipmDealHistory[]
  workspaceBrokerReputations     WorkspaceBrokerReputation[]
  workspaceDealShares            WorkspaceDealShare[]
  workspaceCollaborationMessages WorkspaceCollaborationMessage[]
  workspaceReferrals             WorkspaceReferral[]

  @@index([createdByUserId], map: "idx_enterprise_workspaces_created_by")
  @@map("enterprise_workspaces")
}

model EnterpriseWorkspaceMember {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String              @map("workspace_id") @db.Uuid
  workspace   EnterpriseWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String              @map("user_id")
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        LecipmWorkspaceRole
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([workspaceId, userId], map: "uq_enterprise_workspace_member")
  @@index([userId], map: "idx_enterprise_workspace_member_user")
  @@map("enterprise_workspace_members")
}

model EnterpriseWorkspaceInvite {
  id              String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId     String                      @map("workspace_id") @db.Uuid
  workspace       EnterpriseWorkspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email           String
  role            LecipmWorkspaceRole
  tokenHash       String                      @map("token_hash")
  status          LecipmWorkspaceInviteStatus @default(pending)
  invitedByUserId String                      @map("invited_by_user_id")
  invitedBy       User                        @relation("EnterpriseWorkspaceInviter", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  expiresAt       DateTime                    @map("expires_at") @db.Timestamptz(6)
  createdAt       DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([workspaceId], map: "idx_enterprise_workspace_invites_ws")
  @@index([email], map: "idx_enterprise_workspace_invites_email")
  @@map("enterprise_workspace_invites")
}

model WorkspaceAuditLog {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String              @map("workspace_id") @db.Uuid
  workspace   EnterpriseWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actorUserId String              @map("actor_user_id")
  actor       User                @relation("WorkspaceAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  entityType  String              @map("entity_type")
  entityId    String?             @map("entity_id")
  action      String
  metadata    Json?               @db.JsonB
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([workspaceId, createdAt(sort: Desc)], map: "idx_workspace_audit_ws_created")
  @@index([actorUserId], map: "idx_workspace_audit_actor")
  @@map("workspace_audit_logs")
}

/// LECIPM monopoly layer — terminal deal outcomes per organization (workspace). No cross-workspace queries.
enum LecipmDealHistoryOutcome {
  won
  lost
  canceled

  @@map("lecipm_deal_history_outcome")
}

/// Append-only history rows for closed / canceled deals (workspace-scoped).
model LecipmDealHistory {
  id          String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String                   @map("workspace_id") @db.Uuid
  workspace   EnterpriseWorkspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dealId      String                   @map("deal_id")
  deal        Deal                     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  outcome     LecipmDealHistoryOutcome
  /// Final or best-known price in cents (CAD).
  priceCents  Int                      @map("price_cents")
  /// Structured timeline: e.g. { daysToClose, stages[] } — no PII.
  timeline    Json?                    @db.JsonB
  createdAt   DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([workspaceId, createdAt(sort: Desc)], map: "idx_deal_history_ws_created")
  @@index([dealId], map: "idx_deal_history_deal")
  @@map("deal_history")
}

/// Reputation rollup per broker within one workspace (never shared across orgs).
model WorkspaceBrokerReputation {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId   String              @map("workspace_id") @db.Uuid
  workspace     EnterpriseWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brokerUserId  String              @map("broker_user_id")
  broker        User                @relation("WorkspaceBrokerReputationBroker", fields: [brokerUserId], references: [id], onDelete: Cascade)
  /// 0–100 composite.
  score         Float               @default(0)
  successRate   Float               @default(0) @map("success_rate")
  activityScore Float               @default(0) @map("activity_score")
  dealsCounted  Int                 @default(0) @map("deals_counted")
  updatedAt     DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([workspaceId, brokerUserId], map: "uq_workspace_broker_reputation")
  @@index([workspaceId], map: "idx_ws_broker_rep_ws")
  @@map("workspace_broker_reputation")
}

/// Internal workspace deal share (visibility to a teammate).
model WorkspaceDealShare {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId  String              @map("workspace_id") @db.Uuid
  workspace    EnterpriseWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dealId       String              @map("deal_id")
  deal         Deal                @relation(fields: [dealId], references: [id], onDelete: Cascade)
  targetUserId String              @map("target_user_id")
  targetUser   User                @relation("WorkspaceDealShareTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  createdById  String              @map("created_by_id")
  createdBy    User                @relation("WorkspaceDealShareCreator", fields: [createdById], references: [id], onDelete: Cascade)
  note         String?             @db.Text
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([workspaceId, dealId], map: "idx_ws_deal_share_ws_deal")
  @@index([targetUserId], map: "idx_ws_deal_share_target")
  @@map("workspace_deal_shares")
}

/// Internal collaboration thread (workspace-scoped; optional deal context).
model WorkspaceCollaborationMessage {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String              @map("workspace_id") @db.Uuid
  workspace   EnterpriseWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dealId      String?             @map("deal_id")
  deal        Deal?               @relation(fields: [dealId], references: [id], onDelete: SetNull)
  authorId    String              @map("author_id")
  author      User                @relation("WorkspaceCollabAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  body        String              @db.Text
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([workspaceId, createdAt(sort: Desc)], map: "idx_ws_collab_ws_created")
  @@index([dealId], map: "idx_ws_collab_deal")
  @@map("workspace_collaboration_messages")
}

/// Referral attribution inside a workspace (network effect; PII minimized).
model WorkspaceReferral {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String              @map("workspace_id") @db.Uuid
  workspace      EnterpriseWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  referrerUserId String              @map("referrer_user_id")
  referrer       User                @relation("WorkspaceReferralReferrer", fields: [referrerUserId], references: [id], onDelete: Cascade)
  referredEmail  String              @map("referred_email")
  status         String              @default("pending") // pending | accepted | expired
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([workspaceId], map: "idx_ws_referral_ws")
  @@index([referredEmail], map: "idx_ws_referral_email")
  @@map("workspace_referrals")
}

/// Per-user daily execution checklist (coaching mode — manual sends only; no auto-DM).
model DailyTask {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskDate       DateTime @map("task_date") @db.Date
  taskType       String   @map("task_type") // messages_sent | content_posted | calls_booked | users_onboarded
  targetCount    Int      @map("target_count")
  completedCount Int      @default(0) @map("completed_count")
  /// pending | in_progress | completed
  status         String   @default("pending")
  /// Optional JSON: { callBooked?, callCompleted?, linkedLeadId? }
  metadata       Json?    @db.JsonB
  /// End-of-day manual note (e.g. reply count).
  repliesNote    String?  @map("replies_note") @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([userId, taskDate, taskType], map: "uq_daily_tasks_user_date_type")
  @@index([userId, taskDate], map: "idx_daily_tasks_user_date")
  @@map("daily_tasks")
}

/// Per-user daily metrics for reply rate & variant testing (manual logging only).
model DailyMetric {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  metricDate      DateTime @map("metric_date") @db.Date
  messagesSent    Int      @default(0) @map("messages_sent")
  repliesReceived Int      @default(0) @map("replies_received")
  callsBooked     Int      @default(0) @map("calls_booked")
  usersOnboarded  Int      @default(0) @map("users_onboarded")
  /// { [variantKey]: { uses: number, replies: number } }
  variantStats    Json?    @map("variant_stats") @db.JsonB
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([userId, metricDate], map: "uq_daily_metrics_user_date")
  @@index([userId, metricDate], map: "idx_daily_metrics_user_date")
  @@map("daily_metrics")
}

/// DM script variants for A/B-style coaching (copy-only; never auto-sent).
model DailyDmScript {
  id               String   @id @default(cuid())
  variant          String   @unique // curiosity | problem_focused | direct_value
  body             String   @db.Text
  performanceScore Float?   @map("performance_score")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("dm_scripts")
}

/// Daily snapshot for conservative market trend signals (not appraisals).
model MarketSnapshot {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  regionSlug         String   @map("region_slug")
  propertyType       String   @map("property_type")
  mode               String   @default("investor")
  analysisWindowDays Int      @map("analysis_window_days")
  snapshotDate       DateTime @map("snapshot_date") @db.Date
  medianPriceCents   BigInt?  @map("median_price_cents")
  medianPricePerSqft Decimal? @map("median_price_per_sqft") @db.Decimal(18, 2)
  activeListingCount Int      @default(0) @map("active_listing_count")
  newListingCount    Int      @default(0) @map("new_listing_count")
  confidenceLevel    String   @map("confidence_level")
  directionLabel     String?  @map("direction_label")
  metadata           Json?    @db.JsonB
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([regionSlug, propertyType, mode, analysisWindowDays, snapshotDate], map: "uq_market_snapshots_region_window_date")
  @@index([regionSlug, snapshotDate], map: "idx_market_snapshots_region_date")
  @@map("market_snapshots")
}

/// Daily snapshot of SaaS revenue metrics (LECIPM workspace subscriptions). Written by cron or on-demand.
model RevenueSnapshot {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  snapshotDate DateTime @map("snapshot_date") @db.Date
  mrr          Decimal? @db.Decimal(18, 2)
  churnRate    Decimal? @map("churn_rate") @db.Decimal(12, 8)
  ltv          Decimal? @db.Decimal(18, 2)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([snapshotDate])
  @@index([snapshotDate], map: "idx_revenue_snapshots_date")
  @@map("revenue_snapshots")
}

/// Idempotent growth / retention emails (LECIPM growth engine).
