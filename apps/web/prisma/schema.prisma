/// Senior Living Hub — residences, units, operator leads, family match profiles (Canada).
model SeniorResidence {
  id          String  @id @default(cuid())
  name        String  @db.VarChar(512)
  description String? @db.Text
  address     String  @db.VarChar(512)
  city        String  @db.VarChar(160)
  province    String  @db.VarChar(80)
  operatorId  String? @map("operator_id") @db.VarChar(36)
  operator    User?   @relation("SeniorLivingOperator", fields: [operatorId], references: [id], onDelete: SetNull)

  careLevel          String  @map("care_level") @db.VarChar(40)
  has24hStaff        Boolean @default(false) @map("has_24h_staff")
  medicalSupport     Boolean @default(false) @map("medical_support")
  mealsIncluded      Boolean @default(false) @map("meals_included")
  activitiesIncluded Boolean @default(false) @map("activities_included")

  basePrice     Float? @map("base_price")
  priceRangeMin Float? @map("price_range_min")
  priceRangeMax Float? @map("price_range_max")

  /// WGS84 — Mapbox pins (optional until geocoded).
  latitude  Float?
  longitude Float?

  verified Boolean @default(false)
  rating   Float?

  /// Bounded [-5, 5] additive points applied in browse/match ranking (human or autonomy-governed).
  rankBoostPoints Int @default(0) @map("rank_boost_points")

  units                     SeniorResidenceUnit[]
  servicesOffered           SeniorResidenceService[]
  leads                     SeniorLead[]
  matchingEvents            MatchingEvent[]
  seniorMatchingResults     SeniorMatchingResult[]
  seniorOperatorPerformance SeniorOperatorPerformance?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([city, province])
  @@index([operatorId])
  @@index([careLevel])
  @@index([verified])
  @@map("senior_residences")
}

