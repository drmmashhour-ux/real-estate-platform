  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("user_bnhub_preferences")
}

/// Favorites for Supabase `public.listings` ids (parallel to `BnhubGuestFavorite` for Prisma stays).
model BnhubSupabaseGuestFavorite {
