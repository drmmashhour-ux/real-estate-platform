  @@index([introducedByBrokerId])
  @@index([workspaceId])
  @@index([lastFollowUpByBrokerId])
  @@index([userId])
  @@index([email])
  @@index([source])
  @@index([campaign])
  @@index([leadSource])
  @@index([aiTier])
  @@index([pipelineStatus])
  @@index([pipelineStage])
  @@index([nextFollowUpAt])
  @@index([nextActionAt])
  @@index([dealValue])
  @@index([highIntent])
  @@index([dmStatus])
  @@index([outreachCoachingStage])
  @@index([lastDmAt])
  @@index([engagementScore])
