  rating            Int
  title             String?
  body              String?              @db.Text
  status            ReviewStatus         @default(pending)
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  @@unique([authorUserId, subjectEntityType, subjectEntityId])
  @@index([listingId])
  @@index([subjectEntityType, subjectEntityId])
  @@index([authorUserId])
  @@index([status])
  @@map("reputation_reviews")
}

model ReputationComplaint {
  id               String               @id @default(uuid()) @db.Uuid
  entityType       ReputationEntityType @map("entity_type")
  entityId         String               @map("entity_id")
  reportedByUserId String?              @map("reported_by_user_id")
  reporter         User?                @relation("ReputationComplaintReporter", fields: [reportedByUserId], references: [id], onDelete: SetNull)
  category         String
  description      String               @db.Text
  status           ComplaintStatus      @default(open)
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  @@index([entityType, entityId])
  @@index([status])
  @@map("reputation_complaints")
}

model ReputationResponseMetric {
  id                 String               @id @default(uuid()) @db.Uuid
  entityType         ReputationEntityType @map("entity_type")
  entityId           String               @map("entity_id")
  avgResponseMinutes Int?                 @map("avg_response_minutes")
  replyRate          Float?               @map("reply_rate")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  @@unique([entityType, entityId])
  @@map("reputation_response_metrics")
}

