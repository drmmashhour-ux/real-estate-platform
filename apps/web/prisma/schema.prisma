  active
  archived
}

enum BrokerageCommissionCaseStatus {
  draft
  calculated
  pending_review
  approved
  invoiced
  payout_ready
  paid
  disputed
  archived
}

enum BrokerageCommissionSplitCategory {
  office_share
  broker_share
  team_share
  referral_share
  external_broker
  deduction
  fee
}

enum BrokerageSplitPayeeKind {
  office
  broker
  team
  external
  platform
}

enum OfficeInvoiceStatus {
  draft
  issued
  due
  paid
  overdue
  cancelled
  disputed
}

enum OfficeInvoiceType {
  office_fee
  transaction_admin
  marketing
  software_platform
  compliance_review
  referral
  external_brokerage
  commission_record
  other
}

enum OfficeInvoiceLineType {
  line_item
  adjustment
  tax
}

enum OfficePayoutStatus {
  draft
  ready
  approved
  sent
  paid
  failed
  reversed
}

enum OfficePayoutLineSourceType {
  commission_case
  invoice_adjustment
  manual
}

enum OfficeReconciliationRecordType {
  commission
  invoice
  payout
  deal
}

enum OfficeReconciliationStatus {
  open
  matched
  discrepancy
  resolved
}

model BrokerageOffice {
  id          String              @id @default(uuid())
  name        String              @db.VarChar(200)
  legalName   String?             @map("legal_name") @db.VarChar(300)
  officeCode  String?             @unique @map("office_code") @db.VarChar(32)
  region      String?             @db.VarChar(64)
  address     String?             @db.Text
  phone       String?             @db.VarChar(64)
  email       String?             @db.VarChar(200)
  ownerUserId String?             @map("owner_user_id")
  owner       User?               @relation("BrokerageOfficeOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  /// Product phase: residential brokerage only (no commercial flows in this release).
  officeType  BrokerageOfficeType @default(residential_only) @map("office_type")
  metadata    Json                @default("{}")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  settings                    BrokerageOfficeSettings?
  memberships                 OfficeMembership[]
  teams                       OfficeTeam[]
  commissionPlans             BrokerageCommissionPlan[]
  brokerCommissionAssignments BrokerCommissionAssignment[]
  commissionCases             BrokerageCommissionCase[]
  invoices                    OfficeInvoice[]
  payouts                     OfficePayout[]
  reconciliationRecords       OfficeReconciliationRecord[]
  auditLogs                   BrokerageOfficeAuditLog[]
  deals                       Deal[]

  @@index([ownerUserId])
  @@map("brokerage_offices")
}

model BrokerageOfficeSettings {
  id                        String          @id @default(uuid())
  officeId                  String          @unique @map("office_id")
  office                    BrokerageOffice @relation(fields: [officeId], references: [id], onDelete: Cascade)
  defaultCurrency           String          @default("CAD") @map("default_currency") @db.VarChar(8)
  taxConfig                 Json            @default("{}") @map("tax_config")
  commissionConfig          Json            @default("{}") @map("commission_config")
  payoutConfig              Json            @default("{}") @map("payout_config")
  billingConfig             Json            @default("{}") @map("billing_config")
  featureConfig             Json            @default("{}") @map("feature_config")
  /// Residential deal workflow hints (OACIQ-aligned assistive flows — not legal status).
  residentialWorkflowConfig Json            @default("{}") @map("residential_workflow_config")
  createdAt                 DateTime        @default(now()) @map("created_at")
  updatedAt                 DateTime        @updatedAt @map("updated_at")

  @@map("brokerage_office_settings")
}

model OfficeMembership {
  id               String                 @id @default(uuid())
  officeId         String                 @map("office_id")
  office           BrokerageOffice        @relation(fields: [officeId], references: [id], onDelete: Cascade)
  userId           String                 @map("user_id")
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  membershipStatus OfficeMembershipStatus @default(invited) @map("membership_status")
  role             OfficeMembershipRole
  startDate        DateTime?              @map("start_date") @db.Date
  endDate          DateTime?              @map("end_date") @db.Date
  metadata         Json                   @default("{}")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")

  @@unique([officeId, userId])
  @@index([userId])
  @@index([officeId, membershipStatus])
  @@map("office_memberships")
}

model OfficeTeam {
  id         String          @id @default(uuid())
  officeId   String          @map("office_id")
  office     BrokerageOffice @relation(fields: [officeId], references: [id], onDelete: Cascade)
  name       String          @db.VarChar(160)
  leadUserId String?         @map("lead_user_id")
  lead       User?           @relation("OfficeTeamLead", fields: [leadUserId], references: [id], onDelete: SetNull)
  teamType   OfficeTeamType  @default(residential_sales) @map("team_type")
  metadata   Json            @default("{}")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  members OfficeTeamMembership[]

  @@index([officeId])
  @@index([leadUserId])
  @@map("office_teams")
}

model OfficeTeamMembership {
  id        String     @id @default(uuid())
  teamId    String     @map("team_id")
  team      OfficeTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String     @map("user_id")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String     @default("member") @map("role") @db.VarChar(32)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@unique([teamId, userId])
  @@index([userId])
  @@map("office_team_memberships")
}

model BrokerageCommissionPlan {
  id         String                        @id @default(uuid())
  officeId   String                        @map("office_id")
  office     BrokerageOffice               @relation(fields: [officeId], references: [id], onDelete: Cascade)
  name       String                        @db.VarChar(200)
  status     BrokerageCommissionPlanStatus @default(draft)
  scope      CommissionPlanScope           @default(residential_only)
  ruleConfig Json                          @default("{}") @map("rule_config")
  createdAt  DateTime                      @default(now()) @map("created_at")
  updatedAt  DateTime                      @updatedAt @map("updated_at")

  assignments BrokerCommissionAssignment[]

  @@index([officeId, status])
  @@map("brokerage_commission_plans")
}

model BrokerCommissionAssignment {
  id               String                  @id @default(uuid())
  officeId         String                  @map("office_id")
  office           BrokerageOffice         @relation(fields: [officeId], references: [id], onDelete: Cascade)
  brokerUserId     String                  @map("broker_user_id")
  broker           User                    @relation(fields: [brokerUserId], references: [id], onDelete: Cascade)
  commissionPlanId String                  @map("commission_plan_id")
  commissionPlan   BrokerageCommissionPlan @relation(fields: [commissionPlanId], references: [id], onDelete: Restrict)
  effectiveFrom    DateTime                @map("effective_from") @db.Date
  effectiveTo      DateTime?               @map("effective_to") @db.Date
  overrideConfig   Json?                   @map("override_config")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")

  @@index([officeId, brokerUserId])
  @@index([commissionPlanId])
  @@map("broker_commission_assignments")
}

model BrokerageCommissionCase {
  id                   String                        @id @default(uuid())
  dealId               String                        @map("deal_id")
  deal                 Deal                          @relation(fields: [dealId], references: [id], onDelete: Cascade)
  officeId             String                        @map("office_id")
  office               BrokerageOffice               @relation(fields: [officeId], references: [id], onDelete: Cascade)
  brokerUserId         String                        @map("broker_user_id")
  broker               User                          @relation("BrokerageCommissionCaseBroker", fields: [brokerUserId], references: [id], onDelete: Cascade)
  transactionType      ResidentialTransactionType    @map("transaction_type")
  grossCommissionCents Int                           @map("gross_commission_cents")
  status               BrokerageCommissionCaseStatus @default(draft)
  sourceData           Json                          @default("{}") @map("source_data")
  calculatedBreakdown  Json?                         @map("calculated_breakdown")
  createdAt            DateTime                      @default(now()) @map("created_at")
  updatedAt            DateTime                      @updatedAt @map("updated_at")

  splits BrokerageCommissionSplitLine[]

  @@index([dealId])
  @@index([officeId, status])
  @@index([brokerUserId])
  @@map("brokerage_commission_cases")
}

model BrokerageCommissionSplitLine {
  id                String                           @id @default(uuid())
  commissionCaseId  String                           @map("commission_case_id")
  commissionCase    BrokerageCommissionCase          @relation(fields: [commissionCaseId], references: [id], onDelete: Cascade)
  splitCategory     BrokerageCommissionSplitCategory @map("split_category")
  payeeKind         BrokerageSplitPayeeKind          @map("payee_kind")
  payeeUserId       String?                          @map("payee_user_id")
  payeeUser         User?                            @relation("BrokerageSplitPayee", fields: [payeeUserId], references: [id], onDelete: SetNull)
  payeeExternalName String?                          @map("payee_external_name") @db.VarChar(200)
  amountCents       Int                              @map("amount_cents")
  percentage        Float?
  notes             Json                             @default("{}")
  createdAt         DateTime                         @default(now()) @map("created_at")

  @@index([commissionCaseId])
  @@index([payeeUserId])
  @@map("brokerage_commission_split_lines")
}

model OfficeInvoice {
  id                 String              @id @default(uuid())
  officeId           String              @map("office_id")
  office             BrokerageOffice     @relation(fields: [officeId], references: [id], onDelete: Cascade)
  brokerUserId       String?             @map("broker_user_id")
  broker             User?               @relation("OfficeInvoiceBroker", fields: [brokerUserId], references: [id], onDelete: SetNull)
  dealId             String?             @map("deal_id")
  deal               Deal?               @relation(fields: [dealId], references: [id], onDelete: SetNull)
  invoiceType        OfficeInvoiceType   @map("invoice_type")
  status             OfficeInvoiceStatus @default(draft)
  subtotalCents      Int                 @map("subtotal_cents")
  taxes              Json?               @default("{}")
  totalCents         Int                 @map("total_cents")
  issuedAt           DateTime?           @map("issued_at")
  dueAt              DateTime?           @map("due_at")
  paidAt             DateTime?           @map("paid_at")
  issuedByUserId     String?             @map("issued_by_user_id")
  issuedBy           User?               @relation("OfficeInvoiceIssuedBy", fields: [issuedByUserId], references: [id], onDelete: SetNull)
  markedPaidByUserId String?             @map("marked_paid_by_user_id")
  markedPaidBy       User?               @relation("OfficeInvoiceMarkedPaidBy", fields: [markedPaidByUserId], references: [id], onDelete: SetNull)
  metadata           Json                @default("{}")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  lines OfficeInvoiceLine[]

  @@index([officeId, status])
  @@index([brokerUserId])
  @@index([dealId])
  @@map("office_invoices")
}

model OfficeInvoiceLine {
  id               String                @id @default(uuid())
  invoiceId        String                @map("invoice_id")
  invoice          OfficeInvoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  lineType         OfficeInvoiceLineType @map("line_type")
  description      String                @db.VarChar(500)
  quantity         Float                 @default(1)
  unitAmountCents  Int                   @map("unit_amount_cents")
  totalAmountCents Int                   @map("total_amount_cents")
  metadata         Json                  @default("{}")
  createdAt        DateTime              @default(now()) @map("created_at")

  @@index([invoiceId])
  @@map("office_invoice_lines")
}

model OfficePayout {
  id                   String             @id @default(uuid())
  officeId             String             @map("office_id")
  office               BrokerageOffice    @relation(fields: [officeId], references: [id], onDelete: Cascade)
  brokerUserId         String             @map("broker_user_id")
  broker               User               @relation("OfficePayoutBroker", fields: [brokerUserId], references: [id], onDelete: Cascade)
  status               OfficePayoutStatus @default(draft)
  amountCents          Int                @map("amount_cents")
  periodStart          DateTime?          @map("period_start") @db.Date
  periodEnd            DateTime?          @map("period_end") @db.Date
  payoutMethod         String?            @map("payout_method") @db.VarChar(64)
  externalReference    String?            @map("external_reference") @db.VarChar(200)
  approvedAt           DateTime?          @map("approved_at")
  approvedByUserId     String?            @map("approved_by_user_id")
  approvedBy           User?              @relation("OfficePayoutApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  paidAt               DateTime?          @map("paid_at")
  paidRecordedByUserId String?            @map("paid_recorded_by_user_id")
  paidRecordedBy       User?              @relation("OfficePayoutPaidRecordedBy", fields: [paidRecordedByUserId], references: [id], onDelete: SetNull)
  metadata             Json               @default("{}")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  lines OfficePayoutLine[]

  @@index([officeId, status])
  @@index([brokerUserId])
  @@map("office_payouts")
}

model OfficePayoutLine {
  id          String                     @id @default(uuid())
  payoutId    String                     @map("payout_id")
  payout      OfficePayout               @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  sourceType  OfficePayoutLineSourceType @map("source_type")
  sourceId    String                     @map("source_id") @db.VarChar(64)
  description String                     @db.VarChar(500)
  amountCents Int                        @map("amount_cents")
  metadata    Json                       @default("{}")
  createdAt   DateTime                   @default(now()) @map("created_at")

  @@index([payoutId])
  @@map("office_payout_lines")
}

model OfficeReconciliationRecord {
  id              String                         @id @default(uuid())
  officeId        String                         @map("office_id")
  office          BrokerageOffice                @relation(fields: [officeId], references: [id], onDelete: Cascade)
  recordType      OfficeReconciliationRecordType @map("record_type")
  sourceType      String                         @map("source_type") @db.VarChar(64)
  sourceId        String                         @map("source_id") @db.VarChar(64)
  status          OfficeReconciliationStatus     @default(open)
  notes           Json                           @default("{}")
  createdByUserId String?                        @map("created_by_user_id")
  createdBy       User?                          @relation("OfficeReconciliationActor", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime                       @default(now()) @map("created_at")
  updatedAt       DateTime                       @updatedAt @map("updated_at")

  @@index([officeId, status])
  @@index([sourceType, sourceId])
  @@map("office_reconciliation_records")
}

model BrokerageOfficeAuditLog {
  id          String          @id @default(uuid())
  officeId    String          @map("office_id")
  office      BrokerageOffice @relation(fields: [officeId], references: [id], onDelete: Cascade)
  actorUserId String          @map("actor_user_id")
  actor       User            @relation("BrokerageOfficeAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  actionKey   String          @map("action_key") @db.VarChar(96)
  payload     Json            @default("{}")
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([officeId, createdAt])
  @@index([actionKey])
  @@map("brokerage_office_audit_logs")
}

/// Founder / executive weekly briefings — Québec residential brokerage scope only; review before delivery.
enum ExecutiveBriefingStatus {
  draft
  generated
  reviewed
  delivered
  archived
}

enum ExecutiveBriefingDeliveryChannel {
  in_app
  download
  email_draft
}

enum ExecutiveBriefingDeliveryStatus {
  pending
  completed
  failed
  cancelled
}

enum FounderActionStatus {
  open
  accepted
  rejected
  delegated
  completed
  archived
}

model ExecutiveBriefing {
  id                 String                      @id @default(cuid())
  /// `platform` | `office` — aligns with ExecutiveScope.kind
  scopeKind          String                      @map("scope_kind") @db.VarChar(16)
  /// When scope is office, listed office UUIDs (JSON array of strings).
  scopeOfficeIdsJson Json                        @default("[]") @map("scope_office_ids_json")
  periodType         String                      @map("period_type") @db.VarChar(32)
  periodStart        DateTime                    @map("period_start")
  periodEnd          DateTime                    @map("period_end")
  status             ExecutiveBriefingStatus     @default(draft)
  generatedSummary   Json                        @default("{}") @map("generated_summary")
  reviewedByUserId   String?                     @map("reviewed_by_user_id")
  reviewedBy         User?                       @relation("ExecutiveBriefingReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  reviewedAt         DateTime?                   @map("reviewed_at")
  createdByUserId    String                      @map("created_by_user_id")
  createdBy          User                        @relation("ExecutiveBriefingCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  createdAt          DateTime                    @default(now()) @map("created_at")
  updatedAt          DateTime                    @updatedAt @map("updated_at")
  sections           ExecutiveBriefingSection[]
  deliveries         ExecutiveBriefingDelivery[]
  linkedDecisions    FounderDecisionLog[]

  @@index([scopeKind, periodStart])
  @@index([status, createdAt])
  @@map("executive_briefings")
}

model ExecutiveBriefingSection {
  id         String            @id @default(cuid())
  briefingId String            @map("briefing_id")
  briefing   ExecutiveBriefing @relation(fields: [briefingId], references: [id], onDelete: Cascade)
  sectionKey String            @map("section_key") @db.VarChar(64)
  title      String            @db.VarChar(300)
  content    Json              @default("{}")
  ordering   Int               @default(0)
  createdAt  DateTime          @default(now()) @map("created_at")

  @@index([briefingId, ordering])
  @@map("executive_briefing_sections")
}

model ExecutiveBriefingDelivery {
  id          String                           @id @default(cuid())
  briefingId  String                           @map("briefing_id")
  briefing    ExecutiveBriefing                @relation(fields: [briefingId], references: [id], onDelete: Cascade)
  channel     ExecutiveBriefingDeliveryChannel
  status      ExecutiveBriefingDeliveryStatus  @default(pending)
  deliveredAt DateTime?                        @map("delivered_at")
  metadata    Json                             @default("{}")
  createdAt   DateTime                         @default(now()) @map("created_at")

  @@index([briefingId, channel])
  @@map("executive_briefing_deliveries")
}

model FounderAction {
  id                 String              @id @default(cuid())
  sourceType         String              @map("source_type") @db.VarChar(64)
  sourceId           String?             @map("source_id")
  title              String              @db.VarChar(500)
  summary            String              @map("summary") @db.Text
  priority           String              @default("medium") @map("priority") @db.VarChar(24)
  status             FounderActionStatus @default(open)
  assignedToUserId   String?             @map("assigned_to_user_id")
  assignedTo         User?               @relation("FounderActionAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  createdByUserId    String              @map("created_by_user_id")
  createdBy          User                @relation("FounderActionCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  scopeKind          String              @map("scope_kind") @db.VarChar(16)
  scopeOfficeIdsJson Json                @default("[]") @map("scope_office_ids_json")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([createdByUserId])
  @@map("founder_actions")
}

model FounderDecisionLog {
  id                String             @id @default(cuid())
  title             String             @db.VarChar(500)
  summary           String             @map("summary") @db.Text
  linkedBriefingId  String?            @map("linked_briefing_id")
  linkedBriefing    ExecutiveBriefing? @relation(fields: [linkedBriefingId], references: [id], onDelete: SetNull)
  linkedInsightType String?            @map("linked_insight_type") @db.VarChar(64)
  decidedByUserId   String             @map("decided_by_user_id")
  decidedBy         User               @relation("FounderDecisionAuthor", fields: [decidedByUserId], references: [id], onDelete: Cascade)
  createdAt         DateTime           @default(now()) @map("created_at")

  @@index([decidedByUserId, createdAt])
  @@map("founder_decision_logs")
}

// ---------------------------------------------------------------------------
// LECIPM AI Autopilot v1 — unified orchestrator queue (additive; gated by env flags).
// Does not replace `AiAutopilotAction`, listing optimization, or deal autopilot tables.
// ---------------------------------------------------------------------------

enum PlatformAutopilotActionStatus {
  detected
  recommended
  pending_approval
  approved
  executed
  rejected
  expired
  failed
  archived
}

enum PlatformAutopilotRiskClass {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model PlatformAutopilotPolicy {
  id             String        @id @default(cuid())
  scopeType      String        @map("scope_type") @db.VarChar(32)
  scopeId        String        @default("") @map("scope_id") @db.VarChar(64)
  mode           AutopilotMode @default(ASSIST)
  allowedDomains Json          @default("[]") @map("allowed_domains")
  blockedActions Json          @default("[]") @map("blocked_actions")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@unique([scopeType, scopeId], map: "uniq_platform_autopilot_policy_scope")
  @@map("platform_autopilot_policies")
}

model PlatformAutopilotAction {
  id                 String                        @id @default(cuid())
  domain             String                        @db.VarChar(64)
  entityType         String                        @map("entity_type") @db.VarChar(64)
  entityId           String?                       @map("entity_id") @db.VarChar(64)
  actionType         String                        @map("action_type") @db.VarChar(128)
  title              String                        @db.VarChar(512)
  summary            String                        @db.Text
  severity           String                        @db.VarChar(32)
  riskLevel          PlatformAutopilotRiskClass    @map("risk_level")
  status             PlatformAutopilotActionStatus @default(detected)
  recommendedPayload Json?                         @map("recommended_payload")
  executedPayload    Json?                         @map("executed_payload")
  reasons            Json?
  /// Dedupe + ranking v1 — same logical issue shares one queue row.
  fingerprint        String?                       @map("fingerprint") @db.VarChar(64)
  qualityScore       Int?                          @map("quality_score")
  valueScore         Int?                          @map("value_score")
  noisePenalty       Int?                          @map("noise_penalty")
  priorityBucket     String?                       @map("priority_bucket") @db.VarChar(32)
  duplicateCount     Int                           @default(0) @map("duplicate_count")
  lastDetectedAt     DateTime?                     @map("last_detected_at")
  lastRefreshedAt    DateTime?                     @map("last_refreshed_at")
  /// User the action is scoped for (host/broker); null = platform-admin-only visibility.
  subjectUserId      String?                       @map("subject_user_id")
  audience           String?                       @db.VarChar(32)
  approvedById       String?                       @map("approved_by_id")
  executedBySystem   Boolean                       @default(false) @map("executed_by_system")
  createdAt          DateTime                      @default(now()) @map("created_at")
  updatedAt          DateTime                      @updatedAt @map("updated_at")

  decisions PlatformAutopilotDecision[]

  @@index([domain, status], map: "idx_platform_autopilot_action_domain_status")
  @@index([actionType, status], map: "idx_platform_autopilot_action_type_status")
  @@index([subjectUserId, status], map: "idx_platform_autopilot_action_subject_status")
  @@index([fingerprint, status], map: "idx_platform_autopilot_action_fingerprint_status")
  @@map("platform_autopilot_actions")
}

model PlatformAutopilotDecision {
  id           String                  @id @default(cuid())
  actionId     String                  @map("action_id")
  action       PlatformAutopilotAction @relation(fields: [actionId], references: [id], onDelete: Cascade)
  decisionType String                  @map("decision_type") @db.VarChar(64)
  actorUserId  String?                 @map("actor_user_id")
  actorType    String                  @map("actor_type") @db.VarChar(32)
  notes        Json?
  createdAt    DateTime                @default(now()) @map("created_at")

  @@index([actionId], map: "idx_platform_autopilot_decision_action")
  @@map("platform_autopilot_decisions")
}

/// Per-domain autopilot posture for LECIPM Full Autopilot Layer (additive).
model LecipmFullAutopilotDomainConfig {
  domainId   String @id @map("domain_id") @db.VarChar(64)
  /// OFF | ASSIST | SAFE_AUTOPILOT | FULL_AUTOPILOT_APPROVAL | FULL_AUTOPILOT_BOUNDED
  mode       String @default("ASSIST") @db.VarChar(40)
  /// ON | OFF | LIMITED — when OFF, no future executes; LIMITED = whitelist-only in policy engine
  killSwitch String @default("ON") @map("kill_switch") @db.VarChar(16)

  lastChangedById String? @map("last_changed_by_id")
  lastReason      String? @map("last_reason") @db.Text

