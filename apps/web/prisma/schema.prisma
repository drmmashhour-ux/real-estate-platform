enum LecipmVisitRequestStatus {
  pending
  accepted
  rejected
  cancelled
}

enum LecipmVisitStatus {
  scheduled
  completed
  cancelled
  no_show
}

/// LECIPM no-show pipeline state (advisory; does not replace `LecipmVisitStatus` outcome).
enum LecipmVisitWorkflowState {
  BOOKED
  CONFIRMED
  REMINDER_SENT
  RESCHEDULE_REQUESTED
  RESCHEDULED
  NO_SHOW_RISK_HIGH
  MISSED
  COMPLETED
  CANCELED
}

/// Probabilistic no-show risk tier (0–100 score maps to these bands).
