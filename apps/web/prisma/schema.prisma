// ---------------------------------------------------------------------------
// TrustGraph Phase 7 — enterprise / compliance workspaces
// ---------------------------------------------------------------------------

enum TrustgraphComplianceOrgType {
  brokerage
  investor_firm
  admin_internal
  legal_team
}

enum TrustgraphWorkspaceMemberRole {
  workspace_admin
  workspace_manager
  workspace_reviewer
  workspace_legal_reviewer
  workspace_viewer
}

enum TrustgraphWorkspaceMemberStatus {
  active
  suspended
  invited
}

model TrustgraphComplianceWorkspace {
  id        String                      @id @default(cuid())
  orgType   TrustgraphComplianceOrgType @map("org_type")
  orgId     String                      @map("org_id")
  name      String
  branding  Json?                       @db.JsonB
  settings  Json?                       @db.JsonB
  createdAt DateTime                    @default(now()) @map("created_at")
  updatedAt DateTime                    @updatedAt @map("updated_at")

  members        TrustgraphComplianceWorkspaceMember[]
  entityLinks    TrustgraphComplianceWorkspaceEntityLink[]
  assignments    TrustgraphWorkspaceCaseAssignment[]
  approvalFlows  TrustgraphDocumentApprovalFlow[]
  slaPolicies    TrustgraphSlaPolicy[]
  subscriptions  TrustgraphSubscription[]
  partnerApiKeys TrustgraphPartnerApiKey[]

  @@index([orgType, orgId], map: "idx_tg_workspace_org")
  @@map("trustgraph_compliance_workspaces")
}

model TrustgraphComplianceWorkspaceMember {
  id          String                          @id @default(cuid())
  workspaceId String                          @map("workspace_id")
  workspace   TrustgraphComplianceWorkspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String                          @map("user_id")
  user        User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        TrustgraphWorkspaceMemberRole
  status      TrustgraphWorkspaceMemberStatus @default(active)
  createdAt   DateTime                        @default(now()) @map("created_at")
  updatedAt   DateTime                        @updatedAt @map("updated_at")

  @@unique([workspaceId, userId], map: "uq_tg_workspace_member")
  @@index([userId], map: "idx_tg_workspace_member_user")
  @@map("trustgraph_compliance_workspace_members")
}

model TrustgraphComplianceWorkspaceEntityLink {
  id           String                        @id @default(cuid())
  workspaceId  String                        @map("workspace_id")
  workspace    TrustgraphComplianceWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  entityType   String                        @map("entity_type")
  entityId     String                        @map("entity_id")
  relationType String                        @map("relation_type")
  createdAt    DateTime                      @default(now()) @map("created_at")

  @@index([workspaceId, entityType], map: "idx_tg_ws_entity_workspace")
  @@index([entityType, entityId], map: "idx_tg_ws_entity_lookup")
  @@map("trustgraph_compliance_workspace_entity_links")
}

model TrustgraphWorkspaceCaseAssignment {
  id          String                        @id @default(cuid())
  workspaceId String                        @map("workspace_id")
  workspace   TrustgraphComplianceWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  caseId      String                        @map("case_id") @db.Uuid
  case        VerificationCase              @relation(fields: [caseId], references: [id], onDelete: Cascade)
  assignedTo  String?                       @map("assigned_to")
  assignedBy  String?                       @map("assigned_by")
  priority    String                        @default("normal")
  dueAt       DateTime?                     @map("due_at") @db.Timestamptz(6)
  createdAt   DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([workspaceId, caseId], map: "uq_tg_ws_case_assignment")
  @@index([caseId], map: "idx_tg_ws_case_assignment_case")
  @@map("trustgraph_workspace_case_assignments")
}

model TrustgraphDocumentApprovalFlow {
  id            String                         @id @default(cuid())
  entityType    String                         @map("entity_type")
  entityId      String                         @map("entity_id")
  documentType  String                         @map("document_type")
  currentStatus String                         @map("current_status")
  workspaceId   String?                        @map("workspace_id")
  workspace     TrustgraphComplianceWorkspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  startedBy     String                         @map("started_by")
  resolvedAt    DateTime?                      @map("resolved_at") @db.Timestamptz(6)
  createdAt     DateTime                       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(6)

  steps   TrustgraphDocumentApprovalStep[]
  actions TrustgraphDocumentApprovalAction[]

  @@index([entityType, entityId], map: "idx_tg_doc_approval_entity")
  @@index([workspaceId], map: "idx_tg_doc_approval_workspace")
  @@map("trustgraph_document_approval_flows")
}

model TrustgraphDocumentApprovalStep {
  id             String                         @id @default(cuid())
  approvalFlowId String                         @map("approval_flow_id")
  flow           TrustgraphDocumentApprovalFlow @relation(fields: [approvalFlowId], references: [id], onDelete: Cascade)
  stepKind       String                         @map("step_kind")
  assignedTo     String?                        @map("assigned_to")
  status         String                         @default("pending")
  dueAt          DateTime?                      @map("due_at") @db.Timestamptz(6)
  metadata       Json?                          @db.JsonB
  createdAt      DateTime                       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(6)

  actions TrustgraphDocumentApprovalAction[]

  @@index([approvalFlowId], map: "idx_tg_doc_approval_steps_flow")
  @@map("trustgraph_document_approval_steps")
}

model TrustgraphDocumentApprovalAction {
  id             String                          @id @default(cuid())
  approvalFlowId String                          @map("approval_flow_id")
  flow           TrustgraphDocumentApprovalFlow  @relation(fields: [approvalFlowId], references: [id], onDelete: Cascade)
  stepId         String?                         @map("step_id")
  step           TrustgraphDocumentApprovalStep? @relation(fields: [stepId], references: [id], onDelete: SetNull)
  actorId        String                          @map("actor_id")
  actionType     String                          @map("action_type")
  notes          String?                         @db.Text
  payload        Json?                           @db.JsonB
  createdAt      DateTime                        @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([approvalFlowId], map: "idx_tg_doc_approval_actions_flow")
  @@index([stepId], map: "idx_tg_doc_approval_actions_step")
  @@map("trustgraph_document_approval_actions")
}

model TrustgraphSlaPolicy {
  id                  String                         @id @default(cuid())
  workspaceId         String?                        @map("workspace_id")
  workspace           TrustgraphComplianceWorkspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name                String
  queueKey            String                         @map("queue_key")
  dueHours            Int                            @map("due_hours")
  escalatesAfterHours Int?                           @map("escalates_after_hours")
  settings            Json?                          @db.JsonB
  createdAt           DateTime                       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(6)

  caseSlaStates TrustgraphCaseSlaState[]

  @@index([workspaceId, queueKey], map: "idx_tg_sla_policy_ws_queue")
  @@map("trustgraph_sla_policies")
}

model TrustgraphSlaEvent {
  id             String   @id @default(cuid())
  caseId         String?  @map("case_id") @db.Uuid
  approvalFlowId String?  @map("approval_flow_id")
  eventType      String   @map("event_type")
  payload        Json?    @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([caseId], map: "idx_tg_sla_events_case")
  @@map("trustgraph_sla_events")
}

model TrustgraphCaseSlaState {
  id           String               @id @default(cuid())
  workspaceId  String?              @map("workspace_id")
  caseId       String               @unique @map("case_id") @db.Uuid
  case         VerificationCase     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  slaPolicyId  String?              @map("sla_policy_id")
  slaPolicy    TrustgraphSlaPolicy? @relation(fields: [slaPolicyId], references: [id], onDelete: SetNull)
  state        String
  dueAt        DateTime?            @map("due_at") @db.Timestamptz(6)
  pausedReason String?              @map("paused_reason") @db.Text
  metadata     Json?                @db.JsonB
  updatedAt    DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([workspaceId], map: "idx_tg_case_sla_ws")
  @@map("trustgraph_case_sla_states")
}

