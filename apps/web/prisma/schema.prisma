  identityVerified  Boolean           @default(false) @map("identity_verified")
  brokerVerified    Boolean           @default(false) @map("broker_verified")
  paymentVerified   Boolean           @default(false) @map("payment_verified")
  verificationLevel VerificationLevel @default(basic) @map("verification_level")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  @@index([verificationLevel])
  @@map("verification_profiles")
}

