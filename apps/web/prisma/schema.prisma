  customerUserId    String?                  @map("customer_user_id")
  customer          User?                    @relation("VisitCustomer", fields: [customerUserId], references: [id], onDelete: SetNull)
  startDateTime     DateTime                 @map("start_date_time")
  endDateTime       DateTime                 @map("end_date_time")
