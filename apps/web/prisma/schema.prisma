  metadata           Json?

  @@index([leadId, createdAt])
  @@index([userId, createdAt])
  @@index([shortTermListingId, createdAt])
  @@index([eventType, createdAt])
  @@index([channel, createdAt])
  @@map("internal_crm_events")
}

