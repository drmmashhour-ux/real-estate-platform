  payload          Json           @default("{}")
  actorUserId      String?        @map("actor_user_id")
  createdAt        DateTime       @default(now()) @map("created_at")

  @@index([actionPipelineId, createdAt])
  @@map("signature_control_audit_logs")
}

/// One row per document type — versioned bodies live in `LecipmLegalDocumentTemplateVersion`.
model LecipmLegalDocumentTemplate {
  id          String                               @id @default(cuid())
  kind        LecipmLegalDocumentTemplateKind      @unique
  name        String                               @db.VarChar(256)
  description String?                              @db.Text
  isActive    Boolean                              @default(true) @map("is_active")
  createdAt   DateTime                             @default(now()) @map("created_at")
  updatedAt   DateTime                             @updatedAt @map("updated_at")
  versions    LecipmLegalDocumentTemplateVersion[]

  @@index([isActive])
  @@map("lecipm_legal_document_templates")
}

model LecipmLegalDocumentTemplateVersion {
  id              String                        @id @default(cuid())
  templateId      String                        @map("template_id")
  template        LecipmLegalDocumentTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  versionNumber   Int                           @map("version_number")
  /// HTML with {{dot.path}} placeholders — operational assist; not legal advice.
  bodyHtml        String                        @map("body_html") @db.Text
  changelog       String?                       @db.Text
  createdByUserId String?                       @map("created_by_user_id")
  createdBy       User?                         @relation("LegalDocTemplateVersionAuthor", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime                      @default(now()) @map("created_at")
  artifacts       LecipmLegalDocumentArtifact[]

  @@unique([templateId, versionNumber])
  @@index([templateId])
  @@map("lecipm_legal_document_template_versions")
}

/// Generated document instance with immutable source snapshot and approval gates.
model LecipmLegalDocumentArtifact {
  id                               String                             @id @default(cuid())
  templateVersionId                String                             @map("template_version_id")
  templateVersion                  LecipmLegalDocumentTemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Restrict)
  kind                             LecipmLegalDocumentTemplateKind
  domain                           LecipmLegalDocumentDomain
  dealId                           String?                            @map("deal_id")
  deal                             Deal?                              @relation(fields: [dealId], references: [id], onDelete: SetNull)
  capitalDealId                    String?                            @map("capital_deal_id") @db.VarChar(36)
  capitalDeal                      AmfCapitalDeal?                    @relation(fields: [capitalDealId], references: [id], onDelete: SetNull)
  sourceDataSnapshot               Json                               @map("source_data_snapshot")
  renderedHtml                     String                             @map("rendered_html") @db.Text
  pdfStorageKey                    String?                            @map("pdf_storage_key") @db.VarChar(512)
  status                           LecipmLegalDocumentArtifactStatus  @default(AWAITING_APPROVAL)
  approvedByBrokerId               String?                            @map("approved_by_broker_id")
  approvedByBroker                 User?                              @relation("LegalDocArtifactBrokerApprover", fields: [approvedByBrokerId], references: [id], onDelete: SetNull)
  approvedAt                       DateTime?                          @map("approved_at")
  investmentComplianceApprovedById String?                            @map("investment_compliance_approved_by_id")
  investmentComplianceApprover     User?                              @relation("LegalDocArtifactInvComplianceApprover", fields: [investmentComplianceApprovedById], references: [id], onDelete: SetNull)
  investmentComplianceApprovedAt   DateTime?                          @map("investment_compliance_approved_at")
  signatureSessionId               String?                            @unique @map("signature_session_id")
  signatureSession                 SignatureSession?                  @relation(fields: [signatureSessionId], references: [id], onDelete: SetNull)
  createdByUserId                  String?                            @map("created_by_user_id")
  createdBy                        User?                              @relation("LegalDocArtifactCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt                        DateTime                           @default(now()) @map("created_at")
  updatedAt                        DateTime                           @updatedAt @map("updated_at")
  dispatches                       LecipmLegalDocumentDispatch[]
  digitalSignatures                DigitalSignature[]
  /// Deterministic locked PDF bytes after broker sign (tamper-evident bundle); regenerate if document changes.
  lockedPdfBytes                   Bytes?                             @map("locked_pdf_bytes")
  lockedPdfGeneratedAt             DateTime?                          @map("locked_pdf_generated_at")

  @@index([dealId])
  @@index([capitalDealId])
  @@index([status, createdAt])
  @@index([kind])
  @@map("lecipm_legal_document_artifacts")
}

model DigitalSignature {
  id            String                      @id @default(cuid())
  userId        String                      @map("user_id") @db.VarChar(36)
  user          User                        @relation("DigitalSignatureSigner", fields: [userId], references: [id], onDelete: Cascade)
  documentId    String                      @map("document_id") @db.VarChar(36)
  document      LecipmLegalDocumentArtifact @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signatureHash String                      @map("signature_hash") @db.VarChar(128)
  ipAddress     String?                     @map("ip_address") @db.VarChar(48)
  userAgent     String?                     @map("user_agent") @db.Text
  signedAt      DateTime                    @default(now()) @map("signed_at")
  metadataJson  Json?                       @map("metadata_json")

  @@index([userId, signedAt])
  @@index([documentId])
  @@map("digital_signatures")
}

model LecipmLegalDocumentDispatch {
  id            String                             @id @default(cuid())
  artifactId    String                             @map("artifact_id")
  artifact      LecipmLegalDocumentArtifact        @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  channel       LecipmLegalDocumentDispatchChannel
  status        LecipmLegalDocumentDispatchStatus  @default(PENDING)
  targetSummary Json                               @default("{}") @map("target_summary")
  errorMessage  String?                            @map("error_message") @db.Text
  sentAt        DateTime?                          @map("sent_at")
  createdAt     DateTime                           @default(now()) @map("created_at")

  @@index([artifactId])
  @@index([status])
  @@map("lecipm_legal_document_dispatches")
}

model SignatureSession {
  id                    String                       @id @default(uuid())
  dealId                String                       @map("deal_id")
  deal                  Deal                         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  status                String                       @db.VarChar(32)
  provider              String                       @db.VarChar(32)
  providerSessionId     String?                      @map("provider_session_id") @db.VarChar(160)
  /// Provider envelope/document ids, signing order, last webhook payload refs (non-PII summaries).
  providerMetadata      Json                         @default("{}") @map("provider_metadata")
  documentIds           Json                         @default("[]") @map("document_ids")
  createdAt             DateTime                     @default(now()) @map("created_at")
  updatedAt             DateTime                     @updatedAt @map("updated_at")
  participants          SignatureParticipant[]
  brokerApproval        BrokerApproval?
  legalDocumentArtifact LecipmLegalDocumentArtifact?

  @@index([dealId])
  @@index([provider, status])
  @@map("signature_sessions")
}

model SignatureParticipant {
  id                  String           @id @default(uuid())
  sessionId           String           @map("session_id")
  session             SignatureSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name                String
  role                String           @db.VarChar(32)
  email               String?
  status              String           @default("pending") @db.VarChar(24)
  signedAt            DateTime?        @map("signed_at")
  providerRecipientId String?          @map("provider_recipient_id") @db.VarChar(128)

  @@index([sessionId])
  @@map("signature_participants")
}

model DealClosingCondition {
  id            String    @id @default(uuid())
  dealId        String    @map("deal_id")
  deal          Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  conditionType String    @map("condition_type") @db.VarChar(64)
  deadline      DateTime? @map("deadline")
  status        String    @default("pending") @db.VarChar(24)
  relatedForm   String?   @map("related_form") @db.VarChar(32)
  notes         String?   @db.Text
  fulfilledAt   DateTime? @map("fulfilled_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([dealId])
  @@index([deadline])
  @@map("deal_closing_conditions")
}

model DraftingKnowledgeIngestion {
  id          String   @id @default(uuid())
  sourceType  String   @map("source_type") @db.VarChar(32)
  title       String
  fileUrl     String?  @map("file_url")
  status      String   @default("indexed") @db.VarChar(24)
  metadata    Json     @default("{}")
  brokerScope String?  @map("broker_scope") @db.VarChar(64)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([status])
  @@map("drafting_knowledge_ingestions")
}

// —— Broker deal coordination: document requests, bank/notary hubs (v1) ——

enum DealRequestStatus {
  DRAFT
  READY
  SENT
  AWAITING_RESPONSE
  PARTIALLY_FULFILLED
  FULFILLED
  OVERDUE
  BLOCKED
  CANCELLED
}

enum DealRequestCategory {
  SELLER_DOCUMENTS
  BUYER_DOCUMENTS
  LENDER_DOCUMENTS
  SYNDICATE_DOCUMENTS
  INSPECTION_DOCUMENTS
  IDENTITY_COMPLIANCE
  NOTARY_PREPARATION
  CLOSING_SUPPORT
  OTHER
}

enum CoordinationTargetRole {
  BUYER
  SELLER
  BROKER
  LENDER
  NOTARY
  SYNDICATE
  INSPECTOR
  EXPERT
  INSURER
}

enum DealRequestItemStatus {
  PENDING
  RECEIVED
  VALIDATED
  REJECTED
  WAIVED
}

enum RequestCommunicationChannel {
  IN_APP
  EMAIL_DRAFT
  MANUAL_EXPORT
}

enum RequestCommunicationDirection {
  OUTBOUND
  INBOUND
  INTERNAL_NOTE
}

enum DealFinancingCoordinationStatus {
  NOT_STARTED
  APPLICATION_IN_PROGRESS
  UNDERTAKING_PENDING
  UNDERTAKING_RECEIVED
  ADDITIONAL_INFO_NEEDED
  REFUSED
  CONDITION_FULFILLED
  CONDITION_FAILED
}

enum CoordinationContactType {
  LENDER
  NOTARY
  SYNDICATE
  INSPECTOR
  BUYER_AGENT
  OTHER
}

model DealRequest {
  id                 String                 @id @default(uuid())
  dealId             String                 @map("deal_id")
  deal               Deal                   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  requestType        String                 @map("request_type")
  requestCategory    DealRequestCategory    @map("request_category")
  status             DealRequestStatus      @default(DRAFT)
  title              String
  summary            String?                @db.Text
  targetRole         CoordinationTargetRole @map("target_role")
  targetEntityType   String?                @map("target_entity_type")
  targetEntityId     String?                @map("target_entity_id")
  dueAt              DateTime?              @map("due_at")
  fulfilledAt        DateTime?              @map("fulfilled_at")
  blockedReason      String?                @map("blocked_reason") @db.Text
  metadata           Json                   @default("{}")
  autopilotGenerated Boolean                @default(false) @map("autopilot_generated")
  brokerApprovedAt   DateTime?              @map("broker_approved_at")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")
  items              DealRequestItem[]
  communications     RequestCommunication[]

  @@index([dealId, status])
  @@index([dealId, requestCategory])
  @@map("deal_requests")
}

model DealRequestItem {
  id                String                @id @default(uuid())
  dealRequestId     String                @map("deal_request_id")
  dealRequest       DealRequest           @relation(fields: [dealRequestId], references: [id], onDelete: Cascade)
  itemKey           String                @map("item_key")
  itemLabel         String                @map("item_label")
  isRequired        Boolean               @default(true) @map("is_required")
  status            DealRequestItemStatus @default(PENDING)
  receivedAt        DateTime?             @map("received_at")
  validatedAt       DateTime?             @map("validated_at")
  validatedByUserId String?               @map("validated_by_user_id")
  sourceDocumentId  String?               @map("source_document_id")
  sourceDocument    DealDocument?         @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  notes             Json                  @default("{}")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  @@index([dealRequestId])
  @@index([sourceDocumentId])
  @@map("deal_request_items")
}

model RequestCommunication {
  id              String                        @id @default(uuid())
  dealRequestId   String                        @map("deal_request_id")
  dealRequest     DealRequest                   @relation(fields: [dealRequestId], references: [id], onDelete: Cascade)
  channel         RequestCommunicationChannel
  direction       RequestCommunicationDirection
  subject         String?
  body            String?                       @db.Text
  sentAt          DateTime?                     @map("sent_at")
  deliveredAt     DateTime?                     @map("delivered_at")
  openedAt        DateTime?                     @map("opened_at")
  createdByUserId String?                       @map("created_by_user_id")
  metadata        Json                          @default("{}")
  createdAt       DateTime                      @default(now()) @map("created_at")

  @@index([dealRequestId, createdAt])
  @@map("request_communications")
}

model CoordinationContact {
  id           String                  @id @default(uuid())
  dealId       String                  @map("deal_id")
  deal         Deal                    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contactType  CoordinationContactType @map("contact_type")
  name         String
  email        String?
  phone        String?
  organization String?
  region       String?
  roleMetadata Json                    @default("{}") @map("role_metadata")
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")

  @@index([dealId, contactType])
  @@map("coordination_contacts")
}

model DealBankCoordination {
  id               String                          @id @default(uuid())
  dealId           String                          @unique @map("deal_id")
  deal             Deal                            @relation(fields: [dealId], references: [id], onDelete: Cascade)
  financingStatus  DealFinancingCoordinationStatus @default(NOT_STARTED) @map("financing_status")
  institutionName  String?                         @map("institution_name")
  lastContactAt    DateTime?                       @map("last_contact_at")
  missingInfoFlags Json                            @default("[]") @map("missing_info_flags")
  lenderMetadata   Json                            @default("{}") @map("lender_metadata")
  createdAt        DateTime                        @default(now()) @map("created_at")
  updatedAt        DateTime                        @updatedAt @map("updated_at")

  @@map("deal_bank_coordinations")
}

model DealNotaryCoordination {
  id                   String    @id @default(uuid())
  dealId               String    @unique @map("deal_id")
  deal                 Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  notaryId             String?   @map("notary_id")
  notary               Notary?   @relation(fields: [notaryId], references: [id], onDelete: SetNull)
  selectedAt           DateTime? @map("selected_at")
  invitationSentAt     DateTime? @map("invitation_sent_at")
  /// pending | invited | accepted | declined | completed
  notaryInviteStatus   String?   @map("notary_invite_status") @db.VarChar(24)
  packageChecklistJson Json      @default("[]") @map("package_checklist_json")
  deedReadinessNotes   String?   @map("deed_readiness_notes") @db.Text
  appointmentAt        DateTime? @map("appointment_at")
  notaryFirmName       String?   @map("notary_firm_name")
  packageStatus        String    @default("not_started") @map("package_status")
  metadata             Json      @default("{}")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@index([notaryId])
  @@map("deal_notary_coordinations")
}

model DealCoordinationAuditLog {
  id          String   @id @default(uuid())
  dealId      String   @map("deal_id")
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  action      String
  actorUserId String?  @map("actor_user_id")
  entityType  String?  @map("entity_type")
  entityId    String?  @map("entity_id")
  payload     Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([dealId, createdAt])
  @@index([action])
  @@map("deal_coordination_audit_logs")
}

// Invoices generated from platform payments (bookings, subscriptions, deals)
model PlatformInvoice {
  id                String                @id @default(uuid())
  paymentId         String                @map("payment_id")
  payment           PlatformPayment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoiceIssuer     InvoiceIssuer         @default(PLATFORM) @map("invoice_issuer")
  /**
   * Payer (PLATFORM invoice) or broker recipient (BROKER invoice).
   */
  userId            String                @map("user_id")
  user              User                  @relation("PlatformInvoiceParty", fields: [userId], references: [id], onDelete: Cascade)
  /// Unique human-facing invoice number (e.g. INV-2026-000001). Immutable once issued; tax lines are frozen at issuance.
  invoiceNumber     String                @unique @map("invoice_number")
  status            PlatformInvoiceStatus @default(ISSUED) @map("status")
  /// Product / hub attribution (mirrors `PlatformPayment.paymentType` or finer label).
  hubSource         String?               @map("hub_source")
  amountCents       Int                   @map("amount_cents")
  currency          String                @default("cad")
  pdfUrl            String?               @map("pdf_url")
  invoiceLabel      String?               @map("invoice_label") // Human-readable: Platform service invoice | Broker commission invoice
  invoiceTaxDetails Json?                 @map("invoice_tax_details") // issuer-specific; never merge both issuers in one row
  subtotalCents     Int?                  @map("subtotal_cents")
  gstCents          Int?                  @map("gst_cents")
  qstCents          Int?                  @map("qst_cents")
  totalCents        Int?                  @map("total_cents")
  invoiceLines      Json?                 @map("invoice_lines") // line items with party + tax — snapshot at issuance
  taxMode           String?               @map("tax_mode") // EXCLUSIVE | INCLUSIVE
  issuedAt          DateTime              @default(now()) @map("issued_at")
  dueAt             DateTime?             @map("due_at")
  paidAt            DateTime?             @map("paid_at")
  notes             String?               @map("notes") @db.Text
  linkedContractId  String?               @map("linked_contract_id")
  createdAt         DateTime              @default(now()) @map("created_at")

  @@unique([paymentId, invoiceIssuer])
  @@index([userId])
  @@index([paymentId])
  @@index([invoiceIssuer])
  @@index([status])
  @@map("platform_invoices")
}

// Singleton-style platform tax & registration info (admin-maintained).
model PlatformFinancialSettings {
  id                              String   @id @default("default")
  legalName                       String?  @map("legal_name")
  platformGstNumber               String?  @map("platform_gst_number")
  platformQstNumber               String?  @map("platform_qst_number")
  defaultGstRate                  Decimal  @default(0.05) @map("default_gst_rate") @db.Decimal(12, 8)
  defaultQstRate                  Decimal  @default(0.09975) @map("default_qst_rate") @db.Decimal(12, 8)
  applyTaxToPlatformServices      Boolean  @default(true) @map("apply_tax_platform_services")
  applyTaxToBrokerCommissions     Boolean  @default(true) @map("apply_tax_broker_commissions")
  /**
   * Per payment_type: { "booking": { "taxPlatform": true, "taxBroker": true }, ... } — overrides global toggles when set.
   */
  paymentTypeTaxOverrides         Json?    @map("payment_type_tax_overrides")
  /**
   * Internal: investment / securities-adjacent hub (AMF risk) — default off.
   */
  investmentFeaturesEnabled       Boolean  @default(false) @map("investment_features_enabled")
  /// Revenue control: when true, broker CRM may require paid lead unlock (see `Lead` + unlock checkout).
  revenueMonetizationEnabled      Boolean  @default(false) @map("revenue_monetization_enabled")
  /// CAD cents — floor for dynamic lead unlock price (optional; pricing engine falls back to `PRICING.leadPriceCents`).
  revenueLeadUnlockMinCents       Int?     @map("revenue_lead_unlock_min_cents")
  revenueLeadUnlockMaxCents       Int?     @map("revenue_lead_unlock_max_cents")
  /// Optional admin override for default lead unlock anchor (CAD cents), e.g. 4900 — see `PRICING_CONFIG.canada.lead.default`.
  revenueLeadDefaultPriceCents    Int?     @map("revenue_lead_default_price_cents")
  /// Default BNHub listing boost (featured placement) — CAD cents; duration in days.
  revenueListingBoostPriceCents   Int?     @map("revenue_listing_boost_price_cents")
  revenueListingBoostDurationDays Int?     @map("revenue_listing_boost_duration_days")
  /**
   * Optional override for BNHub host/platform fee on lodging (percent, e.g. 3 = 3%).
   * When null, `lib/bnhub/booking-pricing` uses code constants.
   */
  bnhubHostFeePercentOverride     Decimal? @map("bnhub_host_fee_percent_override") @db.Decimal(6, 3)
  updatedAt                       DateTime @updatedAt @map("updated_at")

  @@map("platform_financial_settings")
}

/// Operator CRM — first brokers acquisition (outreach pipeline; separate from CRM `Lead`).
model BrokerProspect {
  id     String  @id @default(cuid())
  name   String
  agency String?
  phone  String  @default("")
  email  String
  /// manual | instagram | referral
  source String  @default("manual")
  /// new | contacted | replied | demo_scheduled | converted | lost
  status String  @default("new")

  notes String? @db.Text

  linkedBrokerUserId String? @map("linked_broker_user_id")
  linkedBrokerUser   User?   @relation("BrokerProspectLinkedUser", fields: [linkedBrokerUserId], references: [id], onDelete: SetNull)

  firstPurchaseAt DateTime? @map("first_purchase_at")
  totalSpentCents Int       @default(0) @map("total_spent_cents")

  /// Operator marked one free demo lead used for this prospect.
  demoLeadUsedAt DateTime? @map("demo_lead_used_at")

  /// Last close-tool action: follow_up | close | demo | objection (operator outreach tracking).
  lastCloseMessageType String?   @map("last_close_message_type")
  lastCloseContactAt   DateTime? @map("last_close_contact_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([email])
  @@index([status])
  @@map("broker_prospects")
}

// Separate platform vs broker revenue — one row per party per payment slice (never mixed).
model PartyRevenueLedgerEntry {
  id                 String            @id @default(uuid())
  platformPaymentId  String            @map("platform_payment_id")
  platformPayment    PlatformPayment   @relation(fields: [platformPaymentId], references: [id], onDelete: Cascade)
  party              RevenueParty
  category           String            @map("category") // e.g. platform_booking_fee, broker_deal_commission
  amountCents        Int               @map("amount_cents")
  currency           String            @default("cad")
  brokerCommissionId String?           @unique @map("broker_commission_id")
  brokerCommission   BrokerCommission? @relation(fields: [brokerCommissionId], references: [id], onDelete: SetNull)
  brokerId           String?           @map("broker_id")
  broker             User?             @relation(fields: [brokerId], references: [id], onDelete: SetNull)
  dealId             String?           @map("deal_id")
  listingId          String?           @map("listing_id")
  metadata           Json?
  createdAt          DateTime          @default(now()) @map("created_at")

  @@index([platformPaymentId])
  @@index([party])
  @@index([brokerId])
  @@index([category])
  @@map("party_revenue_ledger_entries")
}

// Stripe financial sync — ledger per webhook event (idempotent by stripe_event_id)
model StripeLedgerEntry {
  id                String           @id @default(uuid())
  stripeEventId     String           @unique @map("stripe_event_id")
  objectType        String           @map("object_type") // checkout_session | charge | refund | payment_intent
  stripeObjectId    String           @map("stripe_object_id")
  amountCents       Int              @map("amount_cents")
  feeCents          Int              @default(0) @map("fee_cents")
  currency          String           @default("cad")
  status            String
  userId            String?          @map("user_id")
  platformPaymentId String?          @map("platform_payment_id")
  metadata          Json?
  createdAt         DateTime         @default(now()) @map("created_at")
  user              User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  platformPayment   PlatformPayment? @relation(fields: [platformPaymentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([platformPaymentId])
  @@index([createdAt])
  @@map("stripe_ledger_entries")
}

// Accountant / admin financial audit trail
model FinancialAuditLog {
  id          String   @id @default(uuid())
  actorUserId String   @map("actor_user_id")
  actor       User     @relation(fields: [actorUserId], references: [id], onDelete: Cascade)
  action      String // finance_overview_view | finance_export_csv | finance_export_pdf | tax_doc_generate | stripe_ledger_sync
  entityType  String?  @map("entity_type")
  entityId    String?  @map("entity_id")
  ipAddress   String?  @map("ip_address")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([actorUserId])
  @@index([createdAt])
  @@map("financial_audit_logs")
}

// Tax / accounting documents (invoices, receipts, slips, summaries — data for PDF/CSV export)
model TaxDocument {
  id                String    @id @default(uuid())
  documentType      String    @map("document_type") // INVOICE | RECEIPT | COMMISSION_REPORT | TAX_SUMMARY | ANNUAL_EARNINGS_SUMMARY | BROKER_COMMISSION_SUMMARY | BROKER_PAYOUT_SUMMARY | PLATFORM_REVENUE_SUMMARY | MONTHLY_PLATFORM_REPORT
  title             String
  periodYear        Int?      @map("period_year")
  periodMonth       Int?      @map("period_month")
  subjectUserId     String?   @map("subject_user_id")
  dealId            String?
  platformPaymentId String?   @map("platform_payment_id")
  summaryMarkdown   String?   @map("summary_markdown") @db.Text
  status            String    @default("active") // active | void — internal workflow only
  issueDate         DateTime? @map("issue_date")
  generatedByUserId String    @map("generated_by_user_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  subjectUser       User?     @relation("TaxDocumentSubject", fields: [subjectUserId], references: [id], onDelete: SetNull)
  generatedBy       User      @relation("TaxDocumentGeneratedBy", fields: [generatedByUserId], references: [id])

  @@index([subjectUserId])
  @@index([documentType])
  @@index([periodYear])
  @@index([status])
  @@map("tax_documents")
}

// ---------------------------------------------------------------------------
// BNHub: Reviews (property + host)
// ---------------------------------------------------------------------------
/// Guest reviews stay + host (`reviewerType` = GUEST implicitly; see `BnhubHostReviewOfGuest` for host → guest).
model Review {
  id                    String                   @id @default(uuid())
  propertyRating        Int // 1-5 overall
  hostRating            Int? // 1-5 optional
  cleanlinessRating     Int? // 1-5 BNHub category
  accuracyRating        Int?                     @map("accuracy_rating")
  communicationRating   Int? // 1-5
  locationRating        Int? // 1-5
  valueRating           Int? // 1-5
  checkinRating         Int?                     @map("check_in_rating")
  comment               String?
  /// Guest post-stay checklist (kitchen, beds, amenities accurate, etc.)
  stayChecklistJson     Json?                    @map("stay_checklist_json")
  /// Whether advertised amenities matched reality (guest attestation).
  amenitiesAsAdvertised Boolean?                 @map("amenities_as_advertised")
  /// AI-assisted composite 0–100 for reputation / monthly medians.
  aiCompositeScore      Float?                   @map("ai_composite_score")
  aiSummary             String?                  @map("ai_summary") @db.Text
  /// When true, review is hidden from public until moderation clears.
  moderationHeld        Boolean                  @default(false) @map("moderation_held")
  /// Heuristic 0–1; higher = more spam-like (optional moderation queue).
  spamScore             Float?                   @map("spam_score")
  createdAt             DateTime
  updatedAt             DateTime                 @updatedAt
  guestId               String
  guest                 User                     @relation(fields: [guestId], references: [id], onDelete: Cascade)
  listingId             String
  listing               ShortTermListing         @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bookingId             String                   @unique
  booking               Booking                  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bnhubModeration       BnhubReviewModeration?
  bnhubAbuseReports     BnhubReviewAbuseReport[]

  @@index([listingId])
  @@index([guestId])
}

/// Host → guest post-stay evaluation (`reviewerType` = HOST implicitly). One row per `bookingId`.
model BnhubHostReviewOfGuest {
  id                       String           @id @default(uuid())
  bookingId                String           @unique @map("booking_id")
  booking                  Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  hostId                   String           @map("host_id")
  host                     User             @relation("BnhubHostReviewAuthor", fields: [hostId], references: [id], onDelete: Cascade)
  guestId                  String           @map("guest_id")
  guest                    User             @relation("BnhubHostReviewSubjectGuest", fields: [guestId], references: [id], onDelete: Cascade)
  listingId                String           @map("listing_id")
  listing                  ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  guestRespectRating       Int              @map("guest_respect_rating")
  propertyCareRating       Int?             @map("property_care_rating")
  checkoutComplianceRating Int?             @map("checkout_compliance_rating")
  quietHoursRespected      Boolean?         @map("quiet_hours_respected")
  houseRulesRespected      Boolean?         @map("house_rules_respected")
  theftOrDamageReported    Boolean          @default(false) @map("theft_or_damage_reported")
  incidentDetails          String?          @map("incident_details") @db.Text
  hostNotes                String?          @map("host_notes") @db.Text
  hostChecklistJson        Json?            @map("host_checklist_json")
  aiCompositeScore         Float?           @map("ai_composite_score")
  aiSummary                String?          @map("ai_summary") @db.Text
  createdAt                DateTime         @default(now()) @map("created_at")
  updatedAt                DateTime         @updatedAt @map("updated_at")

  @@index([guestId])
  @@index([hostId])
  @@index([listingId])
  @@map("bnhub_host_reviews_of_guest")
}

/// Monthly median AI-assisted scores + top-performer flags (rewards, listing boost).
model BnhubMonthlyReputationSnapshot {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodYearMonth String   @map("period_year_month") @db.VarChar(7)
  role            String   @map("role") @db.VarChar(16)
  city            String   @default("") @map("city") @db.VarChar(128)
  medianScore     Float    @map("median_score")
  sampleCount     Int      @map("sample_count")
  rankInScope     Int?     @map("rank_in_scope")
  topPerformer    Boolean  @default(false) @map("top_performer")
  perksJson       Json?    @map("perks_json")
  computedAt      DateTime @default(now()) @map("computed_at")

  @@unique([userId, periodYearMonth, role, city])
  @@index([periodYearMonth, role, topPerformer])
  @@map("bnhub_monthly_reputation_snapshots")
}

/// Denormalized guest-review aggregates per BNHub listing (ShortTermListing).
model PropertyRatingAggregate {
  id               String           @id @default(cuid())
  listingId        String           @unique @map("listing_id")
  listing          ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  avgRating        Float            @map("avg_rating")
  totalReviews     Int              @map("total_reviews")
  cleanlinessAvg   Float            @map("cleanliness_avg")
  accuracyAvg      Float            @map("accuracy_avg")
  communicationAvg Float            @map("communication_avg")
  locationAvg      Float            @map("location_avg")
  valueAvg         Float            @map("value_avg")
  checkinAvg       Float            @map("checkin_avg")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@map("property_rating_aggregates")
}

/// BNHub host operational + reputation score (0–100), recomputed from bookings + reviews.
model HostPerformance {
  id               String   @id @default(cuid())
  hostId           String   @unique @map("host_id")
  host             User     @relation(fields: [hostId], references: [id], onDelete: Cascade)
  responseRate     Float    @map("response_rate")
  avgResponseTime  Float    @map("avg_response_time")
  cancellationRate Float    @map("cancellation_rate")
  completionRate   Float    @map("completion_rate")
  disputeRate      Float    @map("dispute_rate")
  score            Float
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("host_performance")
}

model HostBadge {
  id         String   @id @default(cuid())
  hostId     String   @map("host_id")
  host       User     @relation("BnhubHostTrustBadges", fields: [hostId], references: [id], onDelete: Cascade)
  badgeType  String   @map("badge_type") @db.VarChar(48)
  assignedAt DateTime @default(now()) @map("assigned_at")

  @@unique([hostId, badgeType])
  @@index([hostId])
  @@map("host_badges")
}

// ---------------------------------------------------------------------------
// LECIPM + BNHub: explainable listing ranking (scores, configs, telemetry)
// listingId = canonical PK string (UUID/cuid) for ShortTermListing / FsboListing
// ---------------------------------------------------------------------------
model ListingRankingScore {
  id                        String    @id @default(cuid())
  listingType               String    @map("listing_type") @db.VarChar(32)
  listingId                 String    @map("listing_id") @db.VarChar(40)
  city                      String?   @db.VarChar(128)
  neighborhood              String?   @db.VarChar(128)
  totalScore                Float     @map("total_score")
  relevanceScore            Float     @map("relevance_score")
  trustScore                Float     @map("trust_score")
  qualityScore              Float     @map("quality_score")
  engagementScore           Float     @map("engagement_score")
  conversionScore           Float     @map("conversion_score")
  freshnessScore            Float     @map("freshness_score")
  hostScore                 Float?    @map("host_score")
  reviewScore               Float?    @map("review_score")
  priceCompetitivenessScore Float?    @map("price_competitiveness_score")
  availabilityScore         Float?    @map("availability_score")
  metadataJson              Json?     @map("metadata_json")
  /// Human-readable band for internal dashboards / optional UI (elite | good | average | weak).
  performanceBand           String?   @map("performance_band") @db.VarChar(32)
  /// Same as `computedAt` on write; reserved for explicit last-calculation semantics in jobs.
  rankingLastCalculatedAt   DateTime? @map("ranking_last_calculated_at")
  computedAt                DateTime  @default(now()) @map("computed_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  @@unique([listingType, listingId])
  @@index([listingType, city])
  @@index([listingType, totalScore])
  @@index([city, neighborhood])
  @@map("listing_ranking_scores")
}

model RankingConfig {
  id          String   @id @default(cuid())
  configKey   String   @unique @map("config_key")
  listingType String   @map("listing_type") @db.VarChar(32)
  weightsJson Json     @map("weights_json")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([listingType, isActive])
  @@map("ranking_configs")
}

model RankingImpressionLog {
  id          String   @id @default(cuid())
  listingType String   @map("listing_type") @db.VarChar(32)
  listingId   String   @map("listing_id") @db.VarChar(40)
  pageType    String?  @map("page_type") @db.VarChar(32)
  position    Int?
  city        String?  @db.VarChar(128)
  userId      String?  @map("user_id")
  sessionId   String?  @map("session_id") @db.VarChar(64)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([listingType, listingId])
  @@index([pageType, createdAt])
  @@index([city, createdAt])
  @@map("ranking_impression_logs")
}

model RankingClickLog {
  id          String   @id @default(cuid())
  listingType String   @map("listing_type") @db.VarChar(32)
  listingId   String   @map("listing_id") @db.VarChar(40)
  pageType    String?  @map("page_type") @db.VarChar(32)
  position    Int?
  userId      String?  @map("user_id")
  sessionId   String?  @map("session_id") @db.VarChar(64)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([listingType, listingId])
  @@index([pageType, createdAt])
  @@map("ranking_click_logs")
}

/// Append-only marketplace ranking computation rows (explainable breakdown + context hash for replay).
model ListingRankScore {
  id                 String   @id @default(cuid())
  listingId          String   @map("listing_id") @db.VarChar(64)
  listingType        String   @default("bnhub") @map("listing_type") @db.VarChar(16)
  totalScore         Float    @map("total_score")
  breakdownJson      Json     @map("breakdown_json")
  rankingContextHash String   @map("ranking_context_hash") @db.VarChar(64)
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([listingId, createdAt(sort: Desc)])
  @@index([rankingContextHash, createdAt(sort: Desc)])
  @@map("listing_rank_scores")
}

// ---------------------------------------------------------------------------
// LECIPM Core Engine v1 — autopilot runs, actions, rule logs (server-side; audit-friendly)
// ---------------------------------------------------------------------------
enum LecipmCoreAutopilotMode {
  OFF
  ASSIST
  SAFE_AUTOPILOT
  FULL_AUTOPILOT_APPROVAL
}

enum LecipmCoreAutopilotActionStatus {
  pending
  approved
  executed
  skipped
  dismissed
}

model LecipmCoreAutopilotRun {
  id          String                       @id @default(cuid())
  eventType   String                       @map("event_type") @db.VarChar(64)
  targetType  String?                      @map("target_type") @db.VarChar(32)
  targetId    String?                      @map("target_id") @db.VarChar(40)
  mode        LecipmCoreAutopilotMode      @map("mode")
  summaryJson Json                         @default("{}") @map("summary_json")
  createdAt   DateTime                     @default(now()) @map("created_at")
  actions     LecipmCoreAutopilotAction[]
  ruleLogs    LecipmCoreAutopilotRuleLog[]

  @@index([eventType, createdAt])
  @@index([targetType, targetId])
  @@map("lecipm_core_autopilot_runs")
}

model LecipmCoreAutopilotAction {
  id               String                          @id @default(cuid())
  runId            String?                         @map("run_id")
  run              LecipmCoreAutopilotRun?         @relation(fields: [runId], references: [id], onDelete: SetNull)
  type             String                          @db.VarChar(64)
  domain           String                          @db.VarChar(32)
  severity         String                          @db.VarChar(16)
  riskLevel        String                          @map("risk_level") @db.VarChar(16)
  targetType       String                          @map("target_type") @db.VarChar(32)
  targetId         String                          @map("target_id") @db.VarChar(40)
  title            String
  description      String                          @db.Text
  payloadJson      Json                            @default("{}") @map("payload_json")
  suggestedBy      String                          @default("lecipm_core_autopilot_v1") @map("suggested_by") @db.VarChar(64)
  status           LecipmCoreAutopilotActionStatus @default(pending)
  requiresApproval Boolean                         @default(true) @map("requires_approval")
  executedAt       DateTime?                       @map("executed_at")
  createdAt        DateTime                        @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@index([domain, type])
  @@index([targetType, targetId])
  @@map("lecipm_core_autopilot_actions")
}

model LecipmCoreAutopilotRuleLog {
  id         String                 @id @default(cuid())
  runId      String                 @map("run_id")
  run        LecipmCoreAutopilotRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  ruleKey    String                 @map("rule_key") @db.VarChar(128)
  matched    Boolean
  detailJson Json?                  @map("detail_json")
  createdAt  DateTime               @default(now()) @map("created_at")

  @@index([runId])
  @@map("lecipm_core_autopilot_rule_logs")
}

// ---------------------------------------------------------------------------
// Intelligence layer v2 — auditable events, explainable autopilot, outcomes (no fake ML)
// ---------------------------------------------------------------------------

enum AutopilotV2SuggestionStatus {
  pending
  accepted
  rejected
  auto_applied

  @@map("autopilot_v2_suggestion_status")
}

/// Canonical product events for autopilot / liquidity / analytics (server-emitted).
model PlatformIntelligenceEvent {
  id        String   @id @default(cuid())
  type      String   @db.VarChar(80)
  userId    String?  @map("user_id")
  user      User?    @relation("PlatformIntelligenceEvents", fields: [userId], references: [id], onDelete: SetNull)
  listingId String?  @map("listing_id") @db.VarChar(64)
  payload   Json     @default("{}") @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([type, createdAt])
  @@index([userId, createdAt])
  @@index([listingId, createdAt])
  @@map("platform_intelligence_events")
}

/// Unified product analytics — ranking, recommendations, experiments, conversion funnels (server-emitted).
model EventLog {
  id         String   @id @default(cuid())
  eventType  String   @map("event_type") @db.VarChar(80)
  userId     String?  @map("user_id")
  user       User?    @relation("UserEventLogs", fields: [userId], references: [id], onDelete: SetNull)
  sessionId  String?  @map("session_id") @db.VarChar(128)
  listingId  String?  @map("listing_id") @db.VarChar(64)
  entityType String?  @map("entity_type") @db.VarChar(64)
  entityId   String?  @map("entity_id") @db.VarChar(64)
  metadata   Json     @default("{}") @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([eventType, createdAt])
  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@index([listingId, createdAt])
  @@map("event_logs")
}

/// Explainable autopilot suggestions (v2) — distinct from `LecipmCoreAutopilotAction` rows.
model AutopilotV2Suggestion {
  id              String                      @id @default(cuid())
  listingId       String                      @map("listing_id") @db.VarChar(64)
  listing         FsboListing                 @relation(fields: [listingId], references: [id], onDelete: Cascade)
  type            String                      @db.VarChar(64)
  payload         Json                        @default("{}") @db.JsonB
  confidence      Float
  impactEstimate  Float                       @map("impact_estimate")
  status          AutopilotV2SuggestionStatus @default(pending)
  explanation     Json                        @default("[]") @db.JsonB
  suggestedChange Json?                       @map("suggested_change") @db.JsonB
  autoApplicable  Boolean                     @default(false) @map("auto_applicable")
  trigger         String?                     @db.VarChar(64)
  createdAt       DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  outcomes        AutopilotV2Outcome[]

  @@index([listingId, status])
  @@index([type, createdAt])
  @@map("autopilot_v2_suggestions")
}

model AutopilotV2Outcome {
  id            String                @id @default(cuid())
  suggestionId  String                @map("suggestion_id")
  suggestion    AutopilotV2Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  beforeMetrics Json                  @map("before_metrics") @db.JsonB
  afterMetrics  Json                  @map("after_metrics") @db.JsonB
  delta         Float
  successScore  Float                 @map("success_score")
  patternKey    String?               @map("pattern_key") @db.VarChar(128)
  createdAt     DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([suggestionId])
  @@index([createdAt])
  @@map("autopilot_v2_outcomes")
}

/// Host economics ROI runs (optional persistence for analytics — not billing truth).
model RoiCalculation {
  id        String    @id @default(cuid())
  userId    String?   @map("user_id")
  user      User?     @relation("RoiCalculations", fields: [userId], references: [id], onDelete: SetNull)
  leadId    String?   @map("lead_id")
  lead      HostLead? @relation("RoiCalculationsLead", fields: [leadId], references: [id], onDelete: SetNull)
  listingId String?   @map("listing_id") @db.VarChar(64)
  input     Json      @default("{}") @db.JsonB
  output    Json      @default("{}") @db.JsonB
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId, createdAt])
  @@index([leadId, createdAt])
  @@map("roi_calculations")
}

/// Host acquisition funnel — LECIPM/BNHub switchers (distinct from `ListingAcquisitionLead` CRM pipeline).
model HostLead {
  id                    String   @id @default(cuid())
  name                  String?
  email                 String?
  phone                 String?
  source                String   @default("host_landing") @db.VarChar(64)
  sourceDetail          String?  @map("source_detail") @db.VarChar(256)
  funnelStatus          String   @default("visitor") @map("funnel_status") @db.VarChar(48)
  city                  String?  @db.VarChar(128)
  propertyType          String?  @map("property_type") @db.VarChar(64)
  listingUrl            String?  @map("listing_url") @db.Text
  estimatedRevenueCents Int?     @map("estimated_revenue_cents")
  metadata              Json     @default("{}") @db.JsonB
  userId                String?  @map("user_id")
  user                  User?    @relation("HostConversionLeads", fields: [userId], references: [id], onDelete: SetNull)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  onboardingSessions HostOnboardingSession[]
  listingImports     HostListingImport[]
  outreachLogs       HostLeadOutreachLog[]
  roiCalculations    RoiCalculation[]         @relation("RoiCalculationsLead")
  pricingSnapshots   PricingInsightSnapshot[]

  @@index([email])
  @@index([funnelStatus, createdAt])
  @@index([source, createdAt])
  @@map("host_leads")
}

model HostOnboardingSession {
  id        String    @id @default(cuid())
  leadId    String?   @map("lead_id")
  lead      HostLead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
  userId    String?   @map("user_id")
  user      User?     @relation("HostOnboardingSessions", fields: [userId], references: [id], onDelete: SetNull)
  status    String    @default("active") @db.VarChar(32)
  stepKey   String    @default("property_basics") @map("step_key") @db.VarChar(64)
  data      Json      @default("{}") @db.JsonB
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([leadId])
  @@index([userId, updatedAt])
  @@map("host_onboarding_sessions")
}

model HostListingImport {
  id             String    @id @default(cuid())
  leadId         String?   @map("lead_id")
  lead           HostLead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
  userId         String?   @map("user_id")
  user           User?     @relation("HostListingImports", fields: [userId], references: [id], onDelete: SetNull)
  sourcePlatform String    @map("source_platform") @db.VarChar(64)
  sourceUrl      String    @map("source_url") @db.Text
  status         String    @default("pending") @db.VarChar(32)
  parsedData     Json?     @map("parsed_data") @db.JsonB
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([leadId])
  @@index([status, createdAt])
  @@map("host_listing_imports")
}

model HostLeadOutreachLog {
  id        String   @id @default(cuid())
  leadId    String   @map("lead_id")
  lead      HostLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  channel   String   @db.VarChar(32)
  message   String   @db.Text
  status    String   @default("logged") @db.VarChar(32)
  response  String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([leadId, createdAt])
  @@map("host_lead_outreach_logs")
}

/// Server-side pricing v2 snapshot (analytics / sales — not auto-applied to listings).
model PricingInsightSnapshot {
  id        String       @id @default(cuid())
  listingId String?      @map("listing_id")
  listing   FsboListing? @relation("FsboPricingInsights", fields: [listingId], references: [id], onDelete: SetNull)
  leadId    String?      @map("lead_id")
  lead      HostLead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  input     Json         @default("{}") @db.JsonB
  output    Json         @default("{}") @db.JsonB
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([listingId, createdAt])
  @@index([leadId, createdAt])
  @@map("pricing_insight_snapshots")
}

/// Internal launch / market scenarios (planning only — not public market data).
model LaunchSimulation {
  id           String   @id @default(cuid())
  marketKey    String   @map("market_key") @db.VarChar(64)
  scenarioName String   @map("scenario_name") @db.VarChar(128)
  input        Json     @default("{}") @db.JsonB
  output       Json     @default("{}") @db.JsonB
  createdById  String?  @map("created_by_id")
  createdBy    User?    @relation("LaunchSimulationsCreated", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([marketKey, createdAt])
  @@map("launch_simulations")
}

// ---------------------------------------------------------------------------
// Growth Engine v1 — opportunity candidates (no blind outbound; admin/campaign layer applies later)
// ---------------------------------------------------------------------------
model GrowthOpportunityCandidate {
  id           String    @id @default(cuid())
  type         String    @db.VarChar(64)
  targetType   String    @map("target_type") @db.VarChar(32)
  targetId     String    @map("target_id") @db.VarChar(40)
  score        Float     @default(0)
