  severity   String
  /// missing_field | wrong_form | annex_missing | language_issue | clause_risk | inconsistency
  alertType  String         @map("alert_type")
  title      String
  body       String         @db.Text
  sourceType String?        @map("source_type")
  sourceRef  String?        @map("source_ref")
  createdAt  DateTime       @default(now()) @map("created_at")

  @@index([draftId])
  @@index([severity])
