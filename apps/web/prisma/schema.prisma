  sessionId      String?        @map("session_id") @db.VarChar(64)
  createdAt      DateTime       @default(now()) @map("created_at")

  @@index([dealId, createdAt])
  @@index([createdAt])
  @@index([referrerUserId])
  @@map("shared_deal_visits")
