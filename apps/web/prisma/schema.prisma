  disclosure   LecipmRiskDisclosure @relation(fields: [disclosureId], references: [id], onDelete: Cascade)
  acceptedAt   DateTime             @default(now()) @map("accepted_at")

  @@unique([userId, disclosureId])
  @@index([userId])
  @@map("lecipm_user_risk_disclosure_acceptances")
}

/// Admin team — delegated work tracking (LECIPM / BNHUB operations).
enum TeamTaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TeamTaskPriority {
  LOW
  NORMAL
  HIGH
}

model TeamTask {
  id              String           @id @default(cuid())
  title           String           @map("title") @db.VarChar(512)
  description     String?          @map("description") @db.Text
  status          TeamTaskStatus   @default(PENDING) @map("status")
  priority        TeamTaskPriority @default(NORMAL) @map("priority")
  assigneeUserId  String           @map("assignee_user_id")
  assignee        User             @relation("TeamTaskAssignee", fields: [assigneeUserId], references: [id], onDelete: Cascade)
  createdByUserId String           @map("created_by_user_id")
  createdBy       User             @relation("TeamTaskCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  dueAt           DateTime?        @map("due_at")
  startedAt       DateTime?        @map("started_at")
  completedAt     DateTime?        @map("completed_at")
  /// 1–5 impact rating when task is completed (optional).
  impactScore     Int?             @map("impact_score")
  resultNotes     String?          @map("result_notes") @db.Text
  metadata        Json?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@index([assigneeUserId, status])
  @@index([status, createdAt])
  @@map("team_tasks")
}

model TeamDailyReport {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// UTC calendar day `YYYY-MM-DD`.
  reportDay     String   @map("report_day") @db.VarChar(10)
  completedWork String   @map("completed_work") @db.Text
  results       String?  @map("results") @db.Text
  issues        String?  @map("issues") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([userId, reportDay])
  @@index([reportDay])
  @@map("team_daily_reports")
}

model TeamDailyTarget {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation("TeamDailyTargetUser", fields: [userId], references: [id], onDelete: Cascade)
  /// UTC calendar day `YYYY-MM-DD`.
  targetDay   String   @map("target_day") @db.VarChar(10)
  taskGoal    Int      @default(5) @map("task_goal")
  notes       String?  @map("notes") @db.Text
  createdById String?  @map("created_by_id")
  createdBy   User?    @relation("TeamDailyTargetCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([userId, targetDay])
  @@map("team_daily_targets")
}

/// LECIPM + BNHub unified event bus for autonomous workflows (audit + rule dispatch).
enum PlatformAutonomyEventType {
  LISTING_CREATED
  LISTING_UPDATED
  BOOKING_CREATED
  BOOKING_ABANDONED
  USER_ACTIVITY
}

model PlatformAutonomyEvent {
  id              String                    @id @default(cuid())
  eventType       PlatformAutonomyEventType @map("event_type")
  entityType      String?                   @map("entity_type") @db.VarChar(64)
  entityId        String?                   @map("entity_id") @db.VarChar(64)
  userId          String?                   @map("user_id")
  payload         Json?
  dedupeKey       String?                   @unique @map("dedupe_key")
  processedAt     DateTime?                 @map("processed_at")
  processingError String?                   @map("processing_error") @db.Text
  createdAt       DateTime                  @default(now()) @map("created_at")

  @@index([eventType, createdAt])
  @@index([processedAt])
  @@map("platform_autonomy_events")
}

/// Admin-configurable trigger → action (processed by `lib/autonomy/rule-dispatcher`).
model PlatformAutomationRule {
  id            String                    @id @default(cuid())
  name          String                    @unique @map("name")
  enabled       Boolean                   @default(true)
  eventType     PlatformAutonomyEventType @map("event_type")
  conditionJson Json?                     @map("condition_json")
  /// e.g. notify_admin | log_only | trigger_automation | queue_listing_content
  actionKind    String                    @map("action_kind") @db.VarChar(64)
  actionPayload Json?                     @map("action_payload")
  priority      Int                       @default(0) @map("priority")
  createdAt     DateTime                  @default(now()) @map("created_at")
  updatedAt     DateTime                  @updatedAt @map("updated_at")

  @@index([eventType, enabled])
  @@map("platform_automation_rules")
}

enum LoyaltyTier {
  NONE
  BRONZE
  SILVER
  GOLD
}

/// BNHub guest loyalty — simple tier + counters (no points).
model UserLoyaltyProfile {
  id                String      @id @default(cuid())
  userId            String      @unique @map("user_id")
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalBookings     Int         @default(0) @map("total_bookings")
  completedBookings Int         @default(0) @map("completed_bookings")
  lastBookingAt     DateTime?   @map("last_booking_at")
  tier              LoyaltyTier @default(NONE)
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  @@map("user_loyalty_profiles")
}

/// One row per paid booking — idempotent loyalty credit + audit log.
model LoyaltyRewardEvent {
  id                     String      @id @default(cuid())
  userId                 String      @map("user_id")
  user                   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookingId              String      @unique @map("booking_id")
  tierBefore             LoyaltyTier @map("tier_before")
  tierAfter              LoyaltyTier @map("tier_after")
  discountPercentApplied Float?      @map("discount_percent_applied")
  createdAt              DateTime    @default(now()) @map("created_at")

  @@index([userId])
  @@map("loyalty_reward_events")
}

/// Server-side auth session (`lecipm_guest_id` cookie value = opaque `token`).
model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("Session")
}

/// LECIPM AI Operator — explainable suggested actions; execution only per policy + approval.
enum LecipmAiOperatorActionStatus {
  pending
  suggested
  approved
  executed
  failed
  rejected
}

model LecipmAiOperatorAction {
  id                   String                       @id @default(cuid())
  userId               String                       @map("user_id")
  user                 User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId          String?                      @map("workspace_id") @db.Uuid
  workspace            EnterpriseWorkspace?         @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  type                 String
  context              String
  payload              Json
  status               LecipmAiOperatorActionStatus @default(suggested)
  confidenceScore      Float                        @map("confidence_score")
  title                String
  description          String                       @db.Text
  reason               String                       @db.Text
  dataUsedSummary      String?                      @map("data_used_summary") @db.Text
  expectedOutcome      String?                      @map("expected_outcome") @db.Text
  suggestedExecution   Json?                        @map("suggested_execution")
  resultLog            Json?                        @map("result_log")
  editedPayload        Json?                        @map("edited_payload")
  autonomyModeAtCreate String?                      @map("autonomy_mode_at_create")
  outcomeNotes         String?                      @map("outcome_notes") @db.Text
  createdAt            DateTime                     @default(now()) @map("created_at")
  updatedAt            DateTime                     @updatedAt @map("updated_at")

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([context])
  @@index([workspaceId])
  @@map("ai_actions")
}

model LecipmAiOperatorSettings {
  userId       String   @id @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
