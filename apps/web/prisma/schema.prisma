// ---------------------------------------------------------------------------
// Legal Hub Phase 2 — user submission documents (distinct from CMS `LegalDocument`).
// Explicit human review only.
// ---------------------------------------------------------------------------

model LegalHubSubmissionDocument {
  id                   String                   @id @default(cuid())
  userId               String?                  @map("user_id")
  user                 User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  actorType            String                   @map("actor_type")
  workflowType         String                   @map("workflow_type")
  requirementId        String                   @map("requirement_id")
  workflowSubmissionId String?                  @map("workflow_submission_id")
  workflowSubmission   LegalWorkflowSubmission? @relation(fields: [workflowSubmissionId], references: [id], onDelete: SetNull)
  /// Bucket-relative storage path or `local:…` fallback — not a public URL by default.
  fileUrl              String                   @map("file_url") @db.Text
  fileName             String                   @map("file_name")
  fileType             String                   @map("file_type")
  /// uploaded | submitted | approved | rejected
  status               String                   @map("status")
  uploadedAt           DateTime                 @default(now()) @map("uploaded_at")
  submittedAt          DateTime?                @map("submitted_at")
  reviewedAt           DateTime?                @map("reviewed_at")
  reviewedBy           String?                  @map("reviewed_by")
  rejectionReason      String?                  @map("rejection_reason") @db.Text
  createdAt            DateTime                 @default(now()) @map("created_at")
  updatedAt            DateTime                 @updatedAt @map("updated_at")

  @@index([userId])
  @@index([workflowType, userId])
  @@index([status])
  @@index([workflowSubmissionId])
  @@map("legal_hub_submission_documents")
}

model LegalWorkflowSubmission {
  id           String                       @id @default(cuid())
  userId       String?                      @map("user_id")
  user         User?                        @relation(fields: [userId], references: [id], onDelete: SetNull)
  actorType    String                       @map("actor_type")
  workflowType String                       @map("workflow_type")
