  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  decisions        FraudDecision[]

  @@index([entityType])
  @@index([entityId])
  @@index([status])
  @@index([riskLevel])
  @@map("fraud_cases")
}

model FraudDecision {
  id              String          @id @default(uuid()) @db.Uuid
