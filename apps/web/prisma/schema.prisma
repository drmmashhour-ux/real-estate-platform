/// Internal LECIPM calibration — compare engine outputs vs human judgment (admin only).
enum ModelValidationRunStatus {
  draft
  in_progress
  completed
  archived
}

enum ModelValidationRunKind {
  baseline
  tuned_same_set
  tuned_fresh_set
}

model ModelValidationRun {
  id                     String                   @id @default(cuid())
  name                   String?
  description            String?                  @db.Text
  status                 ModelValidationRunStatus @default(draft)
  /**
   * Round-2 workflow: baseline vs tuned same-50 vs tuned fresh-50
   */
  validationRunKind      ModelValidationRunKind   @default(baseline) @map("validation_run_kind")
  appliedTuningProfileId String?                  @map("applied_tuning_profile_id")
  appliedTuningProfile   TuningProfile?           @relation(fields: [appliedTuningProfileId], references: [id], onDelete: SetNull)
  /**
   * Run this result is compared against (usually baseline).
   */
  comparisonTargetRunId  String?                  @map("comparison_target_run_id")
  comparisonTargetRun    ModelValidationRun?      @relation("ValidationRunComparisonTarget", fields: [comparisonTargetRunId], references: [id], onDelete: SetNull)
  comparisonChildren     ModelValidationRun[]     @relation("ValidationRunComparisonTarget")

  createdBy   String?               @map("created_by")
  createdAt   DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt DateTime?             @map("completed_at") @db.Timestamptz(6)
  items       ModelValidationItem[]

  runComparisonsAsBase ValidationRunComparison[] @relation("ValidationRunComparisonBase")
  runComparisonsAsPeer ValidationRunComparison[] @relation("ValidationRunComparisonPeer")

  @@index([createdAt])
  @@index([status])
  @@index([validationRunKind])
  @@index([comparisonTargetRunId])
  @@index([appliedTuningProfileId])
  @@map("model_validation_runs")
}

/// Stored metric deltas between two validation runs (admin / history).
model ValidationRunComparison {
  id              String             @id @default(cuid())
  baseRunId       String             @map("base_run_id")
  baseRun         ModelValidationRun @relation("ValidationRunComparisonBase", fields: [baseRunId], references: [id], onDelete: Cascade)
  comparisonRunId String             @map("comparison_run_id")
  comparisonRun   ModelValidationRun @relation("ValidationRunComparisonPeer", fields: [comparisonRunId], references: [id], onDelete: Cascade)
  metricsDelta    Json               @map("metrics_delta")
  summary         Json?
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([baseRunId, comparisonRunId], map: "uq_validation_run_comparison_pair")
  @@index([baseRunId])
  @@index([comparisonRunId])
  @@map("validation_run_comparisons")
}

