  @@index([entityType, entityId])
  @@index([marketId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// 7. Financial Defense – risk flags, intervention log
// ---------------------------------------------------------------------------
model FinancialRiskFlag {
  id          String    @id @default(uuid())
  entityType  String // PAYOUT | PAYMENT | REFUND | BOOKING
  entityId    String
  flagType    String // SUSPICIOUS_PAYOUT | REFUND_ABUSE | CHARGEBACK_RISK | ANOMALY
  severity    String // LOW | MEDIUM | HIGH
  status      String    @default("OPEN") // OPEN | UNDER_REVIEW | CLEARED | CONFIRMED
  amountCents Int?
  payload     Json?
  createdBy   String?
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime  @default(now())

  @@index([entityType, entityId])
  @@index([flagType])
  @@index([status])
}

// ---------------------------------------------------------------------------
// 8. Enforcement – actions, appeals
// ---------------------------------------------------------------------------
enum EnforcementActionType {
  WARNING
  TEMPORARY_RESTRICTION
  LISTING_FREEZE
  BOOKING_LIMITATION
  PAYOUT_HOLD
  ACCOUNT_SUSPENSION
  PERMANENT_BAN
  MARKET_SPECIFIC
}

model EnforcementAction {
  id          String                @id @default(uuid())
  userId      String
  actionType  EnforcementActionType
  severity    String // LOW | MEDIUM | HIGH | CRITICAL
  reasonCode  String
  reasonText  String?
  marketId    String?
  effectiveAt DateTime              @default(now())
  expiresAt   DateTime?
  performedBy String?
  appealId    String?
  metadata    Json?
  createdAt   DateTime              @default(now())

  @@index([userId])
  @@index([actionType])
  @@index([effectiveAt])
  @@index([reasonCode])
}

enum AppealStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  WITHDRAWN
}

model Appeal {
  id            String       @id @default(uuid())
  enforcementId String?
  userId        String
  reasonCode    String?
  description   String
  status        AppealStatus
  submittedAt   DateTime     @default(now())
  reviewedBy    String?
  reviewedAt    DateTime?
  outcomeNotes  String?
  createdAt     DateTime
  updatedAt     DateTime     @updatedAt

  @@index([userId])
  @@index([status])
  @@index([submittedAt])
}

// ---------------------------------------------------------------------------
// Trust & Safety Engine – incidents, evidence, actions, profiles, appeals
// ---------------------------------------------------------------------------
enum TrustSafetyIncidentStatus {
  SUBMITTED
  UNDER_REVIEW
  WAITING_RESPONSE
  ESCALATED
  RESOLVED
  CLOSED
}

enum TrustSafetySeverity {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

enum TrustSafetyRiskLevel {
  LOW_RISK
  MEDIUM_RISK
  HIGH_RISK
  CRITICAL_RISK
}

model TrustSafetyIncident {
  id               String                        @id @default(uuid())
  reporterId       String                        @map("reporter_id")
  reporter         User                          @relation("IncidentReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  accusedUserId    String?                       @map("accused_user_id")
  accusedUser      User?                         @relation("IncidentAccused", fields: [accusedUserId], references: [id], onDelete: SetNull)
  listingId        String?                       @map("listing_id")
  listing          ShortTermListing?             @relation(fields: [listingId], references: [id], onDelete: SetNull)
  bookingId        String?                       @map("booking_id")
  booking          Booking?                      @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  incidentCategory String                        @map("incident_category")
  severityLevel    TrustSafetySeverity           @default(MEDIUM) @map("severity_level")
  riskScore        Float?                        @map("risk_score") // 0-1
  riskLevel        TrustSafetyRiskLevel?         @map("risk_level")
  status           TrustSafetyIncidentStatus     @default(SUBMITTED)
  urgencyLevel     String?                       @map("urgency_level") // normal | high | urgent | emergency
  description      String
  incidentTime     DateTime?
  createdAt        DateTime                      @default(now()) @map("created_at")
  updatedAt        DateTime                      @updatedAt @map("updated_at")
  resolvedAt       DateTime?                     @map("resolved_at")
  resolvedBy       String?                       @map("resolved_by")
  resolutionNotes  String?                       @map("resolution_notes")
  evidence         TrustSafetyEvidence[]
  actions          TrustSafetyAction[]
  appeals          TrustSafetyAppeal[]
  responses        TrustSafetyIncidentResponse[]

  @@index([reporterId])
  @@index([accusedUserId])
  @@index([listingId])
  @@index([bookingId])
  @@index([status])
  @@index([severityLevel])
  @@index([incidentCategory])
  @@index([createdAt])
  @@map("trust_safety_incidents")
}

model TrustSafetyEvidence {
  id         String              @id @default(uuid())
  incidentId String              @map("incident_id")
  incident   TrustSafetyIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  fileUrl    String              @map("file_url")
  fileType   String?             @map("file_type") // photo | video | screenshot | document
  label      String?
  uploadedBy String              @map("uploaded_by")
  createdAt  DateTime            @default(now()) @map("created_at")

  @@index([incidentId])
  @@map("trust_safety_evidence")
}

enum TrustSafetyActionType {
  WARNING
  LISTING_WARNING
  BOOKING_RESTRICTION
  PAYOUT_HOLD
  LISTING_FREEZE
  ACCOUNT_SUSPENSION
  PERMANENT_LISTING_REMOVAL
  PERMANENT_ACCOUNT_BAN
  REFUND
  ADDITIONAL_VERIFICATION_REQUIRED
  MANUAL_REVIEW_REQUIRED
}

model TrustSafetyAction {
  id         String                @id @default(uuid())
  incidentId String                @map("incident_id")
  incident   TrustSafetyIncident   @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  actionType TrustSafetyActionType @map("action_type")
  reasonCode String                @map("reason_code")
  notes      String?
  createdBy  String
  createdAt  DateTime              @default(now()) @map("created_at")
  metadata   Json?

  @@index([incidentId])
  @@index([actionType])
  @@map("trust_safety_actions")
}

model UserSafetyProfile {
  id                   String   @id @default(uuid())
  userId               String   @unique @map("user_id")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hostRiskScore        Float?   @map("host_risk_score") // 0-1
  guestRiskScore       Float?   @map("guest_risk_score") // 0-1
  warningCount         Int      @default(0) @map("warning_count")
  suspensionCount      Int      @default(0) @map("suspension_count")
  seriousIncidentCount Int      @default(0) @map("serious_incident_count")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("user_safety_profiles")
}

model ListingSafetyProfile {
  id                  String           @id @default(uuid())
  listingId           String           @unique @map("listing_id")
  listing             ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  safetyScore         Float?           @map("safety_score") // 0-1, higher = safer
  complaintCount      Int              @default(0) @map("complaint_count")
  unsafeIncidentCount Int              @default(0) @map("unsafe_incident_count")
  fraudIncidentCount  Int              @default(0) @map("fraud_incident_count")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  @@map("listing_safety_profiles")
}

enum TrustSafetyAppealStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  WITHDRAWN
}

model TrustSafetyAppeal {
  id             String                  @id @default(uuid())
  incidentId     String                  @map("incident_id")
  incident       TrustSafetyIncident     @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  actionId       String?                 @map("action_id") // TrustSafetyAction.id
  submittedBy    String                  @map("submitted_by")
  submitter      User                    @relation(fields: [submittedBy], references: [id], onDelete: Cascade)
  appealReason   String                  @map("appeal_reason")
  status         TrustSafetyAppealStatus @default(PENDING)
  reviewedBy     String?                 @map("reviewed_by")
  resolvedAt     DateTime?               @map("resolved_at")
  resolutionNote String?                 @map("resolution_note")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")

  @@index([incidentId])
  @@index([submittedBy])
  @@index([status])
  @@map("trust_safety_appeals")
}

model TrustSafetyIncidentResponse {
  id           String              @id @default(uuid())
  incidentId   String              @map("incident_id")
  incident     TrustSafetyIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  respondentId String              @map("respondent_id")
  body         String
  createdAt    DateTime

  @@index([incidentId])
  @@map("trust_safety_incident_responses")
}

// ---------------------------------------------------------------------------
// 9. Defense Analytics – metrics snapshots
// ---------------------------------------------------------------------------
model DefenseMetricsSnapshot {
  id                 String   @id @default(uuid())
  date               DateTime
  marketId           String?
  incidentCount      Int      @default(0)
  disputeCount       Int      @default(0)
  disputeRate        Float?
  fraudLossCents     Int      @default(0)
  abuseSignalsCount  Int      @default(0)
  suspensionCount    Int      @default(0)
  appealCount        Int      @default(0)
  appealApprovalRate Float?
  payoutHoldCount    Int      @default(0)
  complianceFailures Int      @default(0)
  data               Json? // extended breakdown
  createdAt          DateTime @default(now())

  @@index([date])
  @@index([marketId])
}

// ---------------------------------------------------------------------------
// Production-ready core models (PostgreSQL)
// User, DesignAsset, Invoice, Subscription exist above with extended fields.
// Listing and Lead added for CRM/listings/leads APIs.
// ---------------------------------------------------------------------------

/**
 * Platform-attributed contact origin (traceability / commission eligibility).
 */
enum LeadContactOrigin {
  IMMO_CONTACT
  PLATFORM_BROKER
  DIRECT
  /// Buyer Hub / marketplace inquiry (sale listing contact)
  BUYER
}

model Listing {
  id                 String                    @id @default(cuid())
  /**
   * Broker CRM listing public code (LST-XXXXXX or legacy LEC-#####).
   */
  listingCode        String                    @unique @map("listing_code")
  title              String
  price              Float
  ownerId            String?                   @map("owner_id")
  owner              User?                     @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  tenantId           String?                   @map("tenant_id")
  tenant             Tenant?                   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  commissionCategory ListingCommissionCategory @default(SALE) @map("commission_category")
  commissionRate     Float?                    @map("commission_rate")
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  brokerAccesses     BrokerListingAccess[]
  appointments       Appointment[]
  conversations      Conversation[]
  documentFolders    DocumentFolder[]
  documentFiles      DocumentFile[]
  dealFinancials     DealFinancial[]
  tenantInvoices     TenantInvoice[]
  /// Optional 1:1 — CRM listing created from safe intake (`ListingAcquisitionLead`).
  sourcedFromAcquisitionLead ListingAcquisitionLead? @relation("CrmListingFromAcquisition")

  @@index([ownerId])
  @@index([tenantId])
}

// Shared listings: multiple brokers can have access to the same listing
model BrokerListingAccess {
  id          String   @id @default(cuid())
  listingId   String   @map("listing_id")
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  brokerId    String   @map("broker_id")
  broker      User     @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  role        String   @default("viewer") // owner | collaborator | viewer
  grantedById String?  @map("granted_by_id")
  grantedBy   User?    @relation("GrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)
  grantedAt   DateTime @default(now()) @map("granted_at")

  @@unique([listingId, brokerId])
  @@index([brokerId])
  @@index([listingId])
  @@map("broker_listing_access")
}

model Lead {
  id                         String                      @id @default(cuid())
  name                       String
  email                      String
  phone                      String
  message                    String
  listingId                  String? // listing or project context
  /**
   * When inquiry originates from FSBO Buyer Hub — links to `FsboListing`.
   */
  fsboListingId              String?                     @map("fsbo_listing_id")
  fsboListing                FsboListing?                @relation("FsboBuyerLead", fields: [fsboListingId], references: [id], onDelete: SetNull)
  /**
   * BNHub short-term listing when the CRM lead is tied to a stay (distinct from broker CRM `listingId`).
   */
  shortTermListingId         String?                     @map("short_term_listing_id")
  bnhubStayForLead           ShortTermListing?           @relation("CrmLeadBnhubStay", fields: [shortTermListingId], references: [id], onDelete: SetNull)
  /**
   * Denormalized LEC code when lead is tied to a ShortTermListing.
   */
  listingCode                String?                     @map("listing_code")
  projectId                  String?
  status                     String
  /**
   * Combined / form + behavior AI score 0–100 (rule-based; not ML).
   */
  score                      Int
  /**
   * Traffic / marketing attribution (URL ?source= / UTM, or "direct").
   */
  source                     String?
  /**
   * Campaign name from ?campaign= or utm_campaign.
   */
  campaign                   String?
  /**
   * Medium from ?medium= or utm_medium (e.g. cpc, social).
   */
  medium                     String?
  /**
   * Capture channel: listing, contact, ai_chat, form, ad, referral, other, mortgage_inquiry
   */
  leadSource                 String?                     @map("lead_source")
  /**
   * Funnel label: mortgage | null for legacy CRM rows
   */
  leadType                   String?                     @map("lead_type")
  assignedExpertId           String?                     @map("assigned_expert_id")
  assignedExpert             MortgageExpert?             @relation(fields: [assignedExpertId], references: [id], onDelete: SetNull)
  /**
   * mortgage marketplace: open = unclaimed pool; null = normal flow
   */
  mortgageMarketplaceStatus  String?                     @map("mortgage_marketplace_status")
  /**
   * Mortgage form payload: amount, timeline, propertyType, etc.
   */
  mortgageInquiry            Json?                       @map("mortgage_inquiry")
  /**
   * Last known AI tier snapshot: hot | warm | cold
   */
  aiTier                     String?                     @map("ai_tier")
  /**
   * Linked platform user for behavior scoring when known.
   */
  userId                     String?                     @map("user_id")
  user                       User?                       @relation("LeadPlatformUser", fields: [userId], references: [id], onDelete: SetNull)
  /**
   * Structured explainability: { formReasons[], behaviorPoints, mergedScore }.
   */
  aiExplanation              Json?                       @map("ai_explanation")
  contactUnlockedAt          DateTime?                   @map("contact_unlocked_at")
  introducedByBrokerId       String?                     @map("introduced_by_broker_id")
  introducedByBroker         User?                       @relation("IntroducedBy", fields: [introducedByBrokerId], references: [id], onDelete: SetNull)
  lastFollowUpByBrokerId     String?                     @map("last_follow_up_by_broker_id")
  lastFollowUpByBroker       User?                       @relation("LastFollowUpBy", fields: [lastFollowUpByBrokerId], references: [id], onDelete: SetNull)
  lastFollowUpAt             DateTime?                   @map("last_follow_up_at")
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt @map("updated_at")
  /**
   * Sales pipeline: new | contacted | qualified | meeting | negotiation | won | lost (legacy: follow_up)
   */
  pipelineStatus             String                      @default("new") @map("pipeline_status")
  /**
   * Duplicate of stage label for reporting / future split from legacy status strings
   */
  pipelineStage              String                      @default("new") @map("pipeline_stage")
  optedOutOfFollowUp         Boolean                     @default(false) @map("opted_out_of_follow_up")
  /**
   * Denormalized deal value (e.g. from evaluation estimate), dollars CAD.
   */
  dealValue                  Int?                        @map("deal_value")
  /**
   * Revenue optimization: estimated opportunity value (CAD), often from purchase price.
   */
  estimatedValue             Int?                        @map("estimated_value")
  /**
   * Heuristic 0–1 close probability from tiering model.
   */
  conversionProbability      Float?                      @map("conversion_probability")
  /**
   * How estimated value / tier was derived (mortgage_form, ai_rule, admin).
   * Note: traffic attribution remains in `source` / UTM fields.
   */
  valueSource                String?                     @map("value_source")
  /**
   * HIGH | MEDIUM | LOW — monetization & expert routing tier.
   */
  revenueTier                String?                     @map("revenue_tier")
  /**
   * Credits charged when this lead is assigned (auto-assign or marketplace claim).
   */
  mortgageCreditCost         Int                         @default(1) @map("mortgage_credit_cost")
  /**
   * Dynamic internal price for this lead (cents CAD) — reporting / future billing.
   */
  dynamicLeadPriceCents      Int?                        @map("dynamic_lead_price_cents")
  /**
   * Per-service platform commission at close (0–1). Mortgage leads default 0.30.
   */
  serviceCommissionRate      Float?                      @map("service_commission_rate")
  /**
   * When assigned to a mortgage expert (auto or claim).
   */
  mortgageAssignedAt         DateTime?                   @map("mortgage_assigned_at")
  /**
   * After first SLA nudge for uncontacted assigned leads.
   */
  mortgageSlaReminderAt      DateTime?                   @map("mortgage_sla_reminder_at")
  /**
   * Mortgage funnel A/B variant (e.g. A | B).
   */
  revenueAbVariant           String?                     @map("revenue_ab_variant")
  /**
   * Client-indicated city/region for demand pricing & city reports.
   */
  purchaseRegion             String?                     @map("purchase_region")
  /**
   * Estimated broker commission in dollars (dealValue × configurable rate).
   */
  commissionEstimate         Int?                        @map("commission_estimate")
  /**
   * Last time broker contacted this lead (outreach / follow-up logged).
   */
  lastContactedAt            DateTime?                   @map("last_contacted_at")
  /**
   * First outbound contact (broker / automation).
   */
  firstContactAt             DateTime?                   @map("first_contact_at")
  /**
   * Mirror of last touch for closing analytics (kept in sync with lastContactedAt on PATCH).
   */
  lastContactAt              DateTime?                   @map("last_contact_at")
