  openedBy    User                       @relation("LecipmDisputeCaseOpenedBy", fields: [openedByUserId], references: [id], onDelete: Restrict)
  againstUser User?                      @relation("LecipmDisputeCaseAgainst", fields: [againstUserId], references: [id], onDelete: SetNull)
  resolvedBy  User?                      @relation("LecipmDisputeCaseResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  messages    LecipmDisputeCaseMessage[]
  events      LecipmDisputeCaseEvent[]

  @@index([openedByUserId])
  @@index([againstUserId])
  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([relatedEntityType, relatedEntityId])
  @@index([createdAt])
  @@map("lecipm_dispute_cases")
}

model LecipmDisputeCaseMessage {
  id          String   @id @default(cuid())
  disputeId   String   @map("dispute_id")
  senderId    String   @map("sender_id")
  message     String   @db.Text
  /// References only: `[{ documentFileId?, url?, fileName, mimeType }]`
  attachments Json?
  createdAt   DateTime @default(now()) @map("created_at")

  dispute LecipmDisputeCase @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  sender  User              @relation("LecipmDisputeCaseMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([disputeId])
  @@index([createdAt])
  @@map("lecipm_dispute_case_messages")
}

model LecipmDisputeCaseEvent {
  id          String                     @id @default(cuid())
  disputeId   String                     @map("dispute_id")
  eventType   LecipmDisputeCaseEventType @map("event_type")
  payload     Json
  actorUserId String?                    @map("actor_user_id")
  createdAt   DateTime                   @default(now()) @map("created_at")

  dispute LecipmDisputeCase @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  actor   User?             @relation("LecipmDisputeCaseEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([disputeId])
  @@index([createdAt])
  @@map("lecipm_dispute_case_events")
}

// —— Autonomous rollout — policy-gated, gradual exposure, measurable, reversible ——

enum RolloutPolicyDomain {
  PRICING
  RANKING
  MESSAGING
  DEAL
  ESG
}

enum RolloutPolicySource {
  AGENT
  EVOLUTION
  MANUAL
}

enum RolloutPolicyStatus {
  DRAFT
  APPROVED
  LIVE
  PAUSED
  ROLLED_BACK
}

enum RolloutExecutionStatus {
  RUNNING
  PAUSED
  COMPLETED
  ROLLED_BACK
}

enum RolloutDecisionAction {
  INCREASE
  PAUSE
  ROLLBACK
}

model RolloutPolicy {
  id               String              @id @default(cuid())
  domain           RolloutPolicyDomain
  strategyKey      String              @map("strategy_key") @db.VarChar(128)
  payloadJson      Json                @map("payload_json")
  source           RolloutPolicySource
  status           RolloutPolicyStatus @default(DRAFT)
  createdByUserId  String?             @map("created_by_user_id") @db.VarChar(36)
  approvedByUserId String?             @map("approved_by_user_id") @db.VarChar(36)
  createdAt        DateTime            @default(now()) @map("created_at")
  approvedAt       DateTime?           @map("approved_at")

  executions RolloutExecution[]

  @@index([domain, strategyKey, status])
  @@index([status, createdAt(sort: Desc)])
  @@map("rollout_policies")
}

model RolloutExecution {
  id              String                 @id @default(cuid())
  policyId        String                 @map("policy_id")
  policy          RolloutPolicy          @relation(fields: [policyId], references: [id], onDelete: Cascade)
  rolloutPercent  Int                    @map("rollout_percent")
  cohortKey       String                 @map("cohort_key") @db.VarChar(128)
  startedAt       DateTime               @default(now()) @map("started_at")
  lastEvaluatedAt DateTime?              @map("last_evaluated_at")
  status          RolloutExecutionStatus @default(RUNNING)
  createdAt       DateTime               @default(now()) @map("created_at")

  metricSnapshots RolloutMetricSnapshot[]
  decisionLogs    RolloutDecisionLog[]

  @@index([policyId, status])
  @@index([status, startedAt(sort: Desc)])
  @@map("rollout_executions")
}

model RolloutMetricSnapshot {
  id          String           @id @default(cuid())
  executionId String           @map("execution_id")
  execution   RolloutExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  timestamp   DateTime         @default(now())
  metricsJson Json             @map("metrics_json")

  @@index([executionId, timestamp(sort: Desc)])
  @@map("rollout_metric_snapshots")
}

model RolloutDecisionLog {
  id          String                @id @default(cuid())
  executionId String                @map("execution_id")
  execution   RolloutExecution      @relation(fields: [executionId], references: [id], onDelete: Cascade)
  action      RolloutDecisionAction
  reason      String                @db.Text
  createdAt   DateTime              @default(now()) @map("created_at")

  @@index([executionId, createdAt(sort: Desc)])
  @@map("rollout_decision_logs")
}

// ---------------------------------------------------------------------------
// Empire Control System — multi-company orchestration & strategic oversight.
// ---------------------------------------------------------------------------

enum EmpireEntityType {
  HOLDING
  OPERATING
  INVESTMENT
  SERVICE
}

model EmpireEntity {
  id             String           @id @default(cuid())
  name           String           @db.VarChar(256)
  entityType     EmpireEntityType @map("entity_type")
  jurisdiction   String?          @db.VarChar(128)
  parentEntityId String?          @map("parent_entity_id")
  isActive       Boolean          @default(true) @map("is_active")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  // Relations
  ownershipsAsParent EmpireOwnership[] @relation("OwnershipParent")
  ownershipsAsChild  EmpireOwnership[] @relation("OwnershipChild")
  roles              EmpireRole[]

  @@map("empire_entities")
}

model EmpireOwnership {
  id               String       @id @default(cuid())
  parentEntityId   String       @map("parent_entity_id")
  parentEntity     EmpireEntity @relation("OwnershipParent", fields: [parentEntityId], references: [id], onDelete: Cascade)
  childEntityId    String       @map("child_entity_id")
  childEntity      EmpireEntity @relation("OwnershipChild", fields: [childEntityId], references: [id], onDelete: Cascade)
  ownershipPercent Float        @map("ownership_percent")
  controlNotes     String?      @map("control_notes") @db.Text
  createdAt        DateTime     @default(now()) @map("created_at")

  @@index([parentEntityId])
  @@index([childEntityId])
  @@map("empire_ownerships")
}

enum EmpireRoleType {
  FOUNDER
  MANAGER
  BOARD
  OPERATOR
  ADVISOR
}

model EmpireRole {
  id         String         @id @default(cuid())
  entityId   String         @map("entity_id")
  entity     EmpireEntity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  roleType   EmpireRoleType @map("role_type")
  personName String         @map("person_name") @db.VarChar(256)
  notes      String?        @db.Text
  createdAt  DateTime       @default(now()) @map("created_at")

  @@index([entityId])
  @@map("empire_roles")
}

// ---------------------------------------------------------------------------
// Growth Engine — autonomous hypothesis testing & funnel optimization.
// ---------------------------------------------------------------------------

enum GrowthChannel {
  CONTENT
  SEO
  REFERRAL
  EMAIL
  LANDING
  PRICING
  ONBOARDING
  PAID
}

enum GrowthExperimentStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
}

model GrowthExperiment {
  id                String                 @id @default(cuid())
  channel           GrowthChannel
  hypothesis        String                 @db.Text
  targetMetric      String                 @map("target_metric") @db.VarChar(64)
  status            GrowthExperimentStatus @default(DRAFT)
  trafficCapPercent Int?                   @map("traffic_cap_percent")
  requiresApproval  Boolean                @default(true) @map("requires_approval")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")

  outcomes GrowthOutcome[]

  @@index([channel, status])
  @@map("growth_experiments")
}

model GrowthOutcome {
  id             String           @id @default(cuid())
  experimentId   String           @map("experiment_id")
  experiment     GrowthExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  impressions    Int?             @default(0)
  clicks         Int?             @default(0)
  signups        Int?             @default(0)
  activations    Int?             @default(0)
  purchases      Int?             @default(0)
  retentionDelta Float?           @map("retention_delta")
  notesJson      Json?            @map("notes_json")
  createdAt      DateTime         @default(now()) @map("created_at")

  @@index([experimentId])
  @@map("growth_outcomes")
}

model GrowthPlaybookMemory {
  id          String        @id @default(cuid())
  strategyKey String        @unique @map("strategy_key") @db.VarChar(128)
  channel     GrowthChannel
  score       Float         @default(0.5)
  wins        Int           @default(0)
  losses      Int           @default(0)
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([channel, score])
  @@map("growth_playbook_memory")
}

// ---------------------------------------------------------------------------
// Multi-Agent Learning Coordination — independent agents competing safely.
// ---------------------------------------------------------------------------

enum AiAgentStatus {
  ACTIVE
  PAUSED
}

model AiAgent {
  id               String        @id @default(cuid())
  name             String        @db.VarChar(128)
  domain           String        @db.VarChar(64) // pricing, ranking, messaging, etc.
  status           AiAgentStatus @default(ACTIVE)
  performanceScore Float         @default(0.5) @map("performance_score")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  strategies AiAgentStrategy[]

  @@index([domain, status])
  @@map("ai_agents")
}

model AiAgentStrategy {
  id           String   @id @default(cuid())
  agentId      String   @map("agent_id")
  agent        AiAgent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  strategyKey  String   @map("strategy_key") @db.VarChar(128)
  description  String?  @db.Text
  payloadJson  Json?    @map("payload_json")
  successCount Int      @default(0) @map("success_count")
  failureCount Int      @default(0) @map("failure_count")
  winRate      Float    @default(0) @map("win_rate")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([agentId])
  @@index([strategyKey])
  @@map("ai_agent_strategies")
}
