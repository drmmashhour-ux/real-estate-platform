model MarketplaceAgentV5DecisionLog {
  id               String   @id @default(cuid())
  agentKind        String   @map("agent_kind") @db.VarChar(32)
  subjectType      String?  @map("subject_type") @db.VarChar(32)
  subjectId        String?  @map("subject_id") @db.VarChar(64)
  decisionType     String   @map("decision_type") @db.VarChar(64)
