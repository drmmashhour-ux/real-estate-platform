// Deal closing workflow (listing sale: buyer, seller, broker, milestones, documents)
model Deal {
  id                               String                            @id @default(uuid())
  /**
   * Immutable deal reference for support / contracts (e.g. DEL-000001).
   */
  dealCode                         String?                           @unique @map("deal_code")
  listingId                        String?                           @map("listing_id") // ShortTermListing or sale listing
  /**
   * Denormalized LEC code when deal references a ShortTermListing.
   */
  listingCode                      String?                           @map("listing_code")
  buyerId                          String                            @map("buyer_id")
  buyer                            User                              @relation("DealBuyer", fields: [buyerId], references: [id], onDelete: Restrict)
  sellerId                         String                            @map("seller_id")
  seller                           User                              @relation("DealSeller", fields: [sellerId], references: [id], onDelete: Restrict)
  brokerId                         String?                           @map("broker_id")
  broker                           User?                             @relation("DealBroker", fields: [brokerId], references: [id], onDelete: SetNull)
  priceCents                       Int                               @map("price_cents")
  status                           String                            @default("initiated") // initiated | offer_submitted | accepted | inspection | financing | closing_scheduled | closed | cancelled | CONFLICT_REQUIRES_DISCLOSURE
  /**
   * Broker CRM pipeline stage (UI / reminders); separate from legal deal status.
   */
  crmStage                         String?                           @map("crm_stage")
  createdAt                        DateTime                          @default(now()) @map("created_at")
  updatedAt                        DateTime                          @updatedAt @map("updated_at")
  /// Broker execution profile — assists official workflows; does not replace mandatory OACIQ forms.
  dealExecutionType                DealExecutionType?                @map("deal_execution_type")
  jurisdiction                     String?                           @default("QC") @db.VarChar(16)
  assignedFormPackageKey           String?                           @map("assigned_form_package_key") @db.VarChar(160)
  propertyReferenceId              String?                           @map("property_reference_id") @db.VarChar(160)
  executionMetadata                Json                              @default("{}") @map("execution_metadata")
  milestones                       DealMilestone[]
  documents                        DealDocument[]
  payments                         PlatformPayment[]
  crmInteractions                  CrmInteraction[]
  contracts                        Contract[]
  /**
   * Optional link to originating CRM lead (e.g. ImmoContact).
   */
  leadId                           String?                           @unique @map("lead_id")
  lead                             Lead?                             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  /**
   * LECIPM enterprise workspace (organization) — optional; null = legacy unscoped rows.
   */
  workspaceId                      String?                           @map("workspace_id") @db.Uuid
  workspace                        EnterpriseWorkspace?              @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  /**
   * Snapshot of lead origin at deal creation (reporting / disputes).
   */
  leadContactOrigin                LeadContactOrigin?                @map("lead_contact_origin")
  /**
   * Commission attribution (e.g. IMMO_CONTACT).
   */
  commissionSource                 LeadContactOrigin?                @map("commission_source")
  commissionEligible               Boolean                           @default(false) @map("commission_eligible")
  /**
   * Heuristic: deal created without auto-linked Immo lead while one existed (compliance review).
   */
  possibleBypassFlag               Boolean                           @default(false) @map("possible_bypass_flag")
  platformCommissionRecords        PlatformCommissionRecord[]
  platformLegalDisputes            PlatformLegalDispute[]
  lecipmDealHistories              LecipmDealHistory[]
  workspaceDealShares              WorkspaceDealShare[]
  workspaceCollaborationMessages   WorkspaceCollaborationMessage[]
  /// Set when sale celebration emails + notifications were sent (idempotency).
  saleCelebrationNotifiedAt        DateTime?                         @map("sale_celebration_notified_at")
  dealRequests                     DealRequest[]
  coordinationContacts             CoordinationContact[]
  bankCoordination                 DealBankCoordination?
  notaryCoordination               DealNotaryCoordination?
  coordinationAuditLogs            DealCoordinationAuditLog[]
  dealParties                      DealParty[]
  copilotSuggestions               DealCopilotSuggestion[]
  executionAuditLogs               DealExecutionAuditLog[]
  /// AI Contract Engine workflow state (intake | drafting | broker_review | …) — assistive, not legal status.
  contractWorkflowState            String?                           @map("contract_workflow_state") @db.VarChar(32)
  dealAssets                       DealAsset[]
  dealStateTransitions             DealStateTransition[]
  suggestionDecisionLogs           SuggestionDecisionLog[]
  /// LECIPM transaction pipeline — does not replace OACIQ official publisher systems.
  lecipmExecutionPipelineState     LecipmExecutionPipelineState?     @map("lecipm_execution_pipeline_state")
  dealExecutionApprovals           DealExecutionApproval[]
  signatureSessions                SignatureSession[]
  dealClosingConditions            DealClosingCondition[]
  /// Escrow / trust-account coordination (v1) — not a regulated trust by default; see `LecipmTrustWorkflow.mode`.
  lecipmDealPayments               LecipmDealPayment[]
  lecipmTrustWorkflow              LecipmTrustWorkflow?
  lecipmPaymentLedgerEntries       LecipmPaymentLedgerEntry[]
  negotiationThreads               NegotiationThread[]
  negotiationSuggestions           NegotiationSuggestion[]
  negotiationStrategies            NegotiationStrategy[]
  lecipmCommunicationDrafts        LecipmCommunicationDraft[]
  lecipmCommunicationLogs          LecipmCommunicationLog[]
  lecipmBrokerTasks                LecipmBrokerTask[]
  lecipmCrmPipelineLeads           LecipmCrmPipelineLead[]           @relation("LecipmCrmPipelineDeal")
  lecipmBrokerCrmAuditLogs         LecipmBrokerCrmAuditLog[]
  brokerCollaborationThreads       BrokerCollaborationThread[]
  brokerDealAssignments            BrokerDealAssignment[]
  brokerInternalNotes              BrokerInternalNote[]
  brokerWorkspaceAuditEvents       BrokerWorkspaceAuditEvent[]
  complianceCases                  ComplianceCase[]
  qaReviews                        QaReview[]
  brokerageOfficeId                String?                           @map("brokerage_office_id")
  brokerageOffice                  BrokerageOffice?                  @relation(fields: [brokerageOfficeId], references: [id], onDelete: SetNull)
  brokerageCommissionCases         BrokerageCommissionCase[]
  officeInvoices                   OfficeInvoice[]
  lecipmFormInstances              LecipmFormInstance[]
  /**
   * Deal Intelligence engine — advisory scores; refreshed on interactions and cron.
   */
  dealScore                        Float?                            @map("deal_score")
  closeProbability                 Float?                            @map("close_probability")
  riskLevel                        String?                           @map("risk_level") @db.VarChar(16)
  /// Pipeline lens: VIEWING | OFFER | NEGOTIATION | CLOSED (distinct from legal `status`).
  intelligenceStage                String?                           @map("intelligence_stage") @db.VarChar(24)
  lastIntelligenceComputedAt       DateTime?                         @map("last_intelligence_computed_at")
  dealIntelligenceEvents           DealIntelligenceEvent[]
  /// Versioned close-probability AI snapshots (0–100, factors, drivers/risks).
  closeProbabilities               CloseProbability[]
  /// Broker decision-support deal scores (accept / review / reject guidance).
  dealScores                       DealScore[]
  /// Autonomous learning layer — outcome rows for closed/failed deals (analytics only).
  dealOutcomes                     DealOutcome[]
  /// Secure closing room + post-close asset onboarding (LECIPM execution bridge).
  lecipmDealClosing                DealClosing?
  lecipmClosingRoomDocuments       DealClosingDocument[]
  lecipmClosingChecklistItems      DealClosingChecklist[]
  lecipmClosingSignatures          DealClosingSignature[]
  postCloseAsset                   PostCloseAsset?
  lecipmDealClosingAudits          DealClosingAudit[]
  /// OACIQ-attested broker approvals with signature linkage (v2 execution gate).
  brokerApprovals                  BrokerApproval[]
  /// Advisory capital allocation proposals — broker approval required before any use.
  dealCapitalAllocations           DealCapitalAllocation[]
  lecipmProductionGuardNoticeAcks  LecipmProductionGuardNoticeAck[]
  lecipmProductionGuardAuditEvents LecipmProductionGuardAuditEvent[]
  lecipmProductionGuardArtifacts   LecipmProductionGuardArtifact[]
  /// AI autopilot action queue — broker signature required before EXECUTED.
  actionPipelines                  ActionPipeline[]
  legalDocumentArtifacts           LecipmLegalDocumentArtifact[]
  /// OACIQ-style conflict / self-dealing — client acknowledgments (exact text + timestamp; optional IP/UA).
  conflictClientConsents           DealConflictClientConsent[]
  /// OACIQ mandatory broker disclosure records filed for this deal (when applicable).
  brokerDisclosures                BrokerDisclosure[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([brokerId])
  @@index([status])
  @@index([crmStage])
  @@index([listingCode])
  @@index([leadId])
  @@index([workspaceId])
  @@index([dealExecutionType])
  @@index([lecipmExecutionPipelineState])
  @@index([brokerageOfficeId])
  @@map("deals")
}

/// AI capital allocator — recommends deployable capital slice for a CRM deal (advisory only; broker approves).
model DealCapitalAllocation {
  id                     String    @id @default(cuid())
  dealId                 String    @map("deal_id")
  deal                   Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  /// Recommended equity / deployable capital in minor units (CAD cents).
  recommendedAmountCents Int       @map("recommended_amount_cents")
  /// Share of declared deployable pool (0–1), e.g. 0.15 = 15%.
  allocationPercent      Float     @map("allocation_percent")
  reasoningJson          Json      @map("reasoning_json")
  /// 0–100 model confidence (data sufficiency), not outcome certainty.
  confidenceScore        Int       @map("confidence_score")
  /// PROPOSED | APPROVED | REJECTED | SUPERSEDED
  brokerApprovalStatus   String    @default("PROPOSED") @map("broker_approval_status") @db.VarChar(16)
  proposedByUserId       String?   @map("proposed_by_user_id")
  proposedBy             User?     @relation("DealCapitalAllocationProposedBy", fields: [proposedByUserId], references: [id], onDelete: SetNull)
  approvedByUserId       String?   @map("approved_by_user_id")
  approvedBy             User?     @relation("DealCapitalAllocationApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  approvedAt             DateTime? @map("approved_at")
  createdAt              DateTime  @default(now()) @map("created_at")

  @@index([dealId, createdAt(sort: Desc)])
  @@index([dealId, brokerApprovalStatus])
  @@map("deal_capital_allocations")
}

/// CRM `Deal` investment commitment — soft interest → broker CONFIRMED → subscription → funded (AMF-style controls).
/// Distinct from fundraising `InvestorCommitment` and AMF `InvestorCapitalCommitment`.
model CrmDealInvestorCommitment {
  id                   String    @id @default(cuid())
  dealId               String    @map("deal_id")
  deal                 Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  investorId           String    @map("investor_id")
  investor             User      @relation("CrmDealInvestorCommitmentInvestor", fields: [investorId], references: [id], onDelete: Restrict)
  spvId                String?   @map("spv_id")
  spv                  AmfSpv?   @relation(fields: [spvId], references: [id], onDelete: SetNull)
  committedAmountCents Int       @map("committed_amount_cents")
  currency             String    @default("CAD") @db.VarChar(8)
  /// SOFT_COMMIT | CONFIRMED | REJECTED | WITHDRAWN
  status               String    @default("SOFT_COMMIT") @map("status") @db.VarChar(24)
  brokerApprovedAt     DateTime? @map("broker_approved_at")
  brokerApprovedById   String?   @map("broker_approved_by_id")
  brokerApprovedBy     User?     @relation("CrmDealInvestorCommitmentApprovedBy", fields: [brokerApprovedById], references: [id], onDelete: SetNull)
  brokerRejectedAt     DateTime? @map("broker_rejected_at")
  brokerRejectedById   String?   @map("broker_rejected_by_id")
  brokerRejectedBy     User?     @relation("CrmDealInvestorCommitmentRejectedBy", fields: [brokerRejectedById], references: [id], onDelete: SetNull)
  rejectionReason      String?   @map("rejection_reason") @db.Text
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  subscription CrmDealInvestorSubscription?

  @@index([dealId, status])
  @@index([investorId])
  @@map("crm_deal_investor_commitments")
}

model CrmDealInvestorSubscription {
  id                      String                    @id @default(cuid())
  commitmentId            String                    @unique @map("commitment_id")
  commitment              CrmDealInvestorCommitment @relation(fields: [commitmentId], references: [id], onDelete: Cascade)
  investorId              String                    @map("investor_id")
  investor                User                      @relation("CrmDealInvestorSubscriptionInvestor", fields: [investorId], references: [id], onDelete: Restrict)
  subscriptionAmountCents Int                       @map("subscription_amount_cents")
  signed                  Boolean                   @default(false)
  signedAt                DateTime?                 @map("signed_at")
  documentId              String?                   @map("document_id")
  document                DealDocument?             @relation(fields: [documentId], references: [id], onDelete: SetNull)
  createdAt               DateTime                  @default(now()) @map("created_at")

  payments CrmDealInvestorPayment[]

  @@index([investorId])
  @@map("crm_deal_investor_subscriptions")
}

model CrmDealInvestorPayment {
  id               String                    @id @default(cuid())
  subscriptionId String                    @map("subscription_id")
  subscription     CrmDealInvestorSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amountCents      Int                       @map("amount_cents")
  /// WIRE | CHEQUE
  method           String                    @db.VarChar(16)
  received         Boolean                   @default(false)
  receivedAt       DateTime?                 @map("received_at")
  referenceNumber  String?                   @map("reference_number") @db.VarChar(128)
  recordedByUserId String?                   @map("recorded_by_user_id")
  recordedBy       User?                     @relation("CrmDealInvestorPaymentRecordedBy", fields: [recordedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime                  @default(now()) @map("created_at")

  @@index([subscriptionId])
  @@map("crm_deal_investor_payments")
}

model CrmDealCapTableEntry {
  id                  String   @id @default(cuid())
  spvId               String   @map("spv_id")
  spv                 AmfSpv   @relation(fields: [spvId], references: [id], onDelete: Cascade)
  investorId          String   @map("investor_id")
  investor            User     @relation("CrmDealCapTableInvestor", fields: [investorId], references: [id], onDelete: Cascade)
  investedAmountCents Int      @map("invested_amount_cents")
  ownershipPercent    Float    @map("ownership_percent")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@unique([spvId, investorId])
  @@index([spvId])
  @@map("crm_deal_cap_table_entries")
}

/// [investment-flow] audit — commitment, approval, subscription, payment, cap table (non-repudiation).
model LecipmInvestmentFlowAuditLog {
  id          String   @id @default(cuid())
  dealId      String   @map("deal_id")
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  actorUserId String?  @map("actor_user_id")
  actor       User?    @relation("LecipmInvestmentFlowAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  action      String   @db.VarChar(64)
  entityType  String?  @map("entity_type") @db.VarChar(64)
  entityId    String?  @map("entity_id") @db.VarChar(64)
  metadata    Json     @default("{}") @db.JsonB
  diff        Json?    @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([dealId, createdAt])
  @@index([action])
  @@map("lecipm_investment_flow_audit_logs")
}

/// Critical disclosure / risk notice — explicit checkbox acknowledgment (timestamp + user + notice id).
model LecipmProductionGuardNoticeAck {
  id             String   @id @default(cuid())
  dealId         String   @map("deal_id")
  deal           Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  userId         String   @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  noticeId       String   @map("notice_id") @db.VarChar(96)
  acknowledgedAt DateTime @default(now()) @map("acknowledged_at")

  @@unique([dealId, userId, noticeId])
  @@index([dealId, userId])
  @@map("lecipm_production_guard_notice_acks")
}

/// Append-only production hardening audit (field changes, notices, AI, signatures, PDF hashes).
model LecipmProductionGuardAuditEvent {
  id          String   @id @default(cuid())
  dealId      String?  @map("deal_id")
  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  actorUserId String?  @map("actor_user_id")
  actor       User?    @relation("LecipmProductionGuardAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  action      String   @db.VarChar(96)
  entityType  String?  @map("entity_type") @db.VarChar(64)
  entityId    String?  @map("entity_id") @db.VarChar(64)
  diff        Json?    @db.JsonB
  metadata    Json     @default("{}") @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([dealId, createdAt])
  @@index([action, createdAt])
  @@map("lecipm_production_guard_audit_events")
}

/// Final draft fingerprint: canonical content SHA-256 + optional PDF bytes hash.
model LecipmProductionGuardArtifact {
  id             String        @id @default(cuid())
  dealId         String        @map("deal_id")
  deal           Deal          @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealDocumentId String?       @map("deal_document_id")
  dealDocument   DealDocument? @relation(fields: [dealDocumentId], references: [id], onDelete: SetNull)
  kind           String        @db.VarChar(32)
  contentSha256  String        @map("content_sha256") @db.VarChar(64)
  pdfSha256      String?       @map("pdf_sha256") @db.VarChar(64)
  createdById    String?       @map("created_by_id")
  createdBy      User?         @relation("LecipmProductionGuardArtifactCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now()) @map("created_at")

  @@index([dealId, createdAt])
  @@index([contentSha256])
  @@map("lecipm_production_guard_artifacts")
}

/// Broker conflict-of-interest / self-dealing — recorded client acknowledgment (OACIQ-oriented operational record).
model DealConflictClientConsent {
  id                 String   @id @default(cuid())
  dealId             String   @map("deal_id")
  deal               Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  userId             String   @map("user_id")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Must match server constant `CONFLICT_DISCLOSURE_ACK_TEXT` at time of acceptance.
  acknowledgmentText String   @map("acknowledgment_text") @db.Text
  acceptedAt         DateTime @default(now()) @map("accepted_at")
  clientIp           String?  @map("client_ip") @db.VarChar(64)
  userAgent          String?  @map("user_agent") @db.VarChar(512)

  @@unique([dealId, userId])
  @@index([dealId])
  @@index([userId])
  @@map("deal_conflict_client_consents")
}

/// OACIQ — broker attestation of role / interest (mandatory disclosure gate when enforcement flag is on).
enum BrokerDisclosureRole {
  BROKER
  BUYER
  SELLER
  INVESTOR
}

model BrokerDisclosure {
  id                  String               @id @default(cuid())
  brokerId            String               @map("broker_id")
  broker              User                 @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  /// Residential `Deal` when disclosure is filed in deal context.
  dealId              String?              @map("deal_id")
  deal                Deal?                @relation(fields: [dealId], references: [id], onDelete: Cascade)
  /// CRM `Listing` for publish / pipeline / offer gates on broker inventory.
  listingId           String?              @map("listing_id")
  listing             Listing?             @relation(fields: [listingId], references: [id], onDelete: Cascade)
  /// FSBO row for broker-managed inventory publish.
  fsboListingId       String?              @map("fsbo_listing_id")
  fsboListing         FsboListing?         @relation(fields: [fsboListingId], references: [id], onDelete: Cascade)
  role                BrokerDisclosureRole
  hasConflict         Boolean              @map("has_conflict")
  conflictDescription String?              @map("conflict_description") @db.Text
  disclosedAt         DateTime             @default(now()) @map("disclosed_at")
  /// Snapshot line appended to generated legal documents (OACIQ declaration).
  declarationLine     String               @map("declaration_line") @db.Text

  @@index([brokerId])
  @@index([dealId])
  @@index([listingId])
  @@index([fsboListingId])
  @@index([brokerId, disclosedAt(sort: Desc)])
  @@map("broker_disclosures")
}

/// Assistive close-likelihood estimate before broker approval / signing (rule blend + pipeline signals).
model CloseProbability {
  id          String   @id @default(cuid())
  dealId      String   @map("deal_id")
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  /// 0–100
  probability Float
  /// VERY_HIGH | HIGH | MEDIUM | LOW
  category    String   @db.VarChar(16)
  /// Factor scores, weights, notes, plus embedded drivers/risks for audit.
  factorsJson Json     @map("factors_json")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([dealId, createdAt(sort: Desc)])
  @@map("deal_close_probabilities")
}

/// Assistive deal scoring for brokers — not a credit/investment recommendation; does not replace diligence.
model DealScore {
  id            String   @id @default(cuid())
  dealId        String   @map("deal_id")
  deal          Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  /// 0–100
  score         Float
  /// EXCELLENT | GOOD | RISKY | REJECT
  category      String   @db.VarChar(16)
  /// LOW | MEDIUM | HIGH
  riskLevel     String   @map("risk_level") @db.VarChar(8)
  reasoningJson Json     @map("reasoning_json")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([dealId, createdAt(sort: Desc)])
  @@map("deal_scores")
}

/// Final execution closing session (secure room, docs, checklist, signatures).
model DealClosing {
  id                String    @id @default(cuid())
  dealId            String    @unique @map("deal_id")
  deal              Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  status            String    @default("NOT_STARTED") @db.VarChar(24) // NOT_STARTED | IN_PROGRESS | READY_TO_CLOSE | CLOSED | FAILED
  closingDate       DateTime? @map("closing_date")
  confirmedByUserId String?   @map("confirmed_by_user_id")
  confirmedBy       User?     @relation("DealClosingConfirmedBy", fields: [confirmedByUserId], references: [id], onDelete: SetNull)
  readinessStatus   String?   @map("readiness_status") @db.VarChar(24) // NOT_READY | PARTIALLY_READY | READY
  notes             String?   @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("lecipm_deal_closings")
}

model DealClosingDocument {
  id               String   @id @default(cuid())
  dealId           String   @map("deal_id")
  deal             Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  title            String   @db.VarChar(512)
  category         String   @db.VarChar(24) // LEGAL | FINANCING | TITLE | INSURANCE | ESG | CORPORATE | OTHER
  fileUrl          String?  @map("file_url") @db.Text
  status           String   @default("MISSING") @db.VarChar(16) // MISSING | UPLOADED | VERIFIED | REJECTED
  required         Boolean  @default(true)
  verifiedByUserId String?  @map("verified_by_user_id")
  verifiedBy       User?    @relation("DealClosingDocVerifier", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  notes            String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  signatures DealClosingSignature[]

  @@index([dealId])
  @@index([dealId, status])
  @@map("lecipm_closing_room_documents")
}

model DealClosingChecklist {
  id          String    @id @default(cuid())
  dealId      String    @map("deal_id")
  deal        Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  title       String    @db.VarChar(512)
  category    String    @db.VarChar(24) // LEGAL | CAPITAL | DOCUMENTATION | ESG | FINAL_APPROVAL | EXECUTION
  priority    String?   @db.VarChar(16)
  status      String    @default("OPEN") @db.VarChar(16) // OPEN | IN_PROGRESS | COMPLETE | BLOCKED
  ownerUserId String?   @map("owner_user_id")
  ownerUser   User?     @relation("DealClosingChecklistOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  dueDate     DateTime? @map("due_date")
  notes       String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([dealId])
  @@index([dealId, status])
  @@map("lecipm_deal_closing_checklists")
}

model DealClosingSignature {
  id         String               @id @default(cuid())
  dealId     String               @map("deal_id")
  deal       Deal                 @relation(fields: [dealId], references: [id], onDelete: Cascade)
  documentId String?              @map("document_id")
  document   DealClosingDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  signerName String               @map("signer_name") @db.VarChar(256)
  signerRole String               @map("signer_role") @db.VarChar(64)
  /// When false, absence does not block closing confirmation (advisory signers).
  required   Boolean              @default(true) @map("required")
  status     String               @default("PENDING") @db.VarChar(16) // PENDING | SIGNED | DECLINED
  signedAt   DateTime?            @map("signed_at")
  notes      String?              @db.Text
  createdAt  DateTime             @default(now()) @map("created_at")

  @@index([dealId])
  @@map("lecipm_deal_closing_signatures")
}

/// Active asset record after transactional deal closes — drives post-close dashboards.
model PostCloseAsset {
  id                     String      @id @default(cuid())
  dealId                 String      @unique @map("deal_id")
  deal                   Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  listingId              String?     @map("listing_id")
  listing                Listing?    @relation(fields: [listingId], references: [id], onDelete: SetNull)
  assetName              String      @map("asset_name") @db.VarChar(512)
  status                 String      @default("ACTIVE") @db.VarChar(16) // ACTIVE | ON_HOLD | SOLD
  acquisitionDate        DateTime?   @map("acquisition_date")
  ownerEntity            String?     @map("owner_entity") @db.VarChar(512)
  esgProfileId           String?     @map("esg_profile_id")
  esgProfile             EsgProfile? @relation(fields: [esgProfileId], references: [id], onDelete: SetNull)
  operationsInitialized  Boolean     @default(false) @map("operations_initialized")
  revenueInitialized     Boolean     @default(false) @map("revenue_initialized")
  onboardingMetadataJson Json        @default("{}") @map("onboarding_metadata_json")
  createdAt              DateTime    @default(now()) @map("created_at")
  updatedAt              DateTime    @updatedAt @map("updated_at")

  portfolioAssetHealth   PortfolioAssetHealth?
  portfolioPriorities    PortfolioPriority[]
  assetManagerPlans      AssetManagerPlan[]
