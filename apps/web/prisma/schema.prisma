  id               String                      @id @default(uuid())
  dealId           String                      @map("deal_id")
  deal             Deal                        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  suggestionType   String                      @map("suggestion_type") @db.VarChar(64)
  title            String
  summary          String                      @db.Text
  payload          Json                        @default("{}")
  confidence       Float?
  impactEstimate   String?                     @map("impact_estimate") @db.VarChar(32)
  riskLevel        String?                     @map("risk_level") @db.VarChar(24)
  sourceReferences Json                        @default("[]") @map("source_references")
  status           NegotiationSuggestionStatus @default(pending_review)
  createdAt        DateTime                    @default(now()) @map("created_at")
  updatedAt        DateTime                    @updatedAt @map("updated_at")

  @@index([dealId])
  @@index([status])
  @@map("negotiation_suggestions")
}

/// AI-assisted counter-offer packages — broker must approve before any outbound counter; never auto-sent.
model NegotiationStrategy {
  id                   String   @id @default(cuid())
  dealId               String   @map("deal_id")
  deal                 Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  /// Groups the three profiles (AGGRESSIVE / BALANCED / SAFE) from one run.
  strategyRunId        String   @map("strategy_run_id") @db.VarChar(40)
  /// AGGRESSIVE | BALANCED | SAFE
  strategyType         String   @map("strategy_type") @db.VarChar(16)
  /// Suggested counter price (CAD, major units) — illustrative until broker edits and approves.
  suggestedPrice       Float    @map("suggested_price")
  conditionChangesJson Json     @map("condition_changes_json")
  timelineSuggestion   String   @map("timeline_suggestion") @db.Text
  reasoningJson        Json     @map("reasoning_json")
  confidenceScore      Float    @map("confidence_score")
  /// AI_PROPOSED | BROKER_SELECTED | BROKER_APPROVED_TO_SEND | DISMISSED
  workflowStatus       String   @default("AI_PROPOSED") @map("workflow_status") @db.VarChar(32)
  brokerNotes          String?  @map("broker_notes") @db.Text
  createdAt            DateTime @default(now()) @map("created_at")

  @@index([dealId, strategyRunId])
  @@index([dealId, createdAt(sort: Desc)])
  @@map("negotiation_strategies")
}

