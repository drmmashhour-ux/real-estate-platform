  AIRBNB
  EXPEDIA
  VRBO
  /// Metasearch / Google Hotels — map when partner or feed supplies a stable property ref
  TRIVAGO
  HOTELS_COM
  GOOGLE_HOTEL
  DIRECT
  OTHER
}

enum BnhubChannelConnectionType {
  ICAL
  API
}

enum BnhubChannelConnectionStatus {
  ACTIVE
  PAUSED
  ERROR
}

enum BnhubChannelListingMapStatus {
  LINKED
  PENDING
  ERROR
}

enum BnhubChannelEventSource {
  BNHUB
  EXTERNAL
}

enum BnhubChannelEventKind {
  RESERVATION
  BLOCK
  AVAILABILITY_UPDATE
}

enum BnhubOtaSyncType {
  IMPORT
  EXPORT
}

enum BnhubOtaSyncResultStatus {
  SUCCESS
  FAILED
}

/// Per-night calendar: available, host/channel blocked, or booked (platform or external)
enum BnhubDayAvailabilityStatus {
  AVAILABLE
  BLOCKED
  BOOKED
}

/// Where the booking was originated (BNHub core vs imported channel)
enum BnhubBookingSource {
  LOCAL
  AIRBNB
  BOOKING_COM
  EXPEDIA
  OTHER
}

/// Last push/pull health for an external listing mapping
enum BnhubChannelSyncStatus {
  IDLE
  OK
  ERROR
  SYNCING
}

// Availability calendar: which dates are available; optional price override per date
model AvailabilitySlot {
  id                 String                     @id @default(uuid())
  date               DateTime
  available          Boolean                    @default(true)
  /// Preferred status for integrations; keep `available` in sync in app code
  dayStatus          BnhubDayAvailabilityStatus @default(AVAILABLE) @map("day_status")
  /// When BOOKED from a BNHub booking row — cleared on cancellation
  bookedByBookingId  String?                    @map("booked_by_booking_id")
  bookedByBooking    Booking?                   @relation(fields: [bookedByBookingId], references: [id], onDelete: SetNull)
  priceOverrideCents Int? // Special price for this date (overrides listing base)
  minStayNights      Int? // Override min stay for this date
  listingId          String
  listing            ShortTermListing           @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, date])
  @@index([listingId])
  @@index([date])
  @@index([bookedByBookingId])
}

/// Maps BNHub listing ↔ external OTA property id (Booking.com, Airbnb, Expedia, etc.)
model BnhubExternalListingMapping {
  id         String                 @id @default(cuid())
  listingId  String                 @map("listing_id")
  listing    ShortTermListing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  platform   BnhubChannelPlatform   @map("platform")
  externalId String                 @map("external_id")
  syncStatus BnhubChannelSyncStatus @default(IDLE) @map("sync_status")
  lastError  String?                @map("last_error") @db.Text
  lastSyncAt DateTime?              @map("last_sync_at")
  createdAt  DateTime               @default(now()) @map("created_at")
  updatedAt  DateTime               @updatedAt @map("updated_at")
  syncLogs   BnhubChannelSyncLog[]

  @@unique([listingId, platform])
  @@index([externalId])
  @@index([syncStatus])
  @@map("external_mapping")
}

/// Audit log for channel sync / webhook errors
model BnhubChannelSyncLog {
  id        String                       @id @default(cuid())
  mappingId String?                      @map("mapping_id")
  mapping   BnhubExternalListingMapping? @relation(fields: [mappingId], references: [id], onDelete: SetNull)
  listingId String?                      @map("listing_id")
  platform  String?
  direction String // push | pull | webhook_in
  status    String // success | error
  message   String?                      @db.Text
  payload   Json?
  createdAt DateTime                     @default(now()) @map("created_at")

  @@index([listingId])
  @@index([createdAt])
  @@map("bnhub_channel_sync_logs")
}

/// Host-owned OTA / iCal channel connection (import URL, future API keys).
model BnhubChannelConnection {
  id                   String                       @id @default(uuid()) @map("id")
  userId               String                       @map("user_id")
  user                 User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform             BnhubChannelPlatform         @map("platform")
  connectionType       BnhubChannelConnectionType   @map("connection_type")
  externalListingId    String?                      @map("external_listing_id")
  icalImportUrl        String?                      @map("ical_import_url") @db.Text
  icalExportUrl        String?                      @map("ical_export_url") @db.Text
  status               BnhubChannelConnectionStatus @default(ACTIVE) @map("status")
  lastSyncAt           DateTime?                    @map("last_sync_at")
  syncFrequencyMinutes Int                          @default(30) @map("sync_frequency_minutes")
  lastError            String?                      @map("last_error") @db.Text
  createdAt            DateTime                     @default(now()) @map("created_at")
  updatedAt            DateTime                     @updatedAt @map("updated_at")

  mappings BnhubChannelListingMapping[]
  syncLogs BnhubOtaSyncLog[]
  events   BnhubChannelCalendarEvent[]

  @@index([userId])
  @@index([platform])
  @@index([status])
  @@index([lastSyncAt])
  @@map("bnhub_channel_connections")
}

/// Links a BNHub listing to a channel connection (one external ref per pair).
model BnhubChannelListingMapping {
  id                  String                       @id @default(uuid()) @map("id")
  listingId           String                       @map("listing_id")
  listing             ShortTermListing             @relation(fields: [listingId], references: [id], onDelete: Cascade)
  channelConnectionId String                       @map("channel_connection_id")
  channelConnection   BnhubChannelConnection       @relation(fields: [channelConnectionId], references: [id], onDelete: Cascade)
  externalListingRef  String                       @map("external_listing_ref")
  mappingStatus       BnhubChannelListingMapStatus @default(LINKED) @map("mapping_status")
  createdAt           DateTime                     @default(now()) @map("created_at")

  @@unique([listingId, channelConnectionId], map: "bnhub_channel_mappings_listing_connection_key")
  @@index([channelConnectionId])
  @@index([listingId])
  @@map("bnhub_channel_mappings")
}

/// Normalized calendar events from BNHub or external iCal/API (audit + UI).
model BnhubChannelCalendarEvent {
  id                  String                  @id @default(uuid()) @map("id")
  listingId           String                  @map("listing_id")
  listing             ShortTermListing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  channelConnectionId String?                 @map("channel_connection_id")
  channelConnection   BnhubChannelConnection? @relation(fields: [channelConnectionId], references: [id], onDelete: SetNull)
  source              BnhubChannelEventSource @map("source")
  platform            BnhubChannelPlatform    @map("platform")
  externalEventId     String?                 @map("external_event_id")
  eventType           BnhubChannelEventKind   @map("event_type")
  startDate           DateTime                @map("start_date") @db.Date
  endDate             DateTime                @map("end_date") @db.Date
  guestName           String?                 @map("guest_name")
  metadataJson        Json                    @default("{}") @map("metadata_json")
  createdAt           DateTime                @default(now()) @map("created_at")

  @@index([listingId])
  @@index([channelConnectionId])
  @@index([source])
  @@index([startDate])
  @@index([platform])
  @@map("bnhub_channel_events")
}

/// Channel manager sync run log (import/export).
model BnhubOtaSyncLog {
  id           String                   @id @default(uuid()) @map("id")
  connectionId String                   @map("connection_id")
  connection   BnhubChannelConnection   @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  listingId    String?                  @map("listing_id")
  listing      ShortTermListing?        @relation(fields: [listingId], references: [id], onDelete: SetNull)
  syncType     BnhubOtaSyncType         @map("sync_type")
  status       BnhubOtaSyncResultStatus @map("status")
  message      String?                  @map("message") @db.Text
  payload      Json?                    @map("payload")
  createdAt    DateTime                 @default(now()) @map("created_at")

  @@index([connectionId])
  @@index([listingId])
  @@index([createdAt])
  @@index([status])
  @@map("bnhub_sync_logs")
}

/// AI-assisted OTA / metasearch parsing & webhook normalization (audit trail; host-owned).
model BnhubOtaAiTrace {
  id          String            @id @default(cuid())
  userId      String            @map("user_id")
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId   String?           @map("listing_id")
  listing     ShortTermListing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  traceType   String            @map("trace_type") @db.VarChar(40)
  sourceLabel String?           @map("source_label") @db.VarChar(80)
  inputDigest String            @map("input_digest") @db.VarChar(64)
  resultJson  Json              @map("result_json")
  model       String?           @map("model") @db.VarChar(80)
  createdAt   DateTime          @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@index([listingId])
  @@map("bnhub_ota_ai_traces")
}

