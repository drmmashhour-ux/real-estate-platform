// LECIPM — automated short-form content machine (5 styles → vertical 9:16 card → TikTok/IG slots)
// ---------------------------------------------------------------------------

enum ContentMachineStyle {
  price_shock
  lifestyle
  comparison
  question
  hidden_gem
}

enum ContentMachinePieceStatus {
  generated
  video_created
  scheduled
  posted
  failed
}

enum ContentMachineScheduleStatus {
  pending
  confirmed
  posted
  failed
  cancelled
}

/// Prompt hints per style (seeded by `lib/content-machine/generate.ts`).
model ContentTemplate {
  id             String              @id @default(cuid())
  style          ContentMachineStyle @unique
  promptTemplate String              @map("prompt_template") @db.Text
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  @@map("content_templates")
}

model MachineGeneratedContent {
  id               String                    @id @default(cuid())
  listingId        String                    @map("listing_id")
  listing          ShortTermListing          @relation(fields: [listingId], references: [id], onDelete: Cascade)
  style            ContentMachineStyle
  hook             String                    @db.VarChar(512)
  script           String                    @db.Text
  caption          String                    @db.Text
  hashtagsJson     Json                      @map("hashtags_json")
  status           ContentMachinePieceStatus @default(generated)
  videoUrl         String?                   @map("video_url") @db.Text
  source           String                    @default("openai") @db.VarChar(24)
  errorMessage     String?                   @map("error_message") @db.Text
  views            Int                       @default(0)
  clicks           Int                       @default(0)
  /// Legacy generic conversions (e.g. tracked goals); see also `bookings`.
  conversions      Int                       @default(0)
  saves            Int                       @default(0)
  shares           Int                       @default(0)
  /// Attributed completed stays / bookings tied to this content piece when tracked.
  bookings         Int                       @default(0)
  /// Sum of booking revenue attributed to this piece (cents).
  revenueCents     Int                       @default(0) @map("revenue_cents")
  /// Denormalized weighted score from metrics (see `computeContentPerformanceScore`).
  performanceScore Float?                    @map("performance_score")
