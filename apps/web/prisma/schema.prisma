  createdAt       DateTime      @default(now()) @map("created_at")

  @@index([propertyId], map: "idx_deal_refresh_events_property_id")
  @@map("deal_analysis_refresh_events")
}

/// Phase 4 — negotiation playbook (rules-based; not legal advice).
model DealNegotiationPlaybook {
  id              String             @id @default(cuid())
  propertyId      String             @map("property_id")
  listing         FsboListing        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  analysisId      String?            @map("analysis_id")
  analysis        DealAnalysis?      @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  offerStrategyId String?            @map("offer_strategy_id")
  offerStrategy   DealOfferStrategy? @relation(fields: [offerStrategyId], references: [id], onDelete: SetNull)
  marketCondition String             @map("market_condition")
  posture         String
  playbookSteps   Json               @default("[]") @map("playbook_steps") @db.JsonB
  warnings        Json               @default("[]") @db.JsonB
  confidenceLevel String             @map("confidence_level")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@index([propertyId], map: "idx_deal_negotiation_playbooks_property_id")
  @@map("deal_negotiation_playbooks")
}

/// Phase 4 — seller repricing review snapshot (not auto price change).
model SellerRepricingReview {
  id                String      @id @default(cuid())
  propertyId        String      @unique @map("property_id")
  listing           FsboListing @relation(fields: [propertyId], references: [id], onDelete: Cascade)
