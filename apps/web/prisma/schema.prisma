  id          String                  @id @default(uuid()) @db.Uuid
  entityType  PlatformTrustEntityType @map("entity_type")
  entityId    String                  @map("entity_id")
  score       Int                     @default(0)
  level       PlatformTrustTier       @default(low)
  reasonsJson Json                    @default("{}") @map("reasons_json")
  updatedAt   DateTime                @updatedAt @map("updated_at")
  createdAt   DateTime                @default(now()) @map("created_at")

  @@unique([entityType, entityId])
  @@index([level])
  @@map("platform_trust_scores")
}

model VerificationRequest {
  id               String                    @id @default(uuid()) @db.Uuid
  userId           String?                   @map("user_id")
  listingId        String?                   @map("listing_id")
  type             String
  status           VerificationRequestStatus @default(pending)
  notes            String?                   @db.Text
  submittedAt      DateTime                  @default(now()) @map("submitted_at")
  reviewedAt       DateTime?                 @map("reviewed_at")
  reviewedByUserId String?                   @map("reviewed_by_user_id")
  submitter        User?                     @relation("VerificationRequestSubmitter", fields: [userId], references: [id], onDelete: SetNull)
  reviewedBy       User?                     @relation("VerificationRequestReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([userId])
  @@index([listingId])
  @@map("verification_requests")
}

// ---------------------------------------------------------------------------
// Platform reputation (reviews + complaints + composite score; distinct from BNHub `Review` booking reviews)
// ---------------------------------------------------------------------------
enum ReputationEntityType {
  host
  broker
  seller
  listing
  buyer
}

enum ReputationLevel {
  poor
  fair
  good
  excellent
}

enum ReviewStatus {
  pending
  published
  hidden
  flagged
}

enum ComplaintStatus {
  open
  under_review
  confirmed
  dismissed
  resolved
}

model ReputationScore {
  id                  String               @id @default(uuid()) @db.Uuid
  entityType          ReputationEntityType @map("entity_type")
  entityId            String               @map("entity_id")
  score               Int                  @default(0)
  level               ReputationLevel      @default(fair)
  reviewScore         Int                  @default(0) @map("review_score")
  reliabilityScore    Int                  @default(0) @map("reliability_score")
  responsivenessScore Int                  @default(0) @map("responsiveness_score")
  complaintScore      Int                  @default(0) @map("complaint_score")
  qualityScore        Int                  @default(0) @map("quality_score")
  reasonsJson         Json                 @default("{}") @map("reasons_json")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  @@unique([entityType, entityId])
  @@index([level])
  @@map("reputation_scores")
}

/// Platform-wide reputation reviews (not BNHub booking `Review`).
model ReputationReview {
  id                String               @id @default(uuid()) @db.Uuid
  listingId         String?              @map("listing_id")
  subjectEntityType ReputationEntityType @map("subject_entity_type")
  subjectEntityId   String               @map("subject_entity_id")
  authorUserId      String               @map("author_user_id")
