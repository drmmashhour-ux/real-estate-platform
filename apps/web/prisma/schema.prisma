// Canva usage per user/listing – trial then $5 per design
model CanvaDesignUsage {
  id          String         @id @default(cuid())
  userId      String         @map("user_id")
  listingId   String         @map("listing_id")
  createdAt   DateTime       @default(now()) @map("created_at")
  trialEndsAt DateTime       @map("trial_ends_at")
  isPaid      Boolean        @default(false) @map("is_paid")
  amount      Float          @default(5) @map("amount")
  invoices    CanvaInvoice[]

  @@index([userId])
  @@index([listingId])
  @@index([trialEndsAt])
  @@index([isPaid])
  @@map("canva_design_usages")
}

// Invoice for Canva usage (after trial / payment)
model CanvaInvoice {
  id            String           @id @default(cuid())
  userId        String           @map("user_id")
  usageId       String           @map("usage_id")
  usage         CanvaDesignUsage @relation(fields: [usageId], references: [id], onDelete: Cascade)
  amount        Float            @map("amount")
  createdAt     DateTime         @default(now()) @map("created_at")
  pdfUrl        String?          @map("pdf_url")
  invoiceNumber String?          @unique @map("invoice_number")

  @@index([userId])
  @@index([usageId])
  @@index([createdAt])
  @@map("canva_invoices")
}

// Storage plan upgrade invoice (Stripe payment → upgrade + invoice)
model UpgradeInvoice {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  amount          Float    @map("amount")
  plan            String   @map("plan") // basic | pro
  date            DateTime @default(now()) @map("date")
  createdAt       DateTime @default(now()) @map("created_at")
  stripePaymentId String?  @unique @map("stripe_payment_id") // idempotency: avoid duplicate on webhook retries

  @@index([userId])
  @@index([date])
  @@map("upgrade_invoices")
}

// Audit log for Stripe billing events (payment confirmed, upgrade applied)
model BillingAuditLog {
  id              String   @id @default(cuid())
  event           String   @map("event") // checkout.session.completed | payment.paid
  userId          String   @map("user_id")
  stripeSessionId String?  @map("stripe_session_id")
  feature         String?  @map("feature") // storage-upgrade
  plan            String?  @map("plan")
  amount          Float?   @map("amount")
  details         Json?    @map("details")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([event])
  @@index([createdAt])
  @@map("billing_audit_logs")
}

// User storage quota – free 500MB, upgrade to Basic 5GB / Pro 50GB
model UserStorage {
  id         String   @id @default(cuid())
  userId     String   @unique @map("user_id")
  usedBytes  Int      @default(0) @map("used_bytes")
  limitBytes Int      @map("limit_bytes")
  alertLevel String   @default("safe") @map("alert_level") // safe | warning | critical | full
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("user_storage")
}

// Saved design assets (from Canva/template flow) – count toward UserStorage
model DesignAsset {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  listingId String?  @map("listing_id")
  title     String   @map("title")
  imageUrl  String   @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([listingId])
  @@map("design_assets")
}

// Storage optimization – file-level metadata for analytics, retention, and compression
model StorageFileRecord {
  id                 String    @id @default(cuid())
  userId             String    @map("user_id")
  listingId          String?   @map("listing_id")
  entityType         String    @map("entity_type") // property_document | listing_photo | transaction_document | generated_document | evidence | temp | preview | export
  entityId           String?   @map("entity_id")
  fileUrl            String    @map("file_url")
  fileType           String    @map("file_type") // image | document | video | other
  mimeType           String?   @map("mime_type")
  originalSize       Int       @default(0) @map("original_size")
  compressedSize     Int?      @map("compressed_size")
  isTemporary        Boolean   @default(false) @map("is_temporary")
  deletedAt          DateTime? @map("deleted_at")
  restoredAt         DateTime? @map("restored_at")
  retentionPolicy    String    @default("standard") @map("retention_policy") // standard | legal | invoice | compliance | temp_30d | preview_7d | export_30d
  optimizationStatus String    @default("pending") @map("optimization_status") // pending | compressed | skipped | failed
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([listingId])
  @@index([entityType])
  @@index([deletedAt])
  @@index([retentionPolicy])
  @@index([createdAt])
  @@map("storage_file_records")
}

// Audit log for storage actions (compression, delete, restore, optimize)
model StorageAuditLog {
  id         String   @id @default(cuid())
  action     String   @map("action") // COMPRESS | DELETE | RESTORE | OPTIMIZE | RETENTION_CLEANUP
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  userId     String?  @map("user_id")
  details    Json?    @map("details") // { originalSize, compressedSize, savedBytes, reason, ... }
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([action])
  @@index([userId])
  @@index([createdAt])
  @@map("storage_audit_logs")
}

// =============================================================================
// PLATFORM DEFENSE LAYER
// =============================================================================

// ---------------------------------------------------------------------------
// 1. Legal Defense – policy acceptance, terms, acknowledgements
// ---------------------------------------------------------------------------
// Centralized legal document content (versioned). Types: terms, privacy, cookies, host_agreement, bnhub_long_term_rental_agreement, bnhub_broker_collaboration_agreement, guest_policy, broker_agreement, platform_usage
model LegalDocument {
  id        String   @id @default(cuid())
  type      String // terms | privacy | cookies | host_agreement | bnhub_long_term_rental_agreement | bnhub_broker_collaboration_agreement | guest_policy | broker_agreement | platform_usage | platform_acknowledgment
  version   String
  content   String   @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([type])
  @@index([type, isActive])
  @@map("legal_documents")
}

/// Corporate / entity legal records for LECIPM Legal Management (name + lifecycle status).
/// Types: shareholder_agreement | privacy_policy | terms. Status: draft | signed.
model CorporateLegalDocument {
  id        String   @id @default(uuid())
  name      String
  type      String
  status    String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([type])
  @@index([status])
  @@map("corporate_legal_documents")
}

model CompanyStructure {
  id           String   @id @default(uuid())
  entityType   String   @map("entity_type")
  jurisdiction String
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([jurisdiction])
  @@map("company_structures")
}

// User acceptance of legal documents – traceable, version-specific
model UserAgreement {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentType String   @map("document_type") // same as LegalDocument.type
  version      String
  acceptedAt   DateTime @default(now()) @map("accepted_at")

  @@index([userId])
  @@index([userId, documentType])
  @@index([documentType])
  @@map("user_agreements")
}

/// User-signed acknowledgments for hub legal gates (audit trail; versioned).
model LegalFormSignature {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// e.g. BUYER_ACKNOWLEDGMENT | MORTGAGE_DISCLOSURE | GUEST_ACKNOWLEDGMENT
  formKey     String   @map("form_key")
  /// e.g. buyer_hub | mortgage_hub | short_term_booking | seller_listing
  contextType String   @map("context_type")
  /// Entity id when scoped (listingId, offerId); "" when global for that context.
  contextId   String   @default("") @map("context_id")
  version     String
  signedAt    DateTime @default(now()) @map("signed_at")
  metadata    Json?

  @@unique([userId, formKey, contextType, contextId])
  @@index([userId, formKey])
  @@index([contextType, contextId])
  @@map("legal_form_signatures")
}

// Contract logic – all agreements stored in DB (host agreement, booking agreement)
model PlatformAgreement {
  id                String   @id @default(uuid())
  agreementType     String   @map("agreement_type") // host_agreement | booking_agreement
  version           String
  contentHtml       String   @map("content_html") @db.Text // Snapshot of agreed content
  relatedEntityType String   @map("related_entity_type") // bnhub_host | booking
  relatedEntityId   String   @map("related_entity_id")
  metadata          Json? // e.g. { guestId, hostId, listingId } for booking
  acceptedAt        DateTime @map("accepted_at")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([agreementType])
  @@index([relatedEntityType, relatedEntityId])
  @@index([acceptedAt])
  @@map("platform_agreements")
}

// Unified contract engine – booking_contract | listing_contract | lease | broker_agreement | investment_agreement
model Contract {
  id                        String                     @id @default(uuid())
  type                      String // booking_contract | listing_contract | lease | broker_agreement | investment_agreement
  userId                    String                     @map("user_id")
  user                      User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId                  String?                    @map("tenant_id")
  tenant                    Tenant?                    @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  createdById               String?                    @map("created_by_id")
  createdBy                 User?                      @relation("ContractCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  listingId                 String?                    @map("listing_id")
  fsboListingId             String?                    @map("fsbo_listing_id")
  fsboListing               FsboListing?               @relation(fields: [fsboListingId], references: [id], onDelete: Cascade)
  bookingId                 String?                    @map("booking_id")
  booking                   Booking?                   @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  /**
   * Optional deal link (e.g. brokerage sale workflow).
   */
  dealId                    String?                    @map("deal_id")
  deal                      Deal?                      @relation(fields: [dealId], references: [id], onDelete: SetNull)
  /// Platform-issued registry number (see `ContractRegistry`).
  contractNumber            String?                    @unique @map("contract_number") @db.VarChar(80)
  title                     String                     @default("")
  contentHtml               String?                    @map("content_html") @db.Text
  /// Plain-text snapshot (PDF / search); immutable after sign.
  contentText               String?                    @map("content_text") @db.Text
  content                   Json? // Structured snapshot (parties, amounts) + future DocuSign metadata
  status                    String                     @default("pending") // pending | signed | draft | sent | completed | cancelled
  /// Primary party acknowledged signature (see also ContractSignature for multi-party).
  signed                    Boolean                    @default(false) @map("is_signed")
  signedAt                  DateTime?                  @map("signed_at")
  signerIpAddress           String?                    @map("signer_ip_address")
  /**
   * Counsel / product version label for this template snapshot.
   */
  version                   String?
  hub                       String? // bnhub | realestate | luxury | broker | projects
  /**
   * Future: docusign | adobe | null
   */
  externalProvider          String?                    @map("external_provider")
  externalEnvelopeId        String?                    @map("external_envelope_id")
  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")
  signatures                ContractSignature[]
  offerDocument             OfferDocument?
  brokerTransactionRecords  BrokerTransactionRecord[]
  appointments              Appointment[]
  conversations             Conversation[]
  documentFolders           DocumentFolder[]
  documentFiles             DocumentFile[]
  dealFinancials            DealFinancial[]
  tenantInvoices            TenantInvoice[]
  legalAuditLogs            LegalContractAuditLog[]
  paymentLegalLinks         Payment[]                  @relation("PaymentLegalLink")
  platformPaymentLegalLinks PlatformPayment[]          @relation("PlatformPaymentLegalLink")
  bnhubInvoiceLegalLinks    BnhubBookingInvoice[]      @relation("BnhubInvoiceLegalLink")
  platformCommissionRecords PlatformCommissionRecord[]
  contractClauses           ContractClause[]
  contractLegalNotices      ContractLegalNotice[]
  contractSignatureGates    ContractSignatureGate[]

  @@index([userId])
  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@index([hub])
  @@index([bookingId])
  @@index([dealId])
  @@index([fsboListingId])
  @@index([listingId])
  @@index([createdById])
  @@index([signed])
  @@map("contracts")
}

/// LECIPM Contract Brain — immutable snapshots of regulated notices acknowledged before signature.
model ContractLegalNotice {
  id              String    @id @default(cuid())
  contractId      String    @map("contract_id")
  contract        Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  userId          String?   @map("user_id")
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  noticeKey       String    @map("notice_key")
  version         String
  title           String
  contentSnapshot String    @map("content_snapshot") @db.Text
  acceptedAt      DateTime? @map("accepted_at")
  ipAddress       String?   @map("ip_address") @db.VarChar(128)
  userAgent       String?   @map("user_agent") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([contractId, userId, noticeKey, version])
  @@index([contractId])
  @@index([userId])
  @@index([noticeKey])
  @@map("contract_legal_notices")
}

/// Last evaluated Contract Brain signature gate per contract + gate key (audit / UX).
model ContractSignatureGate {
  id         String    @id @default(cuid())
  contractId String    @map("contract_id")
  contract   Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  userId     String?   @map("user_id")
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  gateKey    String    @map("gate_key")
  passed     Boolean   @default(false)
  passedAt   DateTime? @map("passed_at")
  reason     String?   @db.Text
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@unique([contractId, gateKey])
  @@index([userId])
  @@map("contract_signature_gates")
}

/// OACIQ clause intelligence — standardized library rows (admin-seeded).
enum OaciqClauseLibraryCategory {
  brokerage_contract
  amendment
  promise_to_purchase
  other
  enterprise_sale
}

enum OaciqClauseFormVersion {
  forms_2022_mandatory @map("2022_mandatory")
}

model ClausesLibrary {
  id                  String                     @id @default(cuid())
  category            OaciqClauseLibraryCategory
  code                String                     @unique @db.VarChar(64)
  title               String                     @db.VarChar(512)
  description         String?                    @db.Text
  templateText        String                     @map("template_text") @db.Text
  requiresDeadline    Boolean                    @default(true) @map("requires_deadline")
  requiresNotice      Boolean                    @default(true) @map("requires_notice")
  requiresConsequence Boolean                    @default(true) @map("requires_consequence")
  requiresActor       Boolean                    @default(true) @map("requires_actor")
  formVersion         OaciqClauseFormVersion     @default(forms_2022_mandatory) @map("form_version")
  active              Boolean                    @default(true)
  /// Optional workflow key: off_market | security_deposit_trust | dual_representation | enterprise_sale
  enforcementKey      String?                    @map("enforcement_key") @db.VarChar(64)
  createdAt           DateTime                   @default(now()) @map("created_at")
  updatedAt           DateTime                   @updatedAt @map("updated_at")

  contractClauses ContractClause[]

  @@index([category, active])
  @@map("clauses_library")
}

model ContractClause {
  id                 String         @id @default(cuid())
  contractId         String         @map("contract_id")
  contract           Contract       @relation(fields: [contractId], references: [id], onDelete: Cascade)
  libraryClauseId    String         @map("clause_id")
  libraryClause      ClausesLibrary @relation(fields: [libraryClauseId], references: [id], onDelete: Restrict)
  customText         String?        @map("custom_text") @db.Text
  actorDefined       Boolean        @default(false) @map("actor_defined")
  deadlineDefined    Boolean        @default(false) @map("deadline_defined")
  noticeDefined      Boolean        @default(false) @map("notice_defined")
  consequenceDefined Boolean        @default(false) @map("consequence_defined")
  validated          Boolean        @default(false)
  validationErrors   Json?          @map("validation_errors")
  createdAt          DateTime       @default(now()) @map("created_at")

  validations ClauseValidation[]

  @@index([contractId])
  @@index([libraryClauseId])
  @@map("contract_clauses")
}

model ClauseValidation {
  id                 String         @id @default(cuid())
  contractClauseId   String         @map("contract_clause_id")
  contractClause     ContractClause @relation(fields: [contractClauseId], references: [id], onDelete: Cascade)
  missingActor       Boolean        @default(false) @map("missing_actor")
  missingDeadline    Boolean        @default(false) @map("missing_deadline")
  missingConsequence Boolean        @default(false) @map("missing_consequence")
  missingNotice      Boolean        @default(false) @map("missing_notice")
  ambiguousLanguage  Boolean        @default(false) @map("ambiguous_language")
  aiFlag             Boolean        @default(false) @map("ai_flag")
  errorCodes         Json?          @map("error_codes")
  validatedByUserId  String?        @map("validated_by_user_id")
  validatedBy        User?          @relation("ClauseValidationValidator", fields: [validatedByUserId], references: [id], onDelete: SetNull)
  createdAt          DateTime       @default(now()) @map("created_at")

  @@index([contractClauseId, createdAt(sort: Desc)])
  @@map("clause_validations")
}

/// Issued contract / instrument numbers for traceability (promise, DS, brokerage, offer, etc.).
model ContractRegistry {
  id             String   @id @default(cuid())
  contractNumber String   @unique @map("contract_number") @db.VarChar(80)
  contractType   String   @map("contract_type") @db.VarChar(64)
  listingId      String?  @map("listing_id")
  dealId         String?  @map("deal_id")
  contractId     String?  @map("contract_id")
  createdBy      String   @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([contractType], map: "idx_contract_registry_type")
  @@index([listingId], map: "idx_contract_registry_listing")
  @@index([dealId], map: "idx_contract_registry_deal")
  @@map("contract_registry")
}

/// Regulator-style compliance inspection snapshot (advisory gate before release).
model ComplianceInspection {
  id        String   @id @default(cuid())
  ownerId   String   @map("owner_id")
  result    String   @db.VarChar(16)
  issues    Json
  context   Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([ownerId, createdAt(sort: Desc)], map: "idx_compliance_inspections_owner_created")
  @@map("compliance_inspections")
}

/// Immutable audit trail for enforceable contracts (append-only in application code).
model LegalContractAuditLog {
  id         String   @id @default(cuid())
  contractId String   @map("contract_id")
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String // created | signed | pdf_download
  ipAddress  String?  @map("ip_address")
  version    String?
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([contractId])
  @@index([userId])
  @@index([createdAt])
  @@map("legal_contract_audit_logs")
}

/// Commission ledger row — amounts require linked signed agreement when product rules say so.
model PlatformCommissionRecord {
  id                    String    @id @default(cuid())
  leadId                String?   @map("lead_id")
  lead                  Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  dealId                String?   @map("deal_id")
  deal                  Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  bookingId             String?   @map("booking_id")
  booking               Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  contractId            String?   @map("contract_id")
  contract              Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  commissionEligible    Boolean   @default(false) @map("commission_eligible")
  commissionSource      String?   @map("commission_source") // IMMO_CONTACT | PLATFORM_BROKER | DIRECT | BNHUB_BOOKING
  commissionAmountCents Int?      @map("commission_amount_cents")
  platformShareCents    Int?      @map("platform_share_cents")
  partnerShareCents     Int?      @map("partner_share_cents")
  currency              String    @default("cad")
  metadata              Json?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([leadId])
  @@index([dealId])
  @@index([bookingId])
  @@index([contractId])
  @@index([commissionSource])
  @@map("platform_commission_records")
}

/// Cross-cutting legal/financial disputes (listing, payment, commission, user report — not only BNHub booking disputes).
model PlatformLegalDispute {
  id                String   @id @default(cuid())
  /**
   * Immutable dispute reference (e.g. DSP-000001).
   */
  disputeCode       String?  @unique @map("dispute_code")
  type              String // booking | listing | payment | commission | user_report
  bookingId         String?  @map("booking_id")
  booking           Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  listingId         String?  @map("listing_id")
  fsboListingId     String?  @map("fsbo_listing_id")
  dealId            String?  @map("deal_id")
  deal              Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  leadId            String?  @map("lead_id")
  lead              Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  platformInvoiceId String?  @map("platform_invoice_id")
  platformPaymentId String?  @map("platform_payment_id")
  openedByUserId    String   @map("opened_by_user_id")
  openedBy          User     @relation("PlatformLegalDisputeOpenedBy", fields: [openedByUserId], references: [id], onDelete: Cascade)
  targetUserId      String?  @map("target_user_id")
  targetUser        User?    @relation("PlatformLegalDisputeTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  description       String   @db.Text
  evidenceUrls      Json?    @map("evidence_urls")
  status            String   @default("OPEN") // OPEN | UNDER_REVIEW | RESOLVED | REJECTED
  resolutionNote    String?  @map("resolution_note") @db.Text
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([type])
  @@index([status])
  @@index([openedByUserId])
  @@index([bookingId])
  @@index([dealId])
  @@index([leadId])
  @@map("platform_legal_disputes")
}

/// E-signatures for lease / rental contracts (multi-party).
model ContractSignature {
  id            String    @id @default(cuid())
  contractId    String    @map("contract_id")
  contract      Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  tenantId      String?   @map("tenant_id")
  tenant        Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  userId        String?   @map("user_id")
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  name          String
  email         String
  role          String // tenant | landlord | broker
  signedAt      DateTime? @map("signed_at")
  ipAddress     String?   @map("ip_address")
  signatureData String?   @map("signature_data") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([contractId])
  @@index([tenantId])
  @@index([userId])
  @@index([email])
  @@map("contract_signatures")
}

/// Auto-generated purchase / rental offer documents; optional link to Contract for e-sign.
model OfferDocument {
  id                       String                    @id @default(cuid())
  type                     String // purchase_offer | rental_offer
  listingId                String?                   @map("listing_id")
  listing                  ShortTermListing?         @relation(fields: [listingId], references: [id], onDelete: SetNull)
  leadId                   String?                   @map("lead_id")
  lead                     Lead?                     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contractId               String?                   @unique @map("contract_id")
  contract                 Contract?                 @relation(fields: [contractId], references: [id], onDelete: SetNull)
  createdById              String                    @map("created_by_id")
  createdBy                User                      @relation("OfferDocumentCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  status                   String                    @default("draft") // draft | sent | signed | accepted | rejected | expired
  offerPriceCents          Int?                      @map("offer_price_cents")
  conditionsJson           Json?
  contentHtml              String                    @map("content_html") @db.Text
  createdAt                DateTime                  @default(now()) @map("created_at")
  updatedAt                DateTime                  @updatedAt @map("updated_at")
  brokerTransactionRecords BrokerTransactionRecord[]

  @@index([listingId])
  @@index([leadId])
  @@index([createdById])
  @@index([status])
  @@index([type])
