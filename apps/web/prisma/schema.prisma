  dispute              BnhubMarketplaceDispute? @relation(fields: [disputeId], references: [id], onDelete: SetNull)
  bookingId            String?                  @map("booking_id")
  booking              Booking?                 @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  actorType            BnhubMpPaymentEventActor @map("actor_type")
  actorId              String?                  @map("actor_id")
  eventType            String                   @map("event_type")
  eventDataJson        Json                     @map("event_data_json")
  createdAt            DateTime                 @default(now()) @map("created_at")

  @@index([reservationPaymentId])
  @@index([bookingId])
  @@index([eventType])
  @@index([createdAt])
  @@map("bnhub_payment_events")
}

model BnhubFinancialLedgerEntry {
