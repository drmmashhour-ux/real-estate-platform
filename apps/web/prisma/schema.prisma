  listingId       String                   @map("listing_id")
  listing         Listing                  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  brokerUserId    String                   @map("broker_user_id")
  broker          User                     @relation("VisitRequestBroker", fields: [brokerUserId], references: [id], onDelete: Cascade)
  customerUserId  String?                  @map("customer_user_id")
  customer        User?                    @relation("VisitRequestCustomer", fields: [customerUserId], references: [id], onDelete: SetNull)
  guestName       String?                  @map("guest_name")
  guestEmail      String?                  @map("guest_email")
  requestedStart  DateTime                 @map("requested_start")
  requestedEnd    DateTime                 @map("requested_end")
  durationMinutes Int                      @default(45) @map("duration_minutes")
  status          LecipmVisitRequestStatus @default(pending)
