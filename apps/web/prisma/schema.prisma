  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("security_ip_blocks")
}

model SystemAlert {
  id           String              @id @default(uuid())
  alertType    String // FRAUD_SPIKE | PAYMENT_FAILURE | DISPUTE_SPIKE | LATENCY | ERROR_RATE
  severity     SystemAlertSeverity
  message      String
  threshold    Float?
  currentValue Float?
  resolvedAt   DateTime?
  resolvedBy   String?
  metadata     Json?
  createdAt    DateTime            @default(now())

  @@index([alertType])
  @@index([severity])
  @@index([resolvedAt])
  @@index([createdAt])
}

model PlatformEvent {
  id               String    @id @default(uuid())
  eventType        String    @map("event_type")
  sourceModule     String    @map("source_module")
  entityType       String?   @map("entity_type")
  entityId         String?   @map("entity_id")
  payload          Json?
  region           String?
  processingStatus String    @default("pending") @map("processing_status") // pending | processed | failed | dead
  processedAt      DateTime? @map("processed_at")
  errorMessage     String?   @map("error_message")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([eventType])
  @@index([sourceModule])
  @@index([entityType, entityId])
  @@index([processingStatus])
  @@index([createdAt])
  @@map("platform_events")
}

// ---------------------------------------------------------------------------
