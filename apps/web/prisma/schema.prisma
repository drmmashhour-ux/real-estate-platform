  featureGapJson       Json?    @map("feature_gap_json")
  recordedAt           DateTime @default(now()) @map("recorded_at")

  @@index([citySlug, recordedAt])
  @@map("monopoly_competitor_snapshots")
}

// ---------------------------------------------------------------------------
// Structured form submissions (OACIQ-style forms: amendments, promise-to-purchase, etc.)
// ---------------------------------------------------------------------------
model FormSubmission {
  id          String         @id @default(cuid())
  formType    String // amendments, promise-to-purchase, etc.
  status      String         @default("draft") // draft, submitted, in-review, approved, rejected, completed
  clientName  String?
  clientEmail String?
  assignedTo  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  payloadJson Json
  activities  FormActivity[]

  @@index([formType])
  @@index([status])
  @@index([createdAt])
}

model FormActivity {
  id               String         @id @default(cuid())
  formSubmissionId String
  formSubmission   FormSubmission @relation(fields: [formSubmissionId], references: [id], onDelete: Cascade)
  action           String // created, updated, submitted, approved, rejected, exported, status_changed
  note             String?
  createdAt        DateTime       @default(now())

  @@index([formSubmissionId])
}

/// Client quotes for marketing / trust sections (admin-moderated).
model Testimonial {
  id         String   @id @default(cuid())
  name       String
  role       String?
  city       String?
  quote      String   @db.Text
  rating     Int      @default(5)
  image      String?
  featured   Boolean  @default(false)
  isApproved Boolean  @default(false) @map("is_approved")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([isApproved, featured])
  @@index([createdAt])
  @@map("testimonials")
}

/// Outcome stories for social proof (admin-published).
model CaseStudy {
  id          String   @id @default(cuid())
  title       String
  city        String?
  summary     String   @db.Text
  challenge   String   @db.Text
  solution    String   @db.Text
  result      String   @db.Text
  image       String?
  featured    Boolean  @default(false)
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([isPublished, featured])
  @@index([createdAt])
  @@map("case_studies")
}

/// High-touch outreach rows for “first 10 clients” acquisition (per admin user).
model ClientAcquisitionLead {
  id            String    @id @default(cuid())
  ownerId       String    @map("owner_id")
  owner         User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name          String
  /// facebook | instagram | marketplace | other
  source        String    @default("facebook")
  phone         String?
  notes         String?   @db.Text
  messageSent   Boolean   @default(false) @map("message_sent")
  replied       Boolean   @default(false)
  interested    Boolean   @default(false)
  callScheduled Boolean   @default(false) @map("call_scheduled")
  closed        Boolean   @default(false)
  messageSentAt DateTime? @map("message_sent_at")
  repliedAt     DateTime? @map("replied_at")
  interestedAt  DateTime? @map("interested_at")
  callAt        DateTime? @map("call_at")
  closedAt      DateTime? @map("closed_at")
  /// mortgage | rent | buy (set when closed)
  serviceType   String?   @map("service_type")
  valueCents    Int?      @map("value_cents")
  revenueCents  Int?      @map("revenue_cents")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([ownerId])
  @@index([ownerId, closed])
  @@index([ownerId, createdAt])
  @@map("client_acquisition_leads")
}

/// Daily counters toward fixed launch targets (contact / leads / calls / closes).
model ClientAcquisitionDailyProgress {
  id                 String   @id @default(cuid())
  ownerId            String   @map("owner_id")
  owner              User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  /// UTC midnight for the calendar day
  date               DateTime
  contactsCount      Int      @default(0) @map("contacts_count")
  leadsCount         Int      @default(0) @map("leads_count")
  callsBookedCount   Int      @default(0) @map("calls_booked_count")
  clientsClosedCount Int      @default(0) @map("clients_closed_count")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([ownerId, date])
  @@index([ownerId])
  @@index([date])
  @@map("client_acquisition_daily_progress")
}

/// Global daily rollup for LECIPM launch phase (outreach, content, conversion). Admin-incremented or scripted.
model LaunchPhaseDailyStats {
  id                 String   @id @default(cuid())
  /// UTC calendar day (store at midnight UTC).
  date               DateTime @db.Date
  /// Outreach
  messagesSent       Int      @default(0) @map("messages_sent")
  repliesReceived    Int      @default(0) @map("replies_received")
  demosBooked        Int      @default(0) @map("demos_booked")
  demosCompleted     Int      @default(0) @map("demos_completed")
  /// Product
  usersCreated       Int      @default(0) @map("users_created")
  activatedUsers     Int      @default(0) @map("activated_users")
  payingUsers        Int      @default(0) @map("paying_users")
  /// Content
  postsCreated       Int      @default(0) @map("posts_created")
  contentViews       Int      @default(0) @map("content_views")
  contentClicks      Int      @default(0) @map("content_clicks")
  contentConversions Int      @default(0) @map("content_conversions")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([date])
  @@index([date])
  @@map("launch_phase_daily_stats")
}

/// Admin-managed spellcheck: allowlist words (valid) or ignore flags (skip warnings).
model SpellDictionaryEntry {
  id        String   @id @default(cuid())
  locale    String   @default("both") // en | fr | both
  word      String
  /// allow = treat as valid dictionary word; ignore = same (do not flag)
  kind      String   @default("allow")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([word, locale, kind])
  @@index([locale])
  @@map("spell_dictionary_entries")
}

/// AI Writing Assistant usage (POST /api/ai/write) for admin reporting.
model AiWriterUsageLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  type      String
  action    String?
  promptLen Int      @default(0) @map("prompt_len")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("ai_writer_usage_logs")
}

/// Daily aggregates: `visitors` incremented by POST /api/analytics/track-visit.
/// Listing and transaction fields on the row are optional denorm targets; charts use live DB counts per day (see getPlatformStats).
model PlatformAnalytics {
  id                 String   @id @default(cuid())
  /// UTC midnight for the calendar day
  date               DateTime
  visitors           Int      @default(0)
  listingsBroker     Int      @default(0) @map("listings_broker")
  listingsSelf       Int      @default(0) @map("listings_self")
  transactionsClosed Int      @default(0) @map("transactions_closed")
  createdAt          DateTime @default(now()) @map("created_at")

  @@unique([date])
  @@index([date])
  @@map("platform_analytics")
}

// ---------------------------------------------------------------------------
// Listing offer workflow (buyer ↔ broker; audit via OfferEvent)
// ---------------------------------------------------------------------------

enum OfferStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  COUNTERED
  ACCEPTED
  REJECTED
  WITHDRAWN
  EXPIRED
}

enum OfferEventType {
  CREATED
  SUBMITTED
  STATUS_CHANGED
  COUNTERED
  ACCEPTED
  REJECTED
  WITHDRAWN
  NOTE_ADDED
}

model Offer {
  id        String      @id @default(cuid())
  listingId String      @map("listing_id")
  buyerId   String      @map("buyer_id")
  brokerId  String?     @map("broker_id")
  tenantId  String?     @map("tenant_id")
  tenant    Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  status    OfferStatus @default(DRAFT)

  offeredPrice      Float     @map("offered_price")
  downPaymentAmount Float?    @map("down_payment_amount")
  financingNeeded   Boolean?  @map("financing_needed")
  closingDate       DateTime? @map("closing_date")
  conditions        String?   @db.Text
  message           String?   @db.Text

  /// Mortgage / offer assumptions (e.g. simulator snapshot)
  scenario Json?

  commissionEligible Boolean @default(true) @map("commission_eligible")
  /// DIRECT_LEAD (buyer contacted listing broker) | PLATFORM_BROKER (platform-facilitated).
  commissionSource   String? @map("commission_source")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  buyer           User             @relation("ListingOfferBuyer", fields: [buyerId], references: [id], onDelete: Restrict)
  broker          User?            @relation("ListingOfferBroker", fields: [brokerId], references: [id], onDelete: SetNull)
  events          OfferEvent[]
  appointments    Appointment[]
  conversations   Conversation[]
  documentFolders DocumentFolder[]
  documentFiles   DocumentFile[]
  dealFinancials  DealFinancial[]
  tenantInvoices  TenantInvoice[]

  @@index([listingId])
  @@index([buyerId])
  @@index([brokerId])
  @@index([tenantId])
  @@index([status])
  @@map("listing_offers")
}

model OfferEvent {
  id        String         @id @default(cuid())
  offerId   String         @map("offer_id")
  tenantId  String?        @map("tenant_id")
  tenant    Tenant?        @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorId   String?        @map("actor_id")
  type      OfferEventType
  message   String?        @db.Text
  metadata  Json?
  createdAt DateTime       @default(now()) @map("created_at")

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  actor User? @relation("ListingOfferEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([offerId])
  @@index([tenantId])
  @@map("listing_offer_events")
}

// ---------------------------------------------------------------------------
// Broker CRM — clients, interactions, listing links (no duplicate offer/contract rows)
// ---------------------------------------------------------------------------

enum BrokerClientStatus {
  LEAD
  CONTACTED
  QUALIFIED
  VIEWING
  NEGOTIATING
  UNDER_CONTRACT
  CLOSED
  LOST
}

enum BrokerInteractionType {
  NOTE
  EMAIL
  CALL
  MEETING
  TASK
  FOLLOW_UP
  STATUS_CHANGE
}

enum BrokerClientListingKind {
  SAVED
  SHARED
  VIEWED
  FAVORITE
}

model BrokerClient {
  id         String             @id @default(cuid())
  brokerId   String             @map("broker_id")
  tenantId   String?            @map("tenant_id")
  tenant     Tenant?            @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  userId     String?            @map("user_id")
  fullName   String             @map("full_name")
  email      String?
  phone      String?
  status     BrokerClientStatus @default(LEAD)
  source     String?
  budgetMin  Float?             @map("budget_min")
  budgetMax  Float?             @map("budget_max")
  targetCity String?            @map("target_city")
  notes      String?            @db.Text
  tags       String[]           @default([])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  broker                User                      @relation("BrokerCrmOwner", fields: [brokerId], references: [id], onDelete: Cascade)
  linkedUser            User?                     @relation("BrokerCrmLinkedUser", fields: [userId], references: [id], onDelete: SetNull)
  interactions          BrokerClientInteraction[]
  listingLinks          BrokerClientListing[]
  appointments          Appointment[]
  conversations         Conversation[]
  buyerRequests         BuyerRequest[]
  documentFolders       DocumentFolder[]
  documentFiles         DocumentFile[]
  intakeProfile         ClientIntakeProfile?
  requiredDocumentItems RequiredDocumentItem[]
  intakeEvents          ClientIntakeEvent[]
  tenantInvoices        TenantInvoice[]

  @@index([brokerId])
  @@index([userId])
  @@index([status])
  @@map("broker_clients")
}

model BrokerClientInteraction {
  id             String                @id @default(cuid())
  brokerClientId String                @map("broker_client_id")
  actorId        String?               @map("actor_id")
  type           BrokerInteractionType
  title          String?
  message        String?               @db.Text
  metadata       Json?
  dueAt          DateTime?             @map("due_at")
  completedAt    DateTime?             @map("completed_at")
  createdAt      DateTime              @default(now()) @map("created_at")

  brokerClient BrokerClient @relation(fields: [brokerClientId], references: [id], onDelete: Cascade)
  actor        User?        @relation("BrokerCrmInteractionActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([brokerClientId])
  @@index([dueAt])
  @@map("broker_client_interactions")
}

model BrokerClientListing {
  id             String                  @id @default(cuid())
  brokerClientId String                  @map("broker_client_id")
  listingId      String                  @map("listing_id")
  kind           BrokerClientListingKind @default(SAVED)
  createdAt      DateTime                @default(now()) @map("created_at")

  brokerClient BrokerClient @relation(fields: [brokerClientId], references: [id], onDelete: Cascade)

  @@unique([brokerClientId, listingId])
  @@index([brokerClientId])
  @@index([listingId])
  @@map("broker_client_listings")
}

// ---------------------------------------------------------------------------
// Scheduling — availability, appointments (calendar / visits / calls)
// ---------------------------------------------------------------------------

enum AppointmentType {
  PROPERTY_VISIT
  CALL
  MEETING
  CONSULTATION
  DOCUMENT_REVIEW
  OFFER_DISCUSSION
  CONTRACT_SIGNING
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  RESCHEDULE_REQUESTED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum MeetingMode {
  IN_PERSON
  PHONE
  VIDEO
}

enum AppointmentEventType {
  REQUESTED
  CONFIRMED
  RESCHEDULED
  CANCELLED
  COMPLETED
  NO_SHOW
  NOTE_ADDED
  STATUS_CHANGED
}

model AvailabilityRule {
  id          String   @id @default(cuid())
  brokerId    String   @map("broker_id")
  /// 0 = Sunday … 6 = Saturday (aligns with Date.getUTCDay() when using UTC rules)
  dayOfWeek   Int      @map("day_of_week")
  /// Minutes from midnight [0, 1440)
  startMinute Int      @map("start_minute")
  endMinute   Int      @map("end_minute")
  isActive    Boolean  @default(true) @map("is_active")
  timezone    String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  broker User @relation(fields: [brokerId], references: [id], onDelete: Cascade)

  @@index([brokerId])
  @@index([dayOfWeek])
  @@map("availability_rules")
}

model AvailabilityException {
  id          String   @id @default(cuid())
  brokerId    String   @map("broker_id")
  startsAt    DateTime @map("starts_at")
  endsAt      DateTime @map("ends_at")
  reason      String?
  /// false = blocked / unavailable; true = extra availability window
  isAvailable Boolean  @default(false) @map("is_available")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  broker User @relation(fields: [brokerId], references: [id], onDelete: Cascade)

  @@index([brokerId])
  @@index([startsAt])
  @@map("availability_exceptions")
}

model Appointment {
  id                 String            @id @default(cuid())
  brokerId           String            @map("broker_id")
  tenantId           String?           @map("tenant_id")
  tenant             Tenant?           @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  clientUserId       String?           @map("client_user_id")
  brokerClientId     String?           @map("broker_client_id")
  listingId          String?           @map("listing_id")
  offerId            String?           @map("offer_id")
  contractId         String?           @map("contract_id")
  type               AppointmentType
  status             AppointmentStatus @default(PENDING)
  title              String
  description        String?           @db.Text
  location           String?
  startsAt           DateTime          @map("starts_at")
  endsAt             DateTime          @map("ends_at")
  timezone           String?
  meetingMode        MeetingMode       @default(IN_PERSON) @map("meeting_mode")
  requestedById      String?           @map("requested_by_id")
  confirmedAt        DateTime?         @map("confirmed_at")
  cancelledAt        DateTime?         @map("cancelled_at")
  cancellationReason String?           @map("cancellation_reason") @db.Text
  rescheduleReason   String?           @map("reschedule_reason") @db.Text
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  broker          User               @relation("AppointmentBroker", fields: [brokerId], references: [id], onDelete: Cascade)
  clientUser      User?              @relation("AppointmentClientUser", fields: [clientUserId], references: [id], onDelete: SetNull)
  brokerClient    BrokerClient?      @relation(fields: [brokerClientId], references: [id], onDelete: SetNull)
  listing         Listing?           @relation(fields: [listingId], references: [id], onDelete: SetNull)
  offer           Offer?             @relation(fields: [offerId], references: [id], onDelete: SetNull)
  contract        Contract?          @relation(fields: [contractId], references: [id], onDelete: SetNull)
  requestedBy     User?              @relation("AppointmentRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  events          AppointmentEvent[]
  conversations   Conversation[]
  documentFolders DocumentFolder[]
  documentFiles   DocumentFile[]

  @@index([brokerId])
  @@index([tenantId])
  @@index([clientUserId])
  @@index([brokerClientId])
  @@index([listingId])
  @@index([offerId])
  @@index([contractId])
  @@index([startsAt])
  @@index([status])
  @@map("appointments")
}

model AppointmentEvent {
  id            String               @id @default(cuid())
  appointmentId String               @map("appointment_id")
  tenantId      String?              @map("tenant_id")
  tenant        Tenant?              @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorId       String?              @map("actor_id")
  type          AppointmentEventType
  message       String?              @db.Text
  metadata      Json?
  createdAt     DateTime             @default(now()) @map("created_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  actor       User?       @relation("AppointmentEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([appointmentId])
  @@index([tenantId])
  @@map("appointment_events")
}

// ---------------------------------------------------------------------------
// In-app messaging — conversations, messages, read state
// ---------------------------------------------------------------------------

enum ConversationType {
  DIRECT
  LISTING
  OFFER
  CONTRACT
  APPOINTMENT
  CLIENT_THREAD
  SUPPORT
}

enum MessageType {
  TEXT
  SYSTEM
  NOTE
}

enum MessageEventType {
  CONVERSATION_CREATED
  PARTICIPANT_ADDED
  MESSAGE_SENT
  MESSAGE_EDITED
  MESSAGE_DELETED
  CONVERSATION_ARCHIVED
  READ
}

model Conversation {
  id             String           @id @default(cuid())
  type           ConversationType @default(DIRECT)
  tenantId       String?          @map("tenant_id")
  tenant         Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  listingId      String?          @map("listing_id")
  offerId        String?          @map("offer_id")
  contractId     String?          @map("contract_id")
  appointmentId  String?          @map("appointment_id")
  brokerClientId String?          @map("broker_client_id")
  createdById    String?          @map("created_by_id")
  subject        String?
  lastMessageAt  DateTime?        @map("last_message_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  createdBy              User?                     @relation("ConversationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  listing                Listing?                  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  offer                  Offer?                    @relation(fields: [offerId], references: [id], onDelete: SetNull)
  contract               Contract?                 @relation(fields: [contractId], references: [id], onDelete: SetNull)
  appointment            Appointment?              @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  brokerClient           BrokerClient?             @relation(fields: [brokerClientId], references: [id], onDelete: SetNull)
  participants           ConversationParticipant[]
  messages               Message[]
  events                 MessageEvent[]
  documentFolders        DocumentFolder[]
  documentFiles          DocumentFile[]
  buyerRequest           BuyerRequest?
  leadForPlatformContact Lead?                     @relation("LeadPlatformConversation")

  @@index([listingId])
  @@index([tenantId])
  @@index([offerId])
  @@index([contractId])
  @@index([appointmentId])
  @@index([brokerClientId])
  @@index([lastMessageAt])
  @@map("conversations")
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String    @map("conversation_id")
  userId         String    @map("user_id")
  roleLabel      String?   @map("role_label")
  isArchived     Boolean   @default(false) @map("is_archived")
  lastReadAt     DateTime? @map("last_read_at")
  joinedAt       DateTime  @default(now()) @map("joined_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String      @id @default(cuid())
  conversationId String      @map("conversation_id")
  tenantId       String?     @map("tenant_id")
  tenant         Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  senderId       String      @map("sender_id")
  body           String      @db.Text
  messageType    MessageType @default(TEXT) @map("message_type")
  metadata       Json?
  editedAt       DateTime?   @map("edited_at")
  deletedAt      DateTime?   @map("deleted_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  conversation Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User           @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  events       MessageEvent[]

  @@index([conversationId])
  @@index([tenantId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}

model MessageEvent {
  id             String           @id @default(cuid())
  messageId      String?          @map("message_id")
  conversationId String           @map("conversation_id")
  actorId        String?          @map("actor_id")
  type           MessageEventType
  metadata       Json?
  createdAt      DateTime         @default(now()) @map("created_at")

  message      Message?     @relation(fields: [messageId], references: [id], onDelete: SetNull)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  actor        User?        @relation("MessageEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@index([messageId])
  @@map("message_events")
}

