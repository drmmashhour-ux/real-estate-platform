/// Rule-based nightly suggestions — apply flow updates listing `nightPriceCents` via `pricing-apply.service`.
model BnhubPricingSuggestion {
  id          String           @id @default(cuid())
  listingId   String           @map("listing_id")
  listing     ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  /// Calendar night (UTC date) this row applies to.
  date        DateTime         @db.Date
  suggested   Float
  basePrice   Float            @map("base_price")
  demandScore Float            @map("demand_score")
  reason      String           @db.Text
  /// pending | approved | rejected | applied
  status      String           @default("pending") @db.VarChar(24)
  appliedAt   DateTime?        @map("applied_at")
  createdAt   DateTime         @default(now()) @map("created_at")

  @@unique([listingId, date])
  @@index([listingId, date])
  @@index([listingId, status])
  @@map("bnhub_pricing_suggestions")
}

/// Append-only audit of pricing applies (never delete rows).
model BnhubPricingExecutionLog {
  id           String           @id @default(cuid())
  listingId    String           @map("listing_id")
  listing      ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  date         DateTime         @db.Date
  oldPrice     Float            @map("old_price")
  newPrice     Float            @map("new_price")
  /// cron_auto | host_ui | manual_approve_auto (source label)
  mode         String           @db.VarChar(32)
  /// success | rejected | skipped
  status       String           @db.VarChar(24)
  reason       String?          @db.Text
  suggestionId String?          @map("suggestion_id")
  createdAt    DateTime         @default(now()) @map("created_at")

  @@index([listingId, createdAt])
  @@map("bnhub_pricing_execution_logs")
}

