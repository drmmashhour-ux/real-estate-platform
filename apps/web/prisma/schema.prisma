  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String // listing_created | contract_signed | booking | payment | etc.
  entityType String?  @map("entity_type") // listing | contract | booking | transaction
  entityId   String?  @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("activity_logs")
}

model PolicyAcceptanceRecord {
  id            String   @id @default(uuid())
  userId        String
  policyKey     String // terms_of_service | privacy_policy | booking_terms | payout_terms | host_responsibility | guest_conduct | listing_accuracy
  policyVersion String
  acceptedAt    DateTime @default(now())
  marketId      String? // jurisdiction / market
  entityType    String? // BOOKING | LISTING | PAYOUT when context-specific
  entityId      String?
  ipAddress     String?
  userAgent     String?
  metadata      Json?

  @@index([userId])
  @@index([policyKey])
  @@index([acceptedAt])
  @@index([marketId])
}

model LegalEventLog {
  id         String   @id @default(uuid())
  eventType  String // TERMS_ACCEPTED | DISCLOSURE_SHOWN | ACKNOWLEDGEMENT | POLICY_CHANGE | JURISDICTION_BINDING
  userId     String?
  entityType String?
  entityId   String?
  marketId   String?
  payload    Json? // version, policyKey, evidence snapshot
  reasonCode String?
  createdAt  DateTime @default(now())

  @@index([eventType])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// 2. Evidence Preservation – chain-of-custody, access log
// ---------------------------------------------------------------------------
model EvidenceRecord {
  id             String    @id @default(uuid())
  caseType       String // DISPUTE | FRAUD | INCIDENT | COMPLIANCE | LEGAL
  caseId         String
  classification String // PHOTO | DOCUMENT | SCREENSHOT | LOG_EXPORT
  url            String // storage URL or reference
  filename       String?
  mimeType       String?
  uploadedBy     String
  uploadedAt     DateTime  @default(now())
  metadata       Json?
  retentionUntil DateTime?
  checksum       String? // integrity

  @@index([caseType, caseId])
  @@index([uploadedAt])
}

model EvidenceAccessLog {
  id         String   @id @default(uuid())
  evidenceId String
  accessedBy String
  accessType String // VIEW | EXPORT | DOWNLOAD
  reasonCode String?
  createdAt  DateTime @default(now())

  @@index([evidenceId])
  @@index([accessedBy])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// 3. Abuse Prevention – signals, offender profiles
// ---------------------------------------------------------------------------
enum AbuseSignalType {
  REPEAT_OFFENDER
  LINKED_ACCOUNT
  EVASION_AFTER_SUSPENSION
  ABUSIVE_MESSAGING
  ABUSIVE_BOOKING
  REFUND_ABUSE
  PROMOTION_ABUSE
  REFERRAL_ABUSE
  BAN_EVASION
}

model AbuseSignal {
  id         String          @id @default(uuid())
  userId     String?
  entityType String?
  entityId   String?
  signalType AbuseSignalType
  severity   String // LOW | MEDIUM | HIGH
  payload    Json? // IP, device hints, correlation ids
  createdBy  String? // system or staff
  createdAt  DateTime        @default(now())

  @@index([userId])
  @@index([signalType])
  @@index([createdAt])
}

model OffenderProfile {
  id               String    @id @default(uuid())
  userId           String    @unique
  strikeCount      Int       @default(0)
  lastStrikeAt     DateTime?
  suspendedAt      DateTime?
  bannedAt         DateTime?
  linkedAccountIds Json      @default("[]") // suspected or confirmed
  notes            String?
  updatedAt        DateTime
  createdAt        DateTime  @default(now())

  @@index([userId])
}

// ---------------------------------------------------------------------------
// 4. Internal Access – privileged actions, approvals
// ---------------------------------------------------------------------------
model PrivilegedAdminAction {
  id         String   @id @default(uuid())
  adminId    String
  actionType String // PAYOUT_RELEASE | SUSPENSION | BAN | IMPERSONATION | EVIDENCE_ACCESS | LEGAL_EXPORT
  entityType String?
  entityId   String?
  reasonCode String?
  reasonText String?
  approvalId String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([actionType])
  @@index([createdAt])
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model ApprovalRequest {
  id          String                @id @default(uuid())
  requestType String // PAYOUT_RELEASE | ACCOUNT_SUSPENSION | BAN | CRISIS_ACTION
  requestedBy String
  targetType  String?
  targetId    String?
  reasonCode  String?
  payload     Json?
  status      ApprovalRequestStatus @default(PENDING)
  reviewedBy  String?
  reviewedAt  DateTime?
