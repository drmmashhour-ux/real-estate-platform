  entityId    String   @map("entity_id")
  signalType  String   @map("signal_type")
  severity    String
  explanation String   @db.Text
  metadata    Json     @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([signalType])
  @@index([createdAt])
  @@map("legal_intelligence_records")
}

// ---------------------------------------------------------------------------
// TrustGraph Autopilot — unified verification / trust / readiness engine
// ---------------------------------------------------------------------------

/// ================================
/// TRUSTGRAPH ENUMS
/// ================================

enum VerificationEntityType {
  LISTING
  SELLER
  BUYER
  TENANT
  GUEST
  BROKER
  BOOKING
  OFFER
  RENTAL_APPLICATION
  MORTGAGE_FILE
  SELLER_DECLARATION
  /// BNHub host profile (`entity_id` = `BnhubHost.id`)
  HOST
  /// BNHub short-term listing (`entity_id` = `ShortTermListing.id`)
  SHORT_TERM_LISTING
}

enum VerificationCaseStatus {
  pending
  in_review
  approved
  rejected
  needs_info
  escalated
}

enum TrustLevel {
  low
  medium
  high
  verified
}

enum ReadinessLevel {
  not_ready
  partial
  ready
  action_required
}

enum VerificationSignalCategory {
  identity
  address
  media
  legal
  financial
  behavior
  fraud
  compliance
  quality
}

enum VerificationSeverity {
  info
  low
  medium
  high
  critical
}

enum VerificationSignalStatus {
  open
  accepted
  dismissed
  resolved
}

enum TrustProfileSubjectType {
  user
  broker
  listing
  property_owner
  host
}

enum HumanReviewActionType {
  approve
  reject
  request_info
  override_score
  dismiss_signal
  escalate
  assign
}

enum NextBestActionPriority {
  low
  medium
  high
  urgent
}

enum NextBestActionActorType {
  user
  broker
  admin
  legal
  system
}

enum NextBestActionStatus {
  pending
  completed
  dismissed
}

enum MediaVerificationJobStatus {
  queued
  processing
  completed
  failed
}

enum MediaVerificationType {
  exterior
  interior
  street
  document
  id
  other
}

/// ================================
/// TRUSTGRAPH MODELS
/// ================================

model VerificationCase {
  id             String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType     VerificationEntityType @map("entity_type")
  entityId       String                 @map("entity_id")
  status         VerificationCaseStatus @default(pending)
  overallScore   Int?                   @map("overall_score")
  trustLevel     TrustLevel?            @map("trust_level")
  readinessLevel ReadinessLevel?        @map("readiness_level")
  summary        Json?                  @db.JsonB
  scoreBreakdown Json?                  @map("score_breakdown") @db.JsonB
  explanation    String?                @db.Text

  createdBy  String? @map("created_by")
  assignedTo String? @map("assigned_to")

  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  resolvedAt DateTime? @map("resolved_at") @db.Timestamptz(6)

  signals               VerificationSignal[]
  ruleResults           VerificationRuleResult[]
  reviewActions         HumanReviewAction[]
  nextBestActions       NextBestAction[]
  mediaJobs             MediaVerificationJob[]
  links                 EntityVerificationLink[]
  trustProfilesLastCase TrustProfile[]                      @relation("TrustProfileLastCase")
  workspaceAssignments  TrustgraphWorkspaceCaseAssignment[]
  slaState              TrustgraphCaseSlaState?

  @@index([entityType, entityId], map: "idx_verification_cases_entity")
  @@index([entityType, entityId, updatedAt(sort: Desc)], map: "idx_verification_cases_entity_updated")
  @@index([status], map: "idx_verification_cases_status")
  @@index([trustLevel], map: "idx_verification_cases_trust_level")
  @@index([readinessLevel], map: "idx_verification_cases_readiness_level")
  @@index([assignedTo], map: "idx_verification_cases_assigned_to")
  @@index([updatedAt], map: "idx_verification_cases_updated_at")
  @@map("verification_cases")
}

model VerificationSignal {
  id          String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caseId      String                     @map("case_id") @db.Uuid
  signalCode  String                     @map("signal_code")
  signalName  String                     @map("signal_name")
  category    VerificationSignalCategory
  severity    VerificationSeverity
  status      VerificationSignalStatus   @default(open)
  scoreImpact Int                        @default(0) @map("score_impact")
  confidence  Decimal?                   @db.Decimal(5, 4)
  evidence    Json?                      @db.JsonB
  message     String?                    @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  case VerificationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId], map: "idx_verification_signals_case_id")
  @@index([signalCode], map: "idx_verification_signals_signal_code")
  @@index([category], map: "idx_verification_signals_category")
  @@index([severity], map: "idx_verification_signals_severity")
  @@index([status], map: "idx_verification_signals_status")
  @@map("verification_signals")
}

model VerificationRuleResult {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caseId      String   @map("case_id") @db.Uuid
  ruleCode    String   @map("rule_code")
  ruleVersion String   @default("1") @map("rule_version")
  passed      Boolean  @default(false)
  scoreDelta  Int      @default(0) @map("score_delta")
  confidence  Decimal? @db.Decimal(5, 4)
  details     Json?    @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  case VerificationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId], map: "idx_verification_rule_results_case_id")
  @@index([ruleCode], map: "idx_verification_rule_results_rule_code")
  @@map("verification_rule_results")
}

model TrustProfile {
  id              String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subjectType     TrustProfileSubjectType @map("subject_type")
  subjectId       String                  @map("subject_id")
  trustScore      Int                     @default(0) @map("trust_score")
  fraudScore      Int                     @default(0) @map("fraud_score")
  completionScore Int                     @default(0) @map("completion_score")
  qualityScore    Int                     @default(0) @map("quality_score")
  legalScore      Int                     @default(0) @map("legal_score")
  badges          Json?                   @db.JsonB

  lastCaseId String?  @map("last_case_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  lastCase VerificationCase? @relation("TrustProfileLastCase", fields: [lastCaseId], references: [id], onDelete: SetNull)

  @@unique([subjectType, subjectId], map: "uq_trust_profiles_subject")
  @@index([subjectType, subjectId], map: "idx_trust_profiles_subject")
  @@index([lastCaseId], map: "idx_trust_profiles_last_case_id")
  @@map("trust_profiles")
}

model HumanReviewAction {
  id         String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caseId     String                @map("case_id") @db.Uuid
  reviewerId String                @map("reviewer_id")
  actionType HumanReviewActionType @map("action_type")
  notes      String?               @db.Text
  payload    Json?                 @db.JsonB
  createdAt  DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  case     VerificationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  reviewer User             @relation("HumanReviewReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([caseId], map: "idx_human_review_actions_case_id")
  @@index([reviewerId], map: "idx_human_review_actions_reviewer_id")
  @@index([actionType], map: "idx_human_review_actions_action_type")
  @@map("human_review_actions")
}

model NextBestAction {
  id          String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caseId      String                  @map("case_id") @db.Uuid
  actionCode  String                  @map("action_code")
  title       String
  description String                  @db.Text
  priority    NextBestActionPriority  @default(medium)
  actorType   NextBestActionActorType @map("actor_type")
  status      NextBestActionStatus    @default(pending)
  dueAt       DateTime?               @map("due_at") @db.Timestamptz(6)
  metadata    Json?                   @db.JsonB
  createdAt   DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  case VerificationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId], map: "idx_next_best_actions_case_id")
  @@index([status], map: "idx_next_best_actions_status")
  @@index([priority], map: "idx_next_best_actions_priority")
  @@index([actorType], map: "idx_next_best_actions_actor_type")
  @@map("next_best_actions")
}

model MediaVerificationJob {
  id                          String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listingId                   String                     @map("listing_id")
  caseId                      String?                    @map("case_id") @db.Uuid
  jobStatus                   MediaVerificationJobStatus @default(queued) @map("job_status")
  mediaType                   MediaVerificationType      @map("media_type")
  filePath                    String                     @map("file_path")
  extractedMetadata           Json?                      @map("extracted_metadata") @db.JsonB
  result                      Json?                      @db.JsonB
  /// Phase 6 — scene classification (exterior | interior | street | document | id | unknown)
  predictedCategory           String?                    @map("predicted_category")
  sceneConfidence             Float?                     @map("scene_confidence")
  classificationEngineVersion String?                    @map("classification_engine_version")
  perceptualHash              String?                    @map("perceptual_hash")
  createdAt                   DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                   DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)

  case VerificationCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([listingId], map: "idx_media_verification_jobs_listing_id")
  @@index([caseId], map: "idx_media_verification_jobs_case_id")
  @@index([jobStatus], map: "idx_media_verification_jobs_status")
  @@index([mediaType], map: "idx_media_verification_jobs_media_type")
  @@map("media_verification_jobs")
}

// ---------------------------------------------------------------------------
// TrustGraph Phase 6 — extraction, geospatial, fraud graph (internal evidence)
// ---------------------------------------------------------------------------

enum TrustgraphExtractionSourceKind {
  seller_supporting_document
  mortgage_request
}

enum TrustgraphExtractionJobStatus {
  queued
  running
  completed
  failed
  needs_review
}

model TrustgraphExtractionJob {
  id             String                         @id @default(uuid())
  sourceKind     TrustgraphExtractionSourceKind @map("source_kind")
  sourceId       String                         @map("source_id")
  fsboListingId  String?                        @map("fsbo_listing_id")
  mortgageFileId String?                        @map("mortgage_file_id")
  status         TrustgraphExtractionJobStatus  @default(queued)
  modelVersion   String                         @default("stub-v1") @map("model_version")
  errorMessage   String?                        @map("error_message") @db.Text
  createdAt      DateTime                       @default(now()) @map("created_at")
  updatedAt      DateTime                       @updatedAt @map("updated_at")

  record TrustgraphExtractedDocumentRecord?

  @@index([sourceKind, sourceId], map: "idx_tg_extraction_source")
  @@index([fsboListingId], map: "idx_tg_extraction_listing")
  @@map("trustgraph_extraction_jobs")
}

model TrustgraphExtractedDocumentRecord {
  id                String                  @id @default(uuid())
  jobId             String                  @unique @map("job_id")
  job               TrustgraphExtractionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  storageRef        String                  @map("storage_ref")
  documentType      String?                 @map("document_type")
  extractionStatus  String                  @default("pending") @map("extraction_status")
  extractedPayload  Json?                   @map("extracted_payload") @db.JsonB
  normalizedPayload Json?                   @map("normalized_payload") @db.JsonB
  confidence        Float?
  modelVersion      String?                 @map("model_version")
  reviewedBy        String?                 @map("reviewed_by")
  reviewedAt        DateTime?               @map("reviewed_at") @db.Timestamptz(6)
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")

  fields  TrustgraphExtractedDocumentField[]
  reviews TrustgraphExtractionReviewAction[]

  @@map("trustgraph_extracted_document_records")
}

model TrustgraphExtractedDocumentField {
  id          String                            @id @default(uuid())
  recordId    String                            @map("record_id")
  record      TrustgraphExtractedDocumentRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  fieldKey    String                            @map("field_key")
  fieldValue  String?                           @map("field_value") @db.Text
  confidence  Float?
  valueSource String                            @default("extraction") @map("value_source")

  @@index([recordId], map: "idx_tg_extracted_fields_record")
  @@map("trustgraph_extracted_document_fields")
}

model TrustgraphExtractionReviewAction {
  id         String                            @id @default(uuid())
  recordId   String                            @map("record_id")
  record     TrustgraphExtractedDocumentRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  actionType String                            @map("action_type")
  reviewerId String                            @map("reviewer_id")
  notes      String?                           @db.Text
  createdAt  DateTime                          @default(now()) @map("created_at")

  @@index([recordId], map: "idx_tg_extraction_reviews_record")
  @@map("trustgraph_extraction_review_actions")
}

enum TrustgraphFraudGraphNodeKind {
  user
  listing
  broker
  upload
  fingerprint
  phone
  email
}

model TrustgraphFraudGraphNode {
  id         String                       @id @default(uuid())
  kind       TrustgraphFraudGraphNodeKind
  externalId String                       @map("external_id")
  metadata   Json?                        @db.JsonB
  createdAt  DateTime                     @default(now()) @map("created_at")
  updatedAt  DateTime                     @updatedAt @map("updated_at")

  edgesFrom TrustgraphFraudGraphEdge[] @relation("FraudGraphEdgeFrom")
  edgesTo   TrustgraphFraudGraphEdge[] @relation("FraudGraphEdgeTo")

  @@unique([kind, externalId], map: "uq_fraud_graph_node_kind_ext")
  @@map("fraud_graph_nodes")
}

model TrustgraphFraudGraphEdge {
  id         String   @id @default(uuid())
