// ---------------------------------------------------------------------------
// LECIPM Enterprise — team workspaces, RBAC, invites, audit (billing scope uses Subscription.workspace_id UUID)
// ---------------------------------------------------------------------------

enum LecipmWorkspaceRole {
  owner
  admin
  manager
  broker
  analyst
  viewer
  compliance_reviewer

  @@map("lecipm_workspace_role")
}

enum LecipmWorkspaceInviteStatus {
  pending
  accepted
  expired
  revoked

  @@map("lecipm_workspace_invite_status")
}

model EnterpriseWorkspace {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  slug            String?  @unique
  createdByUserId String   @map("created_by_user_id")
  createdBy       User     @relation("EnterpriseWorkspaceCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  settings        Json?    @db.JsonB
  seatLimit       Int      @default(10) @map("seat_limit")
  planTier        String   @default("team") @map("plan_tier")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  members                        EnterpriseWorkspaceMember[]
  invites                        EnterpriseWorkspaceInvite[]
  auditLogs                      WorkspaceAuditLog[]
  deals                          Deal[]
  leads                          Lead[]
  documentFiles                  DocumentFile[]
  lecipmAiOperatorActions        LecipmAiOperatorAction[]
  lecipmDealHistories            LecipmDealHistory[]
  workspaceBrokerReputations     WorkspaceBrokerReputation[]
  workspaceDealShares            WorkspaceDealShare[]
  workspaceCollaborationMessages WorkspaceCollaborationMessage[]
  workspaceReferrals             WorkspaceReferral[]

  @@index([createdByUserId], map: "idx_enterprise_workspaces_created_by")
  @@map("enterprise_workspaces")
}

model EnterpriseWorkspaceMember {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String              @map("workspace_id") @db.Uuid
  workspace   EnterpriseWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String              @map("user_id")
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        LecipmWorkspaceRole
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([workspaceId, userId], map: "uq_enterprise_workspace_member")
  @@index([userId], map: "idx_enterprise_workspace_member_user")
  @@map("enterprise_workspace_members")
}

model EnterpriseWorkspaceInvite {
  id              String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId     String                      @map("workspace_id") @db.Uuid
  workspace       EnterpriseWorkspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email           String
  role            LecipmWorkspaceRole
  tokenHash       String                      @map("token_hash")
  status          LecipmWorkspaceInviteStatus @default(pending)
  invitedByUserId String                      @map("invited_by_user_id")
  invitedBy       User                        @relation("EnterpriseWorkspaceInviter", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  expiresAt       DateTime                    @map("expires_at") @db.Timestamptz(6)
  createdAt       DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([workspaceId], map: "idx_enterprise_workspace_invites_ws")
  @@index([email], map: "idx_enterprise_workspace_invites_email")
  @@map("enterprise_workspace_invites")
}

model WorkspaceAuditLog {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String              @map("workspace_id") @db.Uuid
  workspace   EnterpriseWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actorUserId String              @map("actor_user_id")
  actor       User                @relation("WorkspaceAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  entityType  String              @map("entity_type")
  entityId    String?             @map("entity_id")
  action      String
  metadata    Json?               @db.JsonB
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([workspaceId, createdAt(sort: Desc)], map: "idx_workspace_audit_ws_created")
  @@index([actorUserId], map: "idx_workspace_audit_actor")
  @@map("workspace_audit_logs")
}

/// LECIPM monopoly layer — terminal deal outcomes per organization (workspace). No cross-workspace queries.
enum LecipmDealHistoryOutcome {
  won
  lost
  canceled

  @@map("lecipm_deal_history_outcome")
}

/// Append-only history rows for closed / canceled deals (workspace-scoped).
model LecipmDealHistory {
  id          String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String                   @map("workspace_id") @db.Uuid
  workspace   EnterpriseWorkspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dealId      String                   @map("deal_id")
  deal        Deal                     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  outcome     LecipmDealHistoryOutcome
  /// Final or best-known price in cents (CAD).
  priceCents  Int                      @map("price_cents")
  /// Structured timeline: e.g. { daysToClose, stages[] } — no PII.
  timeline    Json?                    @db.JsonB
  createdAt   DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([workspaceId, createdAt(sort: Desc)], map: "idx_deal_history_ws_created")
  @@index([dealId], map: "idx_deal_history_deal")
  @@map("deal_history")
}

/// Reputation rollup per broker within one workspace (never shared across orgs).
model WorkspaceBrokerReputation {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId   String              @map("workspace_id") @db.Uuid
  workspace     EnterpriseWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brokerUserId  String              @map("broker_user_id")
  broker        User                @relation("WorkspaceBrokerReputationBroker", fields: [brokerUserId], references: [id], onDelete: Cascade)
  /// 0–100 composite.
  score         Float               @default(0)
  successRate   Float               @default(0) @map("success_rate")
  activityScore Float               @default(0) @map("activity_score")
  dealsCounted  Int                 @default(0) @map("deals_counted")
  updatedAt     DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([workspaceId, brokerUserId], map: "uq_workspace_broker_reputation")
  @@index([workspaceId], map: "idx_ws_broker_rep_ws")
  @@map("workspace_broker_reputation")
}

/// Internal workspace deal share (visibility to a teammate).
model WorkspaceDealShare {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId  String              @map("workspace_id") @db.Uuid
  workspace    EnterpriseWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dealId       String              @map("deal_id")
  deal         Deal                @relation(fields: [dealId], references: [id], onDelete: Cascade)
  targetUserId String              @map("target_user_id")
  targetUser   User                @relation("WorkspaceDealShareTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  createdById  String              @map("created_by_id")
  createdBy    User                @relation("WorkspaceDealShareCreator", fields: [createdById], references: [id], onDelete: Cascade)
  note         String?             @db.Text
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([workspaceId, dealId], map: "idx_ws_deal_share_ws_deal")
  @@index([targetUserId], map: "idx_ws_deal_share_target")
  @@map("workspace_deal_shares")
}

/// Internal collaboration thread (workspace-scoped; optional deal context).
model WorkspaceCollaborationMessage {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String              @map("workspace_id") @db.Uuid
  workspace   EnterpriseWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dealId      String?             @map("deal_id")
  deal        Deal?               @relation(fields: [dealId], references: [id], onDelete: SetNull)
  authorId    String              @map("author_id")
  author      User                @relation("WorkspaceCollabAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  body        String              @db.Text
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([workspaceId, createdAt(sort: Desc)], map: "idx_ws_collab_ws_created")
  @@index([dealId], map: "idx_ws_collab_deal")
  @@map("workspace_collaboration_messages")
}

/// Referral attribution inside a workspace (network effect; PII minimized).
model WorkspaceReferral {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String              @map("workspace_id") @db.Uuid
  workspace      EnterpriseWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  referrerUserId String              @map("referrer_user_id")
  referrer       User                @relation("WorkspaceReferralReferrer", fields: [referrerUserId], references: [id], onDelete: Cascade)
  referredEmail  String              @map("referred_email")
  status         String              @default("pending") // pending | accepted | expired
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([workspaceId], map: "idx_ws_referral_ws")
  @@index([referredEmail], map: "idx_ws_referral_email")
  @@map("workspace_referrals")
}

/// Per-user daily execution checklist (coaching mode — manual sends only; no auto-DM).
model DailyTask {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskDate       DateTime @map("task_date") @db.Date
  taskType       String   @map("task_type") // messages_sent | content_posted | calls_booked | users_onboarded
  targetCount    Int      @map("target_count")
  completedCount Int      @default(0) @map("completed_count")
  /// pending | in_progress | completed
  status         String   @default("pending")
  /// Optional JSON: { callBooked?, callCompleted?, linkedLeadId? }
  metadata       Json?    @db.JsonB
  /// End-of-day manual note (e.g. reply count).
  repliesNote    String?  @map("replies_note") @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([userId, taskDate, taskType], map: "uq_daily_tasks_user_date_type")
  @@index([userId, taskDate], map: "idx_daily_tasks_user_date")
  @@map("daily_tasks")
}

/// Per-user daily metrics for reply rate & variant testing (manual logging only).
model DailyMetric {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  metricDate      DateTime @map("metric_date") @db.Date
  messagesSent    Int      @default(0) @map("messages_sent")
  repliesReceived Int      @default(0) @map("replies_received")
  callsBooked     Int      @default(0) @map("calls_booked")
  usersOnboarded  Int      @default(0) @map("users_onboarded")
  /// { [variantKey]: { uses: number, replies: number } }
  variantStats    Json?    @map("variant_stats") @db.JsonB
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([userId, metricDate], map: "uq_daily_metrics_user_date")
  @@index([userId, metricDate], map: "idx_daily_metrics_user_date")
  @@map("daily_metrics")
}

/// DM script variants for A/B-style coaching (copy-only; never auto-sent).
model DailyDmScript {
  id               String   @id @default(cuid())
  variant          String   @unique // curiosity | problem_focused | direct_value
  body             String   @db.Text
  performanceScore Float?   @map("performance_score")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("dm_scripts")
}

/// Daily snapshot for conservative market trend signals (not appraisals).
model MarketSnapshot {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  regionSlug         String   @map("region_slug")
  propertyType       String   @map("property_type")
  mode               String   @default("investor")
  analysisWindowDays Int      @map("analysis_window_days")
  snapshotDate       DateTime @map("snapshot_date") @db.Date
  medianPriceCents   BigInt?  @map("median_price_cents")
  medianPricePerSqft Decimal? @map("median_price_per_sqft") @db.Decimal(18, 2)
  activeListingCount Int      @default(0) @map("active_listing_count")
  newListingCount    Int      @default(0) @map("new_listing_count")
  confidenceLevel    String   @map("confidence_level")
  directionLabel     String?  @map("direction_label")
  metadata           Json?    @db.JsonB
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([regionSlug, propertyType, mode, analysisWindowDays, snapshotDate], map: "uq_market_snapshots_region_window_date")
  @@index([regionSlug, snapshotDate], map: "idx_market_snapshots_region_date")
  @@map("market_snapshots")
}

/// Daily snapshot of SaaS revenue metrics (LECIPM workspace subscriptions). Written by cron or on-demand.
model RevenueSnapshot {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  snapshotDate DateTime @map("snapshot_date") @db.Date
  mrr          Decimal? @db.Decimal(18, 2)
  churnRate    Decimal? @map("churn_rate") @db.Decimal(12, 8)
  ltv          Decimal? @db.Decimal(18, 2)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([snapshotDate])
  @@index([snapshotDate], map: "idx_revenue_snapshots_date")
  @@map("revenue_snapshots")
}

/// Idempotent growth / retention emails (LECIPM growth engine).
model GrowthEmailLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  triggerKey     String   @map("trigger_key")
  idempotencyKey String   @unique @map("idempotency_key")
  subject        String?
  bodyPreview    String?  @map("body_preview") @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId], map: "idx_growth_email_logs_user_id")
  @@index([triggerKey], map: "idx_growth_email_logs_trigger_key")
  @@map("growth_email_logs")
}

/// User-saved unified search (buy / rent / short) — filters mirror `GlobalSearchFiltersExtended` JSON.
model SavedSearch {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// SearchEngineMode: buy | rent | short
  mode        String
  name        String
  filtersJson Json     @map("filters_json")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([userId, createdAt])
  @@map("saved_searches")
}

/// Singleton row (`id = global`): current required license version; bump to force re-acceptance.
model ContentLicensePolicy {
  id              String   @id
  currentVersion  String   @default("1.0.0") @map("current_version")
  updatedAt       DateTime @updatedAt @map("updated_at")
  updatedByUserId String?  @map("updated_by_user_id")
  updatedBy       User?    @relation("ContentLicensePolicyUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@map("content_license_policy")
}

model ContentLicenseAcceptance {
  id         String   @id @default(uuid())
  userId     String   @unique @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  version    String
  acceptedAt DateTime @default(now()) @map("accepted_at")

  @@index([userId])
  @@map("content_license_acceptances")
}

// —— Long-term Rent Hub (structured lifecycle: listing → application → lease → payments)

enum RentalListingStatus {
  DRAFT
  ACTIVE
  RENTED
}

enum RentalApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum RentalLeaseStatus {
  PENDING_SIGNATURE
  ACTIVE
  TERMINATED
}

enum RentPaymentStatus {
  PENDING
  PAID
  LATE
}

model RentalListing {
  id            String              @id @default(uuid())
  listingCode   String              @unique @map("listing_code")
  landlordId    String              @map("landlord_id")
  landlord      User                @relation("RentalLandlord", fields: [landlordId], references: [id], onDelete: Cascade)
  title         String
  description   String              @db.Text
  priceMonthly  Int                 @map("price_monthly")
  depositAmount Int                 @map("deposit_amount")
  address       String
  city          String?
  status        RentalListingStatus @default(DRAFT)
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  applications  RentalApplication[]
  leases        RentalLease[]

  @@index([landlordId])
  @@index([status])
  @@map("rental_listings")
}

model RentalApplication {
  id              String                  @id @default(uuid())
  listingId       String                  @map("listing_id")
  listing         RentalListing           @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tenantId        String                  @map("tenant_id")
  tenant          User                    @relation("RentalTenantApplications", fields: [tenantId], references: [id], onDelete: Cascade)
  message         String                  @db.Text
  status          RentalApplicationStatus @default(PENDING)
  legalAcceptedAt DateTime?               @map("legal_accepted_at")
  documentsJson   Json?                   @map("documents_json")
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")
  lease           RentalLease?

  @@index([listingId])
  @@index([tenantId])
  @@index([status])
  @@map("rental_applications")
}

model RentalLease {
  id            String             @id @default(uuid())
  listingId     String             @map("listing_id")
  listing       RentalListing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tenantId      String             @map("tenant_id")
  tenant        User               @relation("RentalLeaseTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  landlordId    String             @map("landlord_id")
  landlord      User               @relation("RentalLeaseLandlord", fields: [landlordId], references: [id], onDelete: Cascade)
  applicationId String?            @unique @map("application_id")
  application   RentalApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  startDate     DateTime           @map("start_date")
  endDate       DateTime           @map("end_date")
  monthlyRent   Int                @map("monthly_rent")
  deposit       Int
  status        RentalLeaseStatus  @default(PENDING_SIGNATURE)
  signedAt      DateTime?          @map("signed_at")
  contractText  String             @map("contract_text") @db.Text
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  payments      RentPayment[]

  @@index([tenantId])
  @@index([landlordId])
  @@index([listingId])
  @@map("rental_leases")
}

model RentPayment {
  id        String            @id @default(uuid())
  leaseId   String            @map("lease_id")
  lease     RentalLease       @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  amount    Int
  dueDate   DateTime          @map("due_date")
  status    RentPaymentStatus @default(PENDING)
  paidAt    DateTime?         @map("paid_at")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  @@index([leaseId])
  @@index([dueDate])
  @@index([status])
  @@map("rent_payments")
}

/// Centralized compliance trace — views, contact clicks, messages, calls, booking requests (all hubs).
enum ImmoContactEventType {
  /// listing_view
  VIEW
  /// contact_click
  CONTACT_CLICK
  /// conversation / thread message
  MESSAGE
  CALL
  BOOKING_REQUEST
  /// Deal / pipeline started (BNHub offer flow).
  DEAL_STARTED
  /// Structured contact form submit (buyer/broker forms).
  CONTACT_FORM_SUBMITTED
  /// Platform conversation thread opened (buyer ↔ seller/broker).
  CONVERSATION_STARTED
  /// Offer / negotiation started on a listing.
  OFFER_STARTED
  /// CRM lead linked to an active deal (compliance).
  DEAL_LINKED
}

model ImmoContactLog {
  id             String               @id @default(cuid())
  userId         String?              @map("user_id")
  user           User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// Counterparty or subject of the action (e.g. listing owner when guest contacts host).
  targetUserId   String?              @map("target_user_id")
  targetUser     User?                @relation("ImmoContactLogTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  /// Broker attributed to this touch when applicable.
  brokerId       String?              @map("broker_id")
  broker         User?                @relation("ImmoContactLogBroker", fields: [brokerId], references: [id], onDelete: SetNull)
  listingId      String?              @map("listing_id")
  listingKind    String?              @map("listing_kind")
  /// buyer | seller | bnhub_guest | bnhub_host | broker | mortgage | admin | system — denormalized hub surface.
  hub            String?              @map("hub")
  /// Same as `eventType` in API responses — semantic event category (immutable after insert).
  contactType    ImmoContactEventType @map("contact_type")
  /// Audit payload (UTC timestamps inside JSON are ISO strings).
  metadata       Json?                @map("metadata")
  createdAt      DateTime             @default(now()) @map("created_at")
  /// Canonical event instant for audit ordering (UTC); defaults to insert time.
  actionAt       DateTime             @default(now()) @map("action_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  /// Admin-only annotation; core event fields remain immutable.
  adminNote      String?              @map("admin_note") @db.Text
  adminNotedAt   DateTime?            @map("admin_noted_at")
  adminNotedById String?              @map("admin_noted_by_id")
  adminNotedBy   User?                @relation("ImmoContactLogAdminNote", fields: [adminNotedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([targetUserId])
  @@index([brokerId])
  @@index([listingId])
  @@index([hub])
  @@index([contactType])
  @@index([createdAt])
  @@index([actionAt])
  @@map("immo_contact_logs")
}

/// Mortgage specialist profile (public card + expert dashboard).
model MortgageExpert {
  id                       String                    @id @default(cuid())
  userId                   String                    @unique @map("user_id")
  user                     User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                     String
  email                    String
  phone                    String?                   @map("phone")
  photo                    String?                   @map("photo")
  company                  String?                   @map("company")
  licenseNumber            String?                   @map("license_number")
  /// Government-issued ID type for identity verification (e.g. qc_driver_license, canadian_passport).
  idDocumentType           String?                   @map("id_document_type")
  /// Stored path under /public (uploaded ID scan; access restricted to expert + admin flows).
  idDocumentPath           String?                   @map("id_document_path")
  /// profile_incomplete | pending_review | verified | rejected
  expertVerificationStatus String                    @default("profile_incomplete") @map("expert_verification_status")
  /// When the broker attested holding a valid AMF mortgage broker licence (Québec).
  ampAttestedAt            DateTime?                 @map("amp_attested_at")
  profileSubmittedAt       DateTime?                 @map("profile_submitted_at")
  title                    String?                   @map("title")
  bio                      String?                   @map("bio") @db.Text
  isActive                 Boolean                   @default(true) @map("is_active")
  /// Accepting new auto-assigned leads (subject to caps / credits).
  isAvailable              Boolean                   @default(true) @map("is_available")
  /// Default daily cap; subscription may override when active.
  maxLeadsPerDay           Int                       @default(10) @map("max_leads_per_day")
  currentLeadsToday        Int                       @default(0) @map("current_leads_today")
  /// Denormalized client review average (1–5).
  rating                   Float                     @default(5)
  reviewCount              Int                       @default(0) @map("review_count")
  totalDeals               Int                       @default(0) @map("total_deals")
  totalRevenue             Int                       @default(0) @map("total_revenue")
  /// Admin can set display/routing boost (also used if you manually curb a bad actor).
  adminRatingBoost         Float                     @default(0) @map("admin_rating_boost")
  /// Optional monetization upsells (admin / ops).
  revenuePremiumListing    Boolean                   @default(false) @map("revenue_premium_listing")
  revenueFeaturedExpert    Boolean                   @default(false) @map("revenue_featured_expert")
  revenuePremiumPlacement  Boolean                   @default(false) @map("revenue_premium_placement")
  /// Expert must accept platform commission & anti-bypass terms before dashboard access.
  acceptedTerms            Boolean                   @default(false) @map("accepted_terms")
  acceptedAt               DateTime?                 @map("accepted_at")
  /// Platform commission rate on closed mortgage deals (default 30%).
  commissionRate           Float                     @default(0.30) @map("commission_rate")
  dashboardLastSeenAt      DateTime?                 @map("dashboard_last_seen_at")
  notificationsLastReadAt  DateTime?                 @map("notifications_last_read_at")
  createdAt                DateTime                  @default(now()) @map("created_at")
  updatedAt                DateTime                  @updatedAt @map("updated_at")
  assignedLeads            Lead[]
  mortgageDeals            MortgageDeal[]
  inAppNotifications       ExpertInAppNotification[]
  expertSubscription       ExpertSubscription?
  expertCredits            ExpertCredits?
  expertBilling            ExpertBilling?
  expertInvoices           ExpertInvoice[]
  expertPayoutRecords      ExpertPayoutRecord[]
  mortgageReviews          MortgageExpertReview[]
  crmConversations         CrmConversation[]

  @@index([isActive])
  @@index([acceptedTerms])
  @@index([isAvailable])
  @@index([currentLeadsToday])
  @@index([expertVerificationStatus])
  @@map("mortgage_experts")
}

/// One-time email 2FA codes (5-minute TTL; mark used after success).
model TwoFactorCode {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code         String   @map("code")
  expiresAt    DateTime @map("expires_at")
  used         Boolean  @default(false)
  attemptCount Int      @default(0) @map("attempt_count")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId, expiresAt])
  @@map("two_factor_codes")
}

/// Subscription tier: basic | pro | premium — caps and routing priority.
model ExpertSubscription {
  id               String         @id @default(cuid())
  expertId         String         @unique @map("expert_id")
  expert           MortgageExpert @relation(fields: [expertId], references: [id], onDelete: Cascade)
  plan             String         @default("basic")
  /// List price in cents (CAD) for display / revenue rollup.
  price            Int            @default(0)
  maxLeadsPerDay   Int            @default(5) @map("max_leads_per_day")
  /// Monthly lead cap (-1 = unlimited, e.g. premium).
  maxLeadsPerMonth Int            @default(10) @map("max_leads_per_month")
  /// Added to distribution score (premium gets more priority).
  priorityWeight   Int            @default(0) @map("priority_weight")
  isActive         Boolean        @default(true) @map("is_active")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  @@index([plan])
  @@map("expert_subscriptions")
}

/// Stripe billing / subscription state for mortgage experts (1:1 with MortgageExpert).
model ExpertBilling {
  id                     String         @id @default(cuid())
  expertId               String         @unique @map("expert_id")
  expert                 MortgageExpert @relation(fields: [expertId], references: [id], onDelete: Cascade)
  stripeCustomerId       String?        @map("stripe_customer_id")
  stripeSubscriptionId   String?        @map("stripe_subscription_id")
  plan                   String         @default("basic")
  /// active | past_due | canceled | incomplete | unpaid
  status                 String         @default("active")
  currentPeriodEnd       DateTime?      @map("current_period_end")
  leadsAssignedThisMonth Int            @default(0) @map("leads_assigned_this_month")
  /// UTC month key YYYY-MM for usage counter rollover
  usageMonthUtc          String?        @map("usage_month_utc")
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")

  @@index([stripeSubscriptionId])
  @@index([stripeCustomerId])
  @@map("expert_billing")
}

model ExpertInvoice {
  id                      String         @id @default(cuid())
  expertId                String         @map("expert_id")
  expert                  MortgageExpert @relation(fields: [expertId], references: [id], onDelete: Cascade)
  type                    String
  amountCents             Int            @map("amount_cents")
  currency                String         @default("cad")
  stripeInvoiceId         String?        @map("stripe_invoice_id")
  stripePaymentIntentId   String?        @map("stripe_payment_intent_id")
  stripeCheckoutSessionId String?        @map("stripe_checkout_session_id")
  description             String?        @db.Text
  metadata                Json?
  createdAt               DateTime       @default(now()) @map("created_at")

  @@index([expertId, createdAt])
  @@map("expert_invoices")
}

/// Track expert share payouts (Stripe Connect transfer or manual).
model ExpertPayoutRecord {
  id                String         @id @default(cuid())
  expertId          String         @map("expert_id")
  expert            MortgageExpert @relation(fields: [expertId], references: [id], onDelete: Cascade)
  mortgageDealId    String?        @unique @map("mortgage_deal_id")
  expertAmountCents Int            @map("expert_amount_cents")
  platformFeeCents  Int            @map("platform_fee_cents")
  /// pending | transferred | failed | manual
  status            String         @default("pending")
  stripeTransferId  String?        @map("stripe_transfer_id")
  failureReason     String?        @map("failure_reason") @db.Text
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  @@index([expertId])
  @@index([status])
  @@map("expert_payout_records")
}

/// Pay-per-lead: row present = program enabled; credits must stay > 0 to receive leads.
model ExpertCredits {
  expertId  String         @id @map("expert_id")
  expert    MortgageExpert @relation(fields: [expertId], references: [id], onDelete: Cascade)
  credits   Int            @default(0)
  updatedAt DateTime       @updatedAt @map("updated_at")

  @@map("expert_credits")
}

/// Post-close client review (1–5 + optional comment).
model MortgageExpertReview {
  id            String         @id @default(cuid())
  expertId      String         @map("expert_id")
  expert        MortgageExpert @relation(fields: [expertId], references: [id], onDelete: Cascade)
  leadId        String         @unique @map("lead_id")
  lead          Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  rating        Int
  comment       String?        @db.Text
  reviewerEmail String?        @map("reviewer_email")
  createdAt     DateTime       @default(now()) @map("created_at")

  @@index([expertId])
  @@map("mortgage_expert_reviews")
}

/// Public “become a broker partner” interest (no account). Ops follows up; paid tiers use signup + Stripe.
model MortgageBrokerProgramInterest {
  id        String   @id @default(cuid())
  email     String   @map("email")
  name      String?  @map("name")
  phone     String?  @map("phone")
  company   String?  @map("company")
  /// free | gold | platinum | ambassador — which card they clicked (free = program info only)
  planSlug  String   @map("plan_slug")
  message   String?  @map("message") @db.Text
  source    String   @default("for-brokers") @map("source")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([email])
  @@index([planSlug])
  @@map("mortgage_broker_program_interests")
}

/// Mortgage broker directory entry (assignments + public contact). Optional `userId` for broker dashboard login.
model MortgageBroker {
  id                     String                        @id @default(cuid())
  userId                 String?                       @unique @map("user_id")
  user                   User?                         @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// Display name (legacy + signup)
  name                   String
  /// Full legal name (signup / profile)
  fullName               String?                       @map("full_name")
  email                  String
  phone                  String?
  company                String?
  licenseNumber          String                        @default("") @map("license_number")
  yearsExperience        Int?                          @map("years_experience")
  /// e.g. residential, commercial (free text)
  specialties            String?                       @db.Text
  profilePhotoUrl        String?                       @map("profile_photo_url")
  /// Government ID (passport / driver license) — manual review; path under /public
  idDocumentUrl          String?                       @map("id_document_url")
  /// Selfie for identity match — manual review
  selfiePhotoUrl         String?                       @map("selfie_photo_url")
  /// pending | verified | rejected (ID + selfie review; separate from license verificationStatus)
  identityStatus         String                        @default("pending") @map("identity_status")
  insuranceProvider      String?                       @map("insurance_provider")
  insuranceValid         Boolean?                      @map("insurance_valid")
  /// Professional references (text)
  brokerReferences       String?                       @map("broker_references") @db.Text
  /// Admin-approved; required for lead pool + dashboard access
  isVerified             Boolean                       @default(false) @map("is_verified")
  /// pending | verified | rejected
  verificationStatus     String                        @default("pending") @map("verification_status")
  profileCompletedAt     DateTime?                     @map("profile_completed_at")
  /// trial | pro — trial has limited leads + 7-day window; pro is subscription
  plan                   String                        @default("trial")
  trialEndsAt            DateTime?                     @map("trial_ends_at")
  /// Trusted fallback when no eligible trial/pro brokers exist for round-robin
  isPrimary              Boolean                       @default(false) @map("is_primary")
  /// Fair rotation: updated each time a lead is assigned to this broker
  lastAssignedLeadAt     DateTime?                     @map("last_assigned_lead_at")
  /// Optional boost for future weighted distribution (higher = tie-break after lastAssigned)
  priorityScore          Int                           @default(0) @map("priority_score")
  /// Cumulative: incremented by visible (unlocked) lead count on each list fetch
  leadsViewedTotal       Int                           @default(0) @map("leads_viewed_total")
  /// Cumulative upgrade CTA clicks (pricing, dashboard, etc.)
  upgradeClickCount      Int                           @default(0) @map("upgrade_click_count")
  /// Average star rating (1–5) from client reviews
  rating                 Float                         @default(0) @map("rating")
  totalReviews           Int                           @default(0) @map("total_reviews")
  /// Rolling average first-response time (hours); updated when broker marks contacted/approved
  responseTimeAvg        Float?                        @map("response_time_avg")
  /// Number of response-time samples (for rolling average)
  responseTimeSamples    Int                           @default(0) @map("response_time_samples")
  /// Leads where broker first marked contacted or approved (engagement count)
  totalLeadsHandled      Int                           @default(0) @map("total_leads_handled")
  /// Sum of paid contact unlocks (CAD dollars)
  totalLeadUnlockRevenue Float                         @default(0) @map("total_lead_unlock_revenue")
  /// Count of contact unlocks (free weekly + paid)
  totalLeadUnlocks       Int                           @default(0) @map("total_lead_unlocks")
  createdAt              DateTime                      @default(now()) @map("created_at")
  requests               MortgageRequest[]
  leadDistributionLogs   MortgageLeadDistributionLog[]
  brokerReviews          BrokerReview[]
  leadUnlocks            MortgageLeadUnlock[]

  @@index([userId])
  @@index([plan])
  @@index([isPrimary])
  @@index([lastAssignedLeadAt])
  @@map("mortgage_brokers")
}

/// User-submitted mortgage pre-qualification / evaluation request.
model MortgageRequest {
  id                       String                        @id @default(cuid())
  userId                   String                        @map("user_id")
  user                     User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Exactly one broker per lead (exclusive routing).
  brokerId                 String?                       @map("broker_id")
  broker                   MortgageBroker?               @relation(fields: [brokerId], references: [id], onDelete: SetNull)
  propertyPrice            Float                         @map("property_price")
  downPayment              Float                         @map("down_payment")
  income                   Float
  /// pending | contacted | approved
  status                   String                        @default("pending")
  /// low | medium | high — auto-scored from income, down %, timeline, pre-approval
  intentLevel              String                        @default("medium") @map("intent_level")
  /// immediate | 1-3 months | 3+ months
  timeline                 String                        @default("1-3 months") @map("timeline")
  preApproved              Boolean                       @default(false) @map("pre_approved")
  /// Broker paid to unlock full contact on this row (pay-per-lead)
  isPurchasedLead          Boolean                       @default(false) @map("is_purchased_lead")
  /// Pay-per-lead price (CAD) for unlocking borrower contact
  leadValue                Float                         @default(35) @map("lead_value")
  /// Borrower email/phone (and extended financials) visible after unlock
  contactUnlocked          Boolean                       @default(false) @map("contact_unlocked")
  unlockedByBrokerId       String?                       @map("unlocked_by_broker_id")
  contactUnlockedAt        DateTime?                     @map("contact_unlocked_at")
  /// Heuristic pre-approval estimate (informational only)
  estimatedApprovalAmount  Float?                        @map("estimated_approval_amount")
  estimatedMonthlyPayment  Float?                        @map("estimated_monthly_payment")
  /// low | medium | high
  approvalConfidence       String?                       @map("approval_confidence")
  /// When the lead was assigned to `brokerId` (for response-time SLA)
  assignedAt               DateTime?                     @map("assigned_at")
  /// True after first performance stats applied (response time + lead handled count)
  performanceStatsRecorded Boolean                       @default(false) @map("performance_stats_recorded")
  createdAt                DateTime                      @default(now()) @map("created_at")
  /// Optional listing context when request originates from BuyerHub.
  fsboListingId            String?                       @map("fsbo_listing_id")
  fsboListing              FsboListing?                  @relation(fields: [fsboListingId], references: [id], onDelete: SetNull)
  employmentStatus         String?                       @map("employment_status")
  creditRange              String?                       @map("credit_range")
  leadDistributionLogs     MortgageLeadDistributionLog[]
  brokerReview             BrokerReview?
  leadUnlock               MortgageLeadUnlock?

  @@index([userId])
  @@index([brokerId])
  @@index([status, createdAt])
  @@index([intentLevel])
  @@index([fsboListingId])
  @@map("mortgage_requests")
}

/// Paid or free-weekly contact unlock for a mortgage lead (one row per request).
model MortgageLeadUnlock {
  id                String          @id @default(cuid())
  mortgageRequestId String          @unique @map("mortgage_request_id")
  request           MortgageRequest @relation(fields: [mortgageRequestId], references: [id], onDelete: Cascade)
  brokerId          String          @map("broker_id")
  broker            MortgageBroker  @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  /// Amount charged in cents (0 for free weekly unlock)
  amountCents       Int             @default(0) @map("amount_cents")
  /// free_weekly | paid
  source            String          @default("paid")
  createdAt         DateTime        @default(now()) @map("created_at")

  @@index([brokerId, createdAt])
  @@map("mortgage_lead_unlocks")
}

/// Client review of a mortgage broker (one per mortgage request).
model BrokerReview {
  id                String          @id @default(cuid())
  brokerId          String          @map("broker_id")
  broker            MortgageBroker  @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  mortgageRequestId String          @unique @map("mortgage_request_id")
  request           MortgageRequest @relation(fields: [mortgageRequestId], references: [id], onDelete: Cascade)
  userId            String          @map("user_id")
  user              User            @relation("BrokerReviewAuthor", fields: [userId], references: [id], onDelete: Cascade)
  rating            Int
  comment           String?         @db.Text
  createdAt         DateTime        @default(now()) @map("created_at")

  @@index([brokerId])
  @@index([userId])
  @@map("broker_reviews")
}

/// Audit trail for mortgage lead routing (admin + transparency).
model MortgageLeadDistributionLog {
  id                String          @id @default(cuid())
  mortgageRequestId String          @map("mortgage_request_id")
  request           MortgageRequest @relation(fields: [mortgageRequestId], references: [id], onDelete: Cascade)
  brokerId          String          @map("broker_id")
  broker            MortgageBroker  @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  /// smart_routing | primary_fallback | emergency_pool
  reason            String
  /// Score used when routing (higher = preferred); null for legacy rows
  routingScore      Float?          @map("routing_score")
  createdAt         DateTime        @default(now()) @map("created_at")

  @@index([brokerId])
  @@index([createdAt])
  @@map("mortgage_lead_distribution_logs")
}

/// Closed mortgage transaction for commission tracking (expert-reported; admin can adjust).
model MortgageDeal {
  id             String         @id @default(cuid())
  leadId         String         @unique @map("lead_id")
  lead           Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  expertId       String         @map("expert_id")
  expert         MortgageExpert @relation(fields: [expertId], references: [id], onDelete: Cascade)
  dealAmount     Int            @map("deal_amount")
  platformShare  Int            @map("platform_share")
  expertShare    Int            @map("expert_share")
  commissionRate Float          @default(0.30) @map("commission_rate")
  /// closed | adjusted | void
  status         String         @default("closed")
  adminNote      String?        @map("admin_note") @db.Text
  /// Public one-time token for client review after close.
  reviewToken    String?        @unique @map("review_token")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@index([expertId])
  @@index([status])
  @@map("mortgage_deals")
}

/// In-app notifications for mortgage experts (bell + unread count).
model ExpertInAppNotification {
  id        String         @id @default(cuid())
  expertId  String         @map("expert_id")
  expert    MortgageExpert @relation(fields: [expertId], references: [id], onDelete: Cascade)
  leadId    String?        @map("lead_id")
  kind      String         @default("mortgage_lead")
  title     String
  body      String?        @db.Text
  readAt    DateTime?      @map("read_at")
  createdAt DateTime       @default(now()) @map("created_at")

  @@index([expertId, readAt])
  @@index([expertId, createdAt])
  @@map("expert_in_app_notifications")
}

/// Shared marketplace listing ownership — FSBO uses `SELLER`; broker-assisted rows use `BROKER` with `ownerId` = broker user.
enum FsboListingOwnerType {
  SELLER
  BROKER
}

// FSBO — sell by yourself (private sale / DuProprio-style)
model FsboListing {
  id                             String                           @id @default(cuid())
  /// Public tracking code LST-XXXXXX (unique across platform with BNHub + CRM).
  listingCode                    String?                          @unique @map("listing_code")
  ownerId                        String                           @map("owner_id")
  owner                          User                             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  /// Multi-tenant scope when the brokerage or platform org publishes the row.
  tenantId                       String?                          @map("tenant_id")
  tenant                         Tenant?                          @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  /// Same physical listing table for DIY sellers vs broker-managed inventory.
  listingOwnerType               FsboListingOwnerType             @default(SELLER) @map("listing_owner_type")
  title                          String
  /// Optional French UI copy; falls back to `title` when absent.
  titleFr                        String?                          @map("title_fr")
  description                    String                           @db.Text
  /// Optional French description; falls back to `description` when absent.
  descriptionFr                  String?                          @map("description_fr") @db.Text
  /// Optional Arabic title (future); falls back to `title` when absent.
  titleAr                        String?                          @map("title_ar")
  /// Optional Arabic description; falls back to `description` when absent.
  descriptionAr                  String?                          @map("description_ar") @db.Text
  priceCents                     Int                              @map("price_cents")
  address                        String
  city                           String
  country                        String                           @default("CA")
  marketCountryId                String?                          @map("market_country_id")
  marketCountry                  ExpansionCountry?                @relation(fields: [marketCountryId], references: [id], onDelete: SetNull)
  marketCityId                   String?                          @map("market_city_id")
  marketCity                     City?                            @relation(fields: [marketCityId], references: [id], onDelete: SetNull)
  listingCurrency                String?                          @map("listing_currency") @db.VarChar(8)
  region                         String?
  bedrooms                       Int?
  bathrooms                      Int?
  surfaceSqft                    Int?                             @map("surface_sqft")
  images                         String[]
  /// Primary hero image; auto-synced to first gallery image for now (manual override later).
  coverImage                     String?                          @map("cover_image")
  /// Per-photo tagging (same order/length as `images`). Each item must be one of:
  /// EXTERIOR | INTERIOR | STREET_VIEW | OTHER
  photoTagsJson                  Json?                            @map("photo_tags_json")
  /// Mismatch lifecycle (auto-set when the platform detects issues; updated on user confirmation too).
  photoVerificationStatus        FsboPhotoVerificationStatus      @default(PENDING) @map("photo_verification_status")
  /// Required checkbox before admin verification / publish.
  photoConfirmationAcceptedAt    DateTime?                        @map("photo_confirmation_accepted_at")
  status                         String                           @default("DRAFT") // DRAFT | PENDING_VERIFICATION | ACTIVE | SOLD
  moderationStatus               String                           @default("APPROVED") @map("moderation_status") // PENDING | APPROVED | REJECTED
  contactEmail                   String                           @map("contact_email")
  contactPhone                   String?                          @map("contact_phone")
  rejectReason                   String?                          @map("reject_reason") @db.Text
  createdAt                      DateTime                         @default(now()) @map("created_at")
  updatedAt                      DateTime                         @updatedAt @map("updated_at")
  /// basic | premium — chosen before publish; premium may set featuredUntil after payment.
  publishPlan                    String                           @default("basic") @map("publish_plan")
  publishPriceCents              Int?                             @map("publish_price_cents")
  paidPublishAt                  DateTime?                        @map("paid_publish_at")
  featuredUntil                  DateTime?                        @map("featured_until")
  /// Listing expiry is contract-driven for broker-managed inventory and platform-driven for owner-direct inventory.
  expiresAt                      DateTime?                        @map("expires_at")
  /// Prevent duplicate renewal reminders inside the same renewal window.
  expiryReminderSentAt           DateTime?                        @map("expiry_reminder_sent_at")
  /// Archive timestamp when the platform auto-expires a listing.
  archivedAt                     DateTime?                        @map("archived_at")
  /// Optional map coordinates; fill via geocoding when available.
  latitude                       Float?                           @map("latitude")
  longitude                      Float?                           @map("longitude")
  /// quiet | moderate | lively — environment signal (Buy / long-term rent hub)
  noiseLevel                     String?                          @map("noise_level")
  familyFriendly                 Boolean                          @default(false) @map("family_friendly")
  kidsAllowed                    Boolean                          @default(true) @map("kids_allowed")
  partyAllowed                   Boolean                          @default(false) @map("party_allowed")
  smokingAllowed                 Boolean                          @default(false) @map("smoking_allowed")
  petsAllowed                    Boolean                          @default(false) @map("pets_allowed")
  /// JSON string[] e.g. ["dog","cat","other"]
  allowedPetTypes                Json                             @default("[]") @map("allowed_pet_types")
  maxPetWeightKg                 Float?                           @map("max_pet_weight_kg")
  petRules                       String?                          @map("pet_rules") @db.Text
  /// JSON string[] e.g. ["waterfront","downtown","near_attractions"]
  experienceTags                 Json                             @default("[]") @map("experience_tags")
  /// JSON string[] e.g. ["airport_pickup","parking"]
  servicesOffered                Json                             @default("[]") @map("services_offered")
  leads                          FsboLead[]
  buyerRequests                  BuyerRequest[]
  buyerListingViews              BuyerListingView[]
  buyerSavedListings             BuyerSavedListing[]
  platformPayments               PlatformPayment[]
  /// e.g. SINGLE_FAMILY | CONDO | TOWNHOUSE — used for public search filters
  propertyType                   String?                          @map("property_type")
  /// Quebec cadastre / lot reference (Seller Hub).
  cadastreNumber                 String?                          @map("cadastre_number")
  yearBuilt                      Int?                             @map("year_built")
  annualTaxesCents               Int?                             @map("annual_taxes_cents")
  condoFeesCents                 Int?                             @map("condo_fees_cents")
  /// Structured seller declaration (condition, defects, inclusions…).
  sellerDeclarationJson          Json?                            @map("seller_declaration_json")
  /// Last rules-based AI review (keywords, gaps); does not auto-reject listings.
  sellerDeclarationAiReviewJson  Json?                            @map("seller_declaration_ai_review_json")
  /// Latest risk (0–100, higher = riskier) and trust (0–100, higher = more trustworthy) snapshot.
  riskScore                      Int?                             @map("risk_score")
  trustScore                     Int?                             @map("trust_score")
  aiScoreReasonsJson             Json?                            @map("ai_score_reasons_json")
  sellerDeclarationCompletedAt   DateTime?                        @map("seller_declaration_completed_at")
  /// Seller confirmed accuracy of listing info before submit/publish (timestamp).
  legalAccuracyAcceptedAt        DateTime?                        @map("legal_accuracy_accepted_at")
  /// Set when listing activation email + in-app/push welcome was sent (idempotency).
  sellerActivationNotifiedAt     DateTime?                        @map("seller_activation_notified_at")
  verification                   FsboListingVerification?
  documents                      FsboListingDocument[]
  commissionCategory             ListingCommissionCategory        @default(SALE) @map("commission_category")
  commissionRate                 Float?                           @map("commission_rate")
  listingDealType                String                           @default("SALE") @map("listing_deal_type")
  contracts                      Contract[]
  mortgageRequests               MortgageRequest[]
  /**
   * CRM `Lead` rows from Buyer Hub contact (parallel to `FsboLead`).
   */
  buyerHubCrmLeads               Lead[]                           @relation("FsboBuyerLead")
  sellerSupportingDocuments      SellerSupportingDocument[]
  riskAlerts                     RiskAlert[]
  listingAiScores                ListingAiScore[]
  mediaContentFingerprints       MediaContentFingerprint[]
  trustgraphGeospatialValidation TrustgraphGeospatialValidation?
  dealAnalyses                   DealAnalysis[]                   @relation("DealAnalysisListing")
  dealOfferStrategies            DealOfferStrategy[]
  dealAffordabilityAnalyses      DealAffordabilityAnalysis[]
  dealWatchlistItems             DealWatchlistItem[]
  dealPortfolioAlerts            DealPortfolioAlert[]
  sellerPricingAdvice            SellerPricingAdvice?
  dealAnalysisRefreshJobs        DealAnalysisRefreshJob[]
  dealAnalysisRefreshEvents      DealAnalysisRefreshEvent[]
  dealNegotiationPlaybooks       DealNegotiationPlaybook[]
  sellerRepricingReviews         SellerRepricingReview[]
  sellerRepricingTriggers        SellerRepricingTrigger[]
  portfolioMonitoringEvents      PortfolioMonitoringEvent[]
  dailyDealFeedItems             DailyDealFeedItem[]
  feedInteractions               FeedInteraction[]
  watchlistItems                 WatchlistItem[]
  brokerDisclosures              BrokerDisclosure[]
  watchlistAlerts                WatchlistAlert[]
  watchlistSnapshots             WatchlistSnapshot[]
  sellerDeclarationDrafts        SellerDeclarationDraft[]
  offerStrategyScenarios         OfferStrategyScenario[]
  negotiationChains              NegotiationChain[]
  /// Optional 1:1 canonical listing row (`properties.id` bigint) for new integrations.
  canonicalListingProperty       ListingProperty?
  internalCrmTelemetryEvents     InternalCrmEvent[]               @relation("CrmEventFsboListing")
  /// Optional 1:1 — FSBO row created from safe intake (`ListingAcquisitionLead`).
  sourcedFromAcquisitionLead     ListingAcquisitionLead?          @relation("FsboFromAcquisition")
  /// Ops workflow: draft | pending_review | approved | published | rejected (alongside `status` / moderation).
  supplyPublicationStage         String                           @default("draft") @map("supply_publication_stage")
  permissionConfirmedAt          DateTime?                        @map("permission_confirmed_at")
  permissionSourceNote           String?                          @map("permission_source_note") @db.Text
  rewrittenDescriptionReviewed   Boolean                          @default(false) @map("rewritten_description_reviewed")
  imagesApproved                 Boolean                          @default(false) @map("images_approved")
  imageSourceNote                String?                          @map("image_source_note") @db.Text
  missingApprovedImages          Boolean                          @default(false) @map("missing_approved_images")
  /// Denormalized from `listing_ranking_scores` when ranking_v1 jobs run (fast catalog sort).
  rankingTotalScoreCache         Float                            @default(0) @map("ranking_total_score_cache")
  rankingPerformanceBand         String?                          @map("ranking_performance_band") @db.VarChar(32)
  rankingCachedAt                DateTime?                        @map("ranking_cached_at")
  /// LECIPM Green Score & Optimization Program — internal model only (not Rénoclimat / municipal programs).
  lecipmGreenInternalScore       Int?                             @map("lecipm_green_internal_score")
  lecipmGreenCertifiedAt         DateTime?                        @map("lecipm_green_certified_at")
  /// none | free | premium — suggests vs full plan + badge + browse boost.
  lecipmGreenProgramTier         String                           @default("none") @map("lecipm_green_program_tier") @db.VarChar(16)
  lecipmGreenMetadataJson        Json?                            @map("lecipm_green_metadata_json")
  /// GREEN | IMPROVABLE | LOW — AI-assessed band (not a government label).
  lecipmGreenAiLabel             String?                          @map("lecipm_green_ai_label") @db.VarChar(24)
  /// AI_ESTIMATED | DOCUMENT_SUPPORTED | PROFESSIONAL_VERIFIED (reserved).
  lecipmGreenVerificationLevel   String?                          @map("lecipm_green_verification_level") @db.VarChar(32)
  /// Confidence 0–100 for the AI assessment; higher when user-supplied documents support claims.
  lecipmGreenConfidence          Int?                             @map("lecipm_green_confidence")
  /// Decision-engine snapshot (refreshed by jobs / dashboard — not an external appraisal).
  metrics                        FsboListingMetrics?
  hostPerformanceSnapshots       HostListingPerformanceSnapshot[]
  autopilotV2Suggestions         AutopilotV2Suggestion[]
  pricingInsightSnapshots        PricingInsightSnapshot[]         @relation("FsboPricingInsights")
  listingMarketingDrafts         ListingMarketingDraft[]
  listingMarketingSuggestions    ListingMarketingSuggestion[]
  /// Optional syndication rows (e.g. Centris) — authorized connector only; never scraped.
  externalListings               ExternalListing[]
  greenProject                   GreenProject?
  /// Marketplace DM threads opened from FSBO detail (`Conversation.fsboListingId`).
  marketplaceConversations       Conversation[]                   @relation("ConversationFsboListing")

  @@index([ownerId])
  @@index([tenantId])
  @@index([city])
  @@index([city, status, moderationStatus])
  @@index([status])
  @@index([moderationStatus])
  @@index([expiresAt])
  @@index([archivedAt])
  @@index([priceCents])
  @@index([riskScore])
  @@index([supplyPublicationStage])
  @@index([updatedAt(sort: Desc)], map: "idx_fsbo_listings_updated_at_desc")
  @@index([rankingTotalScoreCache(sort: Desc)])
  @@index([marketCountryId])
  @@index([marketCityId])
  @@map("fsbo_listings")
}

/// Seller green subsidy / upgrade journey — stage is informational; confirm grants with official programs.
model GreenProject {
  id             String      @id @default(cuid())
  fsboListingId  String      @unique @map("fsbo_listing_id")
  listing        FsboListing @relation(fields: [fsboListingId], references: [id], onDelete: Cascade)
  /// ANALYSIS | PLANNING | EXECUTION | COMPLETED
  stage          String      @default("ANALYSIS") @db.VarChar(24)
  estimatedGrant Float?      @map("estimated_grant")
  metadataJson   Json?       @map("metadata_json")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@map("green_projects")
}

/// Non-binding Rénoclimat checklist — informational only; official flows live on government portals.
model RenoclimatAssistantProgress {
  id                 String    @id @default(cuid())
  userId             String    @unique @map("user_id")
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  checklistJson      Json      @default("{}") @map("checklist_json")
  remindersEnabled   Boolean   @default(true) @map("reminders_enabled")
  lastReminderSentAt DateTime? @map("last_reminder_sent_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@map("renoclimat_assistant_progress")
}

/// External MLS / portal syndication tracking (connector-based; no scraping).
model ExternalListing {
  id           String      @id @default(cuid())
  listingId    String      @map("listing_id")
  listing      FsboListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  platform     String
  externalId   String?     @map("external_id")
  status       String
  lastSyncAt   DateTime?   @map("last_sync_at")
  errorMessage String?     @map("error_message") @db.Text
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@unique([listingId, platform])
  @@index([platform, status])
  @@map("external_listings")
}

