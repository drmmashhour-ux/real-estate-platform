  @@unique([scopeType, scopeId, snapshotDate])
  @@index([scopeType, scopeId, snapshotDate])
  @@map("bnhub_revenue_metric_snapshots")
}

/// BNHub dashboard / analytics events (refresh, anomalies, pricing jobs).
model BnhubDashboardEventLog {
  id        String   @id @default(cuid())
  type      String   @db.VarChar(48)
  scopeType String?  @map("scope_type") @db.VarChar(24)
  scopeId   String?  @map("scope_id")
  status    String   @db.VarChar(24)
  message   String?  @db.Text
  meta      Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([type, createdAt])
  @@map("bnhub_dashboard_event_logs")
}

/// Deterministic (rules-based) revenue narrative snapshots — v1 is not LLM-generated prose.
model BnhubDashboardNarrativeSnapshot {
  id                String   @id @default(cuid())
  scopeType         String   @map("scope_type") @db.VarChar(24)
  scopeId           String   @map("scope_id")
  periodLabel       String   @map("period_label") @db.VarChar(32)
  summaryText       String   @map("summary_text") @db.Text
  factsJson         Json?    @map("facts_json")
  risksJson         Json?    @map("risks_json")
  opportunitiesJson Json?    @map("opportunities_json")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([scopeType, scopeId, periodLabel, createdAt])
  @@map("bnhub_dashboard_narrative_snapshots")
}

/// External read access to a BNHub **host** or **portfolio** scope (email must match the signed-in user).
model InvestorAccess {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  /// portfolio | host
  scopeType String   @map("scope_type") @db.VarChar(24)
  scopeId   String   @map("scope_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([scopeType, scopeId])
  @@map("investor_access")
}

/// Durable log of generated investor/BNHub reports; `meta` stores point-in-time KPIs for history charts.
model ReportDeliveryLog {
  id        String   @id @default(cuid())
  scopeType String   @map("scope_type") @db.VarChar(24)
  scopeId   String   @map("scope_id")
  /// pending | success | failed
  status    String   @default("pending") @db.VarChar(24)
  /// email | scheduled | api | manual
  channel   String?  @db.VarChar(32)
  /// Server-only path or private object key; never expose in public JSON.
  pdfPath   String?  @map("pdf_path") @db.Text
  meta      Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([scopeType, scopeId, status, createdAt])
  @@map("report_delivery_logs")
}

/// Rules-based BNHub investment stance for a listing or portfolio scope (auditable JSON payloads).
model InvestmentRecommendation {
  id              String                        @id @default(cuid())
  scopeType       String                        @map("scope_type") @db.VarChar(24)
  scopeId         String                        @map("scope_id")
  recommendation  String                        @db.VarChar(24)
  confidenceScore Float                         @map("confidence_score")
  score           Float
  reasonsJson     Json?                         @map("reasons_json")
  risksJson       Json?                         @map("risks_json")
  actionsJson     Json?                         @map("actions_json")
  metricsJson     Json?                         @map("metrics_json")
  status          String                        @default("active") @db.VarChar(24)
  createdAt       DateTime                      @default(now()) @map("created_at")
  updatedAt       DateTime                      @updatedAt @map("updated_at")
  logs            InvestmentRecommendationLog[]

  @@index([scopeType, scopeId, createdAt])
  @@map("investment_recommendations")
}

model InvestmentRecommendationLog {
  id               String                   @id @default(cuid())
  recommendationId String                   @map("recommendation_id")
  recommendation   InvestmentRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  actionType       String                   @map("action_type") @db.VarChar(24)
  message          String?
  meta             Json?
  createdAt        DateTime                 @default(now()) @map("created_at")

  @@index([recommendationId, createdAt])
  @@map("investment_recommendation_logs")
}

/// Deterministic acquisition / what-if run (user-supplied inputs; not a market appraisal).
model AcquisitionAnalysis {
  id                   String   @id @default(cuid())
  userId               String?  @map("user_id")
  title                String?
  location             String?
  purchasePrice        Float    @map("purchase_price")
  estimatedADR         Float    @map("estimated_adr")
  estimatedOccupancy   Float    @map("estimated_occupancy")
  operatingCostMonthly Float    @map("operating_cost_monthly")
  financingRate        Float?   @map("financing_rate")
  downPayment          Float?   @map("down_payment")
  resultsJson          Json?    @map("results_json")
  scenariosJson        Json?    @map("scenarios_json")
  recommendation       String   @db.VarChar(24)
  score                Float
  confidenceScore      Float    @map("confidence_score")
  createdAt            DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("acquisition_analyses")
}

/// BNHub asset-manager autonomy: one config per listing or host portfolio scope.
model AutonomyConfig {
  id                      String   @id @default(cuid())
  scopeType               String   @map("scope_type") @db.VarChar(24)
  scopeId                 String   @map("scope_id")
  /// OFF | ASSIST | SAFE_AUTOPILOT | FULL_AUTOPILOT_APPROVAL
  mode                    String   @default("ASSIST") @db.VarChar(32)
  autoPricing             Boolean  @default(true) @map("auto_pricing")
  autoPromotions          Boolean  @default(false) @map("auto_promotions")
  autoMessaging           Boolean  @default(false) @map("auto_messaging")
  autoListingOptimization Boolean  @default(true) @map("auto_listing_optimization")
  maxPriceChangePct       Float?   @map("max_price_change_pct")
  maxDiscountPct          Float?   @map("max_discount_pct")
  minOccupancyThreshold   Float?   @map("min_occupancy_threshold")
  anomalyDropThreshold    Float?   @map("anomaly_drop_threshold")
  quietHoursStartUtc      Int?     @map("quiet_hours_start_utc")
  quietHoursEndUtc        Int?     @map("quiet_hours_end_utc")
  isEnabled               Boolean  @default(true) @map("is_enabled")
  /// Days to wait before evaluating outcomes vs current metrics (deterministic window).
  learningWindowDays      Int?     @default(7) @map("learning_window_days")
  /// Max candidate actions passed to execution per autonomy cycle (UCB1 bandit ranks candidates first).
  maxActionsPerCycle      Int?     @default(2) @map("max_actions_per_cycle")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@unique([scopeType, scopeId])
  @@index([scopeType, scopeId])
  @@map("autonomy_configs")
}

/// Proposed or completed autonomy action (auditable).
model AutonomyAction {
  id                       String                    @id @default(cuid())
  scopeType                String                    @map("scope_type") @db.VarChar(24)
  scopeId                  String                    @map("scope_id")
  domain                   String                    @db.VarChar(32)
  actionType               String                    @map("action_type") @db.VarChar(48)
  signalKey                String?                   @map("signal_key") @db.VarChar(48)
  baselineMetricsJson      Json?                     @map("baseline_metrics_json")
  learningEligible         Boolean                   @default(true) @map("learning_eligible")
  /// Deterministic context feature buckets at selection time (Contextual Bandit audit trail).
  contextFeaturesJson      Json?                     @map("context_features_json")
  payloadJson              Json                      @map("payload_json")
  status                   String                    @db.VarChar(24)
  reason                   String?
  confidence               Float?
  createdAt                DateTime                  @default(now()) @map("created_at")
  executedAt               DateTime?                 @map("executed_at")
  outcome                  AutonomyOutcome?
  counterfactualEvaluation CounterfactualEvaluation?

  @@index([scopeType, scopeId, createdAt])
  @@map("autonomy_actions")
}

model AutonomyOutcome {
  id          String         @id @default(cuid())
  actionId    String         @unique @map("action_id")
  action      AutonomyAction @relation(fields: [actionId], references: [id], onDelete: Cascade)
  scopeType   String         @map("scope_type") @db.VarChar(24)
  scopeId     String         @map("scope_id")
  evaluatedAt DateTime       @default(now()) @map("evaluated_at")

  baselineRevenue   Float? @map("baseline_revenue")
  baselineOccupancy Float? @map("baseline_occupancy")
  baselineBookings  Int?   @map("baseline_bookings")
  baselineAdr       Float? @map("baseline_adr")
  baselineRevpar    Float? @map("baseline_revpar")

  observedRevenue   Float? @map("observed_revenue")
  observedOccupancy Float? @map("observed_occupancy")
  observedBookings  Int?   @map("observed_bookings")
  observedAdr       Float? @map("observed_adr")
  observedRevpar    Float? @map("observed_revpar")

  revenueDelta   Float? @map("revenue_delta")
  occupancyDelta Float? @map("occupancy_delta")
  bookingDelta   Float? @map("booking_delta")
  adrDelta       Float? @map("adr_delta")
  revparDelta    Float? @map("revpar_delta")

  rewardScore          Float?                    @map("reward_score")
  /// Counterfactual baseline expectation for reward (estimate; not causal proof).
  expectedRewardScore  Float?                    @map("expected_reward_score")
  /// Learning signal blending raw outcome reward with uplift estimate (deterministic).
  upliftAdjustedReward Float?                    @map("uplift_adjusted_reward")
  counterfactualEvalId String?                   @unique @map("counterfactual_eval_id")
  counterfactualEval   CounterfactualEvaluation? @relation(fields: [counterfactualEvalId], references: [id], onDelete: SetNull)
  outcomeLabel         String?                   @map("outcome_label") @db.VarChar(24)
  outcomeWindowDays    Int                       @default(7) @map("outcome_window_days")
  notes                String?
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")

  @@index([scopeType, scopeId, createdAt])
  @@map("autonomy_outcomes")
}

/// Deterministic counterfactual / uplift estimate (internal data only; not randomized trial).
model CounterfactualEvaluation {
  id        String         @id @default(cuid())
  actionId  String         @unique @map("action_id")
  action    AutonomyAction @relation(fields: [actionId], references: [id], onDelete: Cascade)
  scopeType String         @map("scope_type") @db.VarChar(24)
  scopeId   String         @map("scope_id")

  baselineWindowDays Int @default(14) @map("baseline_window_days")
  outcomeWindowDays  Int @default(7) @map("outcome_window_days")

  observedRevenue   Float? @map("observed_revenue")
  observedOccupancy Float? @map("observed_occupancy")
  observedBookings  Int?   @map("observed_bookings")
  observedAdr       Float? @map("observed_adr")
  observedRevpar    Float? @map("observed_revpar")

  expectedRevenue   Float? @map("expected_revenue")
  expectedOccupancy Float? @map("expected_occupancy")
  expectedBookings  Float? @map("expected_bookings")
  expectedAdr       Float? @map("expected_adr")
  expectedRevpar    Float? @map("expected_revpar")

  upliftRevenue   Float? @map("uplift_revenue")
  upliftOccupancy Float? @map("uplift_occupancy")
  upliftBookings  Float? @map("uplift_bookings")
  upliftAdr       Float? @map("uplift_adr")
  upliftRevpar    Float? @map("uplift_revpar")

  upliftScore     Float?   @map("uplift_score")
  confidenceScore Float?   @map("confidence_score")
  estimateMethod  String?  @map("estimate_method") @db.VarChar(32)
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  outcome AutonomyOutcome?

  @@index([scopeType, scopeId, createdAt])
  @@map("counterfactual_evaluations")
}

model CounterfactualMatchLog {
  id            String   @id @default(cuid())
  actionId      String   @map("action_id")
  featureKey    String   @map("feature_key") @db.VarChar(48)
  featureValue  String   @map("feature_value") @db.VarChar(64)
  matchedCount  Int      @default(0) @map("matched_count")
  averageReward Float    @default(0) @map("average_reward")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([actionId, createdAt])
  @@map("counterfactual_match_logs")
}

model UpliftLearningLog {
  id        String   @id @default(cuid())
  actionId  String?  @map("action_id")
  scopeType String   @map("scope_type") @db.VarChar(24)
  scopeId   String   @map("scope_id")
  eventType String   @map("event_type") @db.VarChar(32)
  message   String?
  meta      Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([scopeType, scopeId, createdAt])
  @@map("uplift_learning_logs")
}

/// BNHub autonomy holdout / RCT-style measurement (distinct from global `experiments` A/B traffic).
/// Deterministic assignment; policy engine remains authoritative — holdout only skips autonomous execution.
model AutonomyExperiment {
  id           String    @id @default(cuid())
  name         String
  scopeType    String    @map("scope_type") @db.VarChar(24)
  scopeId      String    @map("scope_id")
  domain       String    @db.VarChar(32)
  signalKey    String    @map("signal_key") @db.VarChar(48)
  actionType   String    @map("action_type") @db.VarChar(48)
  /// draft | running | paused | completed
  status       String    @db.VarChar(24)
  /// Fraction [0,1] assigned to treatment (keep low in production; default 15%).
  trafficSplit Float     @default(0.15) @map("traffic_split")
  startDate    DateTime  @map("start_date")
  endDate      DateTime? @map("end_date")

  assignments AutonomyExperimentAssignment[]
  outcomes    AutonomyExperimentOutcome[]
  results     AutonomyExperimentResult[]

  @@index([scopeType, scopeId, status])
  @@index([scopeType, scopeId, domain, signalKey, actionType, status])
  @@map("autonomy_experiments")
}

model AutonomyExperimentAssignment {
  id           String   @id @default(cuid())
  experimentId String   @map("experiment_id")
  entityId     String   @map("entity_id")
  /// control | treatment
  group        String   @db.VarChar(16)
  assignedAt   DateTime @default(now()) @map("assigned_at")

  experiment AutonomyExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@unique([experimentId, entityId])
  @@index([experimentId])
  @@map("autonomy_experiment_assignments")
}

model AutonomyExperimentOutcome {
  id           String @id @default(cuid())
  experimentId String @map("experiment_id")
  entityId     String @map("entity_id")
  group        String @db.VarChar(16)

  revenue   Float
  occupancy Float
  bookings  Int
  adr       Float
  revpar    Float

  createdAt DateTime @default(now()) @map("created_at")

  experiment AutonomyExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@index([experimentId, createdAt])
  @@map("autonomy_experiment_outcomes")
}

model AutonomyExperimentResult {
  id           String @id @default(cuid())
  experimentId String @map("experiment_id")

  treatmentRevenue Float @map("treatment_revenue")
  controlRevenue   Float @map("control_revenue")
  upliftRevenue    Float @map("uplift_revenue")

  treatmentBookings Float @map("treatment_bookings")
  controlBookings   Float @map("control_bookings")
  upliftBookings    Float @map("uplift_bookings")

  confidenceScore Float @map("confidence_score")
  sampleSize      Int   @map("sample_size")

  createdAt DateTime @default(now()) @map("created_at")

  experiment AutonomyExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@index([experimentId, createdAt])
  @@map("autonomy_experiment_results")
}

/// Deterministic BNHub portfolio capital allocation **recommendations** (approval before any spend execution).
model CapitalAllocationPlan {
  id                String  @id @default(cuid())
  scopeType         String  @map("scope_type") @db.VarChar(24)
  scopeId           String  @map("scope_id")
  totalBudget       Float   @map("total_budget")
  allocatableBudget Float   @map("allocatable_budget")
  reserveBudget     Float   @default(0) @map("reserve_budget")
  /// draft | approved | applied | archived
  status            String  @default("draft") @db.VarChar(24)
  periodLabel       String? @map("period_label") @db.VarChar(32)
  notes             String? @db.Text

  items CapitalAllocationItem[]
  logs  CapitalAllocationLog[]  @relation("CapitalAllocationPlanLogs")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([scopeType, scopeId, createdAt])
  @@map("capital_allocation_plans")
}

model CapitalAllocationItem {
  id                  String @id @default(cuid())
  planId              String @map("plan_id")
  listingId           String @map("listing_id")
  /// growth | pricing | operations | optimize | hold | reduce | pause
  allocationType      String @map("allocation_type") @db.VarChar(24)
  allocatedAmount     Float  @map("allocated_amount")
  recommendedAmount   Float  @map("recommended_amount")
  priorityScore       Float  @map("priority_score")
  expectedImpactScore Float  @map("expected_impact_score")
  confidenceScore     Float  @map("confidence_score")
  rationaleJson       Json?  @map("rationale_json")
  metricsJson         Json?  @map("metrics_json")
  /// recommended | approved | rejected | applied
  status              String @default("recommended") @db.VarChar(24)

  plan CapitalAllocationPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([planId, listingId])
  @@map("capital_allocation_items")
}

model CapitalAllocationLog {
  id        String  @id @default(cuid())
  planId    String? @map("plan_id")
  listingId String? @map("listing_id")
  eventType String  @map("event_type") @db.VarChar(32)
  message   String? @db.Text
  meta      Json?

  plan CapitalAllocationPlan? @relation("CapitalAllocationPlanLogs", fields: [planId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([planId, createdAt])
  @@map("capital_allocation_logs")
}

model AutonomyRuleWeight {
  id                  String    @id @default(cuid())
  scopeType           String    @map("scope_type") @db.VarChar(24)
  scopeId             String    @map("scope_id")
  domain              String    @db.VarChar(32)
  signalKey           String    @map("signal_key") @db.VarChar(48)
  actionType          String    @map("action_type") @db.VarChar(48)
  weight              Float     @default(1)
  successCount        Int       @default(0) @map("success_count")
  failureCount        Int       @default(0) @map("failure_count")
  totalReward         Float     @default(0) @map("total_reward")
  /// Bandit (UCB1): times this arm was selected for execution after policy pass.
  selectionCount      Int       @default(0) @map("selection_count")
  /// Running mean of observed rewardScore (outcome evaluation), auditable tie-in to selectionCount.
  averageReward       Float     @default(0) @map("average_reward")
  /// Optional serialized feature affinity profile (reserved for future LinUCB / explainability dumps).
  featureProfileJson  Json?     @map("feature_profile_json")
  contextSuccessCount Int       @default(0) @map("context_success_count")
  contextFailureCount Int       @default(0) @map("context_failure_count")
  lastOutcomeAt       DateTime? @map("last_outcome_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@unique([scopeType, scopeId, domain, signalKey, actionType])
  @@index([scopeType, scopeId])
  @@map("autonomy_rule_weights")
}

model ContextualActionStat {
  id            String   @id @default(cuid())
  scopeType     String   @map("scope_type") @db.VarChar(24)
  scopeId       String   @map("scope_id")
  domain        String   @db.VarChar(32)
  signalKey     String   @map("signal_key") @db.VarChar(48)
  actionType    String   @map("action_type") @db.VarChar(48)
  featureKey    String   @map("feature_key") @db.VarChar(48)
  featureBucket String   @map("feature_bucket") @db.VarChar(48)
  successCount  Int      @default(0) @map("success_count")
  failureCount  Int      @default(0) @map("failure_count")
  averageReward Float    @default(0) @map("average_reward")
  totalReward   Float    @default(0) @map("total_reward")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([scopeType, scopeId, domain, signalKey, actionType, featureKey, featureBucket])
  @@index([scopeType, scopeId, updatedAt])
  @@map("contextual_action_stats")
}

model AutonomyLearningLog {
  id           String   @id @default(cuid())
  scopeType    String   @map("scope_type") @db.VarChar(24)
  scopeId      String   @map("scope_id")
  actionId     String?  @map("action_id")
  ruleWeightId String?  @map("rule_weight_id")
  eventType    String   @map("event_type") @db.VarChar(32)
  message      String?
  meta         Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([scopeType, scopeId, createdAt])
  @@map("autonomy_learning_logs")
}

model AutonomyEventLog {
  id        String   @id @default(cuid())
  scopeType String   @map("scope_type") @db.VarChar(24)
  scopeId   String   @map("scope_id")
  eventType String   @map("event_type") @db.VarChar(32)
  message   String?
  meta      Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([scopeType, scopeId, createdAt])
  @@map("autonomy_event_logs")
}

model BnhubHostQualityProfile {
  id                  String   @id @default(uuid()) @map("id")
  hostUserId          String   @unique @map("host_user_id")
  host                User     @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  responsivenessScore Int      @default(50) @map("responsiveness_score")
  cancellationRateBps Int      @default(0) @map("cancellation_rate_bps")
  messageRateScore    Int      @default(50) @map("message_rate_score")
  breakdownJson       Json?    @map("breakdown_json")
  computedAt          DateTime @default(now()) @map("computed_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([hostUserId])
  @@map("bnhub_host_quality_profiles")
}

