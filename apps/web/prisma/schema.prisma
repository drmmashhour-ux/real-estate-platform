/// Time-series snapshots for city/property-type trend analysis (manual, CSV, or future API).
model MarketDataPoint {
  id               String   @id @default(cuid())
  city             String
  postalCode       String?  @map("postal_code")
  propertyType     String   @map("property_type")
  avgPriceCents    Int      @map("avg_price_cents")
  medianPriceCents Int?     @map("median_price_cents")
  avgRentCents     Int?     @map("avg_rent_cents")
  transactions     Int?
  inventory        Int?
  date             DateTime
