  createdAt      DateTime     @default(now()) @map("created_at")

  @@unique([marketRegionId, period])
  @@index([marketRegionId])
  @@index([period])
  @@map("market_demand_metrics")
}

model MarketInvestmentScore {
  id                 String           @id @default(uuid())
  propertyIdentityId String           @map("property_identity_id")
  propertyIdentity   PropertyIdentity @relation(fields: [propertyIdentityId], references: [id], onDelete: Cascade)
  marketRegionId     String           @map("market_region_id")
  marketRegion       MarketRegion     @relation(fields: [marketRegionId], references: [id], onDelete: Cascade)
  investmentScore    Int              @map("investment_score") // 0-100
  riskLevel          String           @map("risk_level") // low | medium | high
  summary            String?
  createdAt          DateTime         @default(now()) @map("created_at")

  @@unique([propertyIdentityId, marketRegionId])
  @@index([propertyIdentityId])
  @@index([marketRegionId])
  @@map("market_investment_scores")
}

model MarketReport {
  id             String       @id @default(uuid())
  marketRegionId String       @map("market_region_id")
  marketRegion   MarketRegion @relation(fields: [marketRegionId], references: [id], onDelete: Cascade)
  reportPeriod   String       @map("report_period") // e.g. "2025-01"
  reportSummary  String?      @map("report_summary")
  reportData     Json?        @map("report_data")
