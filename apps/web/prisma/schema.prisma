  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("ai_writer_usage_logs")
}

/// Daily aggregates: `visitors` incremented by POST /api/analytics/track-visit.
/// Listing and transaction fields on the row are optional denorm targets; charts use live DB counts per day (see getPlatformStats).
model PlatformAnalytics {
  id                 String   @id @default(cuid())
  /// UTC midnight for the calendar day
  date               DateTime
  visitors           Int      @default(0)
  listingsBroker     Int      @default(0) @map("listings_broker")
  listingsSelf       Int      @default(0) @map("listings_self")
  transactionsClosed Int      @default(0) @map("transactions_closed")
  createdAt          DateTime @default(now()) @map("created_at")

  @@unique([date])
  @@index([date])
  @@map("platform_analytics")
}

// ---------------------------------------------------------------------------
// Listing offer workflow (buyer ↔ broker; audit via OfferEvent)
// ---------------------------------------------------------------------------

enum OfferStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  COUNTERED
  ACCEPTED
  REJECTED
  WITHDRAWN
  EXPIRED
}

enum OfferEventType {
  CREATED
  SUBMITTED
  STATUS_CHANGED
  COUNTERED
  ACCEPTED
  REJECTED
  WITHDRAWN
  NOTE_ADDED
}

model Offer {
  id        String      @id @default(cuid())
  listingId String      @map("listing_id")
  buyerId   String      @map("buyer_id")
  brokerId  String?     @map("broker_id")
  tenantId  String?     @map("tenant_id")
  tenant    Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  status    OfferStatus @default(DRAFT)

  offeredPrice      Float     @map("offered_price")
  downPaymentAmount Float?    @map("down_payment_amount")
  financingNeeded   Boolean?  @map("financing_needed")
  closingDate       DateTime? @map("closing_date")
  conditions        String?   @db.Text
  message           String?   @db.Text

  /// Mortgage / offer assumptions (e.g. simulator snapshot)
  scenario Json?

  commissionEligible Boolean @default(true) @map("commission_eligible")
  /// DIRECT_LEAD (buyer contacted listing broker) | PLATFORM_BROKER (platform-facilitated).
  commissionSource   String? @map("commission_source")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  buyer           User             @relation("ListingOfferBuyer", fields: [buyerId], references: [id], onDelete: Restrict)
  broker          User?            @relation("ListingOfferBroker", fields: [brokerId], references: [id], onDelete: SetNull)
  events          OfferEvent[]
  appointments    Appointment[]
  conversations   Conversation[]
  documentFolders DocumentFolder[]
  documentFiles   DocumentFile[]
  dealFinancials  DealFinancial[]
  tenantInvoices  TenantInvoice[]

  @@index([listingId])
  @@index([buyerId])
  @@index([brokerId])
  @@index([tenantId])
  @@index([status])
  @@map("listing_offers")
}

model OfferEvent {
  id        String         @id @default(cuid())
  offerId   String         @map("offer_id")
  tenantId  String?        @map("tenant_id")
  tenant    Tenant?        @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorId   String?        @map("actor_id")
  type      OfferEventType
  message   String?        @db.Text
  metadata  Json?
  createdAt DateTime       @default(now()) @map("created_at")

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  actor User? @relation("ListingOfferEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([offerId])
  @@index([tenantId])
  @@map("listing_offer_events")
}

// ---------------------------------------------------------------------------
// Broker CRM — clients, interactions, listing links (no duplicate offer/contract rows)
// ---------------------------------------------------------------------------

enum BrokerClientStatus {
  LEAD
  CONTACTED
  QUALIFIED
  VIEWING
  NEGOTIATING
  UNDER_CONTRACT
  CLOSED
  LOST
}

enum BrokerInteractionType {
  NOTE
  EMAIL
  CALL
  MEETING
  TASK
  FOLLOW_UP
  STATUS_CHANGE
}

enum BrokerClientListingKind {
  SAVED
  SHARED
  VIEWED
  FAVORITE
}

model BrokerClient {
  id         String             @id @default(cuid())
  brokerId   String             @map("broker_id")
  tenantId   String?            @map("tenant_id")
  tenant     Tenant?            @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  userId     String?            @map("user_id")
  fullName   String             @map("full_name")
  email      String?
  phone      String?
  status     BrokerClientStatus @default(LEAD)
  source     String?
  budgetMin  Float?             @map("budget_min")
  budgetMax  Float?             @map("budget_max")
  targetCity String?            @map("target_city")
  notes      String?            @db.Text
  tags       String[]           @default([])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  broker                User                      @relation("BrokerCrmOwner", fields: [brokerId], references: [id], onDelete: Cascade)
  linkedUser            User?                     @relation("BrokerCrmLinkedUser", fields: [userId], references: [id], onDelete: SetNull)
  interactions          BrokerClientInteraction[]
  listingLinks          BrokerClientListing[]
  appointments          Appointment[]
  conversations         Conversation[]
  buyerRequests         BuyerRequest[]
  documentFolders       DocumentFolder[]
  documentFiles         DocumentFile[]
  intakeProfile         ClientIntakeProfile?
  requiredDocumentItems RequiredDocumentItem[]
  intakeEvents          ClientIntakeEvent[]
  tenantInvoices        TenantInvoice[]

  @@index([brokerId])
  @@index([userId])
  @@index([status])
  @@map("broker_clients")
}

/// Broker-scoped CRM memory (preferences extracted + broker notes). Minimize retention per Law 25.
model ClientMemory {
  id          String   @id @default(cuid())
  clientId    String   @map("client_id")
  brokerId    String   @map("broker_id")
  preferences Json     @default("{}")
  notes       String   @default("") @db.Text
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([clientId, brokerId])
  @@index([brokerId])
  @@map("client_memories")
}

model BrokerClientInteraction {
  id             String                @id @default(cuid())
  brokerClientId String                @map("broker_client_id")
  actorId        String?               @map("actor_id")
  type           BrokerInteractionType
  title          String?
  message        String?               @db.Text
  metadata       Json?
  dueAt          DateTime?             @map("due_at")
  completedAt    DateTime?             @map("completed_at")
  createdAt      DateTime              @default(now()) @map("created_at")

  brokerClient BrokerClient @relation(fields: [brokerClientId], references: [id], onDelete: Cascade)
  actor        User?        @relation("BrokerCrmInteractionActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([brokerClientId])
  @@index([dueAt])
  @@map("broker_client_interactions")
}

model BrokerClientListing {
  id             String                  @id @default(cuid())
  brokerClientId String                  @map("broker_client_id")
  listingId      String                  @map("listing_id")
  kind           BrokerClientListingKind @default(SAVED)
  createdAt      DateTime                @default(now()) @map("created_at")

  brokerClient BrokerClient @relation(fields: [brokerClientId], references: [id], onDelete: Cascade)

  @@unique([brokerClientId, listingId])
  @@index([brokerClientId])
  @@index([listingId])
  @@map("broker_client_listings")
}

// ---------------------------------------------------------------------------
// Scheduling — availability, appointments (calendar / visits / calls)
// ---------------------------------------------------------------------------

enum AppointmentType {
  PROPERTY_VISIT
  CALL
  MEETING
  CONSULTATION
  DOCUMENT_REVIEW
  OFFER_DISCUSSION
  CONTRACT_SIGNING
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  RESCHEDULE_REQUESTED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum MeetingMode {
  IN_PERSON
  PHONE
  VIDEO
}

enum AppointmentEventType {
  REQUESTED
  CONFIRMED
  RESCHEDULED
  CANCELLED
  COMPLETED
  NO_SHOW
  NOTE_ADDED
  STATUS_CHANGED
}

model AvailabilityRule {
  id          String   @id @default(cuid())
  brokerId    String   @map("broker_id")
  /// 0 = Sunday … 6 = Saturday (aligns with Date.getUTCDay() when using UTC rules)
  dayOfWeek   Int      @map("day_of_week")
  /// Minutes from midnight [0, 1440)
  startMinute Int      @map("start_minute")
  endMinute   Int      @map("end_minute")
  isActive    Boolean  @default(true) @map("is_active")
  timezone    String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  broker User @relation(fields: [brokerId], references: [id], onDelete: Cascade)

  @@index([brokerId])
  @@index([dayOfWeek])
  @@map("availability_rules")
}

model AvailabilityException {
  id          String   @id @default(cuid())
  brokerId    String   @map("broker_id")
  startsAt    DateTime @map("starts_at")
  endsAt      DateTime @map("ends_at")
  reason      String?
  /// false = blocked / unavailable; true = extra availability window
  isAvailable Boolean  @default(false) @map("is_available")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  broker User @relation(fields: [brokerId], references: [id], onDelete: Cascade)

  @@index([brokerId])
  @@index([startsAt])
  @@map("availability_exceptions")
}

model Appointment {
  id                 String            @id @default(cuid())
  brokerId           String            @map("broker_id")
  tenantId           String?           @map("tenant_id")
  tenant             Tenant?           @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  clientUserId       String?           @map("client_user_id")
  brokerClientId     String?           @map("broker_client_id")
  listingId          String?           @map("listing_id")
  offerId            String?           @map("offer_id")
  contractId         String?           @map("contract_id")
  type               AppointmentType
  status             AppointmentStatus @default(PENDING)
  title              String
  description        String?           @db.Text
  location           String?
  startsAt           DateTime          @map("starts_at")
  endsAt             DateTime          @map("ends_at")
  timezone           String?
  meetingMode        MeetingMode       @default(IN_PERSON) @map("meeting_mode")
  requestedById      String?           @map("requested_by_id")
  confirmedAt        DateTime?         @map("confirmed_at")
  cancelledAt        DateTime?         @map("cancelled_at")
  cancellationReason String?           @map("cancellation_reason") @db.Text
  rescheduleReason   String?           @map("reschedule_reason") @db.Text
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  broker          User               @relation("AppointmentBroker", fields: [brokerId], references: [id], onDelete: Cascade)
  clientUser      User?              @relation("AppointmentClientUser", fields: [clientUserId], references: [id], onDelete: SetNull)
  brokerClient    BrokerClient?      @relation(fields: [brokerClientId], references: [id], onDelete: SetNull)
  listing         Listing?           @relation(fields: [listingId], references: [id], onDelete: SetNull)
  offer           Offer?             @relation(fields: [offerId], references: [id], onDelete: SetNull)
  contract        Contract?          @relation(fields: [contractId], references: [id], onDelete: SetNull)
  requestedBy     User?              @relation("AppointmentRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  events          AppointmentEvent[]
  conversations   Conversation[]
  documentFolders DocumentFolder[]
  documentFiles   DocumentFile[]

  @@index([brokerId])
  @@index([tenantId])
  @@index([clientUserId])
  @@index([brokerClientId])
  @@index([listingId])
  @@index([offerId])
  @@index([contractId])
  @@index([startsAt])
  @@index([status])
  @@map("appointments")
}

model AppointmentEvent {
  id            String               @id @default(cuid())
  appointmentId String               @map("appointment_id")
  tenantId      String?              @map("tenant_id")
  tenant        Tenant?              @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorId       String?              @map("actor_id")
  type          AppointmentEventType
  message       String?              @db.Text
  metadata      Json?
  createdAt     DateTime             @default(now()) @map("created_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  actor       User?       @relation("AppointmentEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([appointmentId])
  @@index([tenantId])
  @@map("appointment_events")
}

// ---------------------------------------------------------------------------
// In-app messaging — conversations, messages, read state
// ---------------------------------------------------------------------------

enum ConversationType {
  DIRECT
  LISTING
  OFFER
  CONTRACT
  APPOINTMENT
  CLIENT_THREAD
  SUPPORT
}

enum MessageType {
  TEXT
  SYSTEM
  NOTE
  VOICE
}

enum MessageEventType {
  CONVERSATION_CREATED
  PARTICIPANT_ADDED
  MESSAGE_SENT
  MESSAGE_EDITED
  MESSAGE_DELETED
  CONVERSATION_ARCHIVED
  READ
}

model Conversation {
  id             String           @id @default(cuid())
  type           ConversationType @default(DIRECT)
  tenantId       String?          @map("tenant_id")
  tenant         Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  listingId      String?          @map("listing_id")
  /// FSBO listing context for buyer ↔ owner threads (CRM `listingId` stays null).
  fsboListingId  String?          @map("fsbo_listing_id") @db.VarChar(64)
  offerId        String?          @map("offer_id")
  contractId     String?          @map("contract_id")
  appointmentId  String?          @map("appointment_id")
  brokerClientId String?          @map("broker_client_id")
  createdById    String?          @map("created_by_id")
  subject        String?
  lastMessageAt  DateTime?        @map("last_message_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  createdBy              User?                     @relation("ConversationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  listing                Listing?                  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  fsboListing            FsboListing?              @relation("ConversationFsboListing", fields: [fsboListingId], references: [id], onDelete: SetNull)
  offer                  Offer?                    @relation(fields: [offerId], references: [id], onDelete: SetNull)
  contract               Contract?                 @relation(fields: [contractId], references: [id], onDelete: SetNull)
  appointment            Appointment?              @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  brokerClient           BrokerClient?             @relation(fields: [brokerClientId], references: [id], onDelete: SetNull)
  participants           ConversationParticipant[]
  messages               Message[]
  events                 MessageEvent[]
  documentFolders        DocumentFolder[]
  documentFiles          DocumentFile[]
  buyerRequest           BuyerRequest?
  leadForPlatformContact Lead?                     @relation("LeadPlatformConversation")

  @@index([listingId])
  @@index([fsboListingId])
  @@index([tenantId])
  @@index([offerId])
  @@index([contractId])
  @@index([appointmentId])
  @@index([brokerClientId])
  @@index([lastMessageAt])
  @@map("conversations")
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String    @map("conversation_id")
  userId         String    @map("user_id")
  roleLabel      String?   @map("role_label")
  isArchived     Boolean   @default(false) @map("is_archived")
  lastReadAt     DateTime? @map("last_read_at")
  joinedAt       DateTime  @default(now()) @map("joined_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String      @id @default(cuid())
  conversationId String      @map("conversation_id")
  tenantId       String?     @map("tenant_id")
  tenant         Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  senderId       String      @map("sender_id")
  body           String      @db.Text
  messageType    MessageType @default(TEXT) @map("message_type")
  metadata       Json?
  editedAt       DateTime?   @map("edited_at")
  deletedAt      DateTime?   @map("deleted_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  conversation Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User           @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  events       MessageEvent[]

  @@index([conversationId])
  @@index([tenantId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}

model MessageEvent {
  id             String           @id @default(cuid())
  messageId      String?          @map("message_id")
  conversationId String           @map("conversation_id")
  actorId        String?          @map("actor_id")
  type           MessageEventType
  metadata       Json?
  createdAt      DateTime         @default(now()) @map("created_at")

  message      Message?     @relation(fields: [messageId], references: [id], onDelete: SetNull)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  actor        User?        @relation("MessageEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@index([messageId])
  @@map("message_events")
}

// ---------------------------------------------------------------------------
// Document Center — folders, files, access grants, audit events
// ---------------------------------------------------------------------------

enum DocumentFolderType {
  GENERAL
  LISTING_ROOM
  CLIENT_ROOM
  OFFER_ROOM
  CONTRACT_ROOM
  APPOINTMENT_ROOM
  CONVERSATION_ROOM
}

enum DocumentFileStatus {
  UPLOADING
  AVAILABLE
  ARCHIVED
  DELETED
  FAILED
}

enum DocumentVisibility {
  PRIVATE_INTERNAL
  SHARED_PARTICIPANTS
  BROKER_ONLY
  CLIENT_VISIBLE
  ADMIN_ONLY
}

enum DocumentCategory {
  IDENTITY
  FINANCIAL
  CONTRACT
  DISCLOSURE
  PROPERTY
  APPOINTMENT
  MESSAGE_ATTACHMENT
  OTHER
}

enum DocumentAccessLevel {
  VIEW
  COMMENT
  EDIT
  MANAGE
}

enum DocumentEventType {
  FOLDER_CREATED
  FILE_UPLOADED
  FILE_RENAMED
  FILE_MOVED
  FILE_ARCHIVED
  FILE_DELETED
  FILE_SHARED
  FILE_VIEWED
  FILE_DOWNLOADED
  ACCESS_CHANGED
}

model DocumentFolder {
  id             String             @id @default(cuid())
  tenantId       String?            @map("tenant_id")
  tenant         Tenant?            @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  name           String
  type           DocumentFolderType @default(GENERAL)
  listingId      String?            @map("listing_id")
  brokerClientId String?            @map("broker_client_id")
  offerId        String?            @map("offer_id")
  contractId     String?            @map("contract_id")
  appointmentId  String?            @map("appointment_id")
  conversationId String?            @map("conversation_id")
  createdById    String?            @map("created_by_id")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  createdBy    User?           @relation("DocumentFolderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  listing      Listing?        @relation(fields: [listingId], references: [id], onDelete: SetNull)
  brokerClient BrokerClient?   @relation(fields: [brokerClientId], references: [id], onDelete: SetNull)
  offer        Offer?          @relation(fields: [offerId], references: [id], onDelete: SetNull)
  contract     Contract?       @relation(fields: [contractId], references: [id], onDelete: SetNull)
  appointment  Appointment?    @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  conversation Conversation?   @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  files        DocumentFile[]
  events       DocumentEvent[] @relation("FolderDocumentEvents")

  @@index([listingId])
  @@index([brokerClientId])
  @@index([offerId])
  @@index([contractId])
  @@index([appointmentId])
  @@index([conversationId])
  @@index([tenantId])
  @@map("document_folders")
}

model DocumentFile {
  id              String             @id @default(cuid())
  tenantId        String?            @map("tenant_id")
  tenant          Tenant?            @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  folderId        String?            @map("folder_id")
  uploadedById    String?            @map("uploaded_by_id")
  fileName        String             @map("file_name")
  originalName    String             @map("original_name")
  mimeType        String             @map("mime_type")
  sizeBytes       Int                @map("size_bytes")
  storageKey      String             @map("storage_key")
  storageProvider String?            @map("storage_provider")
  checksum        String?
  status          DocumentFileStatus @default(AVAILABLE)
  visibility      DocumentVisibility @default(PRIVATE_INTERNAL)
  category        DocumentCategory   @default(OTHER)
  listingId       String?            @map("listing_id")
  brokerClientId  String?            @map("broker_client_id")
  offerId         String?            @map("offer_id")
  contractId      String?            @map("contract_id")
  appointmentId   String?            @map("appointment_id")
  conversationId  String?            @map("conversation_id")
  description     String?            @db.Text
  tags            String[]           @default([])
  metadata        Json?
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  folder       DocumentFolder?        @relation(fields: [folderId], references: [id], onDelete: SetNull)
  uploadedBy   User?                  @relation("DocumentFileUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  listing      Listing?               @relation(fields: [listingId], references: [id], onDelete: SetNull)
  brokerClient BrokerClient?          @relation(fields: [brokerClientId], references: [id], onDelete: SetNull)
  offer        Offer?                 @relation(fields: [offerId], references: [id], onDelete: SetNull)
  contract     Contract?              @relation(fields: [contractId], references: [id], onDelete: SetNull)
  appointment  Appointment?           @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  conversation Conversation?          @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  accessGrants DocumentAccessGrant[]
  events       DocumentEvent[]        @relation("FileDocumentEvents")
  intakeLinks  RequiredDocumentItem[] @relation("IntakeLinkedDocument")
  /**
   * Enterprise workspace scope for team document vaults (optional).
   */
  workspaceId  String?                @map("workspace_id") @db.Uuid
  workspace    EnterpriseWorkspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([folderId])
  @@index([uploadedById])
  @@index([listingId])
  @@index([brokerClientId])
  @@index([workspaceId])
  @@index([offerId])
  @@index([contractId])
  @@index([appointmentId])
  @@index([conversationId])
  @@index([visibility])
  @@index([category])
  @@index([tenantId])
  @@map("document_files")
}

model DocumentAccessGrant {
  id             String              @id @default(cuid())
  documentFileId String              @map("document_file_id")
  userId         String              @map("user_id")
  access         DocumentAccessLevel @default(VIEW)
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  documentFile DocumentFile @relation(fields: [documentFileId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([documentFileId, userId])
  @@index([documentFileId])
  @@index([userId])
  @@map("document_access_grants")
}

model DocumentEvent {
  id             String            @id @default(cuid())
  documentFileId String?           @map("document_file_id")
  folderId       String?           @map("folder_id")
  actorId        String?           @map("actor_id")
  type           DocumentEventType
  message        String?           @db.Text
  metadata       Json?
  createdAt      DateTime          @default(now()) @map("created_at")

  documentFile DocumentFile?   @relation("FileDocumentEvents", fields: [documentFileId], references: [id], onDelete: SetNull)
  folder       DocumentFolder? @relation("FolderDocumentEvents", fields: [folderId], references: [id], onDelete: SetNull)
  actor        User?           @relation("DocumentEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([documentFileId])
  @@index([folderId])
  @@map("document_events")
}

// ---------------------------------------------------------------------------
// Client intake / required documents checklist (KYC-style workflow)
// ---------------------------------------------------------------------------

enum ClientIntakeStatus {
  NOT_STARTED
  IN_PROGRESS
  UNDER_REVIEW
  COMPLETE
  ON_HOLD
}

enum RequiredDocumentCategory {
  IDENTITY
  INCOME
  BANKING
  TAX
  RESIDENCY
  CREDIT
  EMPLOYMENT
  CORPORATE
  PROPERTY
  OTHER
}

enum RequiredDocumentStatus {
  REQUIRED
  REQUESTED
  UPLOADED
  UNDER_REVIEW
  APPROVED
  REJECTED
  WAIVED
}

enum ClientIntakeEventType {
  INTAKE_CREATED
  INTAKE_UPDATED
  STATUS_CHANGED
  DOCUMENT_REQUESTED
  DOCUMENT_UPLOADED
  DOCUMENT_LINKED
  DOCUMENT_APPROVED
  DOCUMENT_REJECTED
  DOCUMENT_WAIVED
  NOTE_ADDED
}

model ClientIntakeProfile {
  id                   String             @id @default(cuid())
  tenantId             String?            @map("tenant_id")
  tenant               Tenant?            @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  brokerClientId       String             @unique @map("broker_client_id")
  userId               String?            @map("user_id")
  legalFirstName       String?            @map("legal_first_name")
  legalLastName        String?            @map("legal_last_name")
  dateOfBirth          DateTime?          @map("date_of_birth")
  phone                String?
  email                String?
  employmentStatus     String?            @map("employment_status")
  annualIncome         Float?             @map("annual_income")
  estimatedAssets      Float?             @map("estimated_assets")
  estimatedLiabilities Float?             @map("estimated_liabilities")
  residencyStatus      String?            @map("residency_status")
  citizenshipCountry   String?            @map("citizenship_country")
  maritalStatus        String?            @map("marital_status")
  currentAddress       String?            @map("current_address") @db.Text
  city                 String?
  provinceState        String?            @map("province_state")
  postalCode           String?            @map("postal_code")
  country              String?
  notes                String?            @db.Text
  status               ClientIntakeStatus @default(NOT_STARTED)
  completedAt          DateTime?          @map("completed_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  brokerClient          BrokerClient           @relation(fields: [brokerClientId], references: [id], onDelete: Cascade)
  user                  User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  requiredDocumentItems RequiredDocumentItem[]
  intakeEvents          ClientIntakeEvent[]

  @@index([userId])
  @@index([tenantId])
  @@map("client_intake_profiles")
}

model RequiredDocumentItem {
  id                   String                   @id @default(cuid())
  tenantId             String?                  @map("tenant_id")
  tenant               Tenant?                  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  brokerClientId       String                   @map("broker_client_id")
  intakeProfileId      String?                  @map("intake_profile_id")
  title                String
  description          String?                  @db.Text
  category             RequiredDocumentCategory
  status               RequiredDocumentStatus   @default(REQUIRED)
  isMandatory          Boolean                  @default(true) @map("is_mandatory")
  requestedById        String?                  @map("requested_by_id")
  dueAt                DateTime?                @map("due_at")
  reviewedById         String?                  @map("reviewed_by_id")
  linkedDocumentFileId String?                  @map("linked_document_file_id")
  rejectionReason      String?                  @map("rejection_reason") @db.Text
  notes                String?                  @db.Text
  deletedAt            DateTime?                @map("deleted_at")
  createdAt            DateTime                 @default(now()) @map("created_at")
  updatedAt            DateTime                 @updatedAt @map("updated_at")

  brokerClient       BrokerClient         @relation(fields: [brokerClientId], references: [id], onDelete: Cascade)
  intakeProfile      ClientIntakeProfile? @relation(fields: [intakeProfileId], references: [id], onDelete: SetNull)
  requestedBy        User?                @relation("RequiredDocRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  reviewedBy         User?                @relation("RequiredDocReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  linkedDocumentFile DocumentFile?        @relation("IntakeLinkedDocument", fields: [linkedDocumentFileId], references: [id], onDelete: SetNull)
  intakeEvents       ClientIntakeEvent[]

  @@index([brokerClientId])
  @@index([intakeProfileId])
  @@index([status])
  @@index([linkedDocumentFileId])
  @@index([tenantId])
  @@map("required_document_items")
}

model ClientIntakeEvent {
  id                     String                @id @default(cuid())
  brokerClientId         String                @map("broker_client_id")
  intakeProfileId        String?               @map("intake_profile_id")
  requiredDocumentItemId String?               @map("required_document_item_id")
  actorId                String?               @map("actor_id")
  type                   ClientIntakeEventType
  message                String?               @db.Text
  metadata               Json?
  createdAt              DateTime              @default(now()) @map("created_at")

  brokerClient         BrokerClient          @relation(fields: [brokerClientId], references: [id], onDelete: Cascade)
  intakeProfile        ClientIntakeProfile?  @relation(fields: [intakeProfileId], references: [id], onDelete: SetNull)
  requiredDocumentItem RequiredDocumentItem? @relation(fields: [requiredDocumentItemId], references: [id], onDelete: SetNull)
  actor                User?                 @relation("ClientIntakeEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([brokerClientId])
  @@index([intakeProfileId])
  @@index([requiredDocumentItemId])
  @@map("client_intake_events")
}

