// 2. Evidence Preservation – chain-of-custody, access log
// ---------------------------------------------------------------------------
model EvidenceRecord {
  id             String    @id @default(uuid())
  caseType       String // DISPUTE | FRAUD | INCIDENT | COMPLIANCE | LEGAL
  caseId         String
  classification String // PHOTO | DOCUMENT | SCREENSHOT | LOG_EXPORT
  url            String // storage URL or reference
  filename       String?
  mimeType       String?
  uploadedBy     String
  uploadedAt     DateTime  @default(now())
  metadata       Json?
  retentionUntil DateTime?
  checksum       String? // integrity

  @@index([caseType, caseId])
  @@index([uploadedAt])
}

model EvidenceAccessLog {
  id         String   @id @default(uuid())
  evidenceId String
  accessedBy String
  accessType String // VIEW | EXPORT | DOWNLOAD
  reasonCode String?
  createdAt  DateTime @default(now())

  @@index([evidenceId])
  @@index([accessedBy])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// 3. Abuse Prevention – signals, offender profiles
// ---------------------------------------------------------------------------
enum AbuseSignalType {
  REPEAT_OFFENDER
  LINKED_ACCOUNT
  EVASION_AFTER_SUSPENSION
  ABUSIVE_MESSAGING
  ABUSIVE_BOOKING
  REFUND_ABUSE
  PROMOTION_ABUSE
  REFERRAL_ABUSE
  BAN_EVASION
}

model AbuseSignal {
  id         String          @id @default(uuid())
  userId     String?
  entityType String?
  entityId   String?
  signalType AbuseSignalType
  severity   String // LOW | MEDIUM | HIGH
  payload    Json? // IP, device hints, correlation ids
  createdBy  String? // system or staff
  createdAt  DateTime        @default(now())

  @@index([userId])
  @@index([signalType])
  @@index([createdAt])
}

model OffenderProfile {
  id               String    @id @default(uuid())
  userId           String    @unique
  strikeCount      Int       @default(0)
  lastStrikeAt     DateTime?
  suspendedAt      DateTime?
  bannedAt         DateTime?
  linkedAccountIds Json      @default("[]") // suspected or confirmed
  notes            String?
  updatedAt        DateTime
  createdAt        DateTime  @default(now())

  @@index([userId])
}

// ---------------------------------------------------------------------------
// 4. Internal Access – privileged actions, approvals
// ---------------------------------------------------------------------------
model PrivilegedAdminAction {
  id         String   @id @default(uuid())
  adminId    String
  actionType String // PAYOUT_RELEASE | SUSPENSION | BAN | IMPERSONATION | EVIDENCE_ACCESS | LEGAL_EXPORT
  entityType String?
  entityId   String?
  reasonCode String?
  reasonText String?
  approvalId String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([actionType])
  @@index([createdAt])
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model ApprovalRequest {
  id          String                @id @default(uuid())
  requestType String // PAYOUT_RELEASE | ACCOUNT_SUSPENSION | BAN | CRISIS_ACTION
  requestedBy String
  targetType  String?
  targetId    String?
  reasonCode  String?
  payload     Json?
  status      ApprovalRequestStatus @default(PENDING)
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNotes String?
  createdAt   DateTime
  updatedAt   DateTime              @updatedAt

  @@index([status])
  @@index([requestedBy])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// 5. Crisis Response – events, action log
// ---------------------------------------------------------------------------
enum CrisisSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model CrisisEvent {
  id          String            @id @default(uuid())
  title       String
  severity    CrisisSeverity
  status      String            @default("ACTIVE") // ACTIVE | CONTAINED | RESOLVED
  region      String? // market or region
  startedAt   DateTime          @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?
  playbookRef String? // reference to runbook
  summary     String?
  createdAt   DateTime
  updatedAt   DateTime          @updatedAt
  actionLogs  CrisisActionLog[]

  @@index([status])
  @@index([severity])
  @@index([startedAt])
}

model CrisisActionLog {
  id          String      @id @default(uuid())
  crisisId    String
  crisis      CrisisEvent @relation(fields: [crisisId], references: [id], onDelete: Cascade)
  actionType  String // BOOKING_FREEZE | PAYOUT_FREEZE | CONTENT_TAKEDOWN | ESCALATION
  targetType  String?
  targetId    String?
  performedBy String
  reasonCode  String?
  payload     Json?
  createdAt   DateTime    @default(now())

  @@index([crisisId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// 6. Regulatory Compliance – requirements, reviews
// ---------------------------------------------------------------------------
model ComplianceRequirement {
  id             String   @id @default(uuid())
  marketId       String
  requirementKey String // TAX_REGISTRATION | LICENSING | DATA_RETENTION | DISCLOSURE
  name           String
  description    String?
  active         Boolean
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([marketId])
  @@index([requirementKey])
}

model ComplianceReview {
  id            String    @id @default(uuid())
  requirementId String?
  entityType    String // USER | LISTING | BOOKING
  entityId      String
  marketId      String?
  status        String // PENDING | COMPLIANT | NON_COMPLIANT | EXCEPTION
  reviewedAt    DateTime?
  reviewedBy    String?
  notes         String?
  documentRefs  Json
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([entityType, entityId])
  @@index([marketId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// 7. Financial Defense – risk flags, intervention log
// ---------------------------------------------------------------------------
model FinancialRiskFlag {
  id          String    @id @default(uuid())
  entityType  String // PAYOUT | PAYMENT | REFUND | BOOKING
  entityId    String
  flagType    String // SUSPICIOUS_PAYOUT | REFUND_ABUSE | CHARGEBACK_RISK | ANOMALY
  severity    String // LOW | MEDIUM | HIGH
  status      String    @default("OPEN") // OPEN | UNDER_REVIEW | CLEARED | CONFIRMED
  amountCents Int?
  payload     Json?
  createdBy   String?
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime  @default(now())

  @@index([entityType, entityId])
  @@index([flagType])
  @@index([status])
}

// ---------------------------------------------------------------------------
// 8. Enforcement – actions, appeals
// ---------------------------------------------------------------------------
enum EnforcementActionType {
  WARNING
  TEMPORARY_RESTRICTION
  LISTING_FREEZE
  BOOKING_LIMITATION
  PAYOUT_HOLD
  ACCOUNT_SUSPENSION
  PERMANENT_BAN
  MARKET_SPECIFIC
}

model EnforcementAction {
  id          String                @id @default(uuid())
  userId      String
  actionType  EnforcementActionType
  severity    String // LOW | MEDIUM | HIGH | CRITICAL
  reasonCode  String
  reasonText  String?
  marketId    String?
  effectiveAt DateTime              @default(now())
  expiresAt   DateTime?
  performedBy String?
  appealId    String?
  metadata    Json?
  createdAt   DateTime              @default(now())

  @@index([userId])
  @@index([actionType])
  @@index([effectiveAt])
  @@index([reasonCode])
}

enum AppealStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  WITHDRAWN
}

model Appeal {
  id            String       @id @default(uuid())
  enforcementId String?
  userId        String
  reasonCode    String?
  description   String
  status        AppealStatus
  submittedAt   DateTime     @default(now())
  reviewedBy    String?
  reviewedAt    DateTime?
  outcomeNotes  String?
  createdAt     DateTime
  updatedAt     DateTime     @updatedAt

  @@index([userId])
  @@index([status])
  @@index([submittedAt])
}

// ---------------------------------------------------------------------------
// Trust & Safety Engine – incidents, evidence, actions, profiles, appeals
// ---------------------------------------------------------------------------
enum TrustSafetyIncidentStatus {
  SUBMITTED
  UNDER_REVIEW
  WAITING_RESPONSE
  ESCALATED
  RESOLVED
  CLOSED
}

enum TrustSafetySeverity {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

enum TrustSafetyRiskLevel {
  LOW_RISK
  MEDIUM_RISK
  HIGH_RISK
  CRITICAL_RISK
}

model TrustSafetyIncident {
  id               String                        @id @default(uuid())
  reporterId       String                        @map("reporter_id")
  reporter         User                          @relation("IncidentReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  accusedUserId    String?                       @map("accused_user_id")
  accusedUser      User?                         @relation("IncidentAccused", fields: [accusedUserId], references: [id], onDelete: SetNull)
  listingId        String?                       @map("listing_id")
  listing          ShortTermListing?             @relation(fields: [listingId], references: [id], onDelete: SetNull)
  bookingId        String?                       @map("booking_id")
  booking          Booking?                      @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  incidentCategory String                        @map("incident_category")
  severityLevel    TrustSafetySeverity           @default(MEDIUM) @map("severity_level")
  riskScore        Float?                        @map("risk_score") // 0-1
  riskLevel        TrustSafetyRiskLevel?         @map("risk_level")
  status           TrustSafetyIncidentStatus     @default(SUBMITTED)
  urgencyLevel     String?                       @map("urgency_level") // normal | high | urgent | emergency
  description      String
  incidentTime     DateTime?
  createdAt        DateTime                      @default(now()) @map("created_at")
  updatedAt        DateTime                      @updatedAt @map("updated_at")
  resolvedAt       DateTime?                     @map("resolved_at")
  resolvedBy       String?                       @map("resolved_by")
  resolutionNotes  String?                       @map("resolution_notes")
  evidence         TrustSafetyEvidence[]
  actions          TrustSafetyAction[]
  appeals          TrustSafetyAppeal[]
  responses        TrustSafetyIncidentResponse[]

  @@index([reporterId])
  @@index([accusedUserId])
  @@index([listingId])
  @@index([bookingId])
  @@index([status])
  @@index([severityLevel])
  @@index([incidentCategory])
  @@index([createdAt])
  @@map("trust_safety_incidents")
}

model TrustSafetyEvidence {
  id         String              @id @default(uuid())
  incidentId String              @map("incident_id")
  incident   TrustSafetyIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  fileUrl    String              @map("file_url")
  fileType   String?             @map("file_type") // photo | video | screenshot | document
  label      String?
  uploadedBy String              @map("uploaded_by")
  createdAt  DateTime            @default(now()) @map("created_at")

  @@index([incidentId])
  @@map("trust_safety_evidence")
}

enum TrustSafetyActionType {
  WARNING
  LISTING_WARNING
  BOOKING_RESTRICTION
  PAYOUT_HOLD
  LISTING_FREEZE
  ACCOUNT_SUSPENSION
  PERMANENT_LISTING_REMOVAL
  PERMANENT_ACCOUNT_BAN
  REFUND
  ADDITIONAL_VERIFICATION_REQUIRED
  MANUAL_REVIEW_REQUIRED
}

model TrustSafetyAction {
  id         String                @id @default(uuid())
  incidentId String                @map("incident_id")
  incident   TrustSafetyIncident   @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  actionType TrustSafetyActionType @map("action_type")
  reasonCode String                @map("reason_code")
  notes      String?
  createdBy  String
  createdAt  DateTime              @default(now()) @map("created_at")
  metadata   Json?

  @@index([incidentId])
  @@index([actionType])
  @@map("trust_safety_actions")
}

model UserSafetyProfile {
  id                   String   @id @default(uuid())
  userId               String   @unique @map("user_id")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hostRiskScore        Float?   @map("host_risk_score") // 0-1
  guestRiskScore       Float?   @map("guest_risk_score") // 0-1
  warningCount         Int      @default(0) @map("warning_count")
  suspensionCount      Int      @default(0) @map("suspension_count")
  seriousIncidentCount Int      @default(0) @map("serious_incident_count")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("user_safety_profiles")
}

model ListingSafetyProfile {
  id                  String           @id @default(uuid())
  listingId           String           @unique @map("listing_id")
  listing             ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  safetyScore         Float?           @map("safety_score") // 0-1, higher = safer
  complaintCount      Int              @default(0) @map("complaint_count")
  unsafeIncidentCount Int              @default(0) @map("unsafe_incident_count")
  fraudIncidentCount  Int              @default(0) @map("fraud_incident_count")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  @@map("listing_safety_profiles")
}

enum TrustSafetyAppealStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  WITHDRAWN
}

model TrustSafetyAppeal {
  id             String                  @id @default(uuid())
  incidentId     String                  @map("incident_id")
  incident       TrustSafetyIncident     @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  actionId       String?                 @map("action_id") // TrustSafetyAction.id
  submittedBy    String                  @map("submitted_by")
  submitter      User                    @relation(fields: [submittedBy], references: [id], onDelete: Cascade)
  appealReason   String                  @map("appeal_reason")
  status         TrustSafetyAppealStatus @default(PENDING)
  reviewedBy     String?                 @map("reviewed_by")
  resolvedAt     DateTime?               @map("resolved_at")
  resolutionNote String?                 @map("resolution_note")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")

  @@index([incidentId])
  @@index([submittedBy])
  @@index([status])
  @@map("trust_safety_appeals")
}

model TrustSafetyIncidentResponse {
  id           String              @id @default(uuid())
  incidentId   String              @map("incident_id")
  incident     TrustSafetyIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  respondentId String              @map("respondent_id")
  body         String
  createdAt    DateTime

  @@index([incidentId])
  @@map("trust_safety_incident_responses")
}

// ---------------------------------------------------------------------------
// 9. Defense Analytics – metrics snapshots
// ---------------------------------------------------------------------------
model DefenseMetricsSnapshot {
  id                 String   @id @default(uuid())
  date               DateTime
  marketId           String?
  incidentCount      Int      @default(0)
  disputeCount       Int      @default(0)
  disputeRate        Float?
  fraudLossCents     Int      @default(0)
  abuseSignalsCount  Int      @default(0)
  suspensionCount    Int      @default(0)
  appealCount        Int      @default(0)
  appealApprovalRate Float?
  payoutHoldCount    Int      @default(0)
  complianceFailures Int      @default(0)
  data               Json? // extended breakdown
  createdAt          DateTime @default(now())

  @@index([date])
  @@index([marketId])
}

// ---------------------------------------------------------------------------
// Production-ready core models (PostgreSQL)
// User, DesignAsset, Invoice, Subscription exist above with extended fields.
// Listing and Lead added for CRM/listings/leads APIs.
// ---------------------------------------------------------------------------

/**
 * Platform-attributed contact origin (traceability / commission eligibility).
 */
enum LeadContactOrigin {
  IMMO_CONTACT
  PLATFORM_BROKER
  DIRECT
  /// Buyer Hub / marketplace inquiry (sale listing contact)
  BUYER
}

/// CRM listing asset classification (LECIPM broker listings).
enum LecipmListingAssetType {
  HOUSE
  CONDO
  MULTI_UNIT
  TOWNHOUSE
  LAND
  OTHER
}

enum ComplianceChecklistItemStatus {
  PENDING
  COMPLETED
  NOT_APPLICABLE
}

enum ChecklistItemCategory {
  COOWNERSHIP
  INSURANCE
}

enum ComplianceVerificationLevel {
  DECLARED
  DOCUMENTED
  VERIFIED
}

enum ChecklistPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model CoOwnershipAdvisoryLog {
  id                String   @id @default(cuid())
  listingId         String   @map("listing_id")
  listing           Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  brokerId          String   @map("broker_id")
  broker            User     @relation("CoOwnershipAdvisoryBroker", fields: [brokerId], references: [id], onDelete: Cascade)
  advisoryType      String   @map("advisory_type") // e.g. "INSURANCE_GAP", "CERTIFICATE_MISSING"
  advisoryDelivered Boolean  @default(true) @map("advisory_delivered")
  timestamp         DateTime @default(now())

  @@index([listingId])
  @@index([brokerId])
  @@map("listing_coownership_advisory_logs")
}

model CoOwnershipAuditLog {
  id          String   @id @default(cuid())
  listingId   String   @map("listing_id")
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  actorId     String?  @map("actor_id")
  actor       User?    @relation("CoOwnershipAuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  event       String // e.g. "CHECKLIST_UPDATE", "ENFORCEMENT_BLOCK", "OVERRIDE"
  reason      String?  @db.Text
  beforeValue Json?    @map("before_value")
  afterValue  Json?    @map("after_value")
  timestamp   DateTime @default(now())

  @@index([listingId])
  @@map("listing_coownership_audit_logs")
}

/// Québec Regulation 2025 — divided co-ownership compliance checklist rows (broker CRM `Listing`).
model ChecklistItem {
  id                String                        @id @default(cuid())
  listingId         String                        @map("listing_id")
  listing           Listing                       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  category          ChecklistItemCategory         @default(COOWNERSHIP)
  key               String
  label             String
  description       String?
  status            ComplianceChecklistItemStatus @default(PENDING)
  required          Boolean                       @default(true)
  priority          ChecklistPriority             @default(MEDIUM)
  source            String?                       @db.VarChar(48)
  completedAt       DateTime?                     @map("completed_at")
  completedByUserId String?                       @map("completed_by_user_id")
  completedBy       User?                         @relation("ChecklistItemCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)

  // Hardening extensions (Part 1, 3, 10)
  verificationLevel     ComplianceVerificationLevel @default(DECLARED) @map("verification_level")
  verifiedAt            DateTime?                   @map("verified_at")
  verifiedByUserId      String?                     @map("verified_by_user_id")
  verifiedBy            User?                       @relation("ChecklistItemVerifiedBy", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  supportingDocumentIds Json?                       @map("supporting_document_ids")
  validUntil            DateTime?                   @map("valid_until")
  isExpired             Boolean                     @default(false) @map("is_expired")

  isOverridden       Boolean @default(false) @map("is_overridden")
  overrideReason     String? @map("override_reason") @db.Text
  overriddenByUserId String? @map("overridden_by_user_id")
  overriddenBy       User?   @relation("ChecklistItemOverriddenBy", fields: [overriddenByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([listingId, key], map: "uq_checklist_item_listing_key")
  @@index([listingId], map: "idx_checklist_item_listing_id")
  @@map("listing_coownership_checklist_items")
}

/// Cached merged compliance snapshot for audit / dashboards (optional).
model ListingComplianceSnapshot {
  id                 String   @id @default(cuid())
  listingId          String   @unique @map("listing_id")
  listing            Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  compliancePercent  Float?   @map("compliance_percent")
  insurancePercent   Float?   @map("insurance_percent")
  overallPercent     Float?   @map("overall_percent")
  blockingIssuesJson Json?    @map("blocking_issues_json")
  recommendationText String?  @map("recommendation_text") @db.Text
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("listing_compliance_snapshots")
}

/// CRM listing posture for manual Centris preparation — LECIPM never impersonates or auto-publishes to Centris.
enum LecipmListingCentrisPublicationState {
  DRAFT
  READY_FOR_CENTRIS
  PUBLISHED_INTERNAL
  PUBLISHED_CENTRIS
}

model Listing {
  id                               String                               @id @default(cuid())
  /**
   * Broker CRM listing public code (LST-XXXXXX or legacy LEC-#####).
   */
  listingCode                      String                               @unique @map("listing_code")
  title                            String
  /// Optional French title for CRM surfaces; falls back to `title`.
  titleFr                          String?                              @map("title_fr")
  /// Optional Arabic title; falls back to `title`.
  titleAr                          String?                              @map("title_ar")
  price                            Float
  ownerId                          String?                              @map("owner_id")
  owner                            User?                                @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  tenantId                         String?                              @map("tenant_id")
  tenant                           Tenant?                              @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  commissionCategory               ListingCommissionCategory            @default(SALE) @map("commission_category")
  commissionRate                   Float?                               @map("commission_rate")
  /// Residential / condo classification for CRM workflows (Reg. 2025 co-ownership compliance).
  listingType                      LecipmListingAssetType               @default(HOUSE) @map("listing_type")
  /// Explicit divided co-ownership flag (may be true for non-CONDO edge cases).
  isCoOwnership                    Boolean                              @default(false) @map("is_co_ownership")
  /// Cached 0–100 merged co-ownership (non-insurance) checklist score — recomputed by compliance service.
  complianceScore                  Int?                                 @map("coownership_compliance_score_cache")
  /// Cached 0–100 insurance subsection score — recomputed by compliance service.
  insuranceScore                   Int?                                 @map("coownership_insurance_score_cache")
  /**
   * When true, CRM listing appears on public marketplace/buyer browse.
   * New listings default to draft (false) until explicitly published via broker endpoint.
   */
  crmMarketplaceLive               Boolean                              @default(true) @map("crm_marketplace_live")
  /// Independent-broker Centris readiness (manual export); not a syndication status from Centris.
  centrisPublicationState          LecipmListingCentrisPublicationState @default(DRAFT) @map("centris_publication_state")
  /// AI Listing Assistant — broker working copy (JSON). Does not publish or syndicate.
  assistantDraftContent            Json?                                @map("assistant_draft_content")
  assistantDraftSource             String?                              @map("assistant_draft_source") @db.VarChar(32)
  assistantDraftUpdatedAt          DateTime?                            @map("assistant_draft_updated_at")
  /// OACIQ brokerage forms engine — hard hold (e.g. seller declaration refusal).
  lecipmOaciqComplianceHoldAt      DateTime?                            @map("lecipm_oaciq_compliance_hold_at")
  lecipmOaciqComplianceHoldReason  String?                              @map("lecipm_oaciq_compliance_hold_reason") @db.VarChar(64)
  createdAt                        DateTime                             @default(now())
  updatedAt                        DateTime                             @updatedAt
  checklistItems                   ChecklistItem[]
  complianceSnapshot               ListingComplianceSnapshot?
  advisoryLogs                     CoOwnershipAdvisoryLog[]
  auditLogs                        CoOwnershipAuditLog[]
  brokerAccesses                   BrokerListingAccess[]
  lecipmVisitRequests              LecipmVisitRequest[]
  lecipmVisits                     LecipmVisit[]
  dealRooms                        DealRoom[]
  appointments                     Appointment[]
  conversations                    Conversation[]
  documentFolders                  DocumentFolder[]
  documentFiles                    DocumentFile[]
  dealFinancials                   DealFinancial[]
  tenantInvoices                   TenantInvoice[]
  /// Optional 1:1 — CRM listing created from safe intake (`ListingAcquisitionLead`).
  sourcedFromAcquisitionLead       ListingAcquisitionLead?              @relation("CrmListingFromAcquisition")
  brokerCollaborationThreads       BrokerCollaborationThread[]
  brokerInternalNotes              BrokerInternalNote[]
  complianceCases                  ComplianceCase[]
  lecipmBrokerListingThreads       LecipmBrokerListingThread[]
  lecipmBrokerCrmLeads             LecipmBrokerCrmLead[]
  investmentOpportunitySnapshots   InvestmentOpportunity[]
  esgProfile                       EsgProfile?
  esgEvents                        EsgEvent[]
  esgDocuments                     EsgDocument[]
  esgEvidences                     EsgEvidence[]
  esgActions                       EsgAction[]
  esgActionSnapshots               EsgActionSnapshot[]
  esgRetrofitPlans                 EsgRetrofitPlan[]
  esgRetrofitScenarios             EsgRetrofitScenario[]
  esgFinancingOptions              EsgFinancingOption[]
  esgOptimizationPlans             EsgOptimizationPlan[]
  esgOptimizationActions           EsgOptimizationAction[]
  esgOptimizationRuns              EsgOptimizationRun[]
  esgOutcomeEvents                 EsgOutcomeEvent[]
  esgOptimizationPolicies          EsgOptimizationPolicy[]
  investorMemos                    InvestorMemo[]
  investorIcPacks                  InvestorIcPack[]
  investorDecisionLogs             InvestorDecisionLog[]
  investmentPipelineDeals          InvestmentPipelineDeal[]
  postCloseAssets                  PostCloseAsset[]
  lecipmSdTransactions             LecipmSdTransaction[]
  lecipmPipelineDeals              LecipmPipelineDeal[]
  /// One SPV / offering per listing (optional).
  amfCapitalDeals                  AmfCapitalDeal[]
  listingAssistantContentVersions  ListingAssistantContentVersion[]
  lecipmBrokerageContracts         LecipmBrokerageContract[]
  lecipmCrmOaciqSellerDeclarations LecipmCrmOaciqSellerDeclaration[]
  lecipmDeclarationDisclosures     LecipmDeclarationDisclosure[]
  lecipmBrokerageIdentityProofs    LecipmBrokerageIdentityProof[]
  brokerDisclosures                BrokerDisclosure[]

  @@index([ownerId])
  @@index([tenantId])
}

/// Version history for AI Listing Assistant workflows (additive audit trail).
model ListingAssistantContentVersion {
  id          String   @id @default(cuid())
  listingId   String   @map("listing_id")
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  /// ORIGINAL | AI_GENERATED | BROKER_EDITED | SAVED_DRAFT
  phase       String   @db.VarChar(32)
  content     Json
  /// AI_ASSISTANT | BROKER_MANUAL | SYSTEM
  source      String   @default("AI_ASSISTANT") @db.VarChar(32)
  actorUserId String?  @map("actor_user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([listingId, createdAt(sort: Desc)])
  @@map("listing_assistant_content_versions")
}

// —— LECIPM OACIQ brokerage contracts + CRM seller declarations (2022 mandatory forms) ——
// Note: FSBO `seller_declarations` + platform `identity_verifications` are separate legacy tables.

enum OaciqMandatoryFormVersion {
  REFORM_2022_MANDATORY @map("2022_mandatory")
}

enum BrokerageContractType {
  exclusive     @map("exclusive")
  non_exclusive @map("non_exclusive")
}

enum BrokerageContractStatus {
  draft      @map("draft")
  active     @map("active")
  expired    @map("expired")
  terminated @map("terminated")
}

enum DeclarationDisclosureMethod {
  auto          @map("auto")
  broker_manual @map("broker_manual")
}

enum ComplianceFormEntityType {
  contract    @map("contract")
  declaration @map("declaration")
  identity    @map("identity")
}

enum ComplianceFormAction {
  created         @map("created")
  updated         @map("updated")
  signed          @map("signed")
  refused         @map("refused")
  validated       @map("validated")
  expired         @map("expired")
  version_checked @map("version_checked")
}

enum LecipmIdentityProofMethod {
  in_person @map("in_person")
  remote    @map("remote")
}

enum LecipmIdentityProofVisibility {
  broker_only     @map("broker_only")
  compliance_only @map("compliance_only")
}

/// One current brokerage mandate row per CRM listing (`@@unique(listing_id)`).
model LecipmBrokerageContract {
  id        String  @id @default(cuid())
  listingId String  @unique @map("listing_id")
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  brokerId  String  @map("broker_id")
  broker    User    @relation("LecipmBrokerageContractBroker", fields: [brokerId], references: [id], onDelete: Cascade)
  agencyId  String? @map("agency_id")
  agency    Tenant? @relation(fields: [agencyId], references: [id], onDelete: SetNull)

  contractType BrokerageContractType   @map("contract_type")
  status       BrokerageContractStatus @default(draft)
  startDate    DateTime?               @map("start_date") @db.Date
  endDate      DateTime?               @map("end_date") @db.Date

  includesDistributionAuthorization Boolean @default(false) @map("includes_distribution_authorization")
  distributionScope                 Json?   @map("distribution_scope")

  formVersion OaciqMandatoryFormVersion @map("form_version")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([brokerId])
  @@index([agencyId])
  @@map("brokerage_contracts")
}

/// CRM listing seller declaration (distinct from FSBO `seller_declarations` on `ListingProperty`).
model LecipmCrmOaciqSellerDeclaration {
  id        String  @id @default(cuid())
  listingId String  @map("listing_id")
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sellerId  String  @map("seller_id")
  seller    User    @relation("LecipmCrmOaciqSellerDeclarationSeller", fields: [sellerId], references: [id], onDelete: Cascade)

  formVersion OaciqMandatoryFormVersion @map("form_version")

  completed Boolean @default(false)
  signed    Boolean @default(false)
  refused   Boolean @default(false)

  refusalReason String? @map("refusal_reason") @db.Text

  submittedAt DateTime? @map("submitted_at")
  signedAt    DateTime? @map("signed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  disclosure LecipmDeclarationDisclosure?

  @@unique([listingId, sellerId])
  @@index([listingId])
  @@map("lecipm_crm_oaciq_seller_declarations")
}

model LecipmDeclarationDisclosure {
  id            String                          @id @default(cuid())
  listingId     String                          @map("listing_id")
  listing       Listing                         @relation(fields: [listingId], references: [id], onDelete: Cascade)
  declarationId String                          @unique @map("declaration_id")
  declaration   LecipmCrmOaciqSellerDeclaration @relation(fields: [declarationId], references: [id], onDelete: Cascade)

  disclosedToBuyer    Boolean                      @default(false) @map("disclosed_to_buyer")
  disclosureTimestamp DateTime?                    @map("disclosure_timestamp")
  disclosureMethod    DeclarationDisclosureMethod? @map("disclosure_method")

  buyerAcknowledgedAt DateTime? @map("buyer_acknowledged_at")
  buyerUserId         String?   @map("buyer_user_id")
  buyer               User?     @relation("LecipmDisclosureBuyer", fields: [buyerUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([listingId])
  @@map("declaration_disclosures")
}

/// Confidential identity proof for brokerage compliance — never attachable to promise to purchase (enforced in app).
model LecipmBrokerageIdentityProof {
  id           String  @id @default(cuid())
  listingId    String  @map("listing_id")
  listing      Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sellerUserId String  @map("seller_user_id")
  seller       User    @relation("LecipmBrokerageIdentityProofSeller", fields: [sellerUserId], references: [id], onDelete: Cascade)

  verifiedByBrokerId String @map("verified_by_broker_id")
  verifiedByBroker   User   @relation("LecipmBrokerageIdentityProofVerifier", fields: [verifiedByBrokerId], references: [id], onDelete: Cascade)

  verificationMethod    LecipmIdentityProofMethod @map("verification_method")
  documentType          String                    @map("document_type") @db.VarChar(64)
  documentReferenceHash String                    @map("document_reference_hash") @db.VarChar(128)

  verifiedAt DateTime @map("verified_at")

  confidential Boolean                       @default(true)
  visibleTo    LecipmIdentityProofVisibility @default(broker_only) @map("visible_to")

  attachableToTransactionDocuments Boolean @default(false) @map("attachable_to_transaction_documents")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([listingId, sellerUserId])
  @@index([verifiedByBrokerId])
  @@map("lecipm_brokerage_identity_proofs")
}

model ComplianceFormLog {
  id                String                   @id @default(cuid())
  entityType        ComplianceFormEntityType @map("entity_type")
  entityId          String                   @map("entity_id")
  action            ComplianceFormAction     @map("action")
  performedByUserId String?                  @map("performed_by_user_id")
  performedBy       User?                    @relation("ComplianceFormLogActor", fields: [performedByUserId], references: [id], onDelete: SetNull)
  aiAssisted        Boolean                  @default(false) @map("ai_assisted")
  notes             String?                  @db.Text
  createdAt         DateTime                 @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("compliance_form_logs")
}

/// CRM listing ESG profile — scoring inputs + cached composite (LECIPM internal).
model EsgProfile {
  id                  String           @id @default(cuid())
  listingId           String           @unique @map("listing_id")
  listing             Listing          @relation(fields: [listingId], references: [id], onDelete: Cascade)
  energyScore         Float?           @map("energy_score")
  carbonScore         Float?           @map("carbon_score")
  sustainabilityScore Float?           @map("sustainability_score")
  certification       String?          @db.VarChar(32)
  solar               Boolean          @default(false)
  renovation          Boolean          @default(false)
  /// Penalizes composite when true (high embodied carbon assumptions).
  highCarbonMaterials Boolean          @default(false) @map("high_carbon_materials")
  compositeScore      Float?           @map("composite_score")
  grade               String?          @db.VarChar(1)
  /// 0–100 coverage from verified document evidence ingestion.
  dataCoveragePercent Float?           @default(0) @map("data_coverage_percent")
  /// Aggregate confidence from evidence pipeline (0–100).
  evidenceConfidence  Float?           @map("evidence_confidence")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  postCloseAssets     PostCloseAsset[]

  @@map("esg_profiles")
}

/// Uploaded ESG-related document — classification + extraction pipeline (audit-grade).
model EsgDocument {
  id                       String             @id @default(cuid())
  listingId                String             @map("listing_id")
  listing                  Listing            @relation(fields: [listingId], references: [id], onDelete: Cascade)
  uploadedByUserId         String?            @map("uploaded_by_user_id")
  uploadedBy               User?              @relation("EsgDocumentUploader", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  fileName                 String             @map("file_name") @db.VarChar(512)
  filePath                 String             @map("file_path") @db.VarChar(1024)
  mimeType                 String?            @map("mime_type") @db.VarChar(128)
  fileSizeBytes            Int?               @map("file_size_bytes")
  documentType             String?            @map("document_type") @db.VarChar(48)
  classificationConfidence Float?             @map("classification_confidence")
  processingStatus         String             @default("PENDING") @map("processing_status") @db.VarChar(24)
  extractedSummary         String?            @map("extracted_summary") @db.Text
  processingVersion        String?            @map("processing_version") @db.VarChar(24)
  extractionRulesVersion   String?            @map("extraction_rules_version") @db.VarChar(24)
  createdAt                DateTime           @default(now()) @map("created_at")
  updatedAt                DateTime           @updatedAt @map("updated_at")
  fields                   EsgDocumentField[]
  audits                   EsgDocumentAudit[]
  evidenceLinks            EsgEvidenceLink[]
  evidenceAnchors          EsgEvidence[]      @relation("EsgEvidenceSourceDocument")

  @@index([listingId, processingStatus])
  @@index([listingId, createdAt(sort: Desc)])
  @@map("esg_documents")
}

model EsgDocumentField {
  id               String            @id @default(cuid())
  documentId       String            @map("document_id")
  document         EsgDocument       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  fieldName        String            @map("field_name") @db.VarChar(128)
  fieldValueText   String            @map("field_value_text") @db.Text
  fieldValueNumber Float?            @map("field_value_number")
  unit             String?           @db.VarChar(32)
  extractionMethod String            @map("extraction_method") @db.VarChar(24)
  verification     String            @db.VarChar(16)
  confidence       Float?
  sourcePage       Int?              @map("source_page")
  note             String?           @db.Text
  createdAt        DateTime          @default(now()) @map("created_at")
  evidenceLinks    EsgEvidenceLink[]

  @@index([documentId, fieldName])
  @@map("esg_document_fields")
}

/// Canonical listing-level evidence record (investor-grade; links to documents).
model EsgEvidence {
  id           String            @id @default(cuid())
  listingId    String            @map("listing_id")
  listing      Listing           @relation(fields: [listingId], references: [id], onDelete: Cascade)
  fieldKey     String            @map("field_key") @db.VarChar(128)
  valueText    String?           @map("value_text") @db.Text
  valueNumber  Float?            @map("value_number")
  unit         String?           @db.VarChar(32)
  verification String            @db.VarChar(16)
  confidence   Float?
  documentId   String?           @map("document_id")
  document     EsgDocument?      @relation("EsgEvidenceSourceDocument", fields: [documentId], references: [id], onDelete: SetNull)
  sourcePage   Int?              @map("source_page")
  snippetText  String?           @map("snippet_text") @db.Text
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  links        EsgEvidenceLink[]

  @@index([listingId, fieldKey])
  @@map("esg_evidence")
}

model EsgEvidenceLink {
  id              String            @id @default(cuid())
  evidenceId      String            @map("evidence_id")
  evidence        EsgEvidence       @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  documentId      String            @map("document_id")
  document        EsgDocument       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentFieldId String?           @map("document_field_id")
  documentField   EsgDocumentField? @relation(fields: [documentFieldId], references: [id], onDelete: SetNull)
  snippetText     String?           @map("snippet_text") @db.Text
  sourcePage      Int?              @map("source_page")
  createdAt       DateTime          @default(now()) @map("created_at")

  @@index([documentId])
  @@index([evidenceId])
  @@map("esg_evidence_links")
}

model EsgDocumentAudit {
  id           String      @id @default(cuid())
  documentId   String      @map("document_id")
  document     EsgDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  action       String      @db.VarChar(32)
  status       String      @db.VarChar(16)
  message      String      @db.Text
  metadataJson Json?       @map("metadata_json")
  createdAt    DateTime    @default(now()) @map("created_at")

  @@index([documentId, createdAt])
  @@map("esg_document_audits")
}

model EsgEvent {
  id          String   @id @default(cuid())
  listingId   String   @map("listing_id")
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  type        String   @db.VarChar(24)
  message     String   @db.Text
  scoreImpact Float    @map("score_impact")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([listingId, createdAt(sort: Desc)])
  @@map("esg_events")
}

/// Prioritized broker/investor ESG execution items for a listing (Action Center).
model EsgAction {
  id                         String                  @id @default(cuid())
  listingId                  String                  @map("listing_id")
  listing                    Listing                 @relation(fields: [listingId], references: [id], onDelete: Cascade)
  title                      String                  @db.VarChar(256)
  description                String                  @db.Text
  category                   String                  @db.VarChar(24)
  actionType                 String                  @map("action_type") @db.VarChar(24)
  priority                   String                  @db.VarChar(16)
  status                     String                  @default("OPEN") @db.VarChar(16)
  reasonCode                 String                  @map("reason_code") @db.VarChar(64)
  reasonText                 String?                 @map("reason_text") @db.Text
  estimatedScoreImpact       Float?                  @map("estimated_score_impact")
  estimatedCarbonImpact      Float?                  @map("estimated_carbon_impact")
  estimatedConfidenceImpact  Float?                  @map("estimated_confidence_impact")
  estimatedCostBand          String?                 @map("estimated_cost_band") @db.VarChar(16)
  estimatedEffortBand        String?                 @map("estimated_effort_band") @db.VarChar(16)
  estimatedTimelineBand      String?                 @map("estimated_timeline_band") @db.VarChar(16)
  paybackBand                String?                 @map("payback_band") @db.VarChar(16)
  ownerType                  String?                 @map("owner_type") @db.VarChar(16)
  assigneeUserId             String?                 @map("assignee_user_id")
  assignee                   User?                   @relation("EsgActionAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  blockersJson               Json?                   @map("blockers_json")
  dependenciesJson           Json?                   @map("dependencies_json")
  evidenceNeededJson         Json?                   @map("evidence_needed_json")
  implementationNotes        String?                 @map("implementation_notes") @db.Text
  generatedFromVersion       String?                 @map("generated_from_version") @db.VarChar(24)
  createdAt                  DateTime                @default(now()) @map("created_at")
  updatedAt                  DateTime                @updatedAt @map("updated_at")
  completedAt                DateTime?               @map("completed_at")
  activities                 EsgActionActivity[]
  esgRetrofitActionLinks     EsgRetrofitAction[]
  esgOptimizationSourceLinks EsgOptimizationAction[] @relation("EsgOptimizationSourceAction")
  esgOutcomeEvents           EsgOutcomeEvent[]

  @@index([listingId, status])
  @@index([listingId, reasonCode])
  @@index([assigneeUserId])
  @@map("esg_actions")
}

model EsgActionSnapshot {
  id                String   @id @default(cuid())
  listingId         String   @map("listing_id")
  listing           Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  generatedAt       DateTime @default(now()) @map("generated_at")
  generationVersion String   @map("generation_version") @db.VarChar(24)
  totalActions      Int      @map("total_actions")
  criticalCount     Int      @map("critical_count")
  highCount         Int      @map("high_count")
  mediumCount       Int      @map("medium_count")
  lowCount          Int      @map("low_count")
  actionsJson       Json     @map("actions_json")

  @@index([listingId, generatedAt(sort: Desc)])
  @@map("esg_action_snapshots")
}

model EsgPortfolioActionSummary {
  id                          String   @id @default(cuid())
  ownerId                     String   @map("owner_id")
  owner                       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  totalAssets                 Int      @map("total_assets")
  totalOpenActions            Int      @map("total_open_actions")
  criticalActions             Int      @map("critical_actions")
  quickWins                   Int      @map("quick_wins")
  capexActions                Int      @map("capex_actions")
  averagePotentialScoreUplift Float?   @map("average_potential_score_uplift")
  summaryJson                 Json     @map("summary_json")
  createdAt                   DateTime @default(now()) @map("created_at")

  @@index([ownerId, createdAt(sort: Desc)])
  @@map("esg_portfolio_action_summaries")
}

model EsgActionActivity {
  id           String    @id @default(cuid())
  actionId     String    @map("action_id")
  action       EsgAction @relation(fields: [actionId], references: [id], onDelete: Cascade)
  actorUserId  String?   @map("actor_user_id")
  actor        User?     @relation("EsgActionActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  eventType    String    @map("event_type") @db.VarChar(24)
  note         String?   @db.Text
  metadataJson Json?     @map("metadata_json")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([actionId, createdAt(sort: Desc)])
  @@map("esg_action_activities")
}

/// Phased retrofit strategy for a listing (band-based estimates only).
model EsgRetrofitPlan {
  id                            String               @id @default(cuid())
  listingId                     String               @map("listing_id")
  listing                       Listing              @relation(fields: [listingId], references: [id], onDelete: Cascade)
  planName                      String               @map("plan_name") @db.VarChar(128)
  strategyType                  String               @map("strategy_type") @db.VarChar(24)
  summaryText                   String?              @map("summary_text") @db.Text
  totalEstimatedCostBand        String?              @map("total_estimated_cost_band") @db.VarChar(32)
  totalEstimatedImpactBand      String?              @map("total_estimated_impact_band") @db.VarChar(32)
  totalTimelineBand             String?              @map("total_timeline_band") @db.VarChar(32)
  expectedScoreBand             String?              @map("expected_score_band") @db.VarChar(32)
  expectedCarbonReductionBand   String?              @map("expected_carbon_reduction_band") @db.VarChar(32)
  expectedConfidenceImprovement String?              @map("expected_confidence_improvement") @db.VarChar(32)
  assumptionsJson               Json?                @map("assumptions_json")
  planVersion                   String?              @map("plan_version") @db.VarChar(24)
  createdAt                     DateTime             @default(now()) @map("created_at")
  updatedAt                     DateTime             @updatedAt @map("updated_at")
  retrofitActions               EsgRetrofitAction[]
  financingOptions              EsgFinancingOption[] @relation("EsgFinancingForPlan")

  @@index([listingId, strategyType])
  @@index([listingId, updatedAt(sort: Desc)])
  @@map("esg_retrofit_plans")
}

model EsgRetrofitAction {
  id               String          @id @default(cuid())
  planId           String          @map("plan_id")
  plan             EsgRetrofitPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  actionId         String?         @map("action_id")
  esgAction        EsgAction?      @relation(fields: [actionId], references: [id], onDelete: SetNull)
  title            String          @db.VarChar(256)
  category         String          @db.VarChar(24)
  phase            Int
  costBand         String?         @map("cost_band") @db.VarChar(16)
  impactBand       String?         @map("impact_band") @db.VarChar(24)
  timelineBand     String?         @map("timeline_band") @db.VarChar(24)
  paybackBand      String?         @map("payback_band") @db.VarChar(16)
  dependenciesJson Json?           @map("dependencies_json")
  notes            String?         @db.Text
  createdAt        DateTime        @default(now()) @map("created_at")

  @@index([planId, phase])
  @@map("esg_retrofit_actions")
}

model EsgFinancingOption {
  id                    String           @id @default(cuid())
  listingId             String?          @map("listing_id")
  listing               Listing?         @relation(fields: [listingId], references: [id], onDelete: Cascade)
  planId                String?          @map("plan_id")
  plan                  EsgRetrofitPlan? @relation("EsgFinancingForPlan", fields: [planId], references: [id], onDelete: Cascade)
  financingType         String           @map("financing_type") @db.VarChar(32)
  name                  String           @db.VarChar(256)
  provider              String?          @db.VarChar(128)
  eligibilityCriteria   String?          @map("eligibility_criteria") @db.Text
  applicableActionsJson Json?            @map("applicable_actions_json")
  costCoverageBand      String?          @map("cost_coverage_band") @db.VarChar(24)
  benefitType           String           @map("benefit_type") @db.VarChar(24)
  priority              String?          @db.VarChar(16)
  notes                 String?          @db.Text
  reasoning             String?          @db.Text
  createdAt             DateTime         @default(now()) @map("created_at")

  @@index([listingId])
  @@index([planId])
  @@map("esg_financing_options")
}

model EsgRetrofitScenario {
  id                  String   @id @default(cuid())
  listingId           String   @map("listing_id")
  listing             Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  scenarioName        String   @map("scenario_name") @db.VarChar(128)
  selectedActionsJson Json     @map("selected_actions_json")
  totalCostBand       String?  @map("total_cost_band") @db.VarChar(32)
  totalImpactBand     String?  @map("total_impact_band") @db.VarChar(32)
  timelineBand        String?  @map("timeline_band") @db.VarChar(32)
  expectedScoreBand   String?  @map("expected_score_band") @db.VarChar(32)
  expectedCarbonBand  String?  @map("expected_carbon_band") @db.VarChar(32)
  financingFit        String?  @map("financing_fit") @db.VarChar(32)
  assumptionsJson     Json?    @map("assumptions_json")
  risksJson           Json?    @map("risks_json")
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([listingId, createdAt(sort: Desc)])
  @@map("esg_retrofit_scenarios")
}

/// Autonomous ESG optimization plan (human-approval gated; immutable history via runs).
model EsgOptimizationPlan {
  id                     String                  @id @default(cuid())
  listingId              String                  @map("listing_id")
  listing                Listing                 @relation(fields: [listingId], references: [id], onDelete: Cascade)
  status                 String                  @default("DRAFT") @db.VarChar(24)
  optimizerVersion       String                  @map("optimizer_version") @db.VarChar(24)
  strategyType           String?                 @map("strategy_type") @db.VarChar(32)
  objectiveMode          String?                 @map("objective_mode") @db.VarChar(32)
  confidenceLevel        String?                 @map("confidence_level") @db.VarChar(24)
  headlineRecommendation String?                 @map("headline_recommendation") @db.Text
  executiveSummary       String?                 @map("executive_summary") @db.Text
  currentScore           Float?                  @map("current_score")
  currentGrade           String?                 @map("current_grade") @db.VarChar(8)
  targetBand             String?                 @map("target_band") @db.VarChar(48)
  expectedReadinessShift String?                 @map("expected_readiness_shift") @db.VarChar(256)
  planJson               Json                    @map("plan_json")
  rationaleJson          Json                    @map("rationale_json")
  assumptionsJson        Json                    @map("assumptions_json")
  policyVersion          String?                 @map("policy_version") @db.VarChar(24)
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  activatedAt            DateTime?               @map("activated_at")
  completedAt            DateTime?               @map("completed_at")
  optimizationActions    EsgOptimizationAction[]
  optimizationRuns       EsgOptimizationRun[]

  @@index([listingId, status])
  @@index([listingId, updatedAt(sort: Desc)])
  @@map("esg_optimization_plans")
}

model EsgOptimizationAction {
