  /// prefill | clause | warning | annex_recommendation | summary
  suggestionType String         @map("suggestion_type")
  suggestedValue String?        @map("suggested_value") @db.Text
  sourceType     String?        @map("source_type")
  sourceRef      String?        @map("source_ref")
  confidence     Int?
  explanation    String?        @db.Text
  createdAt      DateTime       @default(now()) @map("created_at")

  @@index([draftId])
  @@index([fieldKey])
  @@map("legal_form_suggestions")
}

model LegalFormAlert {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  draftId    String         @map("draft_id") @db.Uuid
  draft      LegalFormDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
