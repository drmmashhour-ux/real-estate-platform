  confidence Float?
  createdAt  DateTime @default(now()) @map("created_at")

  from TrustgraphFraudGraphNode @relation("FraudGraphEdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  to   TrustgraphFraudGraphNode @relation("FraudGraphEdgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@index([fromNodeId], map: "idx_fraud_edge_from")
  @@index([toNodeId], map: "idx_fraud_edge_to")
  @@map("fraud_graph_edges")
}

model TrustgraphFraudGraphEvent {
  id        String   @id @default(uuid())
  eventType String   @map("event_type")
