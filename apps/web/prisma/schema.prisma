  startedAt     DateTime?     @map("started_at")
  completedAt   DateTime?     @map("completed_at")
  triggerSource String        @map("trigger_source")
  metadata      Json?         @db.JsonB
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@index([propertyId], map: "idx_deal_refresh_jobs_property_id")
  @@index([status], map: "idx_deal_refresh_jobs_status")
  @@map("deal_analysis_refresh_jobs")
}

/// Phase 4 — audit trail for comparable refreshes.
model DealAnalysisRefreshEvent {
  id              String        @id @default(cuid())
  propertyId      String        @map("property_id")
  listing         FsboListing   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  analysisId      String?       @map("analysis_id")
  analysis        DealAnalysis? @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  eventType       String        @map("event_type")
  previousState   Json?         @map("previous_state") @db.JsonB
  newState        Json?         @map("new_state") @db.JsonB
