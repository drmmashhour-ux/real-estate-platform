/// ImmoContact / AI widget: one thread per visitor or logged-in user.
model CrmConversation {
  id               String          @id @default(cuid())
  userId           String?         @map("user_id")
  user             User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestSessionId   String?         @map("guest_session_id")
  expertId         String?         @map("expert_id")
  expert           MortgageExpert? @relation(fields: [expertId], references: [id], onDelete: SetNull)
  leadId           String?         @unique @map("lead_id")
  lead             Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  messages         CrmMessage[]
  metadata         Json?
  expertLastReadAt DateTime?       @map("expert_last_read_at")
  /**
   * Guest-thread execution scores (mirrors Lead when leadId is set; refreshed from chat activity).
   */
  intentScore      Int             @default(0) @map("convo_intent_score")
  urgencyScore     Int             @default(0) @map("convo_urgency_score")
  trustScore       Int             @default(0) @map("convo_trust_score")
  frictionScore    Int             @default(0) @map("convo_friction_score")
  lastActivityAt   DateTime?       @map("convo_last_activity_at")
  nextBestAction   String?         @map("convo_next_best_action")
  priorityScore    Int             @default(0) @map("convo_priority_score")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  @@index([userId])
  @@index([guestSessionId])
  @@index([expertId])
  @@index([updatedAt])
  @@index([priorityScore, lastActivityAt])
  @@map("crm_conversations")
}

model CrmMessage {
  id             String          @id @default(cuid())
