  granted     Boolean
  grantedAt   DateTime                    @default(now()) @map("granted_at")
  revokedAt   DateTime?                   @map("revoked_at")

  @@unique([userId, consentType])
  @@index([userId])
  @@map("lecipm_regulatory_consents")
}

model LecipmRegulatoryAuditLog {
  id           String                          @id @default(cuid())
  userId       String?                         @map("user_id")
  user         User?                           @relation("LecipmRegulatoryAuditActor", fields: [userId], references: [id], onDelete: SetNull)
  entityType   LecipmRegulatoryAuditEntityType @map("entity_type")
