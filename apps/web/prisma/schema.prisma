  @@index([riskLevel, createdAt])
  @@index([actionType, createdAt])
  @@map("fraud_events")
}

// ---------------------------------------------------------------------------
// Platform trust & verification (MVP — complements trustgraph `TrustProfile` / BNHub snapshots)
// `trust_scores` table name is reserved by BNHub `BnhubTrustScoreSnapshot`; platform scores use `platform_trust_scores`.
// ---------------------------------------------------------------------------
enum VerificationLevel {
  basic
  enhanced
  full
}

/// Distinct from trustgraph `TrustProfileSubjectType` — used for `PlatformTrustScore` rows.
enum PlatformTrustEntityType {
  user
  host
  broker
  listing
}

/// Public trust tier for platform scores (0–100 → band). Top band labeled "Trusted" in UI.
enum PlatformTrustTier {
  low
  medium
  high
  trusted
}

enum VerificationRequestStatus {
  pending
  approved
  rejected
}

model UserVerificationProfile {
