  userId      String   @unique @map("user_id") // session/guest id or user id
  trialEndsAt DateTime @map("trial_ends_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([trialEndsAt])
  @@map("design_studio_trials")
