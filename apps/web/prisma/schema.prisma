  messageType String   @map("message_type") @db.VarChar(64)
  triggerType String   @map("trigger_type") @db.VarChar(64)
  locale      String   @default("en") @db.VarChar(8)
  content     String   @db.Text
  status      String   @db.VarChar(24)
  recipient   String   @default("guest") @map("recipient") @db.VarChar(24)
  metadataJson Json?   @map("metadata_json")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([bookingId, createdAt])
  @@index([hostId, createdAt])
  @@index([guestId, createdAt])
  @@map("bnhub_automated_host_message_logs")
}

/// Admin or operator override / incident actions (audit).
model ManagerAiOverrideEvent {
  id          String   @id @default(cuid())
  actorUserId String   @map("actor_user_id")
  actor       User     @relation(fields: [actorUserId], references: [id], onDelete: Cascade)
  scope       String
  targetJson  Json?    @map("target_json")
  note        String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([actorUserId, createdAt])
  @@map("manager_ai_override_events")
}

model ManagerAiHealthEvent {
  id            String   @id @default(cuid())
  level         String
  source        String
  message       String   @db.Text
  payload       Json?
  correlationId String?  @map("correlation_id")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("manager_ai_health_events")
}

model ManagerAiOutcomeEval {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  sourceType String   @map("source_type")
  sourceId   String   @map("source_id")
  outcome    String
  score      Float?
  payload    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([sourceType, sourceId])
  @@index([userId, createdAt])
  @@map("manager_ai_outcome_evals")
}

/// Host Autopilot / AI learning — raw outcome events (no UI).
model AiOutcomeSignal {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now()) @map("created_at")
  hostId      String   @map("host_id")
  listingId   String?  @map("listing_id")
  bookingId   String?  @map("booking_id")
  ruleName    String   @map("rule_name")
  actionType  String   @map("action_type")
  outcomeType String   @map("outcome_type")
  metadata    Json     @default("{}")

  @@index([hostId, createdAt])
  @@index([ruleName])
  @@map("ai_outcome_signals")
}

/// Aggregated per-rule counters for simple learning feedback.
model AiRulePerformance {
  id           String   @id @default(cuid())
  ruleName     String   @unique @map("rule_name")
  total        Int      @default(0)
  successCount Int      @default(0) @map("success_count")
  failureCount Int      @default(0) @map("failure_count")
  lastUpdated  DateTime @updatedAt @map("last_updated")

  @@map("ai_rule_performance")
}

/// Host Autopilot template A/B learning (per rule + template variant).
model AiTemplatePerformance {
  id          String   @id @default(cuid())
  templateKey String   @map("template_key")
  ruleName    String   @map("rule_name")
  impressions Int      @default(0)
  successes   Int      @default(0)
  failures    Int      @default(0)
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([templateKey, ruleName])
  @@index([ruleName])
  @@map("ai_template_performance")
}

/// Maps stated confidence buckets to observed success (calibration).
model AiConfidenceCalibration {
  id           String   @id @default(cuid())
  ruleName     String   @map("rule_name")
  bucket       String   @map("bucket")
  total        Int      @default(0)
  successCount Int      @default(0) @map("success_count")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([ruleName, bucket])
  @@index([ruleName])
  @@map("ai_confidence_calibration")
}

/// Per-host Autopilot personalization (weights, template prefs, ignore sensitivity).
model AiHostPreferenceProfile {
  id                      String   @id @default(cuid())
  hostId                  String   @unique @map("host_id")
  preferredTemplateKeys   Json     @default("{}") @map("preferred_template_keys")
  preferredRuleWeights    Json     @default("{}") @map("preferred_rule_weights")
  rejectionPatterns       Json     @default("{}") @map("rejection_patterns")
  notificationSensitivity Float    @default(0.5) @map("notification_sensitivity")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("ai_host_preference_profiles")
}

// ---------------------------------------------------------------------------
// Marketplace autonomy — human-gated approvals for Level 4 controlled actions
// ---------------------------------------------------------------------------

model MarketplaceAutonomyApproval {
  id                String    @id @default(cuid())
  /// pending | approved | rejected | executed
  status            String    @default("pending") @db.VarChar(20)
  actionType        String    @map("action_type") @db.VarChar(64)
  riskTier          String    @map("risk_tier") @db.VarChar(16)
  payload           Json      @default("{}")
  summary           String?   @db.VarChar(512)
  requestedByUserId String?   @map("requested_by_user_id")
  reviewedByUserId  String?   @map("reviewed_by_user_id")
  reviewNote        String?   @map("review_note") @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  executedAt        DateTime? @map("executed_at")

  @@index([status, createdAt])
  @@index([actionType, status])
  @@map("marketplace_autonomy_approvals")
}

// ---------------------------------------------------------------------------
// Listing demand / monetization analytics (aggregates + cached demand score)
// ---------------------------------------------------------------------------

enum ListingAnalyticsKind {
  FSBO
  CRM
  BNHUB
}

model ListingAnalytics {
  id                    String               @id @default(cuid())
  kind                  ListingAnalyticsKind @map("listing_kind")
  listingId             String               @map("listing_id")
  viewsTotal            Int                  @default(0) @map("views_total")
  saves                 Int                  @default(0)
  contactClicks         Int                  @default(0) @map("contact_clicks")
  bookingAttempts       Int                  @default(0) @map("booking_attempts")
  bookings              Int                  @default(0)
  demandScore           Int                  @default(0) @map("demand_score")
  demandScoreComputedAt DateTime?            @map("demand_score_computed_at")
  views24hCached        Int                  @default(0) @map("views_24h_cached")
  uniqueViews24hCached  Int                  @default(0) @map("unique_views_24h_cached")
  shareCount            Int                  @default(0) @map("share_count")
  unlockCheckoutStarts  Int                  @default(0) @map("unlock_checkout_starts")
  unlockCheckoutSuccesses Int                @default(0) @map("unlock_checkout_successes")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  @@unique([kind, listingId])
  @@index([kind, listingId])
  @@index([demandScore])
  @@map("listing_analytics")
}

model ListingPriceHistory {
  id         String               @id @default(cuid())
  kind       ListingAnalyticsKind @map("listing_kind")
  listingId  String               @map("listing_id")
  priceCents Int                  @map("price_cents")
  recordedAt DateTime             @default(now()) @map("recorded_at")

  @@index([kind, listingId, recordedAt])
  @@map("listing_price_history")
}
