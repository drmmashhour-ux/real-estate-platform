  topCity                String?   @map("top_city")
  topPropertyType        String?   @map("top_property_type")
  topIntentMode          String?   @map("top_intent_mode")
  preferredPriceMinCents Int?      @map("preferred_price_min_cents")
  preferredPriceMaxCents Int?      @map("preferred_price_max_cents")
  interestScore          Int       @default(0) @map("interest_score")
  intentStage            String    @default("cold") @map("intent_stage")
  lastActiveAt           DateTime? @map("last_active_at")
  computedFromEventsAt   DateTime? @map("computed_from_events_at")
  summaryJson            Json?
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  @@index([intentStage])
  @@index([interestScore])
  @@index([topCity])
  @@map("client_interest_profiles")
}

model ClientCelebrationProfile {
  id                 String    @id @default(cuid())
  userId             String    @unique @map("user_id")
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  birthDate          DateTime? @map("birth_date")
  allowBirthdayTouch Boolean   @default(false) @map("allow_birthday_touch")
  lastBirthdaySentAt DateTime? @map("last_birthday_sent_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([birthDate])
  @@map("client_celebration_profiles")
}

enum ClientFollowUpType {
  NEW_MATCH
  INACTIVITY_NUDGE
  BIRTHDAY_GREETING
  BROKER_REENGAGE
}

enum ClientFollowUpStatus {
  PENDING
  SENT
  SKIPPED
  FAILED
}

model ClientFollowUpQueue {
  id          String               @id @default(cuid())
  userId      String               @map("user_id")
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        ClientFollowUpType
  status      ClientFollowUpStatus @default(PENDING)
  title       String
  message     String               @db.Text
  payload     Json?
  scheduledAt DateTime             @map("scheduled_at")
  sentAt      DateTime?            @map("sent_at")
  lastError   String?              @map("last_error") @db.Text
  dedupeKey   String?              @unique @map("dedupe_key")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  @@index([userId, status])
  @@index([scheduledAt, status])
  @@index([type, status])
  @@map("client_follow_up_queue")
}

model ActionQueueItem {
  id          String                @id @default(cuid())
  tenantId    String?               @map("tenant_id")
  tenant      Tenant?               @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  userId      String                @map("user_id")
  type        ActionQueueItemType
  title       String
  description String?               @db.Text
  status      ActionQueueItemStatus @default(OPEN)
  priority    NotificationPriority  @default(NORMAL)
  dueAt       DateTime?             @map("due_at")
  completedAt DateTime?             @map("completed_at")
  sourceKey   String?               @map("source_key")
  sourceType  String?               @map("source_type")
  sourceId    String?               @map("source_id")
  actionUrl   String?               @map("action_url")
  metadata    Json?
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  user   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  events NotificationEvent[]

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([dueAt])
  @@index([sourceType, sourceId])
  @@index([tenantId])
  @@map("action_queue_items")
}

model NotificationEvent {
  id                String                @id @default(cuid())
  notificationId    String?               @map("notification_id")
  actionQueueItemId String?               @map("action_queue_item_id")
  actorId           String?               @map("actor_id")
  type              NotificationEventType
  message           String?               @db.Text
  metadata          Json?
  createdAt         DateTime              @default(now()) @map("created_at")

  notification    Notification?    @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  actionQueueItem ActionQueueItem? @relation(fields: [actionQueueItemId], references: [id], onDelete: Cascade)
  actor           User?            @relation("NotificationEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([notificationId])
  @@index([actionQueueItemId])
  @@map("notification_events")
}

// ---------------------------------------------------------------------------
// Multi-tenant workspaces + finance (commissions, invoices, payments)
// ---------------------------------------------------------------------------

enum TenantStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  ARCHIVED
}

enum TenantRole {
  TENANT_OWNER
  TENANT_ADMIN
  BROKER
  ASSISTANT
  STAFF
  VIEWER
}

enum TenantMembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
  REMOVED
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

/// Agency/tenant finance invoices (distinct from subscription `Invoice` above).
enum TenantInvoiceType {
  COMMISSION
  SERVICE_FEE
  BROKER_FEE
  PLATFORM_FEE
  OTHER
}

enum TenantInvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentRecordType {
  INCOMING
  OUTGOING
  ADJUSTMENT
}

enum PaymentRecordStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
}

model Tenant {
  id              String       @id @default(cuid())
  name            String
  slug            String       @unique
  status          TenantStatus @default(ACTIVE)
  /// solo_broker | agency | enterprise (white-label package)
  tenantType      String?      @map("tenant_type")
  primaryDomain   String?      @unique @map("primary_domain")
  subdomain       String?      @unique @map("subdomain")
  defaultLocale   String?      @default("en") @map("default_locale")
  defaultCurrency String?      @default("CAD") @map("default_currency")
  defaultTimeZone String?      @default("America/Toronto") @map("default_time_zone")
  ownerUserId     String?      @map("owner_user_id")
  owner           User?        @relation("OwnedTenants", fields: [ownerUserId], references: [id], onDelete: SetNull)
  settings        Json?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  brand                    TenantBrand?
  featureFlags             TenantFeatureFlag[]
  memberships              TenantMembership[]
  listings                 Listing[]
  lecipmBrokerageContracts LecipmBrokerageContract[]
  brokerClients            BrokerClient[]
  offers                   Offer[]
  offerEvents              OfferEvent[]
  contracts                Contract[]
  contractSignatures       ContractSignature[]
  appointments             Appointment[]
  appointmentEvents        AppointmentEvent[]
  conversations            Conversation[]
  messages                 Message[]
  documentFolders          DocumentFolder[]
  documentFiles            DocumentFile[]
  clientIntakeProfiles     ClientIntakeProfile[]
  requiredDocumentItems    RequiredDocumentItem[]
  investmentDeals          InvestmentDeal[]
  notifications            Notification[]
  actionQueueItems         ActionQueueItem[]
  dealFinancials           DealFinancial[]
  commissionSplits         CommissionSplit[]
  tenantInvoices           TenantInvoice[]
  paymentRecords           PaymentRecord[]
  billingProfile           TenantBillingProfile?
  fsboLeads                FsboLead[]
  buyerRequests            BuyerRequest[]
  advisoryAccesses         AdvisoryAccess[]
  buyerListingViews        BuyerListingView[]
  fsboListings             FsboListing[]
  bnhubBookings            Booking[]                 @relation("BnhubBookingWorkspaceTenant")
  workspaceWatchlistItems  WatchlistItem[]           @relation("WatchlistItemWorkspaceTenant")
  workspaceAlertCandidates AlertCandidate[]          @relation("AlertCandidateWorkspaceTenant")

  @@index([ownerUserId])
  @@map("tenants")
}

/// White-label branding for broker/agency tenants (portal + dashboard CSS variables).
model TenantBrand {
  id             String   @id @default(cuid())
  tenantId       String   @unique @map("tenant_id")
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  displayName    String   @map("display_name")
  logoUrl        String?  @map("logo_url")
  faviconUrl     String?  @map("favicon_url")
  primaryColor   String?  @default("#D4AF37") @map("primary_color")
  secondaryColor String?  @default("#000000") @map("secondary_color")
  accentColor    String?  @default("#ffffff") @map("accent_color")
  heroTitle      String?  @map("hero_title") @db.Text
  heroSubtitle   String?  @map("hero_subtitle") @db.Text
  customCss      String?  @map("custom_css") @db.Text
  customSettings Json?    @map("custom_settings")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("tenant_brands")
}

/// Per-tenant feature toggles (packages / upsells).
model TenantFeatureFlag {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  featureKey String   @map("feature_key")
  enabled    Boolean  @default(false)
  config     Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, featureKey])
  @@index([tenantId])
  @@map("tenant_feature_flags")
}

model TenantMembership {
  id        String                 @id @default(cuid())
  tenantId  String                 @map("tenant_id")
  tenant    Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String                 @map("user_id")
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      TenantRole
  status    TenantMembershipStatus @default(ACTIVE)
  createdAt DateTime               @default(now()) @map("created_at")
  updatedAt DateTime               @updatedAt @map("updated_at")

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("tenant_memberships")
}

model DealFinancial {
  id               String    @id @default(cuid())
  tenantId         String    @map("tenant_id")
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listingId        String?   @map("listing_id")
  listing          Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  offerId          String?   @map("offer_id")
  offer            Offer?    @relation(fields: [offerId], references: [id], onDelete: SetNull)
  contractId       String?   @map("contract_id")
  contract         Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  salePrice        Float?    @map("sale_price")
  /// Long-term rent: typically one month rent as commission basis.
  rentAmount       Float?    @map("rent_amount")
  commissionAmount Float?    @map("commission_amount")
  commissionSource String?   @map("commission_source")
  rentalCategory   String?   @map("rental_category") // LONG_TERM | SHORT_TERM
  commissionRate   Float?    @map("commission_rate")
  grossCommission  Float?    @map("gross_commission")
  netCommission    Float?    @map("net_commission")
  currency         String    @default("CAD")
  notes            String?   @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  commissionSplits CommissionSplit[]
  paymentRecords   PaymentRecord[]

  @@index([tenantId])
  @@index([listingId])
  @@index([offerId])
  @@index([contractId])
  @@map("deal_financials")
}

model CommissionSplit {
  id              String           @id @default(cuid())
  tenantId        String           @map("tenant_id")
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dealFinancialId String           @map("deal_financial_id")
  dealFinancial   DealFinancial    @relation(fields: [dealFinancialId], references: [id], onDelete: Cascade)
  userId          String?          @map("user_id")
  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  roleLabel       String?          @map("role_label")
  percent         Float?
  amount          Float?
  status          CommissionStatus @default(PENDING)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([dealFinancialId])
  @@index([userId])
  @@map("commission_splits")
}

model TenantInvoice {
  id             String              @id @default(cuid())
  tenantId       String              @map("tenant_id")
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceNumber  String              @unique @map("invoice_number")
  type           TenantInvoiceType
  status         TenantInvoiceStatus @default(DRAFT)
  clientName     String?             @map("client_name")
  clientEmail    String?             @map("client_email")
  billToData     Json?               @map("bill_to_data")
  lineItems      Json                @map("line_items")
  subtotal       Float
  taxAmount      Float?              @map("tax_amount")
  totalAmount    Float               @map("total_amount")
  currency       String              @default("CAD")
  dueAt          DateTime?           @map("due_at")
  issuedAt       DateTime?           @map("issued_at")
  paidAt         DateTime?           @map("paid_at")
  listingId      String?             @map("listing_id")
  listing        Listing?            @relation(fields: [listingId], references: [id], onDelete: SetNull)
  offerId        String?             @map("offer_id")
  offer          Offer?              @relation(fields: [offerId], references: [id], onDelete: SetNull)
  contractId     String?             @map("contract_id")
  contract       Contract?           @relation(fields: [contractId], references: [id], onDelete: SetNull)
  brokerClientId String?             @map("broker_client_id")
  brokerClient   BrokerClient?       @relation(fields: [brokerClientId], references: [id], onDelete: SetNull)
  notes          String?             @db.Text
  createdById    String?             @map("created_by_id")
  createdBy      User?               @relation("TenantInvoiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  paymentRecords PaymentRecord[]

  @@index([tenantId])
  @@index([status])
  @@index([dueAt])
  @@map("tenant_invoices")
}

model PaymentRecord {
  id              String              @id @default(cuid())
  tenantId        String              @map("tenant_id")
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantInvoiceId String?             @map("tenant_invoice_id")
  tenantInvoice   TenantInvoice?      @relation(fields: [tenantInvoiceId], references: [id], onDelete: SetNull)
  dealFinancialId String?             @map("deal_financial_id")
  dealFinancial   DealFinancial?      @relation(fields: [dealFinancialId], references: [id], onDelete: SetNull)
  type            PaymentRecordType
  status          PaymentRecordStatus @default(PENDING)
  amount          Float
  currency        String              @default("CAD")
  provider        String?
  providerRef     String?             @map("provider_ref")
  paidByName      String?             @map("paid_by_name")
  paidByEmail     String?             @map("paid_by_email")
  notes           String?             @db.Text
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantInvoiceId])
  @@index([dealFinancialId])
  @@index([status])
  @@map("payment_records")
}

model TenantBillingProfile {
  id           String   @id @default(cuid())
  tenantId     String   @unique @map("tenant_id")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  legalName    String?  @map("legal_name")
  billingEmail String?  @map("billing_email")
  addressData  Json?    @map("address_data")
  taxNumber    String?  @map("tax_number")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("tenant_billing_profiles")
}

/**
 * Lightweight sales CRM (Supabase-compatible): `lead` | `contacted` | `demo_booked` |
 * `demo_done` | `trial` | `paid` — use `stage` for pipeline position.
 */
model CrmSalesLead {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerUserId     String?            @map("owner_user_id")
  owner           User?              @relation("CrmSalesLeadOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  name            String?
  email           String?
  company         String?
  stage           String             @default("lead")
  source          String?
  notes           String?            @db.Text
  lastContactedAt DateTime?          @map("last_contacted_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  activities      CrmSalesActivity[]

  @@index([stage])
  @@index([email])
  @@index([ownerUserId])
  @@map("crm_leads")
}

model CrmSalesActivity {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId    String       @map("lead_id") @db.Uuid
  lead      CrmSalesLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String?
  note      String?      @db.Text
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([leadId])
  @@map("crm_activities")
}

/// Canonical listing row (`properties` table) — bigint identity; link FSBO via `fsboListingId` when backfilled.
model ListingProperty {
  id            BigInt                    @id @default(autoincrement())
  ownerUserId   String?                   @map("owner_user_id")
  owner         User?                     @relation("ListingPropertyOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  brokerUserId  String?                   @map("broker_user_id")
  broker        User?                     @relation("ListingPropertyBroker", fields: [brokerUserId], references: [id], onDelete: SetNull)
  fsboListingId String?                   @unique @map("fsbo_listing_id")
  fsboListing   FsboListing?              @relation(fields: [fsboListingId], references: [id], onDelete: SetNull)
  mode          String
  propertyType  String                    @map("property_type")
  title         String?
  description   String?                   @db.Text
  price         Decimal?                  @db.Decimal(12, 2)
  addressLine1  String?                   @map("address_line1")
  unitNumber    String?                   @map("unit_number")
  city          String?
  province      String?
  postalCode    String?                   @map("postal_code")
  country       String                    @default("CA")
  bedrooms      Int?
  bathrooms     Decimal?                  @db.Decimal(4, 1)
  areaSqft      Decimal?                  @map("area_sqft") @db.Decimal(10, 2)
  status        String                    @default("draft")
  planType      String                    @default("free") @map("plan_type")
  createdAt     DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  media         ListingPropertyMedia[]
  declarations  SellerDeclarationRecord[]
  dealAnalyses  DealAnalysis[]

  @@index([status], map: "idx_properties_status")
  @@index([ownerUserId], map: "idx_properties_owner_user_id")
  @@index([brokerUserId], map: "idx_properties_broker_user_id")
  @@index([mode, propertyType], map: "idx_properties_mode_type")
  @@index([city, price], map: "idx_properties_city_price")
  @@map("properties")
}

model ListingPropertyMedia {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listingId      BigInt          @map("listing_id")
  listing        ListingProperty @relation(fields: [listingId], references: [id], onDelete: Cascade)
  storagePath    String          @map("storage_path")
  mimeType       String          @map("mime_type")
  mediaKind      String          @map("media_kind")
  mediaTag       String?         @map("media_tag")
  position       Int             @default(0)
  fileHash       String?         @map("file_hash")
  perceptualHash String?         @map("perceptual_hash")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([listingId], map: "idx_listing_property_media_listing_id")
  @@index([fileHash], map: "idx_listing_property_media_file_hash")
  @@map("listing_property_media")
}

model SellerDeclarationRecord {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listingId         BigInt          @map("listing_id")
  listing           ListingProperty @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sellerUserId      String?         @map("seller_user_id")
  seller            User?           @relation(fields: [sellerUserId], references: [id], onDelete: SetNull)
  status            String          @default("draft")
  answers           Json            @default("{}") @db.JsonB
  completionPercent Decimal         @default(0) @map("completion_percent") @db.Decimal(5, 2)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([listingId], map: "idx_seller_declarations_listing_id")
  @@map("seller_declarations")
}

enum SellerDeclarationDraftStatus {
  draft
  in_review
  needs_changes
  ready
  finalized
  approved
  exported
  signed
}

enum DocumentSignatureStatus {
  pending
  viewed
  signed
  declined
}

model SellerDeclarationDraft {
  id                      String                       @id @default(cuid())
  listingId               String                       @map("listing_id")
  listing                 FsboListing                  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sellerUserId            String?                      @map("seller_user_id")
  seller                  User?                        @relation("SellerDeclarationDraftSeller", fields: [sellerUserId], references: [id], onDelete: SetNull)
  adminUserId             String?                      @map("admin_user_id")
  admin                   User?                        @relation("SellerDeclarationDraftAdmin", fields: [adminUserId], references: [id], onDelete: SetNull)
  status                  SellerDeclarationDraftStatus @default(draft)
  draftPayload            Json                         @default("{}") @map("draft_payload") @db.JsonB
  validationSummary       Json?                        @map("validation_summary") @db.JsonB
  aiSummary               Json?                        @map("ai_summary") @db.JsonB
  createdAt               DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                     @updatedAt @map("updated_at") @db.Timestamptz(6)
  aiEvents                SellerDeclarationAiEvent[]
  documentVersions        DocumentVersion[]
  documentAuditLogs       DocumentAuditLog[]
  signatures              DocumentSignature[]
  autoDraftingEvents      AutoDraftingEvent[]
  autonomousWorkflowTasks AutonomousWorkflowTask[]
  negotiationChains       NegotiationChain[]

  @@index([listingId])
  @@index([sellerUserId])
  @@index([adminUserId])
  @@index([status])
  @@map("seller_declaration_drafts")
}

model SellerDeclarationAiEvent {
  id            String                 @id @default(cuid())
  draftId       String                 @map("draft_id")
  draft         SellerDeclarationDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  sectionKey    String                 @map("section_key")
  actionType    String                 @map("action_type")
  promptContext Json                   @map("prompt_context") @db.JsonB
  output        Json                   @db.JsonB
  createdAt     DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([draftId])
  @@index([sectionKey])
  @@index([actionType])
  @@map("seller_declaration_ai_events")
}

model DocumentVersion {
  id            String                 @id @default(cuid())
  documentId    String                 @map("document_id")
  document      SellerDeclarationDraft @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionNumber Int                    @map("version_number")
  payload       Json                   @db.JsonB
  createdBy     String                 @map("created_by")
  createdAt     DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([documentId, versionNumber])
  @@index([documentId])
  @@index([createdBy])
  @@map("document_versions")
}

model DocumentAuditLog {
  id          String                 @id @default(cuid())
  documentId  String                 @map("document_id")
  document    SellerDeclarationDraft @relation(fields: [documentId], references: [id], onDelete: Cascade)
  actorUserId String                 @map("actor_user_id")
  actionType  String                 @map("action_type")
  metadata    Json?                  @db.JsonB
  createdAt   DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([documentId])
  @@index([actorUserId])
  @@index([actionType])
  @@map("document_audit_logs")
}

model DocumentSignature {
  id                   String                  @id @default(cuid())
  documentId           String                  @map("document_id")
  document             SellerDeclarationDraft  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signerName           String                  @map("signer_name")
  signerEmail          String                  @map("signer_email")
  status               DocumentSignatureStatus @default(pending)
