/// Daily investor / board KPI snapshot (growth, marketplace, conversion).
model MetricSnapshot {
  id             String   @id @default(uuid())
  date           DateTime @db.Date
  totalUsers     Int      @map("total_users")
  activeUsers    Int      @map("active_users")
  totalListings  Int      @map("total_listings")
  bookings       Int      @default(0)
  revenue        Float    @default(0)
  conversionRate Float    @default(0) @map("conversion_rate")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([date])
  @@index([date])
  @@map("investor_metric_snapshots")
}

/// Fundraising CRM: prospective capital partners (not product `InvestorProfile`).
model FundraisingInvestor {
  id             String    @id @default(uuid())
  name           String
  email          String
  firm           String    @default("")
  /// contacted | interested | meeting | negotiating | closed
  stage          String    @default("contacted")
  notes          String?
  nextFollowUpAt DateTime? @map("next_follow_up_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  interactions FundraisingInvestorInteraction[]
  deals        FundraisingDeal[]
  commitments  InvestorCommitment[]

  @@index([stage])
  @@index([email])
  @@map("fundraising_investors")
}

/// Logged touchpoints: email, call, meeting, plus outreach / response / follow_up.
model FundraisingInvestorInteraction {
  id         String   @id @default(uuid())
  investorId String   @map("investor_id")
  /// email | call | meeting | outreach | response | follow_up
  type       String
  summary    String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  investor FundraisingInvestor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@index([investorId, createdAt])
  @@map("fundraising_investor_interactions")
}

model FundraisingDeal {
  id         String   @id @default(uuid())
  investorId String   @map("investor_id")
  amount     Float
  /// open | committed | closed
  status     String   @default("open")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  investor FundraisingInvestor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@index([investorId])
  @@index([status])
  @@map("fundraising_deals")
}

/// Active fundraising round (e.g. $100K) with denormalized raised total from commitments.
model FundraisingRound {
  id           String   @id @default(uuid())
  targetAmount Float    @map("target_amount")
  raisedAmount Float    @default(0) @map("raised_amount")
  /// open | closed
  status       String   @default("open")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  commitments InvestorCommitment[]

  @@index([status])
  @@map("fundraising_rounds")
}

/// Per-investor pledge toward a round: interested → committed → transferred.
model InvestorCommitment {
  id         String   @id @default(uuid())
  roundId    String   @map("round_id")
  investorId String   @map("investor_id")
  amount     Float
  /// interested | committed | transferred
  status     String   @default("interested")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  round    FundraisingRound    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  investor FundraisingInvestor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@index([roundId])
  @@index([investorId])
  @@index([status])
  @@map("investor_commitments")
}

/// Daily rollup for revenue execution discipline (messages, contacts, bookings, revenue).
model ExecutionDay {
  id                 String   @id @default(uuid())
  date               DateTime @db.Date
  messagesSent       Int      @default(0) @map("messages_sent")
  brokersContacted   Int      @default(0) @map("brokers_contacted")
  hostsContacted     Int      @default(0) @map("hosts_contacted")
  inquiriesGenerated Int      @default(0) @map("inquiries_generated")
  bookingsCompleted  Int      @default(0) @map("bookings_completed")
  revenue            Float    @default(0)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([date])
  @@index([date])
  @@map("revenue_execution_days")
}

/// Per-touch log: message | call | follow_up | close (CRM user optional).
model ExecutionAction {
  id        String   @id @default(uuid())
  /// message | call | follow_up | close
  type      String
  userId    String?  @map("user_id")
  /// pending | done | skipped | converted
  status    String   @default("done")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation("ExecutionActionCrmUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@map("revenue_execution_actions")
}

/// Generated investor pitch deck (slides stored as JSON content).
model PitchDeck {
  id        String           @id @default(uuid())
  title     String
  createdAt DateTime         @default(now()) @map("created_at")
  slides    PitchDeckSlide[]

  @@index([createdAt])
  @@map("pitch_decks")
}

model PitchDeckSlide {
  id      String @id @default(uuid())
  deckId  String @map("deck_id")
  order   Int
  /// title | problem | solution | product | traction | business_model | growth | vision
  type    String
  title   String
  content Json

  deck PitchDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@index([deckId, order])
  @@map("pitch_deck_slides")
}

/// In-platform sales team member (round-robin / priority routing).
model SalesAgent {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  /// agent | closer | manager
  role      String   @default("agent")
  active    Boolean  @default(true)
  /// Higher = earlier pick in priority mode (tie-breaker: lower load).
  priority  Int      @default(0) @map("priority_weight")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments SalesAssignment[]
  performance SalesPerformance?

  @@index([active, priority])
  @@map("sales_agents")
}

/// One row per lead — links CRM lead to sales agent (Close Room / pipeline).
model SalesAssignment {
  id        String   @id @default(uuid())
  agentId   String   @map("agent_id")
  leadId    String   @unique @map("lead_id")
  /// Denormalized from Lead.userId when present (priority user / CRM).
  userId    String?  @map("user_id")
  /// assigned | contacted | closed | lost
  status    String   @default("assigned")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  agent SalesAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  lead  Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user  User?      @relation("SalesAssignmentProspect", fields: [userId], references: [id], onDelete: SetNull)

  @@index([agentId, status])
  @@index([status])
  @@map("sales_assignments")
}

model SalesPerformance {
  id            String   @id @default(uuid())
  agentId       String   @unique @map("agent_id")
  leadsAssigned Int      @default(0) @map("leads_assigned")
  dealsClosed   Int      @default(0) @map("deals_closed")
  revenue       Float    @default(0)
  commission    Float    @default(0) @map("commission_earned")
  updatedAt     DateTime @updatedAt @map("updated_at")

  agent SalesAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("sales_performance")
}

/// Internal hiring CRM — candidates for sales / ops / growth.
model Candidate {
  id        String   @id @default(uuid())
  name      String
  email     String
  /// sales | operations | growth
  role      String
  /// applied | screening | interview | trial | hired | rejected
  stage     String   @default("applied")
  /// Latest rollup from evaluations (0–10 scale).
  score     Float    @default(0)
  notes     String?
  /// high_performer | low_performer | null (auto from rules)
  flag      String?  @map("performance_flag")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  interactions CandidateInteraction[]
  evaluations  CandidateEvaluation[]
  trialTasks   CandidateTrialTask[]

  @@index([stage])
  @@index([role])
  @@index([email])
  @@index([flag])
  @@map("hiring_candidates")
}

model CandidateInteraction {
  id          String   @id @default(uuid())
  candidateId String   @map("candidate_id")
  /// message | call | interview
  type        String
  summary     String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, createdAt])
  @@map("hiring_candidate_interactions")
}

model CandidateEvaluation {
  id                 String   @id @default(uuid())
  candidateId        String   @map("candidate_id")
  communicationScore Int      @map("communication_score")
  salesSkillScore    Int      @map("sales_skill_score")
  executionScore     Int      @map("execution_score")
  /// Raw pillars (0–10) for structured rubric.
  speedScore         Int      @default(0) @map("speed_score")
  clarityScore       Int      @default(0) @map("clarity_score")
  closingScore       Int      @default(0) @map("closing_score")
  overallScore       Float    @map("overall_score")
  createdAt          DateTime @default(now()) @map("created_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, createdAt])
  @@map("hiring_candidate_evaluations")
}

/// Real-world trial: contact leads, close a user, etc.
model CandidateTrialTask {
  id              String    @id @default(uuid())
  candidateId     String    @map("candidate_id")
  /// contact_leads | close_one_user
  taskKey         String    @map("task_key")
  /// assigned | in_progress | submitted | reviewed | passed | failed
  status          String    @default("assigned")
  resultSummary   String?   @map("result_summary") @db.Text
  /// 0–10 quality of response / execution evidence
  responseQuality Int?      @map("response_quality")
  dueAt           DateTime? @map("due_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, status])
  @@map("hiring_candidate_trial_tasks")
}

/// Cap table holder (founder, employee, advisor, investor).
model EquityHolder {
  id            String        @id @default(uuid())
  name          String
  /// founder | employee | advisor | investor
  role          String
  /// Fully diluted % (denormalized; recomputed from grants).
  equityPercent Float         @default(0) @map("equity_percent")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  grants        EquityGrant[]

  @@index([role])
  @@map("equity_holders")
}

model EquityGrant {
  id              String   @id @default(uuid())
  holderId        String   @map("holder_id")
  totalShares     Float    @map("total_shares")
  vestingStart    DateTime @map("vesting_start")
  /// Total schedule length in months (e.g. 48).
  vestingDuration Int      @map("vesting_duration")
  cliffMonths     Int      @map("cliff_months")
  vestedShares    Float    @default(0) @map("vested_shares")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  holder EquityHolder @relation(fields: [holderId], references: [id], onDelete: Cascade)

  @@index([holderId])
  @@map("equity_grants")
}

model PayoutAdjustment {
  id             String   @id @default(uuid())
  bookingId      String?  @map("booking_id")
  adjustmentType String   @map("adjustment_type") // refund | dispute_deduction | fee_reversal | hold_release
  amountCents    Int      @map("amount_cents") // positive = reduction from host payout, negative = credit
  currency       String   @default("USD")
  reason         String?
  createdAt      DateTime

  @@index([bookingId])
  @@index([adjustmentType])
  @@index([createdAt])
  @@map("payout_adjustments")
}

// ---------------------------------------------------------------------------
// Growth and Acquisition
// ---------------------------------------------------------------------------
enum GrowthCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

model GrowthCampaign {
  id                 String               @id @default(uuid())
  name               String
  campaignType       String // REFERRAL | INVITE | ACQUISITION
  marketId           String?
  startAt            DateTime
  endAt              DateTime
  status             GrowthCampaignStatus @default(DRAFT)
  config             Json? // Reward amounts, eligibility, etc.
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  market             MarketConfig?        @relation(fields: [marketId], references: [id], onDelete: SetNull)
  acquisitionSources AcquisitionSource[]

  @@index([marketId])
  @@index([status])
}

model AcquisitionSource {
  id             String          @id @default(uuid())
  userId         String?
  campaignId     String?
  growthCampaign GrowthCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  source         String // utm_source | referral | organic
  medium         String?
  utmCampaign    String? // utm_campaign
  createdAt      DateTime        @default(now())

  @@index([userId])
  @@index([campaignId])
  @@index([source])
}

model OnboardingMilestone {
  id           String   @id @default(uuid())
  userId       String
  milestoneKey String // PROFILE_COMPLETE | FIRST_LISTING | FIRST_BOOKING | VERIFICATION_DONE
  completedAt  DateTime @default(now())
  metadata     Json?
  createdAt    DateTime @default(now())

  @@unique([userId, milestoneKey])
  @@index([userId])
  @@index([milestoneKey])
}

// ---------------------------------------------------------------------------
// Lifecycle Automation
// ---------------------------------------------------------------------------
enum LifecycleStage {
  ONBOARDING
  ACTIVE
  AT_RISK
  CHURNED
  REACTIVATED
}

model LifecycleState {
  id             String         @id @default(uuid())
  userId         String
  stage          LifecycleStage
  module         String? // BNHUB | BROKER_CRM | OWNER | INVESTOR
  lastActivityAt DateTime?
  metadata       Json?
  updatedAt      DateTime       @updatedAt
  createdAt      DateTime       @default(now())

  @@index([userId])
  @@index([stage])
  @@index([module])
}

// ---------------------------------------------------------------------------
// Market Configuration and Multi-Market Expansion
// ---------------------------------------------------------------------------
model MarketConfig {
  id                   String                @id @default(uuid())
  code                 String                @unique // e.g. NYC, LON, UAE
  name                 String
  country              String
  currency             String                @default("USD")
  defaultLanguage      String                @default("en")
  active               Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  taxRules             MarketTaxRule[]
  policyBindings       MarketPolicyBinding[]
  promotionCampaigns   PromotionCampaign[]
  growthCampaigns      GrowthCampaign[]
  revenueLedgerEntries RevenueLedgerEntry[]

  @@index([active])
  @@index([code])
}

model MarketTaxRule {
  id            String       @id @default(uuid())
  marketId      String
  market        MarketConfig @relation(fields: [marketId], references: [id], onDelete: Cascade)
  ruleType      String // VAT | GST | PLATFORM_FEE
  ratePercent   Float
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime     @default(now())

  @@index([marketId])
}

model MarketPolicyBinding {
  id              String       @id @default(uuid())
  marketId        String
  market          MarketConfig @relation(fields: [marketId], references: [id], onDelete: Cascade)
  policyRuleKey   String
  overridePayload Json?
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([marketId])
  @@index([policyRuleKey])
}

// ---------------------------------------------------------------------------
// Revenue Intelligence
// ---------------------------------------------------------------------------
enum RevenueLedgerType {
  BOOKING_COMMISSION
  REAL_ESTATE_COMMISSION
  SUBSCRIPTION
  PROMOTION
  REFERRAL_COST
  REFUND
  CHARGEBACK
  INCENTIVE
  PAYOUT
}

model RevenueLedgerEntry {
  id          String            @id @default(uuid())
  type        RevenueLedgerType
  entityType  String // BOOKING | SUBSCRIPTION | INVOICE | PROMOTION | REFERRAL
  entityId    String
  amountCents Int // Positive = revenue, negative = cost/refund
  marketId    String?
  market      MarketConfig?     @relation(fields: [marketId], references: [id], onDelete: SetNull)
  module      String? // BNHUB | BROKER_CRM | etc.
  userId      String?
  metadata    Json?
  createdAt   DateTime          @default(now())

  @@index([type])
  @@index([entityType, entityId])
  @@index([marketId])
  @@index([createdAt])
}

model RevenueReport {
  id          String   @id @default(uuid())
  reportType  String // DAILY | WEEKLY | MONTHLY | BY_MARKET | BY_MODULE
  periodStart DateTime
  periodEnd   DateTime
  marketId    String?
  data        Json // Aggregated totals, breakdowns
  createdAt   DateTime @default(now())

  @@index([reportType])
  @@index([periodStart])
  @@index([marketId])
}

// ---------------------------------------------------------------------------
// Executive Business Metrics
// ---------------------------------------------------------------------------
model ExecutiveMetricsSnapshot {
  id                 String   @id @default(uuid())
  date               DateTime
  marketId           String?
  gmvCents           Int      @default(0)
  netRevenueCents    Int      @default(0)
  bookingsCount      Int      @default(0)
  activeHostsCount   Int      @default(0)
  activeBrokersCount Int      @default(0)
  mrrCents           Int      @default(0)
  arrCents           Int      @default(0)
  refundRate         Float?
  disputeRate        Float?
  data               Json? // Extended KPIs, cohort hints
  createdAt          DateTime @default(now())

  @@unique([date, marketId])
  @@index([date])
  @@index([marketId])
}

// =============================================================================
// AI OPERATING SYSTEM (AI-OS) LAYER
// =============================================================================

// ---------------------------------------------------------------------------
// AI Data Pipeline & Feature Store
// ---------------------------------------------------------------------------
model AiFeature {
  id         String   @id @default(uuid())
  entityType String // LISTING | BOOKING | USER | MARKET | etc.
  entityId   String
  featureKey String // e.g. listing_quality_score, user_fraud_risk
  value      Float // numeric feature
  valueJson  Json? // complex or vector
  source     String? // pipeline run id or model version
  computedAt DateTime @default(now())

  @@unique([entityType, entityId, featureKey])
  @@index([entityType, featureKey])
  @@index([computedAt])
}

// ---------------------------------------------------------------------------
// Model Registry & Lifecycle
// ---------------------------------------------------------------------------
model AiModel {
  id           String          @id @default(uuid())
  key          String          @unique // fraud_v1, pricing_v1, ranking_v1
  name         String
  description  String?
  active       Boolean
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  versions     ModelVersion[]
  decisionLogs AiDecisionLog[]

  @@index([key])
}

model ModelVersion {
  id           String    @id @default(uuid())
  modelId      String
  model        AiModel   @relation(fields: [modelId], references: [id], onDelete: Cascade)
  version      Int // 1, 2, 3...
  metrics      Json? // accuracy, precision, recall, drift
  deployedAt   DateTime?
  deprecatedAt DateTime?
  createdAt    DateTime  @default(now())

  @@unique([modelId, version])
  @@index([modelId])
}

// ---------------------------------------------------------------------------
// Fraud Detection AI (aggregated scores per entity)
// ---------------------------------------------------------------------------
model FraudScore {
  id           String   @id @default(uuid())
  entityType   String // LISTING | BOOKING | USER | PAYMENT
  entityId     String
  score        Float // 0-1 risk
  factors      Json? // contributing signals
  modelVersion String?
  priority     String? // HIGH | MEDIUM | LOW (investigation priority)
  createdAt    DateTime @default(now())

  @@index([entityType, entityId])
  @@index([score])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Dynamic Pricing AI (extends PricingRecommendation with model metadata)
// ---------------------------------------------------------------------------
model AiPricingRecommendation {
  id               String    @id @default(uuid())
  listingId        String
  recommendedCents Int
  minCents         Int?
  maxCents         Int?
  demandLevel      String // low | medium | high
  minStayNights    Int?
  factors          Json? // explainable factors
  modelVersion     String?
  forDate          DateTime?
  createdAt        DateTime

  @@index([listingId])
  @@index([forDate])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Search Ranking AI (cached scores and explanations)
// ---------------------------------------------------------------------------
model SearchRankingScore {
  id           String   @id @default(uuid())
  listingId    String
  score        Float
  factors      Json? // breakdown: verification, reviews, conversion...
  modelVersion String?
  computedAt   DateTime @default(now())

  @@index([listingId])
  @@index([score])
  @@index([computedAt])
}

// ---------------------------------------------------------------------------
// Demand Forecasting
// ---------------------------------------------------------------------------
model DemandForecast {
  id                String   @id @default(uuid())
  region            String // city or market code
  propertyType      String? // optional segment
  forecastDate      DateTime
  demandLevel       Float
  bookingsPredicted Int?
  supplyGap         Int? // predicted shortage
  modelVersion      String?
  createdAt         DateTime @default(now())

  @@index([region, forecastDate])
  @@index([forecastDate])
}

// ---------------------------------------------------------------------------
// AI Alerts (marketplace health, fraud spikes, anomalies)
// ---------------------------------------------------------------------------
enum AiAlertType {
  FRAUD_SPIKE
  DISPUTE_SPIKE
  LISTING_QUALITY_DROP
  CANCELLATION_ANOMALY
  DEMAND_CHANGE
  REGIONAL_RISK
  MODEL_DRIFT
}

model AiAlert {
  id             String      @id @default(uuid())
  alertType      AiAlertType
  severity       String // LOW | MEDIUM | HIGH | CRITICAL
  title          String
  message        String
  entityType     String?
  entityId       String?
  region         String?
  payload        Json? // metrics, recommended actions
  acknowledgedAt DateTime?
  acknowledgedBy String?
  createdAt      DateTime    @default(now())

  @@index([alertType])
  @@index([severity])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// AI Decision Log (audit trail for model-driven decisions)
// ---------------------------------------------------------------------------
model AiDecisionLog {
  id           String    @id @default(uuid())
  modelId      String
  model        AiModel   @relation(fields: [modelId], references: [id], onDelete: Restrict)
  modelVersion String?
  entityType   String
  entityId     String
  decision     String // ALLOW | FLAG | BLOCK | RECOMMEND
  score        Float?
  explanation  String?
  overrideBy   String?
  overrideAt   DateTime?
  context      Json?
  createdAt    DateTime  @default(now())

  @@index([modelId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// AI Operator – Fully Autonomous Marketplace Operator (BNHub)
// ---------------------------------------------------------------------------
model AiOperatorDecision {
  id                  String    @id @default(uuid())
  agentType           String // listing_moderation | pricing | fraud_risk | booking_integrity | demand_forecast | host_performance | support_triage | marketplace_health
  entityType          String
  entityId            String
  inputSummary        Json?
  outputSummary       Json?
  confidenceScore     Float
  recommendedAction   String
  reasonCodes         Json      @default("[]")
  automatedAction     String?
  humanOverrideBy     String?
  humanOverrideAt     DateTime?
  humanOverrideAction String?
  humanOverrideNotes  String?
  createdAt           DateTime

  @@index([agentType])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model AiOperatorAlert {
  id         String   @id @default(uuid())
  alertType  String // listing_quality | fraud_risk | booking_anomaly | marketplace_health | pricing | etc.
  severity   String // low | medium | high | critical
  entityType String
  entityId   String
  message    String
  status     String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([alertType])
  @@index([status])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// AI Control Center – unified audit log for all AI decisions
// ---------------------------------------------------------------------------
model AiLog {
  id                    String   @id @default(uuid())
  action                String   @map("action") // evaluate | fraud_check | price_suggestion | trust_score
  entityType            String   @map("entity_type") // listing | booking | user | etc.
  entityId              String   @map("entity_id")
  riskScore             Int?     @map("risk_score") // 0-100
  trustLevel            String?  @map("trust_level") // low | medium | high
  trustScore            Float?   @map("trust_score") // 0-100 or 0-5 depending on context
  recommendedPriceCents Int?     @map("recommended_price_cents")
  details               Json? // factors, explanation, payload
  createdAt             DateTime @default(now()) @map("created_at")

  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("ai_logs")
}

/// Unified audit trail for hub AI assistant calls (no raw secrets; summaries only).
model AiInteractionLog {
  id            String   @id @default(uuid())
  userId        String?  @map("user_id")
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  role          String   @map("role")
  hub           String   @map("hub")
  feature       String   @map("feature")
  intent        String   @map("intent")
  /// When set, this row is a Decision Engine evaluation (see `feature` = decision_engine).
  decisionType  String?  @map("decision_type")
  /// Priority / risk tier from decision engine (low | medium | high | critical).
  riskLevel     String?  @map("risk_level")
  inputSummary  String   @map("input_summary") @db.Text
  outputSummary String   @map("output_summary") @db.Text
  model         String?  @map("model")
  source        String   @default("openai") @map("source")
  feedback      String?  @map("feedback")
  metadata      Json?
  /// True when the interaction is legal-assistant (content license, readiness, contract explain, risk checks).
  legalContext  Boolean  @default(false) @map("legal_context")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([hub, createdAt])
  @@index([createdAt])
  @@index([legalContext, createdAt])
  @@map("ai_interaction_logs")
}

// ---------------------------------------------------------------------------
// LECIPM AI drafting + correction (Turbo Form / ProductionGuard adjacent)
// ---------------------------------------------------------------------------
model AiDraftRun {
  id         String   @id @default(cuid())
  draftId    String   @map("draft_id")
  userId     String?  @map("user_id")
  runType    String   @map("run_type")
  status     String   @default("COMPLETED")
  inputJson  Json?    @map("input_json")
  outputJson Json?    @map("output_json")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([draftId])
  @@index([userId])
  @@index([runType])
  @@map("ai_draft_runs")
}

model AiDraftFinding {
  id             String    @id @default(cuid())
  draftId        String    @map("draft_id")
  userId         String?   @map("user_id")
  findingKey     String    @map("finding_key")
  severity       String
  sectionKey     String?   @map("section_key")
  messageFr      String    @map("message_fr") @db.Text
  messageEn      String?   @map("message_en") @db.Text
  suggestedFixFr String?   @map("suggested_fix_fr") @db.Text
  suggestedFixEn String?   @map("suggested_fix_en") @db.Text
  blocking       Boolean   @default(false)
  resolved       Boolean   @default(false)
  createdAt      DateTime  @default(now()) @map("created_at")
  resolvedAt     DateTime? @map("resolved_at")

  @@index([draftId])
  @@index([severity])
  @@index([blocking])
  @@map("ai_draft_findings")
}

model AiDraftSuggestion {
  id           String   @id @default(cuid())
  draftId      String   @map("draft_id")
  userId       String?  @map("user_id")
  fieldKey     String?  @map("field_key")
  suggestionFr String   @map("suggestion_fr") @db.Text
  suggestionEn String?  @map("suggestion_en") @db.Text
  actionType   String   @map("action_type")
  applied      Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([draftId])
  @@index([fieldKey])
  @@map("ai_draft_suggestions")
}

enum AdminReportPeriodType {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

/// Cached admin operational report payloads (AI-style summaries + KPI JSON).
model AdminReportSnapshot {
  id          String                @id @default(uuid())
  periodType  AdminReportPeriodType @map("period_type")
  periodStart DateTime              @map("period_start")
  periodEnd   DateTime              @map("period_end")
  summaryJson Json                  @map("summary_json")
  generatedAt DateTime              @default(now()) @map("generated_at")

  @@unique([periodType, periodStart])
  @@index([periodType, generatedAt])
  @@map("admin_report_snapshots")
}

// ---------------------------------------------------------------------------
// AI Operations – queue of items for AI review/decision
// ---------------------------------------------------------------------------
model AiQueueItem {
