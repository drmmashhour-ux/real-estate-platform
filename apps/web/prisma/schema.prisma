  mode                 String
  paused               Boolean  @default(false)
  activeDomainsJson    Json     @map("active_domains_json")
  pendingApprovals     Int      @default(0) @map("pending_approvals")
  executedToday        Int      @default(0) @map("executed_today")
  rolledBackToday      Int      @default(0) @map("rolled_back_today")
  criticalPolicyEvents Int      @default(0) @map("critical_policy_events")
  recommendedPause     Boolean  @default(false) @map("recommended_pause")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("manager_ai_autonomy_governance_state")
}

// --- Playbook Memory Engine (decision memory + reusable strategies) ---
//
// Spec names `Playbook` / `PlaybookVersion` map to `MemoryPlaybook` / `MemoryPlaybookVersion` here because
// `model Playbook` is already the CRM conversion pipeline (`conversion_playbooks`). Tables: `memory_strategy_playbooks`, `memory_playbook_versions`, etc.

enum MemoryDomain {
  GROWTH
  PRICING
  LEADS
  DEALS
  LISTINGS
  MESSAGING
  PROMOTIONS
  BOOKINGS
  BROKER_ROUTING
  RISK
  DREAM_HOME
}

enum MemorySource {
  HUMAN
  SYSTEM
  AI_RECOMMENDATION
  AI_AUTOMATION
  IMPORTED
}

enum MemoryOutcomeStatus {
  PENDING
  PARTIAL
  SUCCEEDED
  FAILED
  NEUTRAL
  CANCELLED
}

enum PlaybookStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum PlaybookExecutionMode {
  RECOMMEND_ONLY
  HUMAN_APPROVAL
  SAFE_AUTOPILOT
  FULL_AUTOPILOT
}

enum PlaybookScoreBand {
  LOW
  MEDIUM
  HIGH
  ELITE
}

enum PlaybookAssignmentSelectionMode {
  exploit
  explore
  manual
}

model PlaybookMemoryRecord {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  domain MemoryDomain
  source MemorySource

  triggerEvent  String  @map("trigger_event")
  actionType    String  @map("action_type")
  actionVersion String? @map("action_version")

  actorUserId String? @map("actor_user_id")
  actorSystem String? @map("actor_system")
  actorRole   String? @map("actor_role")

  listingId  String? @map("listing_id")
  leadId     String? @map("lead_id")
  dealId     String? @map("deal_id")
  bookingId  String? @map("booking_id")
  brokerId   String? @map("broker_id")
  customerId String? @map("customer_id")

  memoryPlaybookId        String? @map("memory_playbook_id")
  memoryPlaybookVersionId String? @map("memory_playbook_version_id")

  correlationKey String? @map("correlation_key")
  idempotencyKey String? @unique @map("idempotency_key")

  contextSnapshot   Json  @map("context_snapshot")
  actionPayload     Json  @map("action_payload")
  policySnapshot    Json? @map("policy_snapshot")
  riskSnapshot      Json? @map("risk_snapshot")
  objectiveSnapshot Json? @map("objective_snapshot")

  similarityFingerprint String? @map("similarity_fingerprint")
  segmentKey            String? @map("segment_key")
  marketKey             String? @map("market_key")

  initialConfidence Float? @map("initial_confidence")
  safetyScore       Float? @map("safety_score")
  expectedValue     Float? @map("expected_value")

  outcomeStatus      MemoryOutcomeStatus @default(PENDING) @map("outcome_status")
  outcomeSummary     Json?               @map("outcome_summary")
  realizedValue      Float?              @map("realized_value")
  realizedRevenue    Float?              @map("realized_revenue")
  realizedConversion Float?              @map("realized_conversion")
  realizedLatencyMs  Int?                @map("realized_latency_ms")
  realizedRiskScore  Float?              @map("realized_risk_score")

  outcomeEvaluatedAt DateTime? @map("outcome_evaluated_at")
  expiresAt          DateTime? @map("expires_at")

  memoryPlaybook        MemoryPlaybook?        @relation(fields: [memoryPlaybookId], references: [id], onDelete: SetNull)
  memoryPlaybookVersion MemoryPlaybookVersion? @relation(fields: [memoryPlaybookVersionId], references: [id], onDelete: SetNull)

  outcomeMetrics      MemoryPlaybookOutcomeMetric[]
  retrievalIndexes    MemoryPlaybookRetrievalIndex[]
  playbookAssignments PlaybookAssignment[]           @relation("PlaybookMemoryRecordAssignments")

  @@index([domain, createdAt])
  @@index([actionType, createdAt])
  @@index([segmentKey, createdAt])
  @@index([marketKey, createdAt])
  @@index([listingId])
  @@index([leadId])
  @@index([dealId])
  @@index([bookingId])
  @@index([memoryPlaybookId, createdAt])
  @@index([outcomeStatus, createdAt])
  @@index([similarityFingerprint, createdAt])
  @@map("playbook_memory_records")
}

/// Decision-memory reusable strategy playbooks (distinct from `conversion_playbooks` CRM playbooks).
model MemoryPlaybook {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  key         String       @unique
  name        String
  description String?
  domain      MemoryDomain

  status        PlaybookStatus        @default(DRAFT)
  executionMode PlaybookExecutionMode @default(RECOMMEND_ONLY) @map("execution_mode")

  ownerUserId     String? @map("owner_user_id")
  createdBySystem String? @map("created_by_system")

  tags            String[]
  segmentScope    Json?    @map("segment_scope")
  marketScope     Json?    @map("market_scope")
  constraints     Json?
  objectives      Json?
  successCriteria Json?    @map("success_criteria")
  stopConditions  Json?    @map("stop_conditions")

  currentVersionId String?           @unique @map("current_version_id")
  scoreBand        PlaybookScoreBand @default(LOW) @map("score_band")

  totalExecutions      Int @default(0) @map("total_executions")
  successfulExecutions Int @default(0) @map("successful_executions")
  failedExecutions     Int @default(0) @map("failed_executions")

  avgExpectedValue   Float? @map("avg_expected_value")
  avgRealizedValue   Float? @map("avg_realized_value")
  avgRealizedRevenue Float? @map("avg_realized_revenue")
  avgConversionLift  Float? @map("avg_conversion_lift")
  avgRiskScore       Float? @map("avg_risk_score")

  lastExecutedAt DateTime? @map("last_executed_at")
  lastPromotedAt DateTime? @map("last_promoted_at")
  lastDemotedAt  DateTime? @map("last_demoted_at")

  versions         MemoryPlaybookVersion[]        @relation("MemoryPlaybookVersions")
  memories         PlaybookMemoryRecord[]
  lifecycleEvents  MemoryPlaybookLifecycleEvent[]
  retrievalIndexes MemoryPlaybookRetrievalIndex[]
  currentVersion   MemoryPlaybookVersion?         @relation("MemoryPlaybookCurrentPointer", fields: [currentVersionId], references: [id], onDelete: SetNull)

  @@index([domain, status])
  @@index([executionMode, status])
  @@index([scoreBand, status])
  @@map("memory_strategy_playbooks")
}

model MemoryPlaybookVersion {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  playbookId String @map("playbook_id")
  version    Int

  title              String?
  strategyDefinition Json    @map("strategy_definition")
  retrievalHints     Json?   @map("retrieval_hints")
  actionTemplate     Json?   @map("action_template")
  policyRequirements Json?   @map("policy_requirements")
  riskLimits         Json?   @map("risk_limits")
  rolloutConfig      Json?   @map("rollout_config")

  isActive   Boolean   @default(false) @map("is_active")
  promotedAt DateTime? @map("promoted_at")
  archivedAt DateTime? @map("archived_at")

  executions Int @default(0)
  successes  Int @default(0)
  failures   Int @default(0)

  avgRealizedValue  Float? @map("avg_realized_value")
  avgRevenueLift    Float? @map("avg_revenue_lift")
  avgConversionLift Float? @map("avg_conversion_lift")
  avgRiskScore      Float? @map("avg_risk_score")

  playbook        MemoryPlaybook         @relation("MemoryPlaybookVersions", fields: [playbookId], references: [id], onDelete: Cascade)
  memories        PlaybookMemoryRecord[]
  markedCurrentOn MemoryPlaybook?        @relation("MemoryPlaybookCurrentPointer")

  @@unique([playbookId, version])
  @@index([playbookId, isActive])
  @@map("memory_playbook_versions")
}

model MemoryPlaybookOutcomeMetric {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  memoryRecordId String   @map("memory_record_id")
  metricKey      String   @map("metric_key")
  metricValue    Float?   @map("metric_value")
  metricText     String?  @map("metric_text")
  metricJson     Json?    @map("metric_json")
  observedAt     DateTime @map("observed_at")
  source         String?

  memoryRecord PlaybookMemoryRecord @relation(fields: [memoryRecordId], references: [id], onDelete: Cascade)

  @@index([memoryRecordId, observedAt])
  @@index([metricKey, observedAt])
  @@map("memory_playbook_outcome_metrics")
}

model MemoryPlaybookRetrievalIndex {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  domain     MemoryDomain
  entityType String       @map("entity_type")
  entityId   String       @map("entity_id")

  segmentKey  String? @map("segment_key")
  marketKey   String? @map("market_key")
  fingerprint String
  features    Json

  memoryRecordId   String? @map("memory_record_id")
  memoryPlaybookId String? @map("memory_playbook_id")

  score Float?

  memoryRecord   PlaybookMemoryRecord? @relation(fields: [memoryRecordId], references: [id], onDelete: SetNull)
  memoryPlaybook MemoryPlaybook?       @relation(fields: [memoryPlaybookId], references: [id], onDelete: SetNull)

  @@index([domain, entityType, createdAt])
  @@index([segmentKey, marketKey])
  @@index([fingerprint])
  @@index([memoryPlaybookId])
  @@map("memory_playbook_retrieval_indexes")
}

model MemoryPlaybookLifecycleEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  playbookId        String  @map("playbook_id")
  playbookVersionId String? @map("playbook_version_id")

  eventType String  @map("event_type")
  reason    String?
  payload   Json?

  playbook MemoryPlaybook @relation(fields: [playbookId], references: [id], onDelete: Cascade)

  @@index([playbookId, createdAt])
  @@map("memory_playbook_lifecycle_events")
}

/// Contextual bandit (lite) per-key stats; empty `playbookVersionId` means "no version slot".
model PlaybookBanditStat {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  domain            MemoryDomain
  segmentKey        String       @default("") @map("segment_key")
  marketKey         String       @default("") @map("market_key")
  playbookId        String       @map("playbook_id")
  playbookVersionId String       @default("") @map("playbook_version_id")

  impressions Int @default(0)
  executions  Int @default(0)
  successes   Int @default(0)
  failures    Int @default(0)

  avgReward     Float? @map("avg_reward")
  avgRevenue    Float? @map("avg_revenue")
  avgConversion Float? @map("avg_conversion")
  avgRiskScore  Float? @map("avg_risk_score")

  lastSelectedAt DateTime? @map("last_selected_at")
  lastOutcomeAt  DateTime? @map("last_outcome_at")

  @@unique([domain, playbookId, playbookVersionId, segmentKey, marketKey], map: "playbook_bandit_context_key")
  @@index([domain, createdAt])
  @@index([domain, segmentKey, marketKey])
  @@index([playbookId, domain])
  @@map("playbook_bandit_stats")
}

/// Auditable bandit / manual playbook assignment to an entity; does not run execution.
model PlaybookAssignment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  domain     MemoryDomain
  entityType String       @map("entity_type")
  entityId   String?      @map("entity_id")

  playbookId         String  @map("playbook_id")
  playbookVersionId  String? @map("playbook_version_id")
  /// Normalized for lookups (empty = no version).
  playbookVersionKey String  @default("") @map("playbook_version_key")

  recommendationScore Float? @map("recommendation_score")
  selectionScore      Float? @map("selection_score")
  explorationRate     Float? @map("exploration_rate")

  selectionMode PlaybookAssignmentSelectionMode @map("selection_mode")

  contextSnapshot Json    @map("context_snapshot")
  segmentKey      String? @map("segment_key")
  marketKey       String? @map("market_key")
  fingerprint     String? @map("fingerprint")

  executionMode PlaybookExecutionMode @map("execution_mode")

  executed       Boolean @default(false) @map("executed")
  memoryRecordId String? @map("memory_record_id")

  outcomeStatus      MemoryOutcomeStatus? @map("outcome_status")
  realizedValue      Float?               @map("realized_value")
  realizedRevenue    Float?               @map("realized_revenue")
  realizedConversion Float?               @map("realized_conversion")

  memoryRecord PlaybookMemoryRecord? @relation("PlaybookMemoryRecordAssignments", fields: [memoryRecordId], references: [id], onDelete: SetNull)

  @@index([domain, createdAt])
  @@index([playbookId, createdAt])
  @@index([entityType, entityId])
  @@index([memoryRecordId])
  @@map("playbook_assignments")
}

/// Operator / experiment control plane (admin); auditable; no execution side effects by itself.
model PlaybookControlSetting {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  scopeType String @map("scope_type")
  scopeKey  String @map("scope_key")

  explorationCap  Float?  @map("exploration_cap")
  forceMode       String? @map("force_mode")
  emergencyFreeze Boolean @default(false) @map("emergency_freeze")

  updatedByUserId String? @map("updated_by_user_id")
  reason          String? @map("reason")

  @@unique([scopeType, scopeKey], map: "playbook_control_settings_scope")
  @@index([scopeType, updatedAt])
  @@map("playbook_control_settings")
}

/// Cross-domain, deterministic shared feature index (no vector store).
model PlaybookSharedContextIndex {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  domain     MemoryDomain
  sourceType String       @map("source_type")
  sourceId   String       @map("source_id")

  playbookId        String? @map("playbook_id")
  playbookVersionId String? @map("playbook_version_id")

  sharedSignature String @map("shared_signature")
  sharedFeatures  Json   @map("shared_features")

  segmentKey String?            @map("segment_key")
  marketKey  String?            @map("market_key")
  scoreBand  PlaybookScoreBand? @map("score_band")

  lastUsedAt DateTime? @map("last_used_at")
  isActive   Boolean   @default(true) @map("is_active")

  @@unique([sourceType, sourceId], map: "psci_source_type_id")
  @@index([domain, sourceType, createdAt], map: "psci_domain_source_created")
  @@index([sharedSignature], map: "psci_shared_signature")
  @@index([playbookId, playbookVersionId], map: "psci_playbook_version")
  @@index([isActive, updatedAt], map: "psci_active_updated")
  @@map("playbook_shared_context_indexes")
}

/// Audit trail for CRM pipeline automation (distinct from analytics events).
model CrmPipelineEvent {
  id           String   @id @default(cuid())
  type         String   @db.VarChar(96)
  entityType   String   @map("entity_type") @db.VarChar(32)
  entityId     String   @map("entity_id")
  message      String   @db.Text
  brokerUserId String?  @map("broker_user_id")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([brokerUserId, createdAt])
  @@index([type, createdAt])
  @@map("crm_pipeline_events")
}

/// Green-upgrade execution partners — matching only; not endorsements.
model Contractor {
  id             String   @id @default(cuid())
  name           String
  services       String[]
  region         String   @db.VarChar(128)
  rating         Float    @default(0)
  premiumListing Boolean  @default(false) @map("premium_listing")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  reviews       GreenContractorReview[]
  quoteRequests GreenUpgradeQuoteRequest[]

  @@index([region])
  @@map("contractors")
}

model GreenContractorReview {
  id           String     @id @default(cuid())
  contractorId String     @map("contractor_id")
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  rating       Float
  body         String?    @db.Text
  authorLabel  String?    @map("author_label") @db.VarChar(128)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@index([contractorId])
  @@map("green_contractor_reviews")
}

model GreenUpgradeQuoteRequest {
  id                 String   @id @default(cuid())
  userId             String?  @map("user_id") @db.VarChar(36)
  contractorId       String?  @map("contractor_id")
  projectDescription String   @map("project_description") @db.Text
  upgradeHints       String[] @default([])
  region             String?  @db.VarChar(128)
  createdAt          DateTime @default(now()) @map("created_at")

  contractor Contractor? @relation(fields: [contractorId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([contractorId])
  @@map("green_upgrade_quote_requests")
}

/// Governed brokerage autonomy — queued actions, approvals, execution audit (no unsafe auto-send).
model AutonomousActionQueue {
  id                       String                     @id @default(cuid())
  createdAt                DateTime                   @default(now()) @map("created_at")
  updatedAt                DateTime                   @updatedAt @map("updated_at")
  domain                   String                     @db.VarChar(64)
  actionType               String                     @map("action_type") @db.VarChar(64)
  entityType               String                     @map("entity_type") @db.VarChar(32)
  entityId                 String?                    @map("entity_id")
  brokerId                 String?                    @map("broker_id")
  broker                   User?                      @relation("AutonomousQueueBroker", fields: [brokerId], references: [id], onDelete: SetNull)
  clientId                 String?                    @map("client_id")
  dealId                   String?                    @map("deal_id")
  leadId                   String?                    @map("lead_id")
  listingId                String?                    @map("listing_id")
  candidateJson            Json                       @map("candidate_json")
  riskLevel                String                     @map("risk_level") @db.VarChar(16)
  autonomyMode             String                     @map("autonomy_mode") @db.VarChar(32)
  status                   String                     @map("status") @db.VarChar(16)
  requiresApproval         Boolean                    @default(true) @map("requires_approval")
  blockedReasonsJson       Json?                      @map("blocked_reasons_json")
  sourceAgentType          String?                    @map("source_agent_type") @db.VarChar(64)
  sourceStrategyKey        String?                    @map("source_strategy_key") @db.VarChar(128)
  sourceAssignmentId       String?                    @map("source_assignment_id")
  sourceOrchestrationRunId String?                    @map("source_orchestration_run_id")
  executedAt               DateTime?                  @map("executed_at")
  approvedAt               DateTime?                  @map("approved_at")
  rejectedAt               DateTime?                  @map("rejected_at")
  rationale                String?                    @db.Text
  approvalEvents           AutonomousApprovalEvent[]
  executionEvents          AutonomousExecutionEvent[]

  @@index([brokerId, status])
  @@index([status, createdAt])
  @@index([domain, actionType])
  @@map("autonomous_action_queue")
}

model AutonomousApprovalEvent {
  id              String                @id @default(cuid())
  actionQueueId   String                @map("action_queue_id")
  queue           AutonomousActionQueue @relation(fields: [actionQueueId], references: [id], onDelete: Cascade)
  decision        String                @db.VarChar(16)
  decidedByUserId String                @map("decided_by_user_id")
  decidedBy       User                  @relation("AutonomousApprovalDecider", fields: [decidedByUserId], references: [id], onDelete: Restrict)
  reason          String?               @db.Text
  createdAt       DateTime              @default(now()) @map("created_at")

  @@index([actionQueueId, createdAt])
  @@map("autonomous_approval_events")
}

model AutonomousExecutionEvent {
  id              String                @id @default(cuid())
  actionQueueId   String                @map("action_queue_id")
  queue           AutonomousActionQueue @relation(fields: [actionQueueId], references: [id], onDelete: Cascade)
  executionStatus String                @map("execution_status") @db.VarChar(16)
  resultJson      Json                  @map("result_json")
  createdAt       DateTime              @default(now()) @map("created_at")

  @@index([actionQueueId, createdAt])
  @@map("autonomous_execution_events")
}

/// Versioned autonomy policy — at most one `isActive` per scope enforced in service layer.
model AutonomousPolicySetting {
  id                     String   @id @default(cuid())
  scopeType              String   @map("scope_type") @db.VarChar(16)
  scopeKey               String   @map("scope_key") @db.VarChar(128)
  autonomyMode           String   @map("autonomy_mode") @db.VarChar(32)
  allowedActionTypesJson Json     @map("allowed_action_types_json")
  blockedActionTypesJson Json     @map("blocked_action_types_json")
  maxRiskLevel           String   @map("max_risk_level") @db.VarChar(16)
  requireApprovalForJson Json     @map("require_approval_for_json")
  emergencyFreeze        Boolean  @default(false) @map("emergency_freeze")
  isActive               Boolean  @default(false) @map("is_active")
  version                Int      @default(1)
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@unique([scopeType, scopeKey, version])
  @@index([scopeType, scopeKey, isActive])
  @@map("autonomous_policy_settings")
}

// -----------------------------------------------------------------------------
// Centris-style transaction file (Phase 1) — one SD number per deal folder
// -----------------------------------------------------------------------------

/// Atomic yearly counter for `LEC-SD-YYYY-######` (postgres INSERT…ON CONFLICT RETURNING).
model TransactionSdSequence {
  year    Int @id @map("year")
  lastSeq Int @default(0) @map("last_seq")

  @@map("lecipm_transaction_sd_sequences")
}

/// Centris-style deal file (SD number). Distinct from `RealEstateTransaction` / finance `TransactionEvent`.
model LecipmSdTransaction {
  id                String    @id @default(cuid())
  transactionNumber String    @unique @map("transaction_number") @db.VarChar(48)
  listingId         String?   @map("listing_id") @db.VarChar(36)
  listing           Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  propertyId        String?   @map("property_id") @db.VarChar(36)
  property          Property? @relation("LecipmSdTransactionProperty", fields: [propertyId], references: [id], onDelete: SetNull)
  brokerId          String    @map("broker_id") @db.VarChar(36)
  broker            User      @relation("LecipmSdTransactionBroker", fields: [brokerId], references: [id], onDelete: Restrict)

  transactionType String  @map("transaction_type") @db.VarChar(32)
  status          String  @default("DRAFT") @db.VarChar(24)
  title           String? @db.VarChar(512)

  openedAt       DateTime @default(now()) @map("opened_at")
  brokerSnapshot Json?    @map("broker_snapshot")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  parties               LecipmSdTransactionParty[]
  timelineEvents        LecipmSdTimelineEvent[]
  documents             LecipmSdDocument[]
  financialApproval     LecipmSdFinancialApproval?
  notaryPackage         LecipmSdNotaryPackage?
  signaturePackets      LecipmSdSignaturePacket[]
  signatureSigners      LecipmSdSignatureSigner[]
  complianceChecks      LecipmSdComplianceCheck[]
  auditProofs           LecipmSdAuditProof[]
  pipelineDeal          LecipmPipelineDeal?
  transactionArchive    LecipmSdTransactionArchive?
  closingRoomLink       LecipmPipelineDealClosing?  @relation("ClosingRoomTransaction")
  portfolioAssetsFromTx LecipmPortfolioAsset[]      @relation("PortfolioAssetTransaction")
  tenantCreditChecks    LecipmTenantCreditCheck[]

  @@index([brokerId, status])
  @@index([brokerId, updatedAt(sort: Desc)])
  @@index([listingId])
  @@index([transactionNumber])
  @@map("lecipm_transactions")
}

model LecipmSdTransactionParty {
  id            String              @id @default(cuid())
  transactionId String              @map("transaction_id") @db.VarChar(36)
  transaction   LecipmSdTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  role        String  @db.VarChar(24)
  displayName String  @map("display_name") @db.VarChar(256)
  email       String? @db.VarChar(320)
  phone       String? @db.VarChar(64)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([transactionId])
  @@map("lecipm_transaction_parties")
}

model LecipmSdTimelineEvent {
  id            String              @id @default(cuid())
  transactionId String              @map("transaction_id") @db.VarChar(36)
  transaction   LecipmSdTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  eventType String @map("event_type") @db.VarChar(64)
  summary   String @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  @@index([transactionId, createdAt])
  @@map("lecipm_transaction_events")
}

/// Phase 2 — transaction file documents (SD number denormalized; never standalone).
model LecipmSdDocument {
  id            String              @id @default(cuid())
  transactionId String              @map("transaction_id") @db.VarChar(36)
  transaction   LecipmSdTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  documentType  String  @map("document_type") @db.VarChar(32)
  templateCode  String? @map("template_code") @db.VarChar(64)
  title         String  @db.VarChar(512)
  fileUrl       String? @map("file_url") @db.Text
  fileFormat    String? @map("file_format") @db.VarChar(16)
  versionNumber Int     @default(1) @map("version_number")
  status        String  @default("DRAFT") @db.VarChar(24)

  transactionNumber String  @map("transaction_number") @db.VarChar(48)
  brokerSnapshot    Json?   @map("broker_snapshot")
  bodyHtml          String? @map("body_html") @db.Text
  metadataJson      Json?   @map("metadata_json")

  replacesDocumentId String? @map("replaces_document_id") @db.VarChar(36)
  requiredForClosing Boolean @default(false) @map("required_for_closing")

  /// Privacy Compliance (Law 25)
  sensitivityLevel   PrivacySensitivityLevel @default(INTERNAL) @map("sensitivity_level")
  allowedRoles       Json?                   @map("allowed_roles")
  allowedDepartments Json?                   @map("allowed_departments")
  needToKnow         Boolean                 @default(true) @map("need_to_know")
  organizationId     String?                 @map("organization_id")

  /// Phase 3 — immutable after fully signed packet completes.
  lockedAt             DateTime? @map("locked_at")
  immutableContentHash String?   @map("immutable_content_hash") @db.VarChar(128)

  signaturePackets LecipmSdSignaturePacket[]
  complianceChecks LecipmSdComplianceCheck[]
  auditProofs      LecipmSdAuditProof[]

  pipelineClosingDocumentLinks LecipmPipelineDealClosingDocument[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([transactionId])
  @@index([transactionId, status])
  @@map("lecipm_sd_documents")
}

/// Phase 3 — DocuSign-style envelope per document.
model LecipmSdSignaturePacket {
  id            String              @id @default(cuid())
  transactionId String              @map("transaction_id") @db.VarChar(36)
  transaction   LecipmSdTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  documentId    String              @map("document_id") @db.VarChar(36)
  document      LecipmSdDocument    @relation(fields: [documentId], references: [id], onDelete: Cascade)

  status      String    @default("DRAFT") @db.VarChar(28)
  provider    String    @default("INTERNAL") @db.VarChar(32)
  sentAt      DateTime? @map("sent_at")
  completedAt DateTime? @map("completed_at")

  signers LecipmSdSignatureSigner[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([transactionId])
  @@index([documentId])
  @@map("lecipm_sd_signature_packets")
}

model LecipmSdSignatureSigner {
  id            String                  @id @default(cuid())
  packetId      String                  @map("packet_id") @db.VarChar(36)
  packet        LecipmSdSignaturePacket @relation(fields: [packetId], references: [id], onDelete: Cascade)
  transactionId String                  @map("transaction_id") @db.VarChar(36)
  transaction   LecipmSdTransaction     @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  role   String @db.VarChar(24)
  name   String @db.VarChar(512)
  email  String @db.VarChar(320)
  status String @default("PENDING") @db.VarChar(24)

  signedAt         DateTime? @map("signed_at")
  ipAddress        String?   @map("ip_address") @db.VarChar(64)
  userAgent        String?   @map("user_agent") @db.Text
  signatureHash    String?   @map("signature_hash") @db.VarChar(128)
  identityVerified Boolean   @default(false) @map("identity_verified")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([packetId])
  @@index([transactionId])
  @@map("lecipm_sd_signature_signers")
}

model LecipmSdComplianceCheck {
  id            String              @id @default(cuid())
  transactionId String              @map("transaction_id") @db.VarChar(36)
  transaction   LecipmSdTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  documentId    String?             @map("document_id") @db.VarChar(36)
  document      LecipmSdDocument?   @relation(fields: [documentId], references: [id], onDelete: SetNull)

  checkType String @map("check_type") @db.VarChar(40)
  severity  String @db.VarChar(16)
  status    String @default("OPEN") @db.VarChar(16)
  message   String @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  @@index([transactionId, status])
  @@map("lecipm_sd_compliance_checks")
}

/// Append-only tamper-evident chain (never delete rows in application code).
model LecipmSdAuditProof {
  id            String              @id @default(cuid())
  transactionId String              @map("transaction_id") @db.VarChar(36)
  transaction   LecipmSdTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  documentId    String?             @map("document_id") @db.VarChar(36)
  document      LecipmSdDocument?   @relation(fields: [documentId], references: [id], onDelete: SetNull)

  hash         String  @db.VarChar(128)
  previousHash String? @map("previous_hash") @db.VarChar(128)
  eventType    String  @map("event_type") @db.VarChar(64)
  payloadJson  Json?   @map("payload_json")

  timestamp DateTime @default(now()) @map("timestamp")

  @@index([transactionId, timestamp])
  @@map("lecipm_sd_audit_proofs")
}

model LecipmSdFinancialApproval {
  id            String              @id @default(cuid())
  transactionId String              @unique @map("transaction_id") @db.VarChar(36)
  transaction   LecipmSdTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  lenderName     String? @map("lender_name") @db.VarChar(256)
  brokerName     String? @map("broker_name") @db.VarChar(256)
  approvalStatus String  @default("PENDING") @map("approval_status") @db.VarChar(24)

  approvedAmount Float? @map("approved_amount")
  interestRate   Float? @map("interest_rate")
  conditionsJson Json?  @map("conditions_json")

  approvalDate DateTime? @map("approval_date")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("lecipm_sd_financial_approvals")
}

model LecipmSdNotaryPackage {
  id            String              @id @default(cuid())
  transactionId String              @unique @map("transaction_id") @db.VarChar(36)
  transaction   LecipmSdTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  notaryName  String? @map("notary_name") @db.VarChar(256)
  notaryEmail String? @map("notary_email") @db.VarChar(320)

  packageStatus  String    @default("PENDING") @map("package_status") @db.VarChar(24)
  sentAt         DateTime? @map("sent_at")
  confirmationAt DateTime? @map("confirmation_at")

  documentIdsJson Json? @map("document_ids_json")
  payloadJson     Json? @map("payload_json")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("lecipm_sd_notary_packages")
}

// -----------------------------------------------------------------------------
// Phase 4 — Broker deal pipeline (LEC-DEAL-*). Distinct from transactional `Deal`.
// -----------------------------------------------------------------------------

model LecipmDealNumberSequence {
  year    Int @id @map("year")
  lastSeq Int @default(0) @map("last_seq")

  @@map("lecipm_deal_number_sequences")
}

model LecipmPipelineDeal {
  id            String               @id @default(cuid())
  transactionId String?              @unique @map("transaction_id") @db.VarChar(36)
  transaction   LecipmSdTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  listingId     String?              @map("listing_id") @db.VarChar(36)
  listing       Listing?             @relation(fields: [listingId], references: [id], onDelete: SetNull)

  brokerId                   String    @map("broker_id") @db.VarChar(36)
  broker                     User      @relation("LecipmPipelineDealBroker", fields: [brokerId], references: [id], onDelete: Restrict)
  brokerDecisionApprovedById String?   @map("broker_decision_approved_by_id") @db.VarChar(36)
  brokerDecisionApprovedAt   DateTime? @map("broker_decision_approved_at")

  dealNumber String @unique @map("deal_number") @db.VarChar(48)
  title      String @db.VarChar(512)
  dealType   String @map("deal_type") @db.VarChar(32)

  pipelineStage  String @default("SCREENING") @map("pipeline_stage") @db.VarChar(40)
  decisionStatus String @default("PENDING") @map("decision_status") @db.VarChar(40)

  priority      String? @db.VarChar(16)
  ownerUserId   String? @map("owner_user_id") @db.VarChar(36)
  owner         User?   @relation("LecipmPipelineDealOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  sponsorUserId String? @map("sponsor_user_id") @db.VarChar(36)
  sponsor       User?   @relation("LecipmPipelineDealSponsor", fields: [sponsorUserId], references: [id], onDelete: SetNull)

  latestTransactionNumber String?   @map("latest_transaction_number") @db.VarChar(48)
  latestMemoRef           String?   @map("latest_memo_ref") @db.VarChar(512)
  latestSummary           String?   @map("latest_summary") @db.Text
  /// Set when `compareOffers` runs with ≥2 offers (required before selecting a lender offer).
  lastOfferComparedAt     DateTime? @map("last_offer_compared_at")

  capitalStack        LecipmPipelineDealCapitalStack?
  lenders             LecipmPipelineDealLender[]
  lenderOffers        LecipmPipelineDealLenderOffer[]
  financingConditions LecipmPipelineDealFinancingCondition[]
  closingReadiness    LecipmPipelineDealClosingReadiness?
  closingRoom         LecipmPipelineDealClosing?
  portfolioAssets     LecipmPortfolioAsset[]

  stageHistories       LecipmPipelineDealStageHistory[]
  committeeSubmissions LecipmPipelineDealCommitteeSubmission[]
  committeeDecisions   LecipmPipelineDealCommitteeDecision[]
  conditions           LecipmPipelineDealCondition[]
  diligenceTasks       LecipmPipelineDealDiligenceTask[]
  auditEvents          LecipmPipelineDealAuditEvent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([brokerId, pipelineStage])
  @@index([brokerId, updatedAt(sort: Desc)])
  @@index([listingId])
  @@map("lecipm_pipeline_deals")
}

