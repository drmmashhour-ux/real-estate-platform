// ---------------------------------------------------------------------------
// Monetization – platform revenue events and payout adjustments
// ---------------------------------------------------------------------------
model PlatformRevenueEvent {
  id              String   @id @default(uuid())
  entityType      String   @map("entity_type") // booking | transaction | subscription | promotion | ai_feature
  entityId        String   @map("entity_id")
  revenueType     String   @map("revenue_type") // guest_service_fee | host_fee | transaction_fee | subscription | promotion | refund_reversal
  amountCents     Int      @map("amount_cents")
  currency        String   @default("USD")
  status          String   @default("realized") // pending | realized | refunded | reversed
  sourceReference String?  @map("source_reference") // payment_id | invoice_id | etc.
  marketId        String?  @map("market_id")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([revenueType])
  @@index([status])
  @@index([createdAt])
  @@index([marketId])
  @@map("platform_revenue_events")
}

/// User-centric monetization events (booking completed, lead purchased, premium upgrade) — complements `PlatformRevenueEvent`.
model RevenueEvent {
  id           String   @id @default(uuid())
  userId       String?  @map("user_id")
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  eventType    String   @map("event_type")
  amount       Float    @default(0)
  metadataJson Json?    @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@map("revenue_events")
}

/// Open / converted / lost revenue opportunities for prioritization and nudges.
model RevenueOpportunity {
  id              String   @id @default(uuid())
  userId          String?  @map("user_id")
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  leadId          String?  @map("lead_id")
  lead            Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  opportunityType String   @map("opportunity_type")
  status          String   @default("open")
  valueEstimate   Float    @default(0) @map("value_estimate")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([userId, status])
  @@index([leadId, status])
  @@index([status, createdAt])
  @@map("revenue_opportunities")
}

/// Daily investor / board KPI snapshot (growth, marketplace, conversion).
model MetricSnapshot {
  id             String   @id @default(uuid())
  date           DateTime @db.Date
  totalUsers     Int      @map("total_users")
  activeUsers    Int      @map("active_users")
  totalListings  Int      @map("total_listings")
  bookings       Int      @default(0)
  revenue        Float    @default(0)
  conversionRate Float   @default(0) @map("conversion_rate")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([date])
  @@index([date])
  @@map("investor_metric_snapshots")
}

/// Fundraising CRM: prospective capital partners (not product `InvestorProfile`).
model FundraisingInvestor {
  id             String    @id @default(uuid())
  name           String
  email          String
  firm           String    @default("")
  /// contacted | interested | meeting | negotiating | closed
  stage          String    @default("contacted")
  notes          String?
  nextFollowUpAt DateTime? @map("next_follow_up_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  interactions  FundraisingInvestorInteraction[]
  deals         FundraisingDeal[]
  commitments   InvestorCommitment[]

  @@index([stage])
  @@index([email])
  @@map("fundraising_investors")
}

/// Logged touchpoints: email, call, meeting, plus outreach / response / follow_up.
model FundraisingInvestorInteraction {
  id         String   @id @default(uuid())
  investorId String   @map("investor_id")
  /// email | call | meeting | outreach | response | follow_up
  type       String
  summary    String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  investor FundraisingInvestor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@index([investorId, createdAt])
  @@map("fundraising_investor_interactions")
}

model FundraisingDeal {
  id         String   @id @default(uuid())
  investorId String   @map("investor_id")
  amount     Float
  /// open | committed | closed
  status     String   @default("open")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  investor FundraisingInvestor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@index([investorId])
  @@index([status])
  @@map("fundraising_deals")
}

/// Active fundraising round (e.g. $100K) with denormalized raised total from commitments.
model FundraisingRound {
  id           String   @id @default(uuid())
  targetAmount Float    @map("target_amount")
  raisedAmount Float    @default(0) @map("raised_amount")
  /// open | closed
  status       String   @default("open")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  commitments InvestorCommitment[]

  @@index([status])
  @@map("fundraising_rounds")
}

/// Per-investor pledge toward a round: interested → committed → transferred.
model InvestorCommitment {
  id         String   @id @default(uuid())
  roundId    String   @map("round_id")
  investorId String   @map("investor_id")
  amount     Float
  /// interested | committed | transferred
  status     String   @default("interested")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  round    FundraisingRound    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  investor FundraisingInvestor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@index([roundId])
  @@index([investorId])
  @@index([status])
  @@map("investor_commitments")
}

/// Daily rollup for revenue execution discipline (messages, contacts, bookings, revenue).
model ExecutionDay {
  id                   String   @id @default(uuid())
  date                 DateTime @db.Date
  messagesSent         Int      @default(0) @map("messages_sent")
  brokersContacted     Int      @default(0) @map("brokers_contacted")
  hostsContacted       Int      @default(0) @map("hosts_contacted")
  inquiriesGenerated   Int      @default(0) @map("inquiries_generated")
  bookingsCompleted    Int      @default(0) @map("bookings_completed")
  revenue              Float    @default(0)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@unique([date])
  @@index([date])
  @@map("revenue_execution_days")
}

/// Per-touch log: message | call | follow_up | close (CRM user optional).
model ExecutionAction {
  id        String   @id @default(uuid())
  /// message | call | follow_up | close
  type      String
  userId    String?  @map("user_id")
  /// pending | done | skipped | converted
  status    String   @default("done")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation("ExecutionActionCrmUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@map("revenue_execution_actions")
}

/// Generated investor pitch deck (slides stored as JSON content).
model PitchDeck {
  id        String           @id @default(uuid())
  title     String
  createdAt DateTime         @default(now()) @map("created_at")
  slides    PitchDeckSlide[]

  @@index([createdAt])
  @@map("pitch_decks")
}

model PitchDeckSlide {
  id      String   @id @default(uuid())
  deckId  String   @map("deck_id")
  order   Int
  /// title | problem | solution | product | traction | business_model | growth | vision
  type    String
  title   String
  content Json

  deck PitchDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@index([deckId, order])
  @@map("pitch_deck_slides")
}

/// In-platform sales team member (round-robin / priority routing).
model SalesAgent {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  /// agent | closer | manager
  role      String   @default("agent")
  active    Boolean  @default(true)
  /// Higher = earlier pick in priority mode (tie-breaker: lower load).
  priority  Int      @default(0) @map("priority_weight")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments  SalesAssignment[]
  performance  SalesPerformance?

  @@index([active, priority])
  @@map("sales_agents")
}

/// One row per lead — links CRM lead to sales agent (Close Room / pipeline).
model SalesAssignment {
  id        String   @id @default(uuid())
  agentId   String   @map("agent_id")
  leadId    String   @unique @map("lead_id")
  /// Denormalized from Lead.userId when present (priority user / CRM).
  userId    String?  @map("user_id")
  /// assigned | contacted | closed | lost
  status    String   @default("assigned")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  agent SalesAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  lead  Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user  User?      @relation("SalesAssignmentProspect", fields: [userId], references: [id], onDelete: SetNull)

  @@index([agentId, status])
  @@index([status])
  @@map("sales_assignments")
}

model SalesPerformance {
  id             String   @id @default(uuid())
  agentId        String   @unique @map("agent_id")
  leadsAssigned  Int      @default(0) @map("leads_assigned")
  dealsClosed    Int      @default(0) @map("deals_closed")
  revenue        Float    @default(0)
  commission     Float    @default(0) @map("commission_earned")
  updatedAt      DateTime @updatedAt @map("updated_at")

  agent SalesAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("sales_performance")
}

/// Internal hiring CRM — candidates for sales / ops / growth.
model Candidate {
  id        String   @id @default(uuid())
  name      String
  email     String
  /// sales | operations | growth
  role      String
  /// applied | screening | interview | trial | hired | rejected
  stage     String   @default("applied")
  /// Latest rollup from evaluations (0–10 scale).
  score     Float    @default(0)
  notes     String?
  /// high_performer | low_performer | null (auto from rules)
  flag      String?  @map("performance_flag")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  interactions  CandidateInteraction[]
  evaluations   CandidateEvaluation[]
  trialTasks    CandidateTrialTask[]

  @@index([stage])
  @@index([role])
  @@index([email])
  @@index([flag])
  @@map("hiring_candidates")
}

model CandidateInteraction {
  id          String   @id @default(uuid())
  candidateId String   @map("candidate_id")
  /// message | call | interview
  type        String
  summary     String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, createdAt])
  @@map("hiring_candidate_interactions")
}

model CandidateEvaluation {
  id                 String   @id @default(uuid())
  candidateId        String   @map("candidate_id")
  communicationScore Int      @map("communication_score")
  salesSkillScore    Int      @map("sales_skill_score")
  executionScore     Int      @map("execution_score")
  /// Raw pillars (0–10) for structured rubric.
  speedScore         Int      @default(0) @map("speed_score")
  clarityScore       Int      @default(0) @map("clarity_score")
  closingScore       Int      @default(0) @map("closing_score")
  overallScore       Float    @map("overall_score")
  createdAt          DateTime @default(now()) @map("created_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, createdAt])
  @@map("hiring_candidate_evaluations")
}

/// Real-world trial: contact leads, close a user, etc.
model CandidateTrialTask {
  id              String    @id @default(uuid())
  candidateId     String    @map("candidate_id")
  /// contact_leads | close_one_user
  taskKey         String    @map("task_key")
  /// assigned | in_progress | submitted | reviewed | passed | failed
  status          String    @default("assigned")
  resultSummary   String?   @map("result_summary") @db.Text
  /// 0–10 quality of response / execution evidence
  responseQuality Int?      @map("response_quality")
  dueAt           DateTime? @map("due_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, status])
  @@map("hiring_candidate_trial_tasks")
}

/// Cap table holder (founder, employee, advisor, investor).
model EquityHolder {
  id            String        @id @default(uuid())
  name          String
  /// founder | employee | advisor | investor
  role          String
  /// Fully diluted % (denormalized; recomputed from grants).
  equityPercent Float         @default(0) @map("equity_percent")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  grants        EquityGrant[]

  @@index([role])
  @@map("equity_holders")
}

model EquityGrant {
  id               String   @id @default(uuid())
  holderId         String   @map("holder_id")
  totalShares      Float    @map("total_shares")
  vestingStart     DateTime @map("vesting_start")
  /// Total schedule length in months (e.g. 48).
  vestingDuration  Int      @map("vesting_duration")
  cliffMonths      Int      @map("cliff_months")
  vestedShares     Float    @default(0) @map("vested_shares")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  holder EquityHolder @relation(fields: [holderId], references: [id], onDelete: Cascade)

  @@index([holderId])
  @@map("equity_grants")
}

model PayoutAdjustment {
  id             String   @id @default(uuid())
  bookingId      String?  @map("booking_id")
  adjustmentType String   @map("adjustment_type") // refund | dispute_deduction | fee_reversal | hold_release
  amountCents    Int      @map("amount_cents") // positive = reduction from host payout, negative = credit
  currency       String   @default("USD")
  reason         String?
  createdAt      DateTime

  @@index([bookingId])
  @@index([adjustmentType])
  @@index([createdAt])
  @@map("payout_adjustments")
}

// ---------------------------------------------------------------------------
// Growth and Acquisition
// ---------------------------------------------------------------------------
enum GrowthCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

model GrowthCampaign {
  id                 String               @id @default(uuid())
  name               String
  campaignType       String // REFERRAL | INVITE | ACQUISITION
  marketId           String?
  startAt            DateTime
  endAt              DateTime
  status             GrowthCampaignStatus @default(DRAFT)
  config             Json? // Reward amounts, eligibility, etc.
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  market             MarketConfig?        @relation(fields: [marketId], references: [id], onDelete: SetNull)
  acquisitionSources AcquisitionSource[]

  @@index([marketId])
  @@index([status])
}

model AcquisitionSource {
  id             String          @id @default(uuid())
  userId         String?
  campaignId     String?
  growthCampaign GrowthCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  source         String // utm_source | referral | organic
  medium         String?
  utmCampaign    String? // utm_campaign
  createdAt      DateTime        @default(now())

  @@index([userId])
  @@index([campaignId])
  @@index([source])
}

model OnboardingMilestone {
  id           String   @id @default(uuid())
  userId       String
  milestoneKey String // PROFILE_COMPLETE | FIRST_LISTING | FIRST_BOOKING | VERIFICATION_DONE
  completedAt  DateTime @default(now())
  metadata     Json?
  createdAt    DateTime @default(now())

  @@unique([userId, milestoneKey])
  @@index([userId])
  @@index([milestoneKey])
}

// ---------------------------------------------------------------------------
// Lifecycle Automation
// ---------------------------------------------------------------------------
enum LifecycleStage {
  ONBOARDING
  ACTIVE
  AT_RISK
  CHURNED
  REACTIVATED
}

model LifecycleState {
  id             String         @id @default(uuid())
  userId         String
  stage          LifecycleStage
  module         String? // BNHUB | BROKER_CRM | OWNER | INVESTOR
  lastActivityAt DateTime?
  metadata       Json?
  updatedAt      DateTime       @updatedAt
  createdAt      DateTime       @default(now())

  @@index([userId])
  @@index([stage])
  @@index([module])
}

// ---------------------------------------------------------------------------
// Market Configuration and Multi-Market Expansion
// ---------------------------------------------------------------------------
model MarketConfig {
  id                   String                @id @default(uuid())
  code                 String                @unique // e.g. NYC, LON, UAE
  name                 String
  country              String
  currency             String                @default("USD")
  defaultLanguage      String                @default("en")
  active               Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  taxRules             MarketTaxRule[]
  policyBindings       MarketPolicyBinding[]
  promotionCampaigns   PromotionCampaign[]
  growthCampaigns      GrowthCampaign[]
  revenueLedgerEntries RevenueLedgerEntry[]

  @@index([active])
  @@index([code])
}

model MarketTaxRule {
  id            String       @id @default(uuid())
  marketId      String
  market        MarketConfig @relation(fields: [marketId], references: [id], onDelete: Cascade)
  ruleType      String // VAT | GST | PLATFORM_FEE
  ratePercent   Float
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime     @default(now())

  @@index([marketId])
}

model MarketPolicyBinding {
  id              String       @id @default(uuid())
  marketId        String
  market          MarketConfig @relation(fields: [marketId], references: [id], onDelete: Cascade)
  policyRuleKey   String
  overridePayload Json?
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([marketId])
  @@index([policyRuleKey])
}

// ---------------------------------------------------------------------------
// Revenue Intelligence
// ---------------------------------------------------------------------------
enum RevenueLedgerType {
  BOOKING_COMMISSION
  REAL_ESTATE_COMMISSION
  SUBSCRIPTION
  PROMOTION
  REFERRAL_COST
  REFUND
  CHARGEBACK
  INCENTIVE
  PAYOUT
}

model RevenueLedgerEntry {
  id          String            @id @default(uuid())
  type        RevenueLedgerType
  entityType  String // BOOKING | SUBSCRIPTION | INVOICE | PROMOTION | REFERRAL
  entityId    String
  amountCents Int // Positive = revenue, negative = cost/refund
  marketId    String?
  market      MarketConfig?     @relation(fields: [marketId], references: [id], onDelete: SetNull)
  module      String? // BNHUB | BROKER_CRM | etc.
  userId      String?
  metadata    Json?
  createdAt   DateTime          @default(now())

  @@index([type])
  @@index([entityType, entityId])
  @@index([marketId])
  @@index([createdAt])
}

model RevenueReport {
  id          String   @id @default(uuid())
  reportType  String // DAILY | WEEKLY | MONTHLY | BY_MARKET | BY_MODULE
  periodStart DateTime
  periodEnd   DateTime
  marketId    String?
  data        Json // Aggregated totals, breakdowns
  createdAt   DateTime @default(now())

  @@index([reportType])
  @@index([periodStart])
  @@index([marketId])
}

// ---------------------------------------------------------------------------
// Executive Business Metrics
// ---------------------------------------------------------------------------
model ExecutiveMetricsSnapshot {
  id                 String   @id @default(uuid())
  date               DateTime
  marketId           String?
  gmvCents           Int      @default(0)
  netRevenueCents    Int      @default(0)
  bookingsCount      Int      @default(0)
  activeHostsCount   Int      @default(0)
  activeBrokersCount Int      @default(0)
  mrrCents           Int      @default(0)
  arrCents           Int      @default(0)
  refundRate         Float?
  disputeRate        Float?
  data               Json? // Extended KPIs, cohort hints
  createdAt          DateTime @default(now())

  @@unique([date, marketId])
  @@index([date])
  @@index([marketId])
}

// =============================================================================
// AI OPERATING SYSTEM (AI-OS) LAYER
// =============================================================================

// ---------------------------------------------------------------------------
// AI Data Pipeline & Feature Store
// ---------------------------------------------------------------------------
model AiFeature {
  id         String   @id @default(uuid())
  entityType String // LISTING | BOOKING | USER | MARKET | etc.
  entityId   String
  featureKey String // e.g. listing_quality_score, user_fraud_risk
  value      Float // numeric feature
  valueJson  Json? // complex or vector
  source     String? // pipeline run id or model version
  computedAt DateTime @default(now())

  @@unique([entityType, entityId, featureKey])
  @@index([entityType, featureKey])
  @@index([computedAt])
}

// ---------------------------------------------------------------------------
// Model Registry & Lifecycle
// ---------------------------------------------------------------------------
model AiModel {
  id           String          @id @default(uuid())
  key          String          @unique // fraud_v1, pricing_v1, ranking_v1
  name         String
  description  String?
  active       Boolean
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  versions     ModelVersion[]
  decisionLogs AiDecisionLog[]

  @@index([key])
}

model ModelVersion {
  id           String    @id @default(uuid())
  modelId      String
  model        AiModel   @relation(fields: [modelId], references: [id], onDelete: Cascade)
  version      Int // 1, 2, 3...
  metrics      Json? // accuracy, precision, recall, drift
  deployedAt   DateTime?
  deprecatedAt DateTime?
  createdAt    DateTime  @default(now())

  @@unique([modelId, version])
  @@index([modelId])
}

// ---------------------------------------------------------------------------
// Fraud Detection AI (aggregated scores per entity)
// ---------------------------------------------------------------------------
model FraudScore {
  id           String   @id @default(uuid())
  entityType   String // LISTING | BOOKING | USER | PAYMENT
  entityId     String
  score        Float // 0-1 risk
  factors      Json? // contributing signals
  modelVersion String?
  priority     String? // HIGH | MEDIUM | LOW (investigation priority)
  createdAt    DateTime @default(now())

  @@index([entityType, entityId])
  @@index([score])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Dynamic Pricing AI (extends PricingRecommendation with model metadata)
// ---------------------------------------------------------------------------
model AiPricingRecommendation {
  id               String    @id @default(uuid())
  listingId        String
  recommendedCents Int
  minCents         Int?
  maxCents         Int?
  demandLevel      String // low | medium | high
  minStayNights    Int?
  factors          Json? // explainable factors
  modelVersion     String?
  forDate          DateTime?
  createdAt        DateTime

  @@index([listingId])
  @@index([forDate])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Search Ranking AI (cached scores and explanations)
// ---------------------------------------------------------------------------
model SearchRankingScore {
  id           String   @id @default(uuid())
  listingId    String
  score        Float
  factors      Json? // breakdown: verification, reviews, conversion...
  modelVersion String?
  computedAt   DateTime @default(now())

  @@index([listingId])
  @@index([score])
  @@index([computedAt])
}

// ---------------------------------------------------------------------------
// Demand Forecasting
// ---------------------------------------------------------------------------
model DemandForecast {
  id                String   @id @default(uuid())
  region            String // city or market code
  propertyType      String? // optional segment
  forecastDate      DateTime
  demandLevel       Float
  bookingsPredicted Int?
  supplyGap         Int? // predicted shortage
  modelVersion      String?
  createdAt         DateTime @default(now())

  @@index([region, forecastDate])
  @@index([forecastDate])
}

// ---------------------------------------------------------------------------
// AI Alerts (marketplace health, fraud spikes, anomalies)
// ---------------------------------------------------------------------------
enum AiAlertType {
  FRAUD_SPIKE
  DISPUTE_SPIKE
  LISTING_QUALITY_DROP
  CANCELLATION_ANOMALY
  DEMAND_CHANGE
  REGIONAL_RISK
  MODEL_DRIFT
}

model AiAlert {
  id             String      @id @default(uuid())
  alertType      AiAlertType
  severity       String // LOW | MEDIUM | HIGH | CRITICAL
  title          String
  message        String
  entityType     String?
  entityId       String?
  region         String?
  payload        Json? // metrics, recommended actions
  acknowledgedAt DateTime?
  acknowledgedBy String?
  createdAt      DateTime    @default(now())

  @@index([alertType])
  @@index([severity])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// AI Decision Log (audit trail for model-driven decisions)
// ---------------------------------------------------------------------------
model AiDecisionLog {
  id           String    @id @default(uuid())
  modelId      String
  model        AiModel   @relation(fields: [modelId], references: [id], onDelete: Restrict)
  modelVersion String?
  entityType   String
  entityId     String
  decision     String // ALLOW | FLAG | BLOCK | RECOMMEND
  score        Float?
  explanation  String?
  overrideBy   String?
  overrideAt   DateTime?
  context      Json?
  createdAt    DateTime  @default(now())

  @@index([modelId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// AI Operator – Fully Autonomous Marketplace Operator (BNHub)
// ---------------------------------------------------------------------------
model AiOperatorDecision {
  id                  String    @id @default(uuid())
  agentType           String // listing_moderation | pricing | fraud_risk | booking_integrity | demand_forecast | host_performance | support_triage | marketplace_health
  entityType          String
  entityId            String
  inputSummary        Json?
  outputSummary       Json?
  confidenceScore     Float
  recommendedAction   String
  reasonCodes         Json      @default("[]")
  automatedAction     String?
  humanOverrideBy     String?
  humanOverrideAt     DateTime?
  humanOverrideAction String?
  humanOverrideNotes  String?
  createdAt           DateTime

  @@index([agentType])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model AiOperatorAlert {
  id         String   @id @default(uuid())
  alertType  String // listing_quality | fraud_risk | booking_anomaly | marketplace_health | pricing | etc.
  severity   String // low | medium | high | critical
  entityType String
  entityId   String
  message    String
  status     String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([alertType])
  @@index([status])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// AI Control Center – unified audit log for all AI decisions
// ---------------------------------------------------------------------------
model AiLog {
  id                    String   @id @default(uuid())
  action                String   @map("action") // evaluate | fraud_check | price_suggestion | trust_score
  entityType            String   @map("entity_type") // listing | booking | user | etc.
  entityId              String   @map("entity_id")
  riskScore             Int?     @map("risk_score") // 0-100
  trustLevel            String?  @map("trust_level") // low | medium | high
  trustScore            Float?   @map("trust_score") // 0-100 or 0-5 depending on context
  recommendedPriceCents Int?     @map("recommended_price_cents")
  details               Json? // factors, explanation, payload
  createdAt             DateTime @default(now()) @map("created_at")

  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("ai_logs")
}

/// Unified audit trail for hub AI assistant calls (no raw secrets; summaries only).
model AiInteractionLog {
  id            String   @id @default(uuid())
  userId        String?  @map("user_id")
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  role          String   @map("role")
  hub           String   @map("hub")
  feature       String   @map("feature")
  intent        String   @map("intent")
  /// When set, this row is a Decision Engine evaluation (see `feature` = decision_engine).
  decisionType  String?  @map("decision_type")
  /// Priority / risk tier from decision engine (low | medium | high | critical).
  riskLevel     String?  @map("risk_level")
  inputSummary  String   @map("input_summary") @db.Text
  outputSummary String   @map("output_summary") @db.Text
  model         String?  @map("model")
  source        String   @default("openai") @map("source")
  feedback      String?  @map("feedback")
  metadata      Json?
  /// True when the interaction is legal-assistant (content license, readiness, contract explain, risk checks).
  legalContext  Boolean  @default(false) @map("legal_context")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([hub, createdAt])
  @@index([createdAt])
  @@index([legalContext, createdAt])
  @@map("ai_interaction_logs")
}

enum AdminReportPeriodType {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

/// Cached admin operational report payloads (AI-style summaries + KPI JSON).
model AdminReportSnapshot {
  id          String                @id @default(uuid())
  periodType  AdminReportPeriodType @map("period_type")
  periodStart DateTime              @map("period_start")
  periodEnd   DateTime              @map("period_end")
  summaryJson Json                  @map("summary_json")
  generatedAt DateTime              @default(now()) @map("generated_at")

  @@unique([periodType, periodStart])
  @@index([periodType, generatedAt])
  @@map("admin_report_snapshots")
}

// ---------------------------------------------------------------------------
// AI Operations – queue of items for AI review/decision
// ---------------------------------------------------------------------------
model AiQueueItem {
  id                String   @id @default(uuid())
  type              String   @map("type") // listing | booking | user | dispute
  entityId          String   @map("entity_id")
  riskScore         Int?     @map("risk_score") // 0-100
  trustScore        Float?   @map("trust_score") // 0-100
  status            String   @default("pending") @map("status") // pending | flagged | approved | rejected
  recommendedAction String?  @map("recommended_action") // approve | flag | block | review
  details           Json? // factors, last evaluation payload
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("ai_queue_items")
}

// ---------------------------------------------------------------------------
// Design studio – Canva / marketing design references per listing
// ---------------------------------------------------------------------------
model ListingDesignReference {
  id        String           @id @default(uuid())
  listingId String           @map("listing_id")
  listing   ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  source    String           @default("canva") @map("source") // canva | other
  designUrl String           @map("design_url")
  title     String?          @map("title")
  metadata  Json? // export format, dimensions, etc.
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([listingId])
  @@index([createdAt])
  @@map("listing_design_references")
}

// 7-day free trial for Design Studio (all visitors, brokers, clients, partners)
model DesignStudioTrial {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id") // session/guest id or user id
  trialEndsAt DateTime @map("trial_ends_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([trialEndsAt])
  @@map("design_studio_trials")
}

// Design feature access: 7-day trial then require payment (platform feature, not Canva account)
model DesignAccess {
  id         String   @id @default(cuid())
  userId     String   @unique @map("user_id")
  trialStart DateTime @map("trial_start")
  trialEnd   DateTime @map("trial_end")
  isPaid     Boolean  @default(false) @map("is_paid")

  @@index([userId])
  @@index([trialEnd])
  @@map("design_access")
}

// Canva usage per user/listing – trial then $5 per design
model CanvaDesignUsage {
  id          String         @id @default(cuid())
  userId      String         @map("user_id")
  listingId   String         @map("listing_id")
  createdAt   DateTime       @default(now()) @map("created_at")
  trialEndsAt DateTime       @map("trial_ends_at")
  isPaid      Boolean        @default(false) @map("is_paid")
  amount      Float          @default(5) @map("amount")
  invoices    CanvaInvoice[]

  @@index([userId])
  @@index([listingId])
  @@index([trialEndsAt])
  @@index([isPaid])
  @@map("canva_design_usages")
}

// Invoice for Canva usage (after trial / payment)
model CanvaInvoice {
  id            String           @id @default(cuid())
  userId        String           @map("user_id")
  usageId       String           @map("usage_id")
  usage         CanvaDesignUsage @relation(fields: [usageId], references: [id], onDelete: Cascade)
  amount        Float            @map("amount")
  createdAt     DateTime         @default(now()) @map("created_at")
  pdfUrl        String?          @map("pdf_url")
  invoiceNumber String?          @unique @map("invoice_number")

  @@index([userId])
  @@index([usageId])
  @@index([createdAt])
  @@map("canva_invoices")
}

// Storage plan upgrade invoice (Stripe payment → upgrade + invoice)
model UpgradeInvoice {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  amount          Float    @map("amount")
  plan            String   @map("plan") // basic | pro
  date            DateTime @default(now()) @map("date")
  createdAt       DateTime @default(now()) @map("created_at")
  stripePaymentId String?  @unique @map("stripe_payment_id") // idempotency: avoid duplicate on webhook retries

  @@index([userId])
  @@index([date])
  @@map("upgrade_invoices")
}

// Audit log for Stripe billing events (payment confirmed, upgrade applied)
model BillingAuditLog {
  id              String   @id @default(cuid())
  event           String   @map("event") // checkout.session.completed | payment.paid
  userId          String   @map("user_id")
  stripeSessionId String?  @map("stripe_session_id")
  feature         String?  @map("feature") // storage-upgrade
  plan            String?  @map("plan")
  amount          Float?   @map("amount")
  details         Json?    @map("details")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([event])
  @@index([createdAt])
  @@map("billing_audit_logs")
}

// User storage quota – free 500MB, upgrade to Basic 5GB / Pro 50GB
model UserStorage {
  id         String   @id @default(cuid())
  userId     String   @unique @map("user_id")
  usedBytes  Int      @default(0) @map("used_bytes")
  limitBytes Int      @map("limit_bytes")
  alertLevel String   @default("safe") @map("alert_level") // safe | warning | critical | full
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("user_storage")
}

// Saved design assets (from Canva/template flow) – count toward UserStorage
model DesignAsset {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  listingId String?  @map("listing_id")
  title     String   @map("title")
  imageUrl  String   @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([listingId])
  @@map("design_assets")
}

// Storage optimization – file-level metadata for analytics, retention, and compression
model StorageFileRecord {
  id                 String    @id @default(cuid())
  userId             String    @map("user_id")
  listingId          String?   @map("listing_id")
  entityType         String    @map("entity_type") // property_document | listing_photo | transaction_document | generated_document | evidence | temp | preview | export
  entityId           String?   @map("entity_id")
  fileUrl            String    @map("file_url")
  fileType           String    @map("file_type") // image | document | video | other
  mimeType           String?   @map("mime_type")
  originalSize       Int       @default(0) @map("original_size")
  compressedSize     Int?      @map("compressed_size")
  isTemporary        Boolean   @default(false) @map("is_temporary")
  deletedAt          DateTime? @map("deleted_at")
  restoredAt         DateTime? @map("restored_at")
  retentionPolicy    String    @default("standard") @map("retention_policy") // standard | legal | invoice | compliance | temp_30d | preview_7d | export_30d
  optimizationStatus String    @default("pending") @map("optimization_status") // pending | compressed | skipped | failed
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([listingId])
  @@index([entityType])
  @@index([deletedAt])
  @@index([retentionPolicy])
  @@index([createdAt])
  @@map("storage_file_records")
}

// Audit log for storage actions (compression, delete, restore, optimize)
model StorageAuditLog {
  id         String   @id @default(cuid())
  action     String   @map("action") // COMPRESS | DELETE | RESTORE | OPTIMIZE | RETENTION_CLEANUP
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  userId     String?  @map("user_id")
  details    Json?    @map("details") // { originalSize, compressedSize, savedBytes, reason, ... }
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([action])
  @@index([userId])
  @@index([createdAt])
  @@map("storage_audit_logs")
}

// =============================================================================
// PLATFORM DEFENSE LAYER
// =============================================================================

// ---------------------------------------------------------------------------
// 1. Legal Defense – policy acceptance, terms, acknowledgements
// ---------------------------------------------------------------------------
// Centralized legal document content (versioned). Types: terms, privacy, cookies, host_agreement, bnhub_long_term_rental_agreement, bnhub_broker_collaboration_agreement, guest_policy, broker_agreement, platform_usage
model LegalDocument {
  id        String   @id @default(cuid())
  type      String // terms | privacy | cookies | host_agreement | bnhub_long_term_rental_agreement | bnhub_broker_collaboration_agreement | guest_policy | broker_agreement | platform_usage | platform_acknowledgment
  version   String
  content   String   @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([type])
  @@index([type, isActive])
  @@map("legal_documents")
}

/// Corporate / entity legal records for LECIPM Legal Management (name + lifecycle status).
/// Types: shareholder_agreement | privacy_policy | terms. Status: draft | signed.
model CorporateLegalDocument {
  id        String   @id @default(uuid())
  name      String
  type      String
  status    String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([type])
  @@index([status])
  @@map("corporate_legal_documents")
}

model CompanyStructure {
  id           String   @id @default(uuid())
  entityType   String   @map("entity_type")
  jurisdiction String
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([jurisdiction])
  @@map("company_structures")
}

// User acceptance of legal documents – traceable, version-specific
model UserAgreement {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentType String   @map("document_type") // same as LegalDocument.type
  version      String
  acceptedAt   DateTime @default(now()) @map("accepted_at")

  @@index([userId])
  @@index([userId, documentType])
  @@index([documentType])
  @@map("user_agreements")
}

/// User-signed acknowledgments for hub legal gates (audit trail; versioned).
model LegalFormSignature {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// e.g. BUYER_ACKNOWLEDGMENT | MORTGAGE_DISCLOSURE | GUEST_ACKNOWLEDGMENT
  formKey     String   @map("form_key")
  /// e.g. buyer_hub | mortgage_hub | short_term_booking | seller_listing
  contextType String   @map("context_type")
  /// Entity id when scoped (listingId, offerId); "" when global for that context.
  contextId   String   @default("") @map("context_id")
  version     String
  signedAt    DateTime @default(now()) @map("signed_at")
  metadata    Json?

  @@unique([userId, formKey, contextType, contextId])
  @@index([userId, formKey])
  @@index([contextType, contextId])
  @@map("legal_form_signatures")
}

// Contract logic – all agreements stored in DB (host agreement, booking agreement)
model PlatformAgreement {
  id                String   @id @default(uuid())
  agreementType     String   @map("agreement_type") // host_agreement | booking_agreement
  version           String
  contentHtml       String   @map("content_html") @db.Text // Snapshot of agreed content
  relatedEntityType String   @map("related_entity_type") // bnhub_host | booking
  relatedEntityId   String   @map("related_entity_id")
  metadata          Json? // e.g. { guestId, hostId, listingId } for booking
  acceptedAt        DateTime @map("accepted_at")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([agreementType])
  @@index([relatedEntityType, relatedEntityId])
  @@index([acceptedAt])
  @@map("platform_agreements")
}

// Unified contract engine – booking_contract | listing_contract | lease | broker_agreement | investment_agreement
model Contract {
  id                        String                     @id @default(uuid())
  type                      String // booking_contract | listing_contract | lease | broker_agreement | investment_agreement
  userId                    String                     @map("user_id")
  user                      User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId                  String?                    @map("tenant_id")
  tenant                    Tenant?                    @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  createdById               String?                    @map("created_by_id")
  createdBy                 User?                      @relation("ContractCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  listingId                 String?                    @map("listing_id")
  fsboListingId             String?                    @map("fsbo_listing_id")
  fsboListing               FsboListing?               @relation(fields: [fsboListingId], references: [id], onDelete: Cascade)
  bookingId                 String?                    @map("booking_id")
  booking                   Booking?                   @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  /**
   * Optional deal link (e.g. brokerage sale workflow).
   */
  dealId                    String?                    @map("deal_id")
  deal                      Deal?                      @relation(fields: [dealId], references: [id], onDelete: SetNull)
  title                     String                     @default("")
  contentHtml               String?                    @map("content_html") @db.Text
  /// Plain-text snapshot (PDF / search); immutable after sign.
  contentText               String?                    @map("content_text") @db.Text
  content                   Json? // Structured snapshot (parties, amounts) + future DocuSign metadata
  status                    String                     @default("pending") // pending | signed | draft | sent | completed | cancelled
  /// Primary party acknowledged signature (see also ContractSignature for multi-party).
  signed                    Boolean                    @default(false) @map("is_signed")
  signedAt                  DateTime?                  @map("signed_at")
  signerIpAddress           String?                    @map("signer_ip_address")
  /**
   * Counsel / product version label for this template snapshot.
   */
  version                   String?
  hub                       String? // bnhub | realestate | luxury | broker | projects
  /**
   * Future: docusign | adobe | null
   */
  externalProvider          String?                    @map("external_provider")
  externalEnvelopeId        String?                    @map("external_envelope_id")
  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")
  signatures                ContractSignature[]
  offerDocument             OfferDocument?
  brokerTransactionRecords  BrokerTransactionRecord[]
  appointments              Appointment[]
  conversations             Conversation[]
  documentFolders           DocumentFolder[]
  documentFiles             DocumentFile[]
  dealFinancials            DealFinancial[]
  tenantInvoices            TenantInvoice[]
  legalAuditLogs            LegalContractAuditLog[]
  paymentLegalLinks         Payment[]                  @relation("PaymentLegalLink")
  platformPaymentLegalLinks PlatformPayment[]          @relation("PlatformPaymentLegalLink")
  bnhubInvoiceLegalLinks    BnhubBookingInvoice[]      @relation("BnhubInvoiceLegalLink")
  platformCommissionRecords PlatformCommissionRecord[]

  @@index([userId])
  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@index([hub])
  @@index([bookingId])
  @@index([dealId])
  @@index([fsboListingId])
  @@index([listingId])
  @@index([createdById])
  @@index([signed])
  @@map("contracts")
}

/// Immutable audit trail for enforceable contracts (append-only in application code).
model LegalContractAuditLog {
  id         String   @id @default(cuid())
  contractId String   @map("contract_id")
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String // created | signed | pdf_download
  ipAddress  String?  @map("ip_address")
  version    String?
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([contractId])
  @@index([userId])
  @@index([createdAt])
  @@map("legal_contract_audit_logs")
}

/// Commission ledger row — amounts require linked signed agreement when product rules say so.
model PlatformCommissionRecord {
  id                    String    @id @default(cuid())
  leadId                String?   @map("lead_id")
  lead                  Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  dealId                String?   @map("deal_id")
  deal                  Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  bookingId             String?   @map("booking_id")
  booking               Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  contractId            String?   @map("contract_id")
  contract              Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  commissionEligible    Boolean   @default(false) @map("commission_eligible")
  commissionSource      String?   @map("commission_source") // IMMO_CONTACT | PLATFORM_BROKER | DIRECT | BNHUB_BOOKING
  commissionAmountCents Int?      @map("commission_amount_cents")
