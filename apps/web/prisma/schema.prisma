/// Broker-side transaction outcome, revenue, and unsuccessful transaction (loss) tracking.
model BrokerTransactionRecord {
  id                      String          @id @default(cuid())
  brokerId                String          @map("broker_id")
  broker                  User            @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  leadId                  String?         @map("lead_id")
  lead                    Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contractId              String?         @map("contract_id")
  contract                Contract?       @relation(fields: [contractId], references: [id], onDelete: SetNull)
  offerDocumentId         String?         @map("offer_document_id")
  offerDocument           OfferDocument?  @relation(fields: [offerDocumentId], references: [id], onDelete: SetNull)
  transactionType         String          @map("transaction_type") // buy | sell | rent | mortgage | referral
  outcome                 String          @default("pending") // won | lost | pending
  grossRevenueCents       Int             @default(0) @map("gross_revenue_cents")
  brokerCommissionCents   Int             @default(0) @map("broker_commission_cents")
  platformCommissionCents Int             @default(0) @map("platform_commission_cents")
  expensesCents           Int             @default(0) @map("expenses_cents")
  netBrokerIncomeCents    Int             @default(0) @map("net_broker_income_cents")
  lossReason              String?         @map("loss_reason")
  notes                   String?         @db.Text
  closedAt                DateTime?       @map("closed_at")
  createdAt               DateTime        @default(now()) @map("created_at")
  updatedAt               DateTime        @updatedAt @map("updated_at")
  expenses                BrokerExpense[]

  @@index([brokerId])
  @@index([outcome])
  @@index([leadId])
  @@index([transactionType])
  @@map("broker_transaction_records")
}

model BrokerExpense {
  id                  String                   @id @default(cuid())
  brokerId            String                   @map("broker_id")
  broker              User                     @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  transactionRecordId String?                  @map("transaction_record_id")
  transactionRecord   BrokerTransactionRecord? @relation(fields: [transactionRecordId], references: [id], onDelete: SetNull)
  category            String // mileage | ads | staging | photography | travel | admin | other
  description         String?
  amountCents         Int                      @map("amount_cents")
  taxGstCents         Int                      @default(0) @map("tax_gst_cents")
  taxQstCents         Int                      @default(0) @map("tax_qst_cents")
  expenseDate         DateTime                 @map("expense_date")
  receiptUrl          String?                  @map("receipt_url")
  createdAt           DateTime                 @default(now()) @map("created_at")

  @@index([brokerId])
  @@index([transactionRecordId])
  @@map("broker_expenses")
}

/// Internal platform GST/QST summary snapshots (not a government filing).
model TaxReportSnapshot {
