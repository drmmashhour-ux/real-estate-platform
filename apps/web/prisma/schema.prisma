  status     NegotiationChainStatus  @default(active)
  createdAt  DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  versions   NegotiationVersion[]

  @@index([propertyId])
  @@index([caseId])
  @@index([status])
  @@map("negotiation_chains")
}

model NegotiationVersion {
  id                 String                   @id @default(cuid())
  chainId            String                   @map("chain_id")
  chain              NegotiationChain         @relation(fields: [chainId], references: [id], onDelete: Cascade)
  versionNumber      Int                      @map("version_number")
  parentVersionId    String?                  @map("parent_version_id")
  parentVersion      NegotiationVersion?      @relation("NegotiationVersionLineage", fields: [parentVersionId], references: [id], onDelete: SetNull)
  childVersions      NegotiationVersion[]     @relation("NegotiationVersionLineage")
  createdBy          String                   @map("created_by")
  creator            User                     @relation("NegotiationVersionCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  role               NegotiationVersionRole
  status             NegotiationVersionStatus @default(pending)
  isFinal            Boolean                  @default(false) @map("is_final")
  createdAt          DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  terms              NegotiationTerm?
  clauses            NegotiationClause[]
  documentSignatures DocumentSignature[]

  @@unique([chainId, versionNumber], map: "uq_negotiation_versions_chain_version")
  @@index([chainId])
  @@index([parentVersionId])
  @@index([status])
  @@map("negotiation_versions")
}

model NegotiationTerm {
  id              String             @id @default(cuid())
  versionId       String             @unique @map("version_id")
  version         NegotiationVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  priceCents      Int                @map("price_cents")
  depositCents    Int?               @map("deposit_cents")
  financingTerms  Json               @default("{}") @map("financing_terms") @db.JsonB
  commissionTerms Json               @default("{}") @map("commission_terms") @db.JsonB
  deadlines       Json               @default("{}") @db.JsonB

  @@map("negotiation_terms")
}

model NegotiationClause {
  id             String             @id @default(cuid())
  versionId      String             @map("version_id")
  version        NegotiationVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  clauseType     String             @map("clause_type")
  text           String             @db.Text
  addedInVersion Int                @map("added_in_version")
  removed        Boolean            @default(false)

  @@index([versionId])
  @@map("negotiation_clauses")
}

