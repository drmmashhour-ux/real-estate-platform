// ---------------------------------------------------------------------------
// Monetization – platform revenue events and payout adjustments
// ---------------------------------------------------------------------------
model PlatformRevenueEvent {
  id              String   @id @default(uuid())
  entityType      String   @map("entity_type") // booking | transaction | subscription | promotion | ai_feature
  entityId        String   @map("entity_id")
  revenueType     String   @map("revenue_type") // guest_service_fee | host_fee | transaction_fee | subscription | promotion | refund_reversal
  amountCents     Int      @map("amount_cents")
  currency        String   @default("USD")
  status          String   @default("realized") // pending | realized | refunded | reversed
  sourceReference String?  @map("source_reference") // payment_id | invoice_id | etc.
  marketId        String?  @map("market_id")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([revenueType])
  @@index([status])
  @@index([createdAt])
  @@index([marketId])
  @@map("platform_revenue_events")
}

/// User-centric monetization events (booking completed, lead purchased, premium upgrade) — complements `PlatformRevenueEvent`.
model RevenueEvent {
  id           String   @id @default(uuid())
  userId       String?  @map("user_id")
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  eventType    String   @map("event_type")
  amount       Float    @default(0)
  metadataJson Json?    @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@map("revenue_events")
}

/// Open / converted / lost revenue opportunities for prioritization and nudges.
model RevenueOpportunity {
  id              String   @id @default(uuid())
  userId          String?  @map("user_id")
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  leadId          String?  @map("lead_id")
  lead            Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  opportunityType String   @map("opportunity_type")
  status          String   @default("open")
  valueEstimate   Float    @default(0) @map("value_estimate")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([userId, status])
  @@index([leadId, status])
  @@index([status, createdAt])
  @@map("revenue_opportunities")
}

// ---------------------------------------------------------------------------
// LECIPM Monetization System v1 — catalog + Stripe-backed subscription rows + ledger + attribution
// (Complements `SubscriptionPlan` / workspace `Subscription` — see modules/stripe/*.)
// ---------------------------------------------------------------------------

/// Admin-managed pricing catalog for transparency UI and optional Stripe SKU mapping (v1).
model LecipmPricingPlanCatalog {
  id                String   @id @default(cuid())
  name              String
  /// bnhub_host | bnhub_guest | broker | mortgage_broker | seller | buyer
  type              String
  hostFeePercent    Float?   @map("host_fee_percent")
  guestFeePercent   Float?   @map("guest_fee_percent")
  /// Major currency units (e.g. CAD dollars) — display only unless paired with Stripe price id in metadata.
  leadFee           Float?   @map("lead_fee")
  successFeePercent Float?   @map("success_fee_percent")
  subscriptionPrice Float?   @map("subscription_price")
  features          Json     @default("{}")
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  subscriptions LecipmMonetizationSubscriptionRow[]

  @@index([type, active])
  @@map("lecipm_pricing_plan_catalog")
}

/// Stripe-linked subscription row for LECIPM monetization flows (distinct from workspace `subscriptions`).
model LecipmMonetizationSubscriptionRow {
  id                   String                   @id @default(cuid())
  userId               String                   @map("user_id")
  user                 User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId               String                   @map("plan_id")
  plan                 LecipmPricingPlanCatalog @relation(fields: [planId], references: [id], onDelete: Restrict)
  stripeCustomerId     String?                  @map("stripe_customer_id")
  stripeSubscriptionId String?                  @unique @map("stripe_subscription_id")
  status               String
  currentPeriodEnd     DateTime?                @map("current_period_end") @db.Timestamptz(6)
  createdAt            DateTime                 @default(now()) @map("created_at")
  updatedAt            DateTime                 @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@map("lecipm_monetization_subscriptions")
}

/// Payment-intent level log for monetization checkout (audit; not full double-entry ledger).
model LecipmMonetizationTransaction {
  id                    String   @id @default(cuid())
  userId                String?  @map("user_id")
  user                  User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  type                  String
  amount                Float
  currency              String   @default("CAD")
  status                String
  stripePaymentIntentId String?  @unique @map("stripe_payment_intent_id")
  metadata              Json?
  createdAt             DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([type, status])
  @@map("lecipm_monetization_transactions")
}

/// Aggregated revenue attribution for analytics / investor reporting (amounts in major currency units).
model LecipmRevenueAttributionEvent {
  id          String   @id @default(cuid())
  source      String
  amount      Float
  category    String
  referenceId String?  @map("reference_id")
  currency    String   @default("CAD")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([source, category])
  @@index([createdAt])
  @@map("lecipm_revenue_attribution_events")
}

/// Audit trail for Revenue Engine v4 — pricing/monetization suggestions (not a financial ledger).
model RevenueEngineV4AuditLog {
  id          String   @id @default(cuid())
  engine      String   @db.VarChar(32)
  action      String   @db.VarChar(96)
  entityType  String?  @map("entity_type") @db.VarChar(32)
  entityId    String?  @map("entity_id") @db.VarChar(64)
  inputJson   Json?    @map("input_json")
  outputJson  Json?    @map("output_json")
  confidence  Float?
  explanation String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([engine, createdAt])
  @@index([entityType, entityId])
  @@map("revenue_engine_v4_audit_logs")
}

// ---------------------------------------------------------------------------
// Autonomous Marketplace AI v5 — agent memory + explainable decision log (suggestions only).
// ---------------------------------------------------------------------------

model MarketplaceAgentV5Memory {
