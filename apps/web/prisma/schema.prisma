  ownerBroker   User                        @relation("BrokerTeamOwner", fields: [ownerBrokerId], references: [id], onDelete: Cascade)
  createdAt     DateTime                    @default(now()) @map("created_at")
  updatedAt     DateTime                    @updatedAt @map("updated_at")
  members       BrokerTeamMember[]
  threads       BrokerCollaborationThread[]
  auditEvents   BrokerWorkspaceAuditEvent[]

  @@index([ownerBrokerId])
  @@map("broker_teams")
}

model BrokerTeamMember {
  id       String                 @id @default(uuid())
  teamId   String                 @map("team_id")
  team     BrokerTeam             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId   String                 @map("user_id")
  user     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     BrokerTeamMemberRole
  status   BrokerTeamMemberStatus @default(invited)
  joinedAt DateTime?              @map("joined_at")

  @@unique([teamId, userId])
  @@index([userId])
  @@map("broker_team_members")
}

model BrokerCollaborationThread {
  id              String                             @id @default(uuid())
  teamId          String?                            @map("team_id")
  team            BrokerTeam?                        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  dealId          String?                            @map("deal_id")
  deal            Deal?                              @relation(fields: [dealId], references: [id], onDelete: SetNull)
  listingId       String?                            @map("listing_id")
  listing         Listing?                           @relation(fields: [listingId], references: [id], onDelete: SetNull)
  lecipmContactId String?                            @map("lecipm_contact_id")
  lecipmContact   LecipmCrmContact?                  @relation(fields: [lecipmContactId], references: [id], onDelete: SetNull)
  createdById     String                             @map("created_by_id")
  createdBy       User                               @relation("BrokerCollaborationThreadCreator", fields: [createdById], references: [id], onDelete: Cascade)
  visibilityScope BrokerCollaborationVisibilityScope @map("visibility_scope")
  title           String?                            @db.VarChar(200)
  createdAt       DateTime                           @default(now()) @map("created_at")
  updatedAt       DateTime                           @updatedAt @map("updated_at")
  messages        BrokerCollaborationMessage[]
  auditEvents     BrokerWorkspaceAuditEvent[]

  @@index([teamId])
  @@index([dealId])
  @@index([createdById])
  @@map("broker_collaboration_threads")
}

model BrokerCollaborationMessage {
  id          String                         @id @default(uuid())
  threadId    String                         @map("thread_id")
  thread      BrokerCollaborationThread      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId    String                         @map("author_id")
  author      User                           @relation("BrokerCollaborationMessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  body        String                         @db.Text
  messageType BrokerCollaborationMessageType @default(text) @map("message_type")
  metadata    Json                           @default("{}")
  createdAt   DateTime                       @default(now()) @map("created_at")

  @@index([threadId, createdAt])
  @@map("broker_collaboration_messages")
}

model BrokerDealAssignment {
  id               String                     @id @default(uuid())
  dealId           String                     @map("deal_id")
  deal             Deal                       @relation(fields: [dealId], references: [id], onDelete: Cascade)
  assignedToUserId String                     @map("assigned_to_user_id")
  assignedTo       User                       @relation("BrokerDealAssignmentAssignee", fields: [assignedToUserId], references: [id], onDelete: Cascade)
  assignedByUserId String                     @map("assigned_by_user_id")
  assignedBy       User                       @relation("BrokerDealAssignmentAssigner", fields: [assignedByUserId], references: [id], onDelete: Cascade)
  roleOnDeal       BrokerDealAssignmentRole   @map("role_on_deal")
  status           BrokerDealAssignmentStatus @default(active)
  createdAt        DateTime                   @default(now()) @map("created_at")
  updatedAt        DateTime                   @updatedAt @map("updated_at")

  @@index([dealId])
  @@index([assignedToUserId, status])
  @@index([assignedByUserId])
  @@map("broker_deal_assignments")
}

model BrokerInternalNote {
  id              String                             @id @default(uuid())
  dealId          String?                            @map("deal_id")
  deal            Deal?                              @relation(fields: [dealId], references: [id], onDelete: SetNull)
  listingId       String?                            @map("listing_id")
  listing         Listing?                           @relation(fields: [listingId], references: [id], onDelete: SetNull)
  lecipmContactId String?                            @map("lecipm_contact_id")
  lecipmContact   LecipmCrmContact?                  @relation(fields: [lecipmContactId], references: [id], onDelete: SetNull)
  createdById     String                             @map("created_by_id")
  createdBy       User                               @relation("BrokerInternalNoteAuthor", fields: [createdById], references: [id], onDelete: Cascade)
  visibilityScope BrokerCollaborationVisibilityScope @map("visibility_scope")
  noteType        BrokerInternalNoteType             @map("note_type")
  body            String                             @db.Text
  metadata        Json                               @default("{}")
  createdAt       DateTime                           @default(now()) @map("created_at")
  updatedAt       DateTime                           @updatedAt @map("updated_at")

  @@index([dealId])
  @@index([listingId])
  @@index([createdById])
  @@map("broker_internal_notes")
}

model BrokerWorkspaceAuditEvent {
  id          String                     @id @default(uuid())
  actorUserId String                     @map("actor_user_id")
  actor       User                       @relation("BrokerWorkspaceAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  teamId      String?                    @map("team_id")
  team        BrokerTeam?                @relation(fields: [teamId], references: [id], onDelete: SetNull)
  dealId      String?                    @map("deal_id")
  deal        Deal?                      @relation(fields: [dealId], references: [id], onDelete: SetNull)
  threadId    String?                    @map("thread_id")
  thread      BrokerCollaborationThread? @relation(fields: [threadId], references: [id], onDelete: SetNull)
  actionKey   String                     @map("action_key") @db.VarChar(96)
  payload     Json                       @default("{}")
  createdAt   DateTime                   @default(now()) @map("created_at")

  @@index([actorUserId, createdAt])
  @@index([actionKey])
  @@index([teamId])
  @@index([dealId])
  @@map("broker_workspace_audit_events")
}

// —— Admin compliance command center + brokerage QA review (internal signals; not legal conclusions) ——

enum ComplianceCaseType {
  missing_disclosure
  representation_risk
  document_inconsistency
  execution_readiness_risk
  communication_compliance_risk
  payment_workflow_risk
  closing_readiness_risk
  suspicious_activity_internal
}

enum ComplianceCaseSeverity {
  low
  medium
  high
  critical
}

enum ComplianceCaseStatus {
  open
  under_review
  action_required
  resolved
  dismissed
  escalated
  archived
}

enum QaReviewType {
  pre_execution_review
  document_quality_review
  communication_compliance_review
  closing_readiness_review
  spot_audit
  supervisor_review
}

enum QaReviewStatus {
  draft
  pending
  in_progress
  completed
  cancelled
}

enum QaReviewOutcome {
  approved
  approved_with_notes
  changes_required
  escalated
  rejected
}

enum QaChecklistItemStatus {
  pending
  passed
  failed
  skipped
}

enum ComplianceEscalationType {
  supervisory
  legal
  risk
  operations
}

enum ComplianceEscalationTargetRole {
  reviewer
  supervisor
  admin
  compliance_officer
}

enum ComplianceEscalationStatus {
  open
  acknowledged
  resolved
  cancelled
}

model ComplianceCase {
  id                 String                 @id @default(uuid())
  dealId             String?                @map("deal_id")
  deal               Deal?                  @relation(fields: [dealId], references: [id], onDelete: SetNull)
  documentId         String?                @map("document_id")
  dealDocument       DealDocument?          @relation(fields: [documentId], references: [id], onDelete: SetNull)
  listingId          String?                @map("listing_id")
  listing            Listing?               @relation(fields: [listingId], references: [id], onDelete: SetNull)
  lecipmContactId    String?                @map("lecipm_contact_id")
  lecipmContact      LecipmCrmContact?      @relation(fields: [lecipmContactId], references: [id], onDelete: SetNull)
  caseType           ComplianceCaseType     @map("case_type")
  severity           ComplianceCaseSeverity
  status             ComplianceCaseStatus   @default(open)
  summary            String                 @db.Text
  findings           Json                   @default("{}")
  openedBySystem     Boolean                @default(true) @map("opened_by_system")
  assignedReviewerId String?                @map("assigned_reviewer_id")
  assignedReviewer   User?                  @relation("ComplianceCaseReviewer", fields: [assignedReviewerId], references: [id], onDelete: SetNull)
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")
  complianceFindings ComplianceFinding[]
  escalations        ComplianceEscalation[]
  auditLogs          ComplianceAuditLog[]

  @@index([dealId])
  @@index([status])
  @@index([severity])
  @@index([caseType])
  @@index([assignedReviewerId])
  @@map("compliance_cases")
}

model ComplianceFinding {
  id                 String                 @id @default(uuid())
  caseId             String                 @map("case_id")
  complianceCase     ComplianceCase         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  findingType        String                 @map("finding_type") @db.VarChar(64)
  severity           ComplianceCaseSeverity
  title              String                 @db.VarChar(200)
  summary            String                 @db.Text
  affectedEntityType String?                @map("affected_entity_type") @db.VarChar(32)
  affectedEntityId   String?                @map("affected_entity_id")
  sourceRefs         Json                   @default("[]") @map("source_refs")
  metadata           Json                   @default("{}")
  createdAt          DateTime               @default(now()) @map("created_at")

  @@index([caseId])
  @@map("compliance_findings")
}

model QaReview {
  id                String                  @id @default(uuid())
  dealId            String?                 @map("deal_id")
  deal              Deal?                   @relation(fields: [dealId], references: [id], onDelete: SetNull)
  documentId        String?                 @map("document_id")
  dealDocument      DealDocument?           @relation(fields: [documentId], references: [id], onDelete: SetNull)
  reviewType        QaReviewType            @map("review_type")
  status            QaReviewStatus          @default(pending)
  assignedToUserId  String?                 @map("assigned_to_user_id")
  assignedTo        User?                   @relation("QaReviewAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  requestedByUserId String?                 @map("requested_by_user_id")
  requestedBy       User?                   @relation("QaReviewRequester", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  outcome           QaReviewOutcome?
  notes             Json                    @default("{}")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")
  checklistItems    QaReviewChecklistItem[]
  auditLogs         ComplianceAuditLog[]

  @@index([dealId])
  @@index([status])
  @@index([reviewType])
  @@map("qa_reviews")
}

model QaReviewChecklistItem {
  id           String                @id @default(uuid())
  reviewId     String                @map("review_id")
  review       QaReview              @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  itemKey      String                @map("item_key") @db.VarChar(96)
  itemLabel    String                @map("item_label") @db.VarChar(200)
  status       QaChecklistItemStatus @default(pending)
  reviewerNote String?               @map("reviewer_note") @db.Text
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  @@index([reviewId])
  @@map("qa_review_checklist_items")
}

model ComplianceEscalation {
  id             String                         @id @default(uuid())
  caseId         String                         @map("case_id")
  complianceCase ComplianceCase                 @relation(fields: [caseId], references: [id], onDelete: Cascade)
  escalationType ComplianceEscalationType       @map("escalation_type")
  targetRole     ComplianceEscalationTargetRole @map("target_role")
  status         ComplianceEscalationStatus     @default(open)
  createdAt      DateTime                       @default(now()) @map("created_at")
  updatedAt      DateTime                       @updatedAt @map("updated_at")

  @@index([caseId])
  @@index([status])
  @@map("compliance_escalations")
}

model ComplianceAuditLog {
  id             String          @id @default(uuid())
  actorUserId    String          @map("actor_user_id")
  actor          User            @relation("ComplianceAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  actionKey      String          @map("action_key") @db.VarChar(96)
  caseId         String?         @map("case_id")
  complianceCase ComplianceCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)
  reviewId       String?         @map("review_id")
  qaReview       QaReview?       @relation(fields: [reviewId], references: [id], onDelete: SetNull)
  payload        Json            @default("{}")
  createdAt      DateTime        @default(now()) @map("created_at")

  @@index([actorUserId, createdAt])
  @@index([actionKey])
  @@map("compliance_audit_logs")
}

// —— LECIPM complaints, public protection & syndic-oriented routing (audit + human accountability) ——

/// Consumer / broker complaint & public assistance case file (distinct from `ComplianceCase` deal QA).
model ComplaintCase {
  id         String @id @default(cuid())
  caseNumber String @unique @map("case_number")

  ownerType String @map("owner_type") // agency | solo_broker | platform
  ownerId   String @map("owner_id")

  complainantUserId             String?   @map("complainant_user_id")
  complainantName               String?   @map("complainant_name")
  complainantEmail              String?   @map("complainant_email")
  complainantPhone              String?   @map("complainant_phone")
  complainantRelation           String?   @map("complainant_relation")
  consentToBeContacted          Boolean   @default(false) @map("consent_to_be_contacted")
  preferredResolution           String?   @map("preferred_resolution") @db.Text
  resolutionNote                String?   @map("resolution_note") @db.Text
  consumerProtectionExplainedAt DateTime? @map("consumer_protection_explained_at")
  evidenceDocumentIds           Json?     @map("evidence_document_ids") @db.JsonB

  assignedOwnerUserId String? @map("assigned_owner_user_id")
  assignedOwner       User?   @relation("ComplaintCaseAssignedOwner", fields: [assignedOwnerUserId], references: [id], onDelete: SetNull)

  targetType String? @map("target_type")
  targetId   String? @map("target_id")

  linkedBrokerId         String? @map("linked_broker_id")
  linkedEmployeeUserId   String? @map("linked_employee_user_id")
  linkedAgencyId         String? @map("linked_agency_id")
  linkedListingId        String? @map("linked_listing_id")
  linkedDealId           String? @map("linked_deal_id")
  linkedOfferId          String? @map("linked_offer_id")
  linkedContractId       String? @map("linked_contract_id")
  linkedComplianceCaseId String? @map("linked_compliance_case_id")

  complaintChannel String @map("complaint_channel")
  complaintType    String @map("complaint_type")
  severity         String

  summary        String  @db.Text
  description    String  @db.Text
  intakeLanguage String? @map("intake_language")

  status          String
  routingDecision String? @map("routing_decision")

  aiSummary String? @map("ai_summary") @db.Text
  aiFlags   Json?   @map("ai_flags") @db.JsonB

  firstReceivedAt DateTime  @default(now()) @map("first_received_at")
  acknowledgedAt  DateTime? @map("acknowledged_at")
  closedAt        DateTime? @map("closed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  events                   ComplaintEvent[]
  attachments              ComplaintAttachment[]
  publicProtectionReferral PublicProtectionReferral?
  classificationReviews    ComplaintClassificationReview[]
  correctiveActionPlans    ComplaintCorrectiveActionPlan[]
  escalationSuggestions    ComplaintEscalationSuggestion[]

  @@index([ownerType, ownerId], map: "idx_complaint_case_owner")
  @@index([status], map: "idx_complaint_case_status")
  @@index([complaintType], map: "idx_complaint_case_type")
  @@index([linkedBrokerId], map: "idx_complaint_case_linked_broker")
  @@index([assignedOwnerUserId], map: "idx_complaint_case_assigned_owner")
  @@map("complaint_cases")
}

model ComplaintEvent {
  id                   String   @id @default(cuid())
  complaintCaseId      String   @map("complaint_case_id")
  eventType            String   @map("event_type")
  performedById        String?  @map("performed_by_id")
  aiAssisted           Boolean  @default(false) @map("ai_assisted")
  visibleToComplainant Boolean  @default(false) @map("visible_to_complainant")
  details              Json?    @db.JsonB
  createdAt            DateTime @default(now()) @map("created_at")

  complaintCase ComplaintCase @relation(fields: [complaintCaseId], references: [id], onDelete: Cascade)

  @@index([complaintCaseId], map: "idx_complaint_events_case")
  @@index([eventType], map: "idx_complaint_events_type")
  @@map("complaint_events")
}

model ComplaintAttachment {
  id              String   @id @default(cuid())
  complaintCaseId String   @map("complaint_case_id")
  fileName        String   @map("file_name")
  fileUrl         String   @map("file_url") @db.Text
  fileType        String?  @map("file_type")
  uploadedById    String?  @map("uploaded_by_id")
  confidential    Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")

  complaintCase ComplaintCase @relation(fields: [complaintCaseId], references: [id], onDelete: Cascade)

  @@index([complaintCaseId], map: "idx_complaint_attachments_case")
  @@map("complaint_attachments")
}

model PublicProtectionReferral {
  id              String   @id @default(cuid())
  complaintCaseId String   @unique @map("complaint_case_id")
  referralType    String   @map("referral_type")
  referralStatus  String   @map("referral_status")
  referralReason  String   @map("referral_reason") @db.Text
  referredById    String?  @map("referred_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  complaintCase ComplaintCase @relation(fields: [complaintCaseId], references: [id], onDelete: Cascade)

  @@index([referralType], map: "idx_public_protection_referral_type")
  @@map("public_protection_referrals")
}

model ComplaintPolicyRule {
  id               String   @id @default(cuid())
  ownerType        String   @map("owner_type")
  ownerId          String   @map("owner_id")
  complaintType    String   @map("complaint_type")
  defaultSeverity  String   @map("default_severity")
  suggestedRouting String   @map("suggested_routing")
  autoFlagSyndic   Boolean  @default(false) @map("auto_flag_syndic")
  active           Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([ownerType, ownerId], map: "idx_complaint_policy_owner")
  @@map("complaint_policy_rules")
}

/// Record that a written complaint-handling policy exists for an agency or solo broker (governance control).
model ComplaintWrittenPolicyRecord {
  id            String   @id @default(cuid())
  ownerType     String   @map("owner_type")
  ownerId       String   @map("owner_id")
  documentUrl   String?  @map("document_url") @db.Text
  policySummary String   @map("policy_summary") @db.Text
  versionLabel  String?  @map("version_label") @db.VarChar(64)
  effectiveAt   DateTime @map("effective_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([ownerType, ownerId], map: "uq_complaint_written_policy_owner")
  @@map("complaint_written_policy_records")
}

model ComplaintClassificationReview {
  id                                    String        @id @default(cuid())
  complaintCaseId                       String        @map("complaint_case_id")
  complaintCase                         ComplaintCase @relation(fields: [complaintCaseId], references: [id], onDelete: Cascade)
  initialClassification                 String        @map("initial_classification")
  severity                              String
  plausibleComplianceCategories         Json          @default("[]") @map("plausible_compliance_categories")
  requiresManualReview                  Boolean       @default(false) @map("requires_manual_review")
  requiresConsumerProtectionExplanation Boolean       @default(false) @map("requires_consumer_protection_explanation")
  suggestPublicAssistanceReferral       Boolean       @default(false) @map("suggest_public_assistance_referral")
  suggestSyndicReferral                 Boolean       @default(false) @map("suggest_syndic_referral")
  reviewerId                            String        @map("reviewer_id")
  reviewer                              User          @relation("ComplaintClassificationReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  createdAt                             DateTime      @default(now()) @map("created_at")

  @@index([complaintCaseId], map: "idx_complaint_classification_case")
  @@map("complaint_classification_reviews")
}

model ComplaintCorrectiveActionPlan {
  id                String        @id @default(cuid())
  complaintCaseId   String        @map("complaint_case_id")
  complaintCase     ComplaintCase @relation(fields: [complaintCaseId], references: [id], onDelete: Cascade)
  rootCauseSummary  String        @map("root_cause_summary") @db.Text
  correctiveActions Json          @default("[]") @map("corrective_actions")
  preventiveActions Json          @default("[]") @map("preventive_actions")
  ownerUserId       String        @map("owner_user_id")
  owner             User          @relation("ComplaintCapaOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  dueDate           DateTime?     @map("due_date") @db.Date
  completed         Boolean       @default(false)
  completedAt       DateTime?     @map("completed_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@index([complaintCaseId], map: "idx_complaint_capa_case")
  @@map("complaint_corrective_action_plans")
}

/// Structured escalation destination (Info OACIQ, syndic, etc.) — logged only; never auto-submitted.
model ComplaintEscalationSuggestion {
  id              String        @id @default(cuid())
  complaintCaseId String        @map("complaint_case_id")
  complaintCase   ComplaintCase @relation(fields: [complaintCaseId], references: [id], onDelete: Cascade)
  destination     String        @map("destination")
  reason          String        @db.Text
  recommended     Boolean       @default(true)
  completed       Boolean       @default(false)
  completedAt     DateTime?     @map("completed_at")
  createdByUserId String?       @map("created_by_user_id")
  createdBy       User?         @relation("ComplaintEscalationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now()) @map("created_at")

  @@index([complaintCaseId], map: "idx_complaint_escalation_case")
  @@index([destination], map: "idx_complaint_escalation_destination")
  @@map("complaint_escalation_suggestions")
}

/// Public assistance / consumer guidance intake (pre-complaint; converts to `ComplaintCase` when escalated).
model AssistanceRequest {
  id            String @id @default(cuid())
  requestNumber String @unique @map("request_number")

  userId String? @map("user_id")
  name   String?
  email  String?
  phone  String?

  requestType String @map("request_type") // info | guidance | issue | pre-complaint
  topic       String // listing | offer | deposit | contract | commission | general

  relatedListingId String? @map("related_listing_id")
  relatedDealId    String? @map("related_deal_id")
  relatedBrokerId  String? @map("related_broker_id")

  message  String @db.Text
  language String // en | fr | ar

  aiSuggestedPath String? @map("ai_suggested_path") // self_resolve | contact_broker | file_complaint
  status          String // new | responded | converted_to_complaint | closed

  threadLocked          Boolean @default(false) @map("thread_locked")
  linkedComplaintCaseId String? @map("linked_complaint_case_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  messages AssistanceMessage[]

  @@index([userId], map: "idx_assistance_request_user")
  @@index([status], map: "idx_assistance_request_status")
  @@index([email], map: "idx_assistance_request_email")
  @@map("assistance_requests")
}

model AssistanceMessage {
  id                  String  @id @default(cuid())
  assistanceRequestId String  @map("assistance_request_id")
  senderType          String  @map("sender_type") // user | broker | admin | ai
  senderId            String? @map("sender_id")

  message    String  @db.Text
  isOfficial Boolean @default(false) @map("is_official")

  createdAt DateTime @default(now()) @map("created_at")

  assistanceRequest AssistanceRequest @relation(fields: [assistanceRequestId], references: [id], onDelete: Cascade)

  @@index([assistanceRequestId], map: "idx_assistance_messages_request")
  @@map("assistance_messages")
}

model AcknowledgmentTemplate {
  id          String   @id @default(cuid())
  templateKey String   @map("template_key")
  language    String
  subject     String
  body        String   @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([templateKey, language], map: "uq_ack_template_key_lang")
  @@index([templateKey], map: "idx_ack_template_key")
