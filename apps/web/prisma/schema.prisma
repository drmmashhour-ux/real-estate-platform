  clicks      Int      @default(0)
  conversions Int      @default(0)
  channel     String   @default("mixed")
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([date])
  @@map("bnhub_ads_daily_rollups")
}

/// Host outbound sales pipeline (not the same as approved BnhubHost).
model BnhubHostPipelineEntry {
  id                 String    @id @default(cuid())
  name               String
  email              String?
  phone              String?
  status             String    @default("not_contacted")
  contactedAt        DateTime? @map("contacted_at")
  responseStatus     String?   @map("response_status")
  listingCreated     Boolean   @default(false) @map("listing_created")
  shortTermListingId String?   @map("short_term_listing_id")
  notes              String?   @db.Text
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@map("bnhub_host_pipeline_entries")
}

/// Canadian investor CRM for BNHub / platform fundraise outreach.
model BnhubInvestorContact {
  id              String    @id @default(cuid())
  name            String
  organization    String
  email           String    @unique
  status          String    @default("not_contacted")
  notes           String?   @db.Text
  lastContactDate DateTime? @map("last_contact_date") @db.Date
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([organization])
  @@map("bnhub_investor_contacts")
}

/// BNHub promotion products — weekly/monthly; featured listing, homepage/category slots, local business ads.
model BnhubPromotionPlan {
  id            String                @id @default(cuid())
  sku           String                @unique
  name          String
  placement     String
  billingPeriod String                @map("billing_period")
  priceCents    Int                   @map("price_cents")
  currency      String                @default("cad")
  active        Boolean               @default(true)
  description   String?               @db.Text
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  orders        BnhubPromotionOrder[]

  @@index([placement])
  @@index([active])
  @@map("bnhub_promotion_plans")
}

/// Purchased promotion window (manual “paid” or Stripe later via platformPaymentId string).
model BnhubPromotionOrder {
  id                 String             @id @default(cuid())
  planId             String             @map("plan_id")
  plan               BnhubPromotionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)
  payerUserId        String             @map("payer_user_id")
  payer              User               @relation("BnhubPromotionPayer", fields: [payerUserId], references: [id], onDelete: Cascade)
  shortTermListingId String?            @map("short_term_listing_id")
  listing            ShortTermListing?  @relation(fields: [shortTermListingId], references: [id], onDelete: SetNull)
  status             String             @default("pending")
  startAt            DateTime           @map("start_at")
  endAt              DateTime           @map("end_at")
  amountCents        Int                @map("amount_cents")
  platformPaymentId  String?            @map("platform_payment_id")
  metadata           Json?
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  @@index([planId])
  @@index([payerUserId])
  @@index([status])
  @@index([endAt])
  @@map("bnhub_promotion_orders")
}

/// Manual concierge sales — guest outreach → booking conversion.
model BnhubSalesAssistEntry {
  id                 String    @id @default(cuid())
  guestUserId        String?   @map("guest_user_id")
  guest              User?     @relation("BnhubSalesGuest", fields: [guestUserId], references: [id], onDelete: SetNull)
  guestEmail         String?   @map("guest_email")
  assignedToUserId   String?   @map("assigned_to_user_id")
  assignedTo         User?     @relation("BnhubSalesAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  stage              String    @default("new")
  notes              String?   @db.Text
  nextFollowUpAt     DateTime? @map("next_follow_up_at")
  convertedBookingId String?   @unique @map("converted_booking_id")
  convertedBooking   Booking?  @relation("BnhubSalesAssistBooking", fields: [convertedBookingId], references: [id], onDelete: SetNull)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([stage])
  @@index([nextFollowUpAt])
  @@map("bnhub_sales_assist_entries")
}

/// Audit + dedupe for BNHub growth automations (signup nudges, upsells, reminders).
model BnhubAutomationEvent {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  trigger   String
  bookingId String?  @map("booking_id")
  dedupeKey String?  @unique @map("dedupe_key")
  meta      Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([trigger])
  @@index([createdAt])
  @@map("bnhub_automation_events")
}

// Host must accept before creating listings. Stored and traceable.
model HostAgreement {
  id         String    @id @default(cuid())
  hostId     String    @map("host_id")
  host       BnhubHost @relation(fields: [hostId], references: [id], onDelete: Cascade)
  accepted   Boolean   @default(false)
  acceptedAt DateTime? @map("accepted_at")
  version    String // e.g. "2024-01"
  createdAt  DateTime  @default(now()) @map("created_at")

  @@unique([hostId])
  @@index([hostId])
  @@map("bnhub_host_agreements")
}

model BnhubHostListing {
  id          String    @id @default(cuid())
  hostId      String    @map("host_id")
  host        BnhubHost @relation(fields: [hostId], references: [id], onDelete: Cascade)
  title       String
  description String?
  location    String
  price       Float
  maxGuests   Int       @default(4) @map("max_guests")
  images      Json      @default("[]") // array of image URLs
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([hostId])
  @@map("bnhub_host_listings")
}

// ---------------------------------------------------------------------------
// Hotel Hub (Booking.com style)
// ---------------------------------------------------------------------------
model Hotel {
  id          String   @id @default(cuid())
  name        String
  location    String
  description String?
  images      Json     @default("[]") // array of image URLs
  createdAt   DateTime @default(now()) @map("created_at")
  rooms       Room[]

  @@index([location])
  @@map("hotel_hub_hotels")
}

model Room {
  id       String         @id @default(cuid())
  hotelId  String         @map("hotel_id")
  hotel    Hotel          @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  title    String
  price    Float
  capacity Int            @default(2)
  bookings HotelBooking[]

  @@index([hotelId])
  @@map("hotel_hub_rooms")
}

model HotelBooking {
  id         String   @id @default(cuid())
  roomId     String   @map("room_id")
  room       Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  guestName  String   @map("guest_name")
  checkIn    DateTime @map("check_in")
  checkOut   DateTime @map("check_out")
  totalPrice Float    @map("total_price")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([roomId])
  @@index([checkIn])
  @@map("hotel_hub_bookings")
}

// ---------------------------------------------------------------------------
// Travel Package System
// ---------------------------------------------------------------------------
model Package {
  id        String           @id @default(cuid())
  title     String
  location  String
  price     Float
  includes  String[]         @default([])
  duration  String? // e.g. "5 days" – shown on /packages
  createdAt DateTime         @default(now()) @map("created_at")
  bookings  PackageBooking[]

  @@index([location])
  @@map("travel_packages")
}

model PackageBooking {
  id             String   @id @default(cuid())
  packageId      String   @map("package_id")
  package        Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  guestName      String?  @map("guest_name")
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  numberOfPeople Int      @map("number_of_people")
  totalPrice     Float    @map("total_price")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([packageId])
  @@index([startDate])
  @@map("travel_package_bookings")
}

// ---------------------------------------------------------------------------
// Shared Booking System (join-a-stay spots)
// ---------------------------------------------------------------------------
model SharedBooking {
  id           String @id @default(cuid())
  listingId    String @map("listing_id")
  totalSpots   Int    @map("total_spots")
  bookedSpots  Int    @default(0) @map("booked_spots")
  pricePerSpot Float  @map("price_per_spot")

  @@index([listingId])
  @@map("shared_bookings")
}

// ---------------------------------------------------------------------------
// BNHub: Short-term rental listings
// ---------------------------------------------------------------------------
model ShortTermListing {
  id                                 String                            @id @default(uuid())
  /**
   * Human-readable immutable public id: LST-XXXXXX (new) or legacy LEC-#####.
   */
  listingCode                        String                            @unique @map("listing_code")
  title                              String
  subtitle                           String?
  description                        String?
  propertyType                       String? // e.g. House, Apartment, Villa
  roomType                           String? // e.g. Entire place, Private room
  category                           String? // e.g. Vacation rental
  address                            String
  city                               String
  region                             String? // State / region
  country                            String                            @default("US")
  latitude                           Float?
  longitude                          Float?
  nightPriceCents                    Int // Base nightly price in cents
  currency                           String                            @default("USD")
  maxGuests                          Int                               @default(4)
  bedrooms                           Int? // Optional alias for beds
  beds                               Int
  baths                              Float
  photos                             Json                              @default("[]") // Legacy URLs; prefer BnhubListingPhoto for order/cover
  amenities                          Json                              @default("[]")
  houseRules                         String?
  /// Optional structured rules checklist (e.g. JSON array of { key, label, allowed }); complements `houseRules` text.
  listingRulesStructured             Json?                             @map("listing_rules_structured")
  checkInInstructions                String?
  checkInTime                        String? // e.g. "15:00"
  checkOutTime                       String? // e.g. "11:00"
  cancellationPolicy                 String? // flexible | moderate | strict
  cleaningFeeCents                   Int                               @default(0)
  securityDepositCents               Int                               @default(0)
  instantBookEnabled                 Boolean                           @default(false)
  /// When true, guests must have approved government ID (`IdentityVerification`) before booking.
  requireGuestIdentityVerification   Boolean                           @default(false) @map("require_guest_identity_verification")
  /// Denormalized guest-review average (1–5) for cards / mobile.
  bnhubListingRatingAverage          Float?                            @map("bnhub_listing_rating_average")
  bnhubListingReviewCount            Int                               @default(0) @map("bnhub_listing_review_count")
  /// Completed paid stays for this listing.
  bnhubListingCompletedStays         Int                               @default(0) @map("bnhub_listing_completed_stays")
  /// Platform-verified host/listing (cadastre + identity path complete).
  bnhubListingHostVerified           Boolean                           @default(false) @map("bnhub_listing_host_verified")
  /// Heuristic “top host” badge for discovery UI.
  bnhubListingTopHostBadge           Boolean                           @default(false) @map("bnhub_listing_top_host_badge")
  /// Optional cached 0–100 AI discovery score; search API computes live scores for map/cards regardless.
  aiDiscoveryScore                   Int?                              @map("ai_discovery_score")
  minStayNights                      Int? // null = no minimum
  maxStayNights                      Int?
  listingStatus                      ListingStatus                     @default(DRAFT)
  verificationStatus                 VerificationStatus                @default(PENDING)
  listingAuthorityType               ListingAuthorityType? // Required when submitting for verification
  listingVerificationStatus          ListingVerificationStatus         @default(DRAFT)
  rejectionReason                    String?
  cadastreNumber                     String?
  municipality                       String? // Required with cadastre for Québec
  province                           String? // e.g. QC
  verificationDocUrl                 String? // Legacy; prefer property_documents
  verifiedAt                         DateTime?
  submittedForVerificationAt         DateTime?
  // Broker-only fields (when listingAuthorityType = BROKER)
  brokerLicenseNumber                String?
  brokerageName                      String?
  safetyFeatures                     Json                              @default("[]") // e.g. Smoke detector, First aid
  accessibilityFeatures              Json                              @default("[]") // e.g. Step-free access
  parkingDetails                     String?
  neighborhoodDetails                String?
  /// quiet | moderate | lively — environment signal for guests
  noiseLevel                         String?                           @map("noise_level")
  familyFriendly                     Boolean                           @default(false) @map("family_friendly")
  kidsAllowed                        Boolean                           @default(true) @map("kids_allowed")
  partyAllowed                       Boolean                           @default(false) @map("party_allowed")
  smokingAllowed                     Boolean                           @default(false) @map("smoking_allowed")
  petsAllowed                        Boolean                           @default(false) @map("pets_allowed")
  /// JSON string[] e.g. ["dog","cat","other"]
  allowedPetTypes                    Json                              @default("[]") @map("allowed_pet_types")
  maxPetWeightKg                     Float?                            @map("max_pet_weight_kg")
  petRules                           String?                           @map("pet_rules") @db.Text
  /// Added to BNHub search review signal for monthly top-host winners (0–0.12). Reset by admin monthly job.
  reputationRankBoost                Float                             @default(0) @map("reputation_rank_boost")
  /// JSON string[] e.g. ["waterfront","downtown","near_attractions"]
  experienceTags                     Json                              @default("[]") @map("experience_tags")
  /// JSON string[] e.g. ["airport_pickup","parking","shuttle"]
  servicesOffered                    Json                              @default("[]") @map("services_offered")
  conditionOfProperty                String?                           @map("condition_of_property") // Mandatory disclosure: overall condition
  knownIssues                        String?                           @map("known_issues") @db.Text // Mandatory disclosure: known issues (e.g. "None" or description)
  /// Host attestation timestamp: legal right to offer the stay (audit via ListingVerificationLog).
  legalRentRightAttestedAt           DateTime?                         @map("legal_rent_right_attested_at")
  /// Version of attestation copy the host agreed to; bump to require re-attestation.
  legalRentRightAttestationVersion   String?                           @map("legal_rent_right_attestation_version")
  createdAt                          DateTime                          @default(now()) @map("created_at")
  updatedAt                          DateTime                          @updatedAt @map("updated_at")
  ownerId                            String                            @map("host_id")
  owner                              User                              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  availability                       AvailabilitySlot[]
  listingPhotos                      BnhubListingPhoto[]
  bookings                           Booking[]
  reviews                            Review[]
  hostReviewsOfGuest                 BnhubHostReviewOfGuest[]
  verificationLogs                   ListingVerificationLog[]
  disputes                           Dispute[]
  propertyDocuments                  PropertyDocument[]
  propertyVerification               PropertyVerification?
  propertyLocationValidation         PropertyLocationValidation?
  verificationMatch                  VerificationMatch?
  verificationFraudAlerts            VerificationFraudAlert[]
  propertyFraudScores                PropertyFraudScore[]
  propertyFraudAlerts                PropertyFraudAlert[]
  fraudCheckRuns                     BnhubFraudCheck[]
  propertyIdentityId                 String?                           @map("property_identity_id")
  propertyIdentity                   PropertyIdentity?                 @relation(fields: [propertyIdentityId], references: [id], onDelete: SetNull)
  investigations                     ListingInvestigation[]
  listingSafetyProfile               ListingSafetyProfile?
  trustSafetyIncidents               TrustSafetyIncident[]
  listingDesignReferences            ListingDesignReference[]
  offerDocuments                     OfferDocument[]
  sellerDisclosure                   SellerDisclosure?
  propertyDisclosure                 PropertyDisclosure?
  listingTemplateAnswers             ListingTemplateAnswers?
  complianceReview                   ListingComplianceReview?
  /// Channel manager / OTA integration — push availability, receive webhooks
  externalSyncEnabled                Boolean                           @default(false) @map("external_sync_enabled")
  /// Secret token for `GET /api/bnhub/ical/export/:listingId?token=` (host rotates from channel manager).
  channelIcalExportToken             String?                           @unique @map("channel_ical_export_token")
  externalMappings                   BnhubExternalListingMapping[]
  bnhubChannelListingMappings        BnhubChannelListingMapping[]
  bnhubOtaAiTraces                   BnhubOtaAiTrace[]
  bnhubChannelCalendarEvents         BnhubChannelCalendarEvent[]
  bnhubOtaSyncLogs                   BnhubOtaSyncLog[]
  bnhubPaymentQuotes                 BnhubPaymentQuote[]
  bnhubReservationPayments           BnhubReservationPayment[]
  bnhubHostPayoutRecordsListing      BnhubHostPayoutRecord[]
  dealAnalyses                       DealAnalysis[]
  bnhubPromotionOrders               BnhubPromotionOrder[]
  bnhubMarketingCampaigns            BnhubMarketingCampaign[]
  bnhubListingMarketingProfile       BnhubListingMarketingProfile?
  bnhubMarketingAssets               BnhubMarketingAsset[]
  bnhubMarketingRecommendations      BnhubMarketingRecommendation[]
  bnhubEmailCampaignQueueItems       BnhubEmailCampaignQueue[]
  bnhubGrowthCampaigns               BnhubGrowthCampaign[]
  bnhubGrowthAssets                  BnhubGrowthAsset[]
  bnhubLeads                         BnhubLead[]
  crmPlatformLeads                   Lead[]                            @relation("CrmLeadBnhubStay")
  internalCrmTelemetryEvents         InternalCrmEvent[]                @relation("CrmEventBnhubListing")
  bnhubGrowthEngineRecommendations   BnhubGrowthEngineRecommendation[]
  bnhubPropertyClassification        BnhubPropertyClassification?
  bnhubLuxuryTier                    BnhubLuxuryTier?
  bnhubTrustProfile                  BnhubTrustProfile?
  bnhubFraudFlags                    BnhubFraudFlag[]
  bnhubAddressVerification           BnhubAddressVerification?
  bnhubMediaTrustValidation          BnhubMediaTrustValidation?
  bnhubListingTrustRiskProfileEngine BnhubListingTrustRiskProfile?     @relation("BnhubListingTrustRiskEngine")
  bnhubTrustRiskFlagsEngine          BnhubTrustRiskFlag[]              @relation("BnhubTrustRiskFlagListing")
  bnhubLocationPolicyProfile         BnhubLocationPolicyProfile?
  bnhubDynamicPricingProfile         BnhubDynamicPricingProfile?
  bnhubPricingHistory                BnhubPricingHistory[]
  bnhubListingSafetyProfile          BnhubListingSafetyProfile?
  bnhubSafetyFlags                   BnhubSafetyFlag[]
  bnhubGuestFavorites                BnhubGuestFavorite[]
  listingSearchMetrics               ListingSearchMetrics?
  searchEvents                       SearchEvent[]
  userBehaviorEvents                 UserBehaviorEvent[]
  listingLearningStats               ListingLearningStats?
  listingIntelligenceSnapshots       ListingIntelligenceSnapshot[]
  propertyRatingAggregate            PropertyRatingAggregate?
  bnhubListingServices               BnhubListingService[]
  bnhubBookingServiceLines           BnhubBookingService[]
  bnhubServiceRequests               BnhubServiceRequest[]
  bnhubBookingBundles                BnhubBookingBundle[]
  bnhubConciergeSessions             BnhubConciergeSession[]
  bnhubHostListingPromotions         BnhubHostListingPromotion[]
  listingPricingSnapshots            ListingPricingSnapshot[]
  bnhubAiSuggestions                 AiSuggestion[]                    @relation("AiSuggestionListing")
  bnhubAiAutopilotActions            AiAutopilotAction[]               @relation("AiAutopilotActionListing")
  /// Optional 1:1 — stay created from safe intake (`ListingAcquisitionLead`).
  sourcedFromAcquisitionLead         ListingAcquisitionLead?           @relation("StayFromAcquisition")
  permissionConfirmedAt              DateTime?                         @map("permission_confirmed_at")
  permissionSourceNote             String?                           @map("permission_source_note") @db.Text
  imagesApproved                   Boolean                           @default(false) @map("images_approved")
  imageSourceNote                  String?                           @map("image_source_note") @db.Text
  missingApprovedImages            Boolean                           @default(false) @map("missing_approved_images")
  bnhubAutomatedHostMessages       BnhubAutomatedHostMessageLog[]
  aiConversionSignals              AiConversionSignal[]

  @@index([city, verificationStatus])
  @@index([city, listingStatus])
  @@index([nightPriceCents])
  @@index([createdAt])
  @@index([propertyIdentityId])
  @@index([ownerId])
  @@index([verificationStatus])
  @@index([listingStatus])
  @@index([listingVerificationStatus])
  @@index([cadastreNumber])
  @@map("bnhub_listings")
}

enum SearchEventType {
  VIEW
  CLICK
  SAVE
  BOOK
  SEARCH
}

/// Denormalized BNHub listing signals for AI search ranking (refreshed by events + optional cron).
model ListingSearchMetrics {
  id               String   @id @default(cuid())
  listingId        String   @unique @map("listing_id")
  views7d          Int      @default(0) @map("views_7d")
  views30d         Int      @default(0) @map("views_30d")
  bookings7d       Int      @default(0) @map("bookings_7d")
  bookings30d      Int      @default(0) @map("bookings_30d")
  ctr              Float?
  conversionRate   Float?   @map("conversion_rate")
  avgStayLength    Float?   @map("avg_stay_length")
  updatedAt        DateTime @updatedAt @map("updated_at")

  listing ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("listing_search_metrics")
}

/// Learned guest preferences for personalized BNHub search & recommendations.
model UserSearchProfile {
  id                 String    @id @default(cuid())
  userId             String    @unique @map("user_id")
  preferredCities    String[]  @default([]) @map("preferred_cities")
  preferredTypes     String[]  @default([]) @map("preferred_types")
  preferredPriceMin  Float?    @map("preferred_price_min")
  preferredPriceMax  Float?    @map("preferred_price_max")
  preferredGuests    Int?      @map("preferred_guests")
  preferredAmenities String[]  @default([]) @map("preferred_amenities")
  lastSearchAt       DateTime? @map("last_search_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_search_profiles")
}

model SearchEvent {
  id        String          @id @default(cuid())
  userId    String?         @map("user_id")
  listingId String?         @map("listing_id")
  eventType SearchEventType @map("event_type")
  metadata  Json?
  createdAt DateTime        @default(now()) @map("created_at")

  user    User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  listing ShortTermListing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([listingId, createdAt])
  @@index([eventType, createdAt])
  @@map("search_events")
}

/// High-granularity behavior stream for ranking learning (BNHub + future verticals).
enum BehaviorEventType {
  LISTING_IMPRESSION
  LISTING_CLICK
  LISTING_SAVE
  LISTING_SHARE
  LISTING_CONTACT_CLICK
  LISTING_UNLOCK_START
  LISTING_UNLOCK_SUCCESS
  LISTING_BOOKING_ATTEMPT
  LISTING_BOOKING_SUCCESS
  SEARCH_FILTERS_APPLIED
  MAP_PIN_CLICK
  SIMILAR_LISTING_CLICK
  SEARCH_RESULT_IMPRESSION
  DWELL_POSITIVE
  DWELL_NEGATIVE
}

model UserBehaviorEvent {
  id              String            @id @default(cuid())
  sessionId       String            @map("session_id") @db.VarChar(64)
  userId          String?           @map("user_id")
  listingId       String?           @map("listing_id")
  eventType       BehaviorEventType @map("event_type")
  pageType        String            @map("page_type") @db.VarChar(64)
  city            String?           @db.VarChar(128)
  category        String?           @db.VarChar(64)
  propertyType    String?           @map("property_type") @db.VarChar(64)
  priceCents      Int?              @map("price_cents")
  aiScoreSnapshot Float?            @map("ai_score_snapshot")
  metadataJson    Json?             @map("metadata_json")
  createdAt       DateTime          @default(now()) @map("created_at")

  user    User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  listing ShortTermListing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
  @@index([userId, createdAt])
  @@index([listingId, createdAt])
  @@index([eventType, createdAt])
  @@map("user_behavior_events")
}

/// BNHub guest conversion funnel — explicit events (supplements SearchEvent / UserBehaviorEvent).
model AiConversionSignal {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  listingId String   @map("listing_id")
  listing   ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  guestId   String?  @map("guest_id")
  guest     User?    @relation("AiConversionSignalGuest", fields: [guestId], references: [id], onDelete: SetNull)
  eventType String   @map("event_type")
  metadata  Json?

  @@index([listingId, createdAt])
  @@index([guestId, createdAt])
  @@index([eventType, createdAt])
  @@map("ai_conversion_signals")
}

/// Cached per-listing behavior + learning scores (updated by aggregation job, not every request).
model ListingLearningStats {
  listingId           String   @id @map("listing_id")
  behaviorScore       Float    @default(0.5) @map("behavior_score")
  clickThroughRate    Float?   @map("click_through_rate")
  saveRate            Float?   @map("save_rate")
  contactRate         Float?   @map("contact_rate")
  unlockRate          Float?   @map("unlock_rate")
  bookingAttemptRate  Float?   @map("booking_attempt_rate")
  bookingSuccessRate  Float?   @map("booking_success_rate")
