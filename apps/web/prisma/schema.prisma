  @@unique([context, version])
  @@index([context])
  @@map("lecipm_risk_disclosures")
}

model LecipmUserRiskDisclosureAcceptance {
  id           String               @id @default(cuid())
  userId       String               @map("user_id")
  user         User                 @relation("LecipmRiskDisclosureAcceptanceUser", fields: [userId], references: [id], onDelete: Cascade)
