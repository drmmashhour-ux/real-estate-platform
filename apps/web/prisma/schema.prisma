/// MVP: saved deal analysis from /analyze (cash-on-cash style ROI).
model InvestmentDeal {
  id                String            @id @default(uuid())
  userId            String            @map("user_id")
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId          String?           @map("tenant_id")
  tenant            Tenant?           @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  /// LONG_TERM (monthly rent) | SHORT_TERM (nightly + occupancy → effective revenue in monthlyRent)
  rentalType        String            @default("LONG_TERM") @map("rental_type")
  propertyPrice     Float             @map("property_price")
  /// Long-term monthly lease rent (dual-strategy saves). Legacy short-term-only rows may hold est. monthly revenue here.
  monthlyRent       Float             @map("monthly_rent")
  monthlyExpenses   Float             @map("monthly_expenses")
  /// Short-term only (CAD/night)
  nightlyRate       Float?            @map("nightly_rate")
  /// Short-term only — percent 0–100
  occupancyRate     Float?            @map("occupancy_rate")
  /// Cash-on-cash ROI for long-term assumptions (monthly lease rent).
  roiLongTerm       Float?            @map("roi_long_term")
  /// Cash-on-cash ROI for short-term assumptions (nightly × occupancy × 30).
  roiShortTerm      Float?            @map("roi_short_term")
  /// LONG_TERM | SHORT_TERM — which strategy has higher ROI (ties → LONG_TERM).
  preferredStrategy String            @default("LONG_TERM") @map("preferred_strategy")
  /// Percent, e.g. 8.5 = 8.5% — matches preferred strategy (backward compat with single-roi views).
  roi               Float             @map("roi")
  /// 0–100, higher = riskier (deterministic model from ROI + cash flow)
  riskScore         Float             @map("risk_score")
  /// Strong Buy | Moderate Investment | High Risk
  rating            String            @map("rating")
  /// Montreal | Laval | Toronto | Vancouver
  city              String            @map("city")
  /// Above Market | Market Average | Below Market
  marketComparison  String            @map("market_comparison")
  createdAt         DateTime          @default(now()) @map("created_at")
  sharedDealVisits  SharedDealVisit[]

  @@index([userId])
  @@map("investment_deals")
}

/// Public /deal/[id] page views — referral + viral leaderboard (anonymous session id optional).
