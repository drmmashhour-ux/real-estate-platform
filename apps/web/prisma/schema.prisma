  entityType        String   @map("entity_type")
  entityId          String   @map("entity_id")
  inputSummary      String?  @map("input_summary")
  outputSummary     String?  @map("output_summary")
  confidenceScore   Int?     @map("confidence_score")
  recommendedAction String?  @map("recommended_action")
  automatedAction   String?  @map("automated_action") // none | suggestion_created | alert_created | etc.
