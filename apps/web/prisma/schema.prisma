  taxableRevenueCents    Int      @default(0) @map("taxable_revenue_cents")
  nonTaxableRevenueCents Int      @default(0) @map("non_taxable_revenue_cents")
  sourceJson             Json?    @map("source_json")
  createdAt              DateTime @default(now()) @map("created_at")

  @@index([periodStart])
  @@index([periodEnd])
  @@map("tax_report_snapshots")
}

/// Internal ledger line (revenue, expense, payout, refund, tax) — not bank-automated reconciliation.
model AccountingEntry {
  id             String                @id @default(cuid())
  entryType      String                @map("entry_type") // revenue | expense | payout | refund | tax
  category       String
  sourceType     String?               @map("source_type") // booking | fsbo | subscription | lead | mortgage | manual
  sourceId       String?               @map("source_id")
  subtotalCents  Int                   @default(0) @map("subtotal_cents")
  gstCents       Int                   @default(0) @map("gst_cents")
  qstCents       Int                   @default(0) @map("qst_cents")
  totalCents     Int                   @default(0) @map("total_cents")
  status         String // pending | completed | failed | reconciled
  notes          String?               @db.Text
  entryDate      DateTime              @map("entry_date")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  reconciliation ReconciliationRecord?

  @@index([entryType])
  @@index([category])
  @@index([entryDate])
  @@index([status])
  @@map("accounting_entries")
}

/// Manual reconciliation status per ledger entry — not automatic bank matching unless integrated.
model ReconciliationRecord {
