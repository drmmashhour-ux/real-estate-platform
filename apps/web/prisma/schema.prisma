}

/// Unified telemetry for internal CRM (BNHub + LECIPM): views, clicks, bookings — complements `TrafficEvent` and `AiUserActivityLog`.
model InternalCrmEvent {
  id                 String            @id @default(cuid())
  createdAt          DateTime          @default(now()) @map("created_at")
  /**
   * listing_view | cta_click | booking_confirmed | session_heartbeat
   */
  eventType          String            @map("event_type")
  /**
   * bnhub | fsbo | marketplace | mortgage | platform
   */
  channel            String            @default("platform") @map("channel")
  userId             String?           @map("user_id")
  user               User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId          String?           @map("session_id")
  leadId             String?           @map("lead_id")
  lead               Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  shortTermListingId String?           @map("short_term_listing_id")
  shortTermListing   ShortTermListing? @relation("CrmEventBnhubListing", fields: [shortTermListingId], references: [id], onDelete: SetNull)
  fsboListingId      String?           @map("fsbo_listing_id")
