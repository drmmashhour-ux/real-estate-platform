// Seller Declaration (DV style): mandatory disclosure before publish. If declined, listing cannot be published.
model SellerDisclosure {
  id               String           @id @default(cuid())
  listingId        String           @unique @map("listing_id")
  listing          ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  structuralIssues String?          @map("structural_issues") @db.Text
  waterDamage      String?          @map("water_damage") @db.Text
  renovations      String?          @map("renovations") @db.Text
  defects          String?          @map("defects") @db.Text
  /**
   * Structured Seller Declaration form (property) — see `SellerDeclarationFormData` in app code.
   */
  formData         Json?            @map("form_data")
  completedAt      DateTime?        @map("completed_at") // Set when seller submits declaration
  declinedAt       DateTime?        @map("declined_at") // Set when seller refuses; listing cannot publish
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@map("seller_disclosures")
}

