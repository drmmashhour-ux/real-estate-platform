model DocumentFolder {
  id             String             @id @default(cuid())
  tenantId       String?            @map("tenant_id")
  tenant         Tenant?            @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  name           String
  type           DocumentFolderType @default(GENERAL)
  listingId      String?            @map("listing_id")
  brokerClientId String?            @map("broker_client_id")
  offerId        String?            @map("offer_id")
  contractId     String?            @map("contract_id")
  appointmentId  String?            @map("appointment_id")
  conversationId String?            @map("conversation_id")
  createdById    String?            @map("created_by_id")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  createdBy    User?           @relation("DocumentFolderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  listing      Listing?        @relation(fields: [listingId], references: [id], onDelete: SetNull)
  brokerClient BrokerClient?   @relation(fields: [brokerClientId], references: [id], onDelete: SetNull)
  offer        Offer?          @relation(fields: [offerId], references: [id], onDelete: SetNull)
  contract     Contract?       @relation(fields: [contractId], references: [id], onDelete: SetNull)
  appointment  Appointment?    @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  conversation Conversation?   @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  files        DocumentFile[]
  events       DocumentEvent[] @relation("FolderDocumentEvents")

  @@index([listingId])
  @@index([brokerClientId])
  @@index([offerId])
  @@index([contractId])
  @@index([appointmentId])
  @@index([conversationId])
  @@index([tenantId])
  @@map("document_folders")
}

model DocumentFile {
  id              String             @id @default(cuid())
  tenantId        String?            @map("tenant_id")
  tenant          Tenant?            @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  folderId        String?            @map("folder_id")
  uploadedById    String?            @map("uploaded_by_id")
  fileName        String             @map("file_name")
  originalName    String             @map("original_name")
  mimeType        String             @map("mime_type")
  sizeBytes       Int                @map("size_bytes")
  storageKey      String             @map("storage_key")
  storageProvider String?            @map("storage_provider")
  checksum        String?
  status          DocumentFileStatus @default(AVAILABLE)
  visibility      DocumentVisibility @default(PRIVATE_INTERNAL)
  category        DocumentCategory   @default(OTHER)
  listingId       String?            @map("listing_id")
  brokerClientId  String?            @map("broker_client_id")
  offerId         String?            @map("offer_id")
  contractId      String?            @map("contract_id")
  appointmentId   String?            @map("appointment_id")
  conversationId  String?            @map("conversation_id")
  description     String?            @db.Text
  tags            String[]           @default([])
  metadata        Json?
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  folder       DocumentFolder?        @relation(fields: [folderId], references: [id], onDelete: SetNull)
  uploadedBy   User?                  @relation("DocumentFileUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  listing      Listing?               @relation(fields: [listingId], references: [id], onDelete: SetNull)
  brokerClient BrokerClient?          @relation(fields: [brokerClientId], references: [id], onDelete: SetNull)
  offer        Offer?                 @relation(fields: [offerId], references: [id], onDelete: SetNull)
  contract     Contract?              @relation(fields: [contractId], references: [id], onDelete: SetNull)
  appointment  Appointment?           @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  conversation Conversation?          @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  accessGrants DocumentAccessGrant[]
  events       DocumentEvent[]        @relation("FileDocumentEvents")
  intakeLinks  RequiredDocumentItem[] @relation("IntakeLinkedDocument")
  /**
   * Enterprise workspace scope for team document vaults (optional).
   */
  workspaceId  String?                @map("workspace_id") @db.Uuid
  workspace    EnterpriseWorkspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([folderId])
  @@index([uploadedById])
  @@index([listingId])
  @@index([brokerClientId])
  @@index([workspaceId])
  @@index([offerId])
  @@index([contractId])
  @@index([appointmentId])
  @@index([conversationId])
  @@index([visibility])
  @@index([category])
  @@index([tenantId])
  @@map("document_files")
}

model DocumentAccessGrant {
  id             String              @id @default(cuid())
  documentFileId String              @map("document_file_id")
  userId         String              @map("user_id")
  access         DocumentAccessLevel @default(VIEW)
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  documentFile DocumentFile @relation(fields: [documentFileId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([documentFileId, userId])
  @@index([documentFileId])
  @@index([userId])
  @@map("document_access_grants")
}

model DocumentEvent {
  id             String            @id @default(cuid())
  documentFileId String?           @map("document_file_id")
  folderId       String?           @map("folder_id")
  actorId        String?           @map("actor_id")
  type           DocumentEventType
  message        String?           @db.Text
  metadata       Json?
  createdAt      DateTime          @default(now()) @map("created_at")

  documentFile DocumentFile?   @relation("FileDocumentEvents", fields: [documentFileId], references: [id], onDelete: SetNull)
  folder       DocumentFolder? @relation("FolderDocumentEvents", fields: [folderId], references: [id], onDelete: SetNull)
  actor        User?           @relation("DocumentEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([documentFileId])
  @@index([folderId])
  @@map("document_events")
}

// ---------------------------------------------------------------------------
// Client intake / required documents checklist (KYC-style workflow)
// ---------------------------------------------------------------------------

enum ClientIntakeStatus {
  NOT_STARTED
  IN_PROGRESS
  UNDER_REVIEW
  COMPLETE
  ON_HOLD
}

enum RequiredDocumentCategory {
  IDENTITY
  INCOME
  BANKING
  TAX
  RESIDENCY
  CREDIT
  EMPLOYMENT
  CORPORATE
  PROPERTY
  OTHER
}

enum RequiredDocumentStatus {
  REQUIRED
  REQUESTED
  UPLOADED
  UNDER_REVIEW
  APPROVED
  REJECTED
  WAIVED
}

enum ClientIntakeEventType {
  INTAKE_CREATED
  INTAKE_UPDATED
  STATUS_CHANGED
  DOCUMENT_REQUESTED
  DOCUMENT_UPLOADED
  DOCUMENT_LINKED
  DOCUMENT_APPROVED
  DOCUMENT_REJECTED
  DOCUMENT_WAIVED
  NOTE_ADDED
}

model ClientIntakeProfile {
  id                   String             @id @default(cuid())
  tenantId             String?            @map("tenant_id")
  tenant               Tenant?            @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  brokerClientId       String             @unique @map("broker_client_id")
  userId               String?            @map("user_id")
  legalFirstName       String?            @map("legal_first_name")
  legalLastName        String?            @map("legal_last_name")
  dateOfBirth          DateTime?          @map("date_of_birth")
  phone                String?
  email                String?
  employmentStatus     String?            @map("employment_status")
  annualIncome         Float?             @map("annual_income")
  estimatedAssets      Float?             @map("estimated_assets")
  estimatedLiabilities Float?             @map("estimated_liabilities")
  residencyStatus      String?            @map("residency_status")
  citizenshipCountry   String?            @map("citizenship_country")
  maritalStatus        String?            @map("marital_status")
  currentAddress       String?            @map("current_address") @db.Text
  city                 String?
  provinceState        String?            @map("province_state")
  postalCode           String?            @map("postal_code")
  country              String?
  notes                String?            @db.Text
  status               ClientIntakeStatus @default(NOT_STARTED)
  completedAt          DateTime?          @map("completed_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  brokerClient          BrokerClient           @relation(fields: [brokerClientId], references: [id], onDelete: Cascade)
  user                  User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  requiredDocumentItems RequiredDocumentItem[]
  intakeEvents          ClientIntakeEvent[]

  @@index([userId])
  @@index([tenantId])
  @@map("client_intake_profiles")
}

model RequiredDocumentItem {
  id                   String                   @id @default(cuid())
  tenantId             String?                  @map("tenant_id")
  tenant               Tenant?                  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  brokerClientId       String                   @map("broker_client_id")
  intakeProfileId      String?                  @map("intake_profile_id")
  title                String
  description          String?                  @db.Text
  category             RequiredDocumentCategory
  status               RequiredDocumentStatus   @default(REQUIRED)
  isMandatory          Boolean                  @default(true) @map("is_mandatory")
  requestedById        String?                  @map("requested_by_id")
  dueAt                DateTime?                @map("due_at")
  reviewedById         String?                  @map("reviewed_by_id")
  linkedDocumentFileId String?                  @map("linked_document_file_id")
  rejectionReason      String?                  @map("rejection_reason") @db.Text
  notes                String?                  @db.Text
  deletedAt            DateTime?                @map("deleted_at")
  createdAt            DateTime                 @default(now()) @map("created_at")
  updatedAt            DateTime                 @updatedAt @map("updated_at")

  brokerClient       BrokerClient         @relation(fields: [brokerClientId], references: [id], onDelete: Cascade)
  intakeProfile      ClientIntakeProfile? @relation(fields: [intakeProfileId], references: [id], onDelete: SetNull)
  requestedBy        User?                @relation("RequiredDocRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  reviewedBy         User?                @relation("RequiredDocReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  linkedDocumentFile DocumentFile?        @relation("IntakeLinkedDocument", fields: [linkedDocumentFileId], references: [id], onDelete: SetNull)
  intakeEvents       ClientIntakeEvent[]

  @@index([brokerClientId])
  @@index([intakeProfileId])
  @@index([status])
  @@index([linkedDocumentFileId])
  @@index([tenantId])
  @@map("required_document_items")
}

model ClientIntakeEvent {
  id                     String                @id @default(cuid())
  brokerClientId         String                @map("broker_client_id")
  intakeProfileId        String?               @map("intake_profile_id")
  requiredDocumentItemId String?               @map("required_document_item_id")
  actorId                String?               @map("actor_id")
  type                   ClientIntakeEventType
  message                String?               @db.Text
  metadata               Json?
  createdAt              DateTime              @default(now()) @map("created_at")

  brokerClient         BrokerClient          @relation(fields: [brokerClientId], references: [id], onDelete: Cascade)
  intakeProfile        ClientIntakeProfile?  @relation(fields: [intakeProfileId], references: [id], onDelete: SetNull)
  requiredDocumentItem RequiredDocumentItem? @relation(fields: [requiredDocumentItemId], references: [id], onDelete: SetNull)
  actor                User?                 @relation("ClientIntakeEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([brokerClientId])
  @@index([intakeProfileId])
  @@index([requiredDocumentItemId])
  @@map("client_intake_events")
}

// ---------------------------------------------------------------------------
// Internal notifications + action queue (in-app command center)
// ---------------------------------------------------------------------------

enum NotificationType {
  MESSAGE
  OFFER
  CONTRACT
  APPOINTMENT
  DOCUMENT
  INTAKE
  CRM
  SYSTEM
  TASK
  REMINDER
  FINANCE
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ActionQueueItemType {
  REVIEW_DOCUMENT
  REVIEW_OFFER
  REVIEW_CONTRACT
  RESPOND_MESSAGE
  CONFIRM_APPOINTMENT
  FOLLOW_UP_CLIENT
  COMPLETE_INTAKE
  SIGN_CONTRACT
  UPLOAD_REQUIRED_DOCUMENT
  REVIEW_COUNTER_OFFER
  INTERNAL_TASK
  SYSTEM_ACTION
  REVIEW_COMMISSION
  ISSUE_INVOICE
  RECORD_PAYMENT
  FOLLOW_UP_OVERDUE_INVOICE
}

enum ActionQueueItemStatus {
  OPEN
  IN_PROGRESS
  DONE
  DISMISSED
  ARCHIVED
}

enum NotificationEventType {
  CREATED
  READ
  ARCHIVED
  ACTION_COMPLETED
  ACTION_DISMISSED
  STATUS_CHANGED
}

model Notification {
  id                     String               @id @default(cuid())
  tenantId               String?              @map("tenant_id")
  tenant                 Tenant?              @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  userId                 String               @map("user_id")
  type                   NotificationType
  title                  String
  message                String?              @db.Text
  status                 NotificationStatus   @default(UNREAD)
  priority               NotificationPriority @default(NORMAL)
  actionUrl              String?              @map("action_url")
  actionLabel            String?              @map("action_label")
  actorId                String?              @map("actor_id")
  listingId              String?              @map("listing_id")
  brokerClientId         String?              @map("broker_client_id")
  intakeProfileId        String?              @map("intake_profile_id")
  requiredDocumentItemId String?              @map("required_document_item_id")
  offerId                String?              @map("offer_id")
  contractId             String?              @map("contract_id")
  appointmentId          String?              @map("appointment_id")
  conversationId         String?              @map("conversation_id")
  documentFileId         String?              @map("document_file_id")
  metadata               Json?
  readAt                 DateTime?            @map("read_at")
  archivedAt             DateTime?            @map("archived_at")
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")

  user   User                @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor  User?               @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  events NotificationEvent[]

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@index([offerId])
  @@index([contractId])
  @@index([appointmentId])
  @@index([conversationId])
  @@index([tenantId])
  @@map("notifications")
}

model MobileDeviceToken {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String    @unique
  platform    String
  provider    String    @default("expo")
  deviceName  String?   @map("device_name")
  appVersion  String?   @map("app_version")
  lastSeenAt  DateTime  @default(now()) @map("last_seen_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([platform])
  @@index([provider])
  @@index([revokedAt])
  @@map("mobile_device_tokens")
}

model ClientInterestProfile {
  id                      String   @id @default(cuid())
  userId                  String   @unique @map("user_id")
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topCity                 String?  @map("top_city")
  topPropertyType         String?  @map("top_property_type")
  topIntentMode           String?  @map("top_intent_mode")
  preferredPriceMinCents  Int?     @map("preferred_price_min_cents")
  preferredPriceMaxCents  Int?     @map("preferred_price_max_cents")
  interestScore           Int      @default(0) @map("interest_score")
  intentStage             String   @default("cold") @map("intent_stage")
  lastActiveAt            DateTime? @map("last_active_at")
  computedFromEventsAt    DateTime? @map("computed_from_events_at")
  summaryJson             Json?
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@index([intentStage])
  @@index([interestScore])
  @@index([topCity])
  @@map("client_interest_profiles")
}

model ClientCelebrationProfile {
  id                 String    @id @default(cuid())
  userId             String    @unique @map("user_id")
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  birthDate          DateTime? @map("birth_date")
  allowBirthdayTouch Boolean   @default(false) @map("allow_birthday_touch")
  lastBirthdaySentAt DateTime? @map("last_birthday_sent_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([birthDate])
  @@map("client_celebration_profiles")
}

enum ClientFollowUpType {
  NEW_MATCH
  INACTIVITY_NUDGE
  BIRTHDAY_GREETING
  BROKER_REENGAGE
}

enum ClientFollowUpStatus {
  PENDING
  SENT
  SKIPPED
  FAILED
}

model ClientFollowUpQueue {
  id            String               @id @default(cuid())
  userId        String               @map("user_id")
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          ClientFollowUpType
  status        ClientFollowUpStatus @default(PENDING)
  title         String
  message       String               @db.Text
  payload       Json?
  scheduledAt   DateTime             @map("scheduled_at")
  sentAt        DateTime?            @map("sent_at")
  lastError     String?              @map("last_error") @db.Text
  dedupeKey     String?              @unique @map("dedupe_key")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  @@index([userId, status])
  @@index([scheduledAt, status])
  @@index([type, status])
  @@map("client_follow_up_queue")
}

model ActionQueueItem {
  id          String                @id @default(cuid())
  tenantId    String?               @map("tenant_id")
  tenant      Tenant?               @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  userId      String                @map("user_id")
  type        ActionQueueItemType
  title       String
  description String?               @db.Text
  status      ActionQueueItemStatus @default(OPEN)
  priority    NotificationPriority  @default(NORMAL)
  dueAt       DateTime?             @map("due_at")
  completedAt DateTime?             @map("completed_at")
  sourceKey   String?               @map("source_key")
  sourceType  String?               @map("source_type")
  sourceId    String?               @map("source_id")
  actionUrl   String?               @map("action_url")
  metadata    Json?
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  user   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  events NotificationEvent[]

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([dueAt])
  @@index([sourceType, sourceId])
  @@index([tenantId])
  @@map("action_queue_items")
}

model NotificationEvent {
  id                String                @id @default(cuid())
  notificationId    String?               @map("notification_id")
  actionQueueItemId String?               @map("action_queue_item_id")
  actorId           String?               @map("actor_id")
  type              NotificationEventType
  message           String?               @db.Text
  metadata          Json?
  createdAt         DateTime              @default(now()) @map("created_at")

  notification    Notification?    @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  actionQueueItem ActionQueueItem? @relation(fields: [actionQueueItemId], references: [id], onDelete: Cascade)
  actor           User?            @relation("NotificationEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([notificationId])
  @@index([actionQueueItemId])
  @@map("notification_events")
}

// ---------------------------------------------------------------------------
// Multi-tenant workspaces + finance (commissions, invoices, payments)
// ---------------------------------------------------------------------------

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum TenantRole {
  TENANT_OWNER
  TENANT_ADMIN
  BROKER
  ASSISTANT
  STAFF
  VIEWER
}

enum TenantMembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
  REMOVED
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

/// Agency/tenant finance invoices (distinct from subscription `Invoice` above).
enum TenantInvoiceType {
  COMMISSION
  SERVICE_FEE
  BROKER_FEE
  PLATFORM_FEE
  OTHER
}

enum TenantInvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentRecordType {
  INCOMING
  OUTGOING
  ADJUSTMENT
}

enum PaymentRecordStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
}

model Tenant {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  status      TenantStatus @default(ACTIVE)
  ownerUserId String?      @map("owner_user_id")
  owner       User?        @relation("OwnedTenants", fields: [ownerUserId], references: [id], onDelete: SetNull)
  settings    Json?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  memberships           TenantMembership[]
  listings              Listing[]
  brokerClients         BrokerClient[]
  offers                Offer[]
  offerEvents           OfferEvent[]
  contracts             Contract[]
  contractSignatures    ContractSignature[]
  appointments          Appointment[]
  appointmentEvents     AppointmentEvent[]
  conversations         Conversation[]
  messages              Message[]
  documentFolders       DocumentFolder[]
  documentFiles         DocumentFile[]
  clientIntakeProfiles  ClientIntakeProfile[]
  requiredDocumentItems RequiredDocumentItem[]
  investmentDeals       InvestmentDeal[]
  notifications         Notification[]
  actionQueueItems      ActionQueueItem[]
  dealFinancials        DealFinancial[]
  commissionSplits      CommissionSplit[]
  tenantInvoices        TenantInvoice[]
  paymentRecords        PaymentRecord[]
  billingProfile        TenantBillingProfile?
  fsboLeads             FsboLead[]
  buyerRequests         BuyerRequest[]
  advisoryAccesses      AdvisoryAccess[]
  buyerListingViews     BuyerListingView[]
  fsboListings          FsboListing[]

  @@index([ownerUserId])
  @@map("tenants")
}

model TenantMembership {
  id        String                 @id @default(cuid())
  tenantId  String                 @map("tenant_id")
  tenant    Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String                 @map("user_id")
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      TenantRole
  status    TenantMembershipStatus @default(ACTIVE)
  createdAt DateTime               @default(now()) @map("created_at")
  updatedAt DateTime               @updatedAt @map("updated_at")

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("tenant_memberships")
}

model DealFinancial {
  id               String    @id @default(cuid())
  tenantId         String    @map("tenant_id")
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listingId        String?   @map("listing_id")
  listing          Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  offerId          String?   @map("offer_id")
  offer            Offer?    @relation(fields: [offerId], references: [id], onDelete: SetNull)
  contractId       String?   @map("contract_id")
  contract         Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  salePrice        Float?    @map("sale_price")
  /// Long-term rent: typically one month rent as commission basis.
  rentAmount       Float?    @map("rent_amount")
  commissionAmount Float?    @map("commission_amount")
  commissionSource String?   @map("commission_source")
  rentalCategory   String?   @map("rental_category") // LONG_TERM | SHORT_TERM
  commissionRate   Float?    @map("commission_rate")
  grossCommission  Float?    @map("gross_commission")
  netCommission    Float?    @map("net_commission")
  currency         String    @default("CAD")
  notes            String?   @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  commissionSplits CommissionSplit[]
  paymentRecords   PaymentRecord[]

  @@index([tenantId])
  @@index([listingId])
  @@index([offerId])
  @@index([contractId])
  @@map("deal_financials")
}

model CommissionSplit {
  id              String           @id @default(cuid())
  tenantId        String           @map("tenant_id")
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
