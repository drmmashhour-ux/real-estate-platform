// —— LECIPM deal-file payments / trust workflow / negotiation (v1) — broker-controlled; not a regulated trust unless configured. ——

enum LecipmPaymentKind {
  deposit
  additional_sum
  balance_due
  trust_release
  refund
  fee
}

enum LecipmPaymentRecordStatus {
  draft
  requested
  awaiting_payment
  awaiting_confirmation
  confirmed
  held
  release_pending
  released
  refund_pending
  refunded
  failed
  cancelled
}

enum LecipmTrustWorkflowMode {
  tracking_only
  manual_trust_workflow
  provider_connected
  notary_coordinated
}

enum LecipmTrustWorkflowStatus {
  not_started
  profiled
  funds_expected
  funds_held
  release_scheduled
  released
  closed
}

enum LecipmLedgerEntryKind {
  request_created
  payment_received
  payment_confirmed
  held_in_trust
  released_to_notary_or_closing
  refunded
  adjustment
  failure
}

enum LecipmPaymentConfirmationKind {
  manual_broker
  provider_webhook
  bank_reference_upload
  notary_attestation
  other
}

model LecipmDealPayment {
  id                String                      @id @default(uuid())
  dealId            String                      @map("deal_id")
  deal              Deal                        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  paymentKind       LecipmPaymentKind           @map("payment_kind")
  status            LecipmPaymentRecordStatus
  amountCents       Int                         @map("amount_cents")
  currency          String                      @default("cad") @db.VarChar(8)
  requestedAt       DateTime?                   @map("requested_at")
  dueAt             DateTime?                   @map("due_at")
  receivedAt        DateTime?                   @map("received_at")
  confirmedAt       DateTime?                   @map("confirmed_at")
  releasedAt        DateTime?                   @map("released_at")
  refundedAt        DateTime?                   @map("refunded_at")
  /// Provider key: manual | stripe_request | escrow_placeholder | notary_funds | external
  provider          String                      @db.VarChar(64)
  providerReference String?                     @map("provider_reference") @db.VarChar(160)
  metadata          Json                        @default("{}")
  createdAt         DateTime                    @default(now()) @map("created_at")
  updatedAt         DateTime                    @updatedAt @map("updated_at")
  instructions      LecipmPaymentInstruction[]
  confirmations     LecipmPaymentConfirmation[]
  ledgerEntries     LecipmPaymentLedgerEntry[]

  @@index([dealId])
  @@index([status])
  @@index([paymentKind])
  @@map("lecipm_deal_payments")
}

model LecipmPaymentInstruction {
  id              String            @id @default(uuid())
  dealPaymentId   String            @map("deal_payment_id")
  dealPayment     LecipmDealPayment @relation(fields: [dealPaymentId], references: [id], onDelete: Cascade)
  instructionType String            @map("instruction_type") @db.VarChar(64)
  payload         Json              @default("{}")
  createdAt       DateTime          @default(now()) @map("created_at")

  @@index([dealPaymentId])
  @@map("lecipm_payment_instructions")
}

model LecipmTrustWorkflow {
  id                    String                    @id @default(uuid())
  dealId                String                    @unique @map("deal_id")
  deal                  Deal                      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  mode                  LecipmTrustWorkflowMode
  status                LecipmTrustWorkflowStatus @default(not_started)
  trusteeName           String?                   @map("trustee_name") @db.VarChar(160)
  trusteeType           String?                   @map("trustee_type") @db.VarChar(64)
  trustAccountReference String?                   @map("trust_account_reference") @db.VarChar(160)
  notes                 Json                      @default("[]")
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @updatedAt @map("updated_at")

  @@index([dealId])
  @@map("lecipm_trust_workflows")
}

model LecipmPaymentLedgerEntry {
  id          String                @id @default(uuid())
  dealId      String                @map("deal_id")
  deal        Deal                  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  paymentId   String?               @map("payment_id")
  payment     LecipmDealPayment?    @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  entryKind   LecipmLedgerEntryKind @map("entry_kind")
  amountCents Int                   @map("amount_cents")
  currency    String                @default("cad") @db.VarChar(8)
  description String                @db.Text
  metadata    Json                  @default("{}")
  createdAt   DateTime              @default(now()) @map("created_at")

  @@index([dealId])
  @@index([paymentId])
  @@index([entryKind])
  @@map("lecipm_payment_ledger_entries")
}

model LecipmPaymentConfirmation {
  id               String                        @id @default(uuid())
  dealPaymentId    String                        @map("deal_payment_id")
