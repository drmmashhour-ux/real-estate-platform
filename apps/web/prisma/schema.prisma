  buyerTier   String    @default("PREMIUM") @map("buyer_tier")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([status])
  @@map("advisory_access")
}

model BuyerListingView {
