model DealRoom {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listingId      String?           @map("listing_id")
  listing        Listing?          @relation(fields: [listingId], references: [id], onDelete: SetNull)
  brokerUserId   String            @map("broker_user_id")
  broker         User              @relation("DealRoomBroker", fields: [brokerUserId], references: [id], onDelete: Cascade)
  leadId         String?           @map("lead_id")
  lead           Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  /// Platform `Conversation.id` or `CrmConversation.id` — opaque in MVP.
  threadId       String?           @map("thread_id")
  customerUserId String?           @map("customer_user_id")
  customer       User?             @relation("DealRoomCustomer", fields: [customerUserId], references: [id], onDelete: SetNull)
  guestName      String?           @map("guest_name")
  guestEmail     String?           @map("guest_email")
  stage          DealRoomStage     @default(new_interest)
  priorityLabel  DealPriorityLabel @default(medium) @map("priority_label")
  summary        String?           @db.Text
  nextAction     String?           @map("next_action") @db.Text
  nextFollowUpAt DateTime?         @map("next_follow_up_at")
  isArchived     Boolean           @default(false) @map("is_archived")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  participants DealRoomParticipant[]
  tasks        DealRoomTask[]
  events       DealRoomEvent[]
  documents    DealRoomDocument[]
  payments     DealRoomPayment[]

  @@unique([leadId])
  @@unique([threadId])
  @@index([brokerUserId])
  @@index([listingId])
  @@index([stage])
  @@index([nextFollowUpAt])
  @@map("deal_rooms")
}

model DealRoomParticipant {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dealRoomId  String              @map("deal_room_id") @db.Uuid
  dealRoom    DealRoom            @relation(fields: [dealRoomId], references: [id], onDelete: Cascade)
  userId      String?             @map("user_id")
  user        User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  role        DealParticipantRole
  displayName String?             @map("display_name")
  email       String?
  createdAt   DateTime            @default(now()) @map("created_at")

  @@index([dealRoomId])
  @@index([userId])
  @@map("deal_room_participants")
}

model DealRoomTask {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dealRoomId     String         @map("deal_room_id") @db.Uuid
  dealRoom       DealRoom       @relation(fields: [dealRoomId], references: [id], onDelete: Cascade)
  title          String
  description    String?        @db.Text
  status         DealTaskStatus @default(todo)
  assignedUserId String?        @map("assigned_user_id")
  assignedUser   User?          @relation("DealRoomTaskAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  dueAt          DateTime?      @map("due_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@index([dealRoomId])
  @@index([status])
  @@index([dueAt])
  @@map("deal_room_tasks")
}

model DealRoomEvent {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dealRoomId      String   @map("deal_room_id") @db.Uuid
  dealRoom        DealRoom @relation(fields: [dealRoomId], references: [id], onDelete: Cascade)
  eventType       String   @map("event_type")
  title           String
  body            String?  @db.Text
  metadataJson    Json     @default("{}") @map("metadata_json")
  createdByUserId String?  @map("created_by_user_id")
  createdBy       User?    @relation("DealRoomEventCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([dealRoomId])
  @@index([createdAt])
  @@map("deal_room_events")
}

model DealRoomDocument {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dealRoomId      String              @map("deal_room_id") @db.Uuid
  dealRoom        DealRoom            @relation(fields: [dealRoomId], references: [id], onDelete: Cascade)
  documentType    String              @map("document_type")
  documentRefType DealDocumentRefType @map("document_ref_type")
  documentRefId   String?             @map("document_ref_id")
  status          DealDocumentStatus  @default(requested)
  title           String
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  @@index([dealRoomId])
  @@index([status])
  @@map("deal_room_documents")
}

model DealRoomPayment {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dealRoomId  String            @map("deal_room_id") @db.Uuid
  dealRoom    DealRoom          @relation(fields: [dealRoomId], references: [id], onDelete: Cascade)
  paymentType DealPaymentType   @map("payment_type")
  status      DealPaymentStatus @default(pending)
  amountCents Int?              @map("amount_cents")
  currency    String?
  paymentRef  String?           @map("payment_ref")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@index([dealRoomId])
  @@index([status])
  @@index([paymentType])
  @@map("deal_room_payments")
}

// ---------------------------------------------------------------------------
// A/B experiments — surfaces, assignments, funnel events (LECIPM + BNHub)
// ---------------------------------------------------------------------------

enum ExperimentStatus {
  draft
  running
  paused
  completed
  archived
}

model Experiment {
  id                 String           @id @default(uuid())
  name               String
  slug               String           @unique
  status             ExperimentStatus @default(draft)
  targetSurface      String           @map("target_surface")
  hypothesis         String?
  /// Short objective line (e.g. “Improve LP CTA CTR”) — additive to hypothesis.
  objective          String?          @db.Text
  primaryMetric      String           @map("primary_metric")
  metricSecondary    Json?            @map("metric_secondary")
  audienceScope      Json?            @map("audience_scope")
  notes              Json?
  trafficSplitJson   Json             @map("traffic_split_json")
  startAt            DateTime?        @map("start_at")
  endAt              DateTime?        @map("end_at")
  winnerVariantKey   String?          @map("winner_variant_key")
  stoppedVariantKeys Json             @default("[]") @map("stopped_variant_keys")
  archivedAt         DateTime?        @map("archived_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  variants         ExperimentVariant[]
  assignments      ExperimentAssignment[]
  events           ExperimentEvent[]
  resultSnapshots  ExperimentResultSnapshot[]
  metricSnapshots  ExperimentMetricSnapshot[]
  outcomeDecisions ExperimentOutcomeDecision[]

  @@index([status])
  @@index([targetSurface])
  @@map("experiments")
}

model ExperimentVariant {
  id            String   @id @default(uuid())
  experimentId  String   @map("experiment_id")
  variantKey    String   @map("variant_key")
  name          String
  configJson    Json     @map("config_json")
  /// active | winner | loser | inconclusive — recommendation layer; not auto-applied UX.
  outcomeStatus String?  @map("outcome_status") @db.VarChar(24)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  experiment              Experiment                  @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  assignments             ExperimentAssignment[]
  events                  ExperimentEvent[]
  metricSnapshots         ExperimentMetricSnapshot[]
  winningOutcomeDecisions ExperimentOutcomeDecision[] @relation("ExperimentWinningVariant")

  @@unique([experimentId, variantKey])
  @@index([experimentId])
  @@map("experiment_variants")
}

model ExperimentAssignment {
  id           String   @id @default(uuid())
  experimentId String   @map("experiment_id")
  variantId    String   @map("variant_id")
  userId       String?  @map("user_id")
  sessionId    String   @map("session_id") @db.VarChar(128)
  assignedAt   DateTime @default(now()) @map("assigned_at")

  experiment Experiment        @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  variant    ExperimentVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  user       User?             @relation("ExperimentAssignmentUser", fields: [userId], references: [id], onDelete: SetNull)

  @@unique([experimentId, sessionId])
  @@index([experimentId])
  @@index([variantId])
  @@index([userId])
  @@index([sessionId])
  @@map("experiment_assignments")
}

model ExperimentEvent {
  id           String   @id @default(uuid())
  experimentId String   @map("experiment_id")
  variantId    String   @map("variant_id")
  userId       String?  @map("user_id")
  sessionId    String   @map("session_id") @db.VarChar(128)
  eventName    String   @map("event_name") @db.VarChar(64)
  metadataJson Json     @default("{}") @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")

  experiment Experiment        @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  variant    ExperimentVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  user       User?             @relation("ExperimentEventUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([experimentId])
  @@index([variantId])
  @@index([eventName])
  @@index([sessionId])
  @@map("experiment_events")
}

/// Optional time-series metric rollups per experiment variant (aggregates / cron snapshots).
model ExperimentMetricSnapshot {
  id           String   @id @default(cuid())
  experimentId String   @map("experiment_id")
  variantId    String   @map("variant_id")
  metricKey    String   @map("metric_key") @db.VarChar(64)
  metricValue  Float    @map("metric_value")
  measuredAt   DateTime @default(now()) @map("measured_at") @db.Timestamptz(6)

  experiment Experiment        @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  variant    ExperimentVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([experimentId, metricKey, measuredAt])
  @@index([variantId, measuredAt])
  @@map("experiment_metric_snapshots")
}

/// Auditable A/B outcome recommendation — does not auto-publish UX changes.
model ExperimentOutcomeDecision {
  id               String   @id @default(cuid())
  experimentId     String   @map("experiment_id")
  decisionType     String   @map("decision_type") @db.VarChar(32)
  winningVariantId String?  @map("winning_variant_id")
  losingVariantIds Json     @map("losing_variant_ids")
  confidence       Float
  rationale        Json
  recommendation   String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")

  experiment     Experiment         @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  winningVariant ExperimentVariant? @relation("ExperimentWinningVariant", fields: [winningVariantId], references: [id], onDelete: SetNull)

  @@index([experimentId, createdAt])
  @@map("experiment_outcome_decisions")
}

