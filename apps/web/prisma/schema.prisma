// ---------------------------------------------------------------------------
// LECIPM OACIQ form engine — uploaded PDF-derived templates + deal-scoped instances (broker-controlled).
// ---------------------------------------------------------------------------

enum OaciqFormFamily {
  PPG
  CP
  DS
  IV
  ANNEX_G
  ANNEX_R
  ANNEX_RC
  ANNEX_L
  SYNDICATE_REQUEST
  MORTGAGE_REQUEST
  DISCLOSURE_NOTICE
  LISTING_CONTRACT
  BUYER_CONTRACT
  LEASE_CONTRACT
  OTHER
}

enum OaciqPdfFieldKind {
  text
  checkbox
  date
  signature
  dropdown
  radio
  unknown
}

enum LecipmFormInstanceStatus {
  draft
  ai_generated
  broker_review
  client_review
  signed
  archived
}

model OaciqFormTemplate {
  id                  String          @id @default(uuid())
  formFamily          OaciqFormFamily @map("form_family")
  versionLabel        String?         @map("version_label") @db.VarChar(64)
  /// Storage key for the uploaded specimen PDF (S3/local) — optional when schema is registry-only.
  sourcePdfKey        String?         @map("source_pdf_key") @db.VarChar(512)
  /// Full schema: sections, fields, extraction metadata (no invented fields — only extractor + registry merge).
  schema              Json            @default("{}")
  extractedFieldCount Int             @default(0) @map("extracted_field_count")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  fields    OaciqFormField[]
  instances LecipmFormInstance[]

  @@index([formFamily])
  @@map("oaciq_form_templates")
}

model OaciqFormField {
  id         String            @id @default(uuid())
  templateId String            @map("template_id")
  template   OaciqFormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fieldKey   String            @map("field_key") @db.VarChar(200)
  label      String            @db.Text
  fieldType  OaciqPdfFieldKind @map("field_type")
  section    String?           @db.VarChar(200)
  page       Int?
  required   Boolean?
  metadata   Json              @default("{}")

  @@index([templateId])
  @@index([fieldKey])
  @@map("oaciq_form_fields")
}

model LecipmFormInstance {
  id              String                   @id @default(uuid())
  templateId      String                   @map("template_id")
  template        OaciqFormTemplate        @relation(fields: [templateId], references: [id], onDelete: Restrict)
  dealId          String                   @map("deal_id")
  deal            Deal                     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  status          LecipmFormInstanceStatus @default(draft)
  data            Json                     @default("{}")
  version         Int                      @default(1)
  createdByUserId String?                  @map("created_by_user_id")
  createdBy       User?                    @relation("LecipmFormInstanceAuthor", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")

  versions LecipmFormVersion[]

  @@index([dealId])
  @@index([templateId])
  @@index([status])
  @@map("lecipm_form_instances")
}

model LecipmFormVersion {
  id             String             @id @default(uuid())
  formInstanceId String             @map("form_instance_id")
  formInstance   LecipmFormInstance @relation(fields: [formInstanceId], references: [id], onDelete: Cascade)
  version        Int
  data           Json               @default("{}")
  createdAt      DateTime           @default(now()) @map("created_at")

  @@index([formInstanceId])
  @@map("lecipm_form_versions")
}

// ---------------------------------------------------------------------------
// Structured form submissions (OACIQ-style forms: amendments, promise-to-purchase, etc.)
// ---------------------------------------------------------------------------
model FormSubmission {
  id          String         @id @default(cuid())
  formType    String // amendments, promise-to-purchase, etc.
  status      String         @default("draft") // draft, submitted, in-review, approved, rejected, completed
  clientName  String?
  clientEmail String?
  assignedTo  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  payloadJson Json
  activities  FormActivity[]

  @@index([formType])
  @@index([status])
  @@index([createdAt])
}

model FormActivity {
  id               String         @id @default(cuid())
  formSubmissionId String
  formSubmission   FormSubmission @relation(fields: [formSubmissionId], references: [id], onDelete: Cascade)
  action           String // created, updated, submitted, approved, rejected, exported, status_changed
  note             String?
  createdAt        DateTime       @default(now())

  @@index([formSubmissionId])
}

/// Fast Deal Engine — operator-attributed measurement only (no outreach automation).
