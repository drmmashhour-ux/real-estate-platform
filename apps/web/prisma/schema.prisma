// -----------------------------------------------------------------------------
// PART 1: FULLY AUTONOMOUS FUND LAYER
// -----------------------------------------------------------------------------

enum InvestmentFundStrategy {
  CAPITAL_PRESERVATION
  GROWTH
  AGRESSIVE_GROWTH
  INCOME
}

enum InvestmentFundStatus {
  ACTIVE
  PAUSED
  CLOSED
}

enum InvestmentFundMode {
  SIMULATION
  LIVE
}

model InvestmentFund {
  id               String                 @id @default(cuid())
  name             String                 @db.VarChar(512)
  strategyMode     InvestmentFundStrategy @default(GROWTH) @map("strategy_mode")
  totalCapital     Decimal                @default(0) @map("total_capital") @db.Decimal(18, 2)
  availableCapital Decimal                @default(0) @map("available_capital") @db.Decimal(18, 2)
  allocatedCapital Decimal                @default(0) @map("allocated_capital") @db.Decimal(18, 2)
  status           InvestmentFundStatus   @default(ACTIVE)
  mode             InvestmentFundMode     @default(SIMULATION)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  investors            FundInvestor[]
  allocations          FundAllocation[]
  performanceSnapshots FundPerformanceSnapshot[]
  distributions        FundDistribution[]

  @@map("investment_funds")
}

model FundInvestor {
  id               String         @id @default(cuid())
  fundId           String         @map("fund_id") @db.VarChar(36)
  fund             InvestmentFund @relation(fields: [fundId], references: [id], onDelete: Cascade)
  userId           String         @map("user_id") @db.VarChar(36)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  investedAmount   Decimal        @default(0) @map("invested_amount") @db.Decimal(18, 2)
  ownershipPercent Float          @default(0) @map("ownership_percent")

  createdAt DateTime @default(now()) @map("created_at")

  distributions FundDistribution[]

  @@unique([fundId, userId])
  @@map("fund_investors")
}

model FundAllocation {
  id                String         @id @default(cuid())
  fundId            String         @map("fund_id") @db.VarChar(36)
  fund              InvestmentFund @relation(fields: [fundId], references: [id], onDelete: Cascade)
  dealId            String         @map("deal_id") @db.VarChar(36)
  deal              AmfCapitalDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  allocatedAmount   Decimal        @map("allocated_amount") @db.Decimal(18, 2)
  allocationPercent Float          @map("allocation_percent")
  rationaleJson     Json?          @map("rationale_json")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("fund_allocations")
}

model FundPerformanceSnapshot {
  id                    String         @id @default(cuid())
  fundId                String         @map("fund_id") @db.VarChar(36)
  fund                  InvestmentFund @relation(fields: [fundId], references: [id], onDelete: Cascade)
  timestamp             DateTime       @default(now())
  totalValue            Decimal        @map("total_value") @db.Decimal(18, 2)
  allocatedValue        Decimal        @map("allocated_value") @db.Decimal(18, 2)
  unrealizedPerformance Float          @map("unrealized_performance")
  realizedPerformance   Float          @map("realized_performance")
  diversificationScore  Float          @map("diversification_score")
  riskScore             Float          @map("risk_score")

  @@map("fund_performance_snapshots")
}

enum FundDistributionType {
  PROFIT
  RETURN_OF_CAPITAL
}

model FundDistribution {
  id         String               @id @default(cuid())
  fundId     String               @map("fund_id") @db.VarChar(36)
  fund       InvestmentFund       @relation(fields: [fundId], references: [id], onDelete: Cascade)
  investorId String               @map("investor_id") @db.VarChar(36)
  investor   FundInvestor         @relation(fields: [investorId], references: [id], onDelete: Cascade)
  amount     Decimal              @db.Decimal(18, 2)
  type       FundDistributionType @default(PROFIT)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("fund_distributions")
}

model AmfPolicy {
  id                    String  @id @default("amf_policy_global")
  fundMode              String  @default("SIMULATION") @map("fund_mode") @db.VarChar(24) // SIMULATION | PRIVATE | REGISTERED
  maxInvestorsPerDeal   Int     @default(50) @map("max_investors_per_deal")
  requireIndependentSpv Boolean @default(true) @map("require_independent_spv")
  blockPublicMarketing  Boolean @default(true) @map("block_public_marketing")
  disableAutoAllocation Boolean @default(true) @map("disable_auto_allocation")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("amf_policies")
}

// ---------------------------------------------------------------------------
// Soins Hub (Senior Care) — operational residences, residents, family, alerts
// ---------------------------------------------------------------------------

enum CareResidenceType {
  INDEPENDENT
  ASSISTED
  MEDICAL
}

enum CareServiceKind {
  MEDICAL
  DAILY_LIVING
  SAFETY
}

enum CareFoodPlanTier {
  NONE
  ONE_MEAL
  FULL
}

enum CareLevel {
  INDEPENDENT
  ASSISTED
  MEMORY_CARE
  SKILLED
}

enum CareHubEventKind {
  ALERT
  HEALTH
  MOVEMENT
  EMERGENCY
}

enum CareHubEventSeverity {
  LOW
  MEDIUM
  HIGH
}

/// Senior care residence listing (Soins Hub).
model CareResidence {
  id          String            @id @default(cuid())
  title       String            @db.VarChar(512)
  description String?           @db.Text
  city        String            @db.VarChar(160)
  address     String            @db.VarChar(512)
  type        CareResidenceType
  basePrice   Float             @map("base_price")
  operatorId  String?           @map("operator_id") @db.VarChar(36)
  operator    User?             @relation("CareResidenceOperator", fields: [operatorId], references: [id], onDelete: SetNull)

  units     CareUnit[]
  services  CareService[]
  foodPlans FoodPlan[]
  residents ResidentProfile[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([city])
  @@index([operatorId])
  @@map("care_residences")
}

model CareUnit {
  id           String        @id @default(cuid())
  residenceId  String        @map("residence_id") @db.VarChar(36)
  residence    CareResidence @relation(fields: [residenceId], references: [id], onDelete: Cascade)
  title        String        @db.VarChar(256)
  price        Float
  availability Boolean       @default(true)
  roomType     String        @map("room_type") @db.VarChar(64)

  @@index([residenceId])
  @@map("care_units")
}

model CareService {
  id            String          @id @default(cuid())
  residenceId   String          @map("residence_id") @db.VarChar(36)
  residence     CareResidence   @relation(fields: [residenceId], references: [id], onDelete: Cascade)
  name          String          @db.VarChar(256)
  type          CareServiceKind
  price         Float
  requiredLevel CareLevel       @map("required_level")

  @@index([residenceId])
  @@map("care_services")
}

model FoodPlan {
  id          String           @id @default(cuid())
  residenceId String           @map("residence_id") @db.VarChar(36)
  residence   CareResidence    @relation(fields: [residenceId], references: [id], onDelete: Cascade)
  name        CareFoodPlanTier
  mealsPerDay Int              @default(0) @map("meals_per_day")
  price       Float

  residentProfiles ResidentProfile[]

  @@unique([residenceId, name])
  @@map("care_food_plans")
}

model ResidentProfile {
  id               String        @id @default(cuid())
  userId           String        @unique @map("user_id") @db.VarChar(36)
  user             User          @relation("ResidentProfileUser", fields: [userId], references: [id], onDelete: Cascade)
  residenceId      String        @map("residence_id") @db.VarChar(36)
  residence        CareResidence @relation(fields: [residenceId], references: [id], onDelete: Cascade)
  careLevel        CareLevel     @map("care_level")
  foodPlanId       String?       @map("food_plan_id") @db.VarChar(36)
  foodPlan         FoodPlan?     @relation(fields: [foodPlanId], references: [id], onDelete: SetNull)
  healthNotes      String?       @map("health_notes") @db.Text
  emergencyContact String?       @map("emergency_contact") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  familyAccess  FamilyAccess[]
  careEvents    CareEvent[]
  cameraStreams CameraStream[]
  chatMessages  CareChatMessage[]

  @@index([residenceId])
  @@map("care_resident_profiles")
}

model FamilyAccess {
  id               String          @id @default(cuid())
  residentId       String          @map("resident_id") @db.VarChar(36)
  resident         ResidentProfile @relation(fields: [residentId], references: [id], onDelete: Cascade)
  familyUserId     String          @map("family_user_id") @db.VarChar(36)
  familyUser       User            @relation("CareFamilyMember", fields: [familyUserId], references: [id], onDelete: Cascade)
  canViewCamera    Boolean         @default(false) @map("can_view_camera")
  canChat          Boolean         @default(true) @map("can_chat")
  canReceiveAlerts Boolean         @default(true) @map("can_receive_alerts")

  @@unique([residentId, familyUserId])
  @@index([familyUserId])
  @@map("care_family_access")
}

model CareEvent {
  id         String               @id @default(cuid())
  residentId String               @map("resident_id") @db.VarChar(36)
  resident   ResidentProfile      @relation(fields: [residentId], references: [id], onDelete: Cascade)
  type       CareHubEventKind
  message    String               @db.Text
  severity   CareHubEventSeverity
  createdAt  DateTime             @default(now()) @map("created_at")

  @@index([residentId, createdAt(sort: Desc)])
  @@map("care_events")
}

model CameraStream {
  id         String          @id @default(cuid())
  residentId String          @map("resident_id") @db.VarChar(36)
  resident   ResidentProfile @relation(fields: [residentId], references: [id], onDelete: Cascade)
  streamUrl  String          @map("stream_url") @db.VarChar(2048)
  isActive   Boolean         @default(true) @map("is_active")

  @@index([residentId])
  @@map("care_camera_streams")
}

/// Mapped to DB as `care_chat_messages` — “ChatMessage” concept in product docs.
model CareChatMessage {
  id         String          @id @default(cuid())
  residentId String          @map("resident_id") @db.VarChar(36)
  resident   ResidentProfile @relation(fields: [residentId], references: [id], onDelete: Cascade)
  senderId   String          @map("sender_id") @db.VarChar(36)
  sender     User            @relation("CareChatSender", fields: [senderId], references: [id], onDelete: Cascade)
  message    String          @db.Text
  createdAt  DateTime        @default(now()) @map("created_at")

  @@index([residentId, createdAt(sort: Desc)])
  @@index([senderId])
  @@map("care_chat_messages")
}

/// Structured e-sign audit row — traceable identity, time, location (internal compliance).
model FormSignature {
  id              String   @id @default(cuid())
  entityType      String   @map("entity_type") @db.VarChar(64)
  entityId        String   @map("entity_id") @db.VarChar(64)
  signerId        String   @map("signer_id") @db.VarChar(36)
  signer          User     @relation("FormSignatureSigner", fields: [signerId], references: [id], onDelete: Cascade)
  signerType      String   @map("signer_type") @db.VarChar(24)
  signedAt        DateTime @map("signed_at")
  signedDate      String   @map("signed_date") @db.VarChar(16)
  signedTime      String   @map("signed_time") @db.VarChar(16)
  signedCity      String?  @map("signed_city") @db.VarChar(160)
  signatureMethod String   @map("signature_method") @db.VarChar(24)
  /**
   * Integrity proof for captured signature payload / method binding
   */
  signatureHash   String   @map("signature_hash") @db.VarChar(128)
  /**
   * SHA-256 of canonical document content at signing time
   */
  documentHash    String?  @map("document_hash") @db.VarChar(128)
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([signerId])
  @@index([signedAt])
  @@map("form_signatures")
}

/// DS (seller declaration) transaction linkage — traceability; distinct from `SellerDeclarationRecord` listing forms.
model SellerDeclaration {
  id              String   @id @default(cuid())
  listingId       String?  @map("listing_id") @db.VarChar(64)
  contractId      String?  @map("contract_id") @db.VarChar(64)
  referenceNumber String   @unique @map("reference_number") @db.VarChar(48)
  status          String   @default("recorded") @map("status") @db.VarChar(32)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([listingId])
  @@index([contractId])
  @@map("compliance_seller_declarations")
}

/// Chunked knowledge for source-grounded drafting (OACIQ forms, uploaded references).
/// Embeddings are a JSON number array (same semantics as `Float[]`; stored as Json for Prisma portability).
model VectorDocument {
  id        String   @id @default(cuid())
  sourceKey String   @map("source_key") @db.VarChar(512)
  title     String?  @db.VarChar(512)
  content   String   @db.Text
  /// Float vector as JSON array. Dimension matches ingest/query mode: OpenAI `text-embedding-3-small` when `OPENAI_API_KEY` is set, else deterministic stub in `lib/ai/vector-store.ts` (re-ingest after switching modes).
  embedding Json     @map("embedding")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([sourceKey])
  @@map("vector_documents")
}

/**
 * LECIPM Privacy + Consent + Compliance System
 * Aligned with Québec (Law 25) and OACIQ standards.
 */

enum PrivacyPurpose {
  TRANSACTION_EXECUTION
  IDENTITY_VERIFICATION
  DISCLOSURE_TO_BROKERS
  DISCLOSURE_TO_INFORMATION_DISSEMINATION_SERVICE
  DISCLOSURE_TO_BUYER_BROKER
  DISCLOSURE_TO_UNREPRESENTED_BUYER
  MARKETING
  COMMERCIAL_PROSPECTING
  SECONDARY_USE
  LOCKBOX_CODE_DISCLOSURE
  ALARM_CODE_DISCLOSURE
  PHONE_DISCLOSURE_FOR_VISIT
  SOLD_PRICE_DISCLOSURE_TO_LICENSE_HOLDERS
}

enum PrivacySensitivityLevel {
  PUBLIC
  INTERNAL
  CONFIDENTIAL
  RESTRICTED
  HIGHLY_SENSITIVE
}

enum PrivacyDataCategory {
  CONTACT_INFORMATION
  IDENTITY_INFORMATION
  FINANCIAL_INFORMATION
  LEGAL_AUTHORITY_INFORMATION
  PROPERTY_LINKED_SENSITIVE_INFORMATION
  COMMUNICATION_MEDIA
}

enum ConfidentialityIncidentCategory {
  UNAUTHORIZED_ACCESS
  UNAUTHORIZED_DISCLOSURE
  LOSS_OF_DATA
  THEFT_OF_DATA
  SECURITY_BREACH
  HUMAN_ERROR
  MALICIOUS_ACT
}

enum ConfidentialityIncidentRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Consent {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactionId  String?   @map("transaction_id")
  purpose        String // "MARKETING", "SHARE_WITH_BROKERS", etc.
  scopeText      String?   @map("scope_text") @db.Text
  granted        Boolean   @default(false)
  explicit       Boolean   @default(false)
  written        Boolean   @default(false)
  grantedAt      DateTime  @default(now()) @map("granted_at")
  expiresAt      DateTime? @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")
  legalBasisText String?   @map("legal_basis_text") @db.Text
  evidenceRef    String?   @map("evidence_ref")
  createdBy      String?   @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([transactionId])
  @@map("privacy_consent_records")
}

model PrivacyOfficer {
  id                  String    @id @default(cuid())
  organizationId      String?   @map("organization_id")
  name                String
  title               String
  email               String
  phone               String?
  published           Boolean   @default(false)
  publishedAt         DateTime? @map("published_at")
  delegatedFromUserId String?   @map("delegated_from_user_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@map("privacy_officers")
}

model PrivacyTransferLog {
  id                String   @id @default(cuid())
  transactionId     String?  @map("transaction_id")
  fromDepartment    String   @map("from_department")
  toDepartment      String   @map("to_department")
  initiatedBy       String   @map("initiated_by")
  approvedBy        String?  @map("approved_by")
  purpose           String   @db.Text
  fieldsTransferred Json     @map("fields_transferred")
  redacted          Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([transactionId])
  @@map("privacy_transfer_logs")
