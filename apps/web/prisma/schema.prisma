  @@index([requestedBy])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// 5. Crisis Response – events, action log
// ---------------------------------------------------------------------------
enum CrisisSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model CrisisEvent {
  id          String            @id @default(uuid())
  title       String
  severity    CrisisSeverity
  status      String            @default("ACTIVE") // ACTIVE | CONTAINED | RESOLVED
  region      String? // market or region
  startedAt   DateTime          @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?
  playbookRef String? // reference to runbook
  summary     String?
  createdAt   DateTime
  updatedAt   DateTime          @updatedAt
  actionLogs  CrisisActionLog[]

  @@index([status])
  @@index([severity])
  @@index([startedAt])
}

model CrisisActionLog {
  id          String      @id @default(uuid())
  crisisId    String
  crisis      CrisisEvent @relation(fields: [crisisId], references: [id], onDelete: Cascade)
  actionType  String // BOOKING_FREEZE | PAYOUT_FREEZE | CONTENT_TAKEDOWN | ESCALATION
  targetType  String?
  targetId    String?
  performedBy String
  reasonCode  String?
  payload     Json?
  createdAt   DateTime    @default(now())

  @@index([crisisId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// 6. Regulatory Compliance – requirements, reviews
// ---------------------------------------------------------------------------
model ComplianceRequirement {
  id             String   @id @default(uuid())
  marketId       String
  requirementKey String // TAX_REGISTRATION | LICENSING | DATA_RETENTION | DISCLOSURE
  name           String
  description    String?
  active         Boolean
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([marketId])
  @@index([requirementKey])
}

model ComplianceReview {
  id            String    @id @default(uuid())
  requirementId String?
  entityType    String // USER | LISTING | BOOKING
  entityId      String
  marketId      String?
  status        String // PENDING | COMPLIANT | NON_COMPLIANT | EXCEPTION
  reviewedAt    DateTime?
  reviewedBy    String?
  notes         String?
  documentRefs  Json
  createdAt     DateTime  @default(now())
