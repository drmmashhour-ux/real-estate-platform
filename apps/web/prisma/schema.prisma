  activatedUsers     Int      @default(0) @map("activated_users")
  payingUsers        Int      @default(0) @map("paying_users")
  /// Content
  postsCreated       Int      @default(0) @map("posts_created")
  contentViews       Int      @default(0) @map("content_views")
  contentClicks      Int      @default(0) @map("content_clicks")
  contentConversions Int      @default(0) @map("content_conversions")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

