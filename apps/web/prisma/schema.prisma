  @@index([propertyIdentityId])
  @@index([brokerIdentityId])
  @@index([ownerIdentityId])
  @@map("broker_authorization_history")
}

model IdentityRiskProfile {
  id                  String   @id @default(uuid())
  identityType        String   @map("identity_type") // OWNER | BROKER | ORGANIZATION
  identityId          String   @map("identity_id")
  riskScore           Int      @map("risk_score") // 0-100
  riskLevel           String   @map("risk_level") // low | medium | high | critical
  riskReasons         Json?    @map("risk_reasons")
  investigationStatus String?  @map("investigation_status") // open | closed | pending_review
  updatedAt           DateTime @updatedAt @map("updated_at")
  createdAt           DateTime @default(now()) @map("created_at")

  @@unique([identityType, identityId])
  @@index([identityType])
  @@index([riskLevel])
  @@map("identity_risk_profiles")
}

model IdentityEvent {
  id           String   @id @default(uuid())
  identityType String   @map("identity_type")
  identityId   String   @map("identity_id")
  eventType    String   @map("event_type")
  eventData    Json?    @map("event_data")
  createdBy    String?  @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([identityType, identityId])
  @@index([eventType])
  @@map("identity_events")
}

// OwnerIdentity and BrokerIdentity need optional riskProfile relation - IdentityRiskProfile has identityType+identityId so we can't have FK from IdentityRiskProfile to both. So IdentityRiskProfile is standalone (identityType, identityId). Remove riskProfile from OwnerIdentity and BrokerIdentity - we look up by identityType+identityId.
model PropertyValuation {
  id                    String           @id @default(uuid())
  propertyIdentityId    String           @map("property_identity_id")
  propertyIdentity      PropertyIdentity @relation(fields: [propertyIdentityId], references: [id], onDelete: Cascade)
  listingId             String?          @map("listing_id") // Optional: BNHub or sale listing
  valuationType         String           @map("valuation_type") // sale | long_term_rental | short_term_rental | investment
  estimatedValue        Int?             @map("estimated_value") // Cents for sale; null for rent-only
  valueMin              Int?             @map("value_min")
  valueMax              Int?             @map("value_max")
  monthlyRentEstimate   Int?             @map("monthly_rent_estimate") // Cents
  nightlyRateEstimate   Int?             @map("nightly_rate_estimate") // Cents
  annualRevenueEstimate Int?             @map("annual_revenue_estimate") // Cents
  grossYieldEstimate    Float?           @map("gross_yield_estimate") // Percent
  investmentScore       Int?             @map("investment_score") // 0-100
  confidenceScore       Int              @map("confidence_score") // 0-100
  confidenceLabel       String           @map("confidence_label") // low | medium | high
  valuationSummary      String?          @map("valuation_summary")
  explanation           Json? // main_factors, positives, negatives, position_note, data_note
  comparablesSummary    Json?            @map("comparables_summary")
  riskLevel             String?          @map("risk_level") // low | medium | high (investment)
  seasonalitySummary    Json?            @map("seasonality_summary")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  @@index([propertyIdentityId])
  @@index([listingId])
  @@index([valuationType])
  @@index([confidenceLabel])
  @@map("property_valuations")
}

// ---------------------------------------------------------------------------
// Global Property Data Graph – semantic edges and market nodes
// ---------------------------------------------------------------------------
model Market {
  id           String   @id @default(uuid())
  city         String?
  municipality String?
  province     String
  country      String   @default("US")
  slug         String   @unique // e.g. "montreal-qc-ca" for city-level; "qc-ca" for province
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([province, country])
  @@index([slug])
  @@map("markets")
}

model PropertyGraphEdge {
  id             String   @id @default(uuid())
  fromEntityType String   @map("from_entity_type") // PROPERTY | USER | LISTING | MARKET | etc.
  fromEntityId   String   @map("from_entity_id")
  toEntityType   String   @map("to_entity_type")
  toEntityId     String   @map("to_entity_id")
  edgeType       String   @map("edge_type") // SIMILAR_TO | SAME_AREA | SAME_MARKET | SAME_BUILDING | OWNED_BY | LISTED_BY | etc.
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([fromEntityType, fromEntityId])
  @@index([toEntityType, toEntityId])
  @@index([edgeType])
  @@map("property_graph_edges")
}

// ---------------------------------------------------------------------------
// Market Intelligence Engine – regions, indexes, demand, investment
// ---------------------------------------------------------------------------
model MarketRegion {
  id                 String                  @id @default(uuid())
  name               String
  regionType         String                  @map("region_type") // city | municipality | neighborhood | postal_area
  parentRegionId     String?                 @map("parent_region_id")
  parentRegion       MarketRegion?           @relation("RegionHierarchy", fields: [parentRegionId], references: [id], onDelete: SetNull)
  childRegions       MarketRegion[]          @relation("RegionHierarchy")
  country            String                  @default("US")
  province           String?
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")
  propertyIdentities PropertyIdentity[]
  priceIndexRows     MarketPriceIndex[]
  rentIndexRows      MarketRentIndex[]
  bnhubIndexRows     MarketBnhubIndex[]
  demandMetrics      MarketDemandMetrics[]
  investmentScores   MarketInvestmentScore[]
  marketReports      MarketReport[]

  @@index([regionType])
  @@index([parentRegionId])
  @@index([country, province])
  @@map("market_regions")
}

model MarketPriceIndex {
  id             String       @id @default(uuid())
  marketRegionId String       @map("market_region_id")
  marketRegion   MarketRegion @relation(fields: [marketRegionId], references: [id], onDelete: Cascade)
  period         String       @map("period") // e.g. "2025-01" for monthly, "2025-W03" for weekly
  averagePrice   Int?         @map("average_price") // Cents
  medianPrice    Int?         @map("median_price") // Cents
  pricePerUnit   Int?         @map("price_per_unit") // Cents per sqm or sqft
  trendDirection String?      @map("trend_direction") // up | down | stable
  sampleSize     Int?         @map("sample_size")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@unique([marketRegionId, period])
  @@index([marketRegionId])
  @@index([period])
  @@map("market_price_index")
}

model MarketRentIndex {
  id             String       @id @default(uuid())
  marketRegionId String       @map("market_region_id")
  marketRegion   MarketRegion @relation(fields: [marketRegionId], references: [id], onDelete: Cascade)
  period         String       @map("period")
  averageRent    Int?         @map("average_rent") // Cents per month
  medianRent     Int?         @map("median_rent")
  rentPerUnit    Int?         @map("rent_per_unit") // Cents per sqm/sqft per month
  trendDirection String?      @map("trend_direction")
  sampleSize     Int?         @map("sample_size")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@unique([marketRegionId, period])
  @@index([marketRegionId])
  @@index([period])
  @@map("market_rent_index")
}

model MarketBnhubIndex {
  id                    String       @id @default(uuid())
  marketRegionId        String       @map("market_region_id")
  marketRegion          MarketRegion @relation(fields: [marketRegionId], references: [id], onDelete: Cascade)
  period                String       @map("period")
  averageNightlyRate    Int?         @map("average_nightly_rate") // Cents
  averageOccupancy      Float?       @map("average_occupancy") // 0-1
  averageMonthlyRevenue Int?         @map("average_monthly_revenue") // Cents
  averageRating         Float?       @map("average_rating")
  sampleSize            Int?         @map("sample_size")
  createdAt             DateTime     @default(now()) @map("created_at")

  @@unique([marketRegionId, period])
  @@index([marketRegionId])
  @@index([period])
  @@map("market_bnhub_index")
}

model MarketDemandMetrics {
  id             String       @id @default(uuid())
  marketRegionId String       @map("market_region_id")
  marketRegion   MarketRegion @relation(fields: [marketRegionId], references: [id], onDelete: Cascade)
  period         String       @map("period")
  demandScore    Float?       @map("demand_score") // 0-100 or normalized
  searchVolume   Int?         @map("search_volume")
  bookingVolume  Int?         @map("booking_volume")
  inventoryLevel Int?         @map("inventory_level") // Listing count in region
  createdAt      DateTime     @default(now()) @map("created_at")

  @@unique([marketRegionId, period])
  @@index([marketRegionId])
  @@index([period])
  @@map("market_demand_metrics")
}

model MarketInvestmentScore {
  id                 String           @id @default(uuid())
  propertyIdentityId String           @map("property_identity_id")
  propertyIdentity   PropertyIdentity @relation(fields: [propertyIdentityId], references: [id], onDelete: Cascade)
  marketRegionId     String           @map("market_region_id")
  marketRegion       MarketRegion     @relation(fields: [marketRegionId], references: [id], onDelete: Cascade)
  investmentScore    Int              @map("investment_score") // 0-100
  riskLevel          String           @map("risk_level") // low | medium | high
  summary            String?
  createdAt          DateTime         @default(now()) @map("created_at")

  @@unique([propertyIdentityId, marketRegionId])
  @@index([propertyIdentityId])
  @@index([marketRegionId])
  @@map("market_investment_scores")
}

model MarketReport {
  id             String       @id @default(uuid())
  marketRegionId String       @map("market_region_id")
  marketRegion   MarketRegion @relation(fields: [marketRegionId], references: [id], onDelete: Cascade)
  reportPeriod   String       @map("report_period") // e.g. "2025-01"
  reportSummary  String?      @map("report_summary")
  reportData     Json?        @map("report_data")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@unique([marketRegionId, reportPeriod])
  @@index([marketRegionId])
  @@index([reportPeriod])
  @@map("market_reports")
}

/// Time-series snapshots for city/property-type trend analysis (manual, CSV, or future API).
model MarketDataPoint {
  id               String   @id @default(cuid())
  city             String
  postalCode       String?  @map("postal_code")
  propertyType     String   @map("property_type")
  avgPriceCents    Int      @map("avg_price_cents")
  medianPriceCents Int?     @map("median_price_cents")
  avgRentCents     Int?     @map("avg_rent_cents")
  transactions     Int?
  inventory        Int?
  date             DateTime
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([city, propertyType, date])
  @@index([city, date])
  @@map("market_data_points")
}

// ---------------------------------------------------------------------------
// Document Drafting – generated documents and versioning
// ---------------------------------------------------------------------------
model GeneratedDocument {
  id                      String                   @id @default(uuid())
  documentType            String                   @map("document_type") // offer | rental_agreement | broker_agreement | booking_confirmation | investment_report | verification_report | transaction_summary | dispute_report
  relatedEntityType       String                   @map("related_entity_type") // transaction | property | listing | booking | dispute
  relatedEntityId         String                   @map("related_entity_id")
  generatedById           String                   @map("generated_by")
  generatedBy             User                     @relation(fields: [generatedById], references: [id], onDelete: Restrict)
  filePath                String?                  @map("file_path") // Storage path or URL
  format                  String                   @default("html") // html | pdf | docx
  status                  String                   @default("draft") // draft | final | signed
  versionNumber           Int                      @default(1) @map("version_number")
  changeSummary           String?                  @map("change_summary")
  signatureFields         Json?                    @map("signature_fields") // [{ signerRole, signerName, signerEmail }]
  contentHtml             String?                  @map("content_html") // Rendered HTML for preview/storage
  createdAt               DateTime                 @default(now()) @map("created_at")
  closingPackageDocuments ClosingPackageDocument[]

  @@index([documentType])
  @@index([relatedEntityType, relatedEntityId])
  @@index([generatedById])
  @@index([status])
  @@map("generated_documents")
}

// ---------------------------------------------------------------------------
// Notary and Closing Integration
// ---------------------------------------------------------------------------
model Notary {
  id               String                   @id @default(uuid())
  notaryName       String                   @map("notary_name")
  notaryEmail      String                   @map("notary_email")
  notaryOffice     String?                  @map("notary_office")
  jurisdiction     String? // e.g. Quebec, Ontario
  /// Québec / regional routing for matching (e.g. montréal, laval, qc-wide).
  region           String?                  @db.VarChar(64)
  phone            String?                  @db.VarChar(32)
  address          String?                  @db.Text
  /// Chambre des notaires or other registry id — informational only.
  licenseNumber    String?                  @map("license_number") @db.VarChar(64)
  languagesJson    Json                     @default("[]") @map("languages_json")
  availabilityJson Json                     @default("{}") @map("availability_json")
  isActive         Boolean                  @default(true) @map("is_active")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")
  closingPackages  ClosingPackage[]
  dealAssignments  DealNotaryCoordination[]

  @@index([jurisdiction])
  @@index([region])
  @@map("notaries")
}

model ClosingPackage {
  id            String                   @id @default(uuid())
  transactionId String                   @map("transaction_id")
  transaction   RealEstateTransaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  packageStatus String                   @map("package_status") // draft | ready | notary_review | closing_scheduled | completed
  generatedById String                   @map("generated_by")
  generatedBy   User                     @relation(fields: [generatedById], references: [id], onDelete: Restrict)
  notaryId      String?                  @map("notary_id")
  notary        Notary?                  @relation(fields: [notaryId], references: [id], onDelete: SetNull)
  createdAt     DateTime                 @default(now()) @map("created_at")
  updatedAt     DateTime                 @updatedAt @map("updated_at")
  documents     ClosingPackageDocument[]

  @@index([transactionId])
  @@index([packageStatus])
  @@index([notaryId])
  @@map("closing_packages")
}

model ClosingPackageDocument {
  id           String            @id @default(uuid())
  packageId    String            @map("package_id")
  package      ClosingPackage    @relation(fields: [packageId], references: [id], onDelete: Cascade)
  documentId   String            @map("document_id")
  document     GeneratedDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentType String            @map("document_type") // offer | property_sheet | buyer_info | seller_info | broker_details | transaction_summary | payment_summary | ownership_verification | broker_authorization
  createdAt    DateTime          @default(now()) @map("created_at")

  @@unique([packageId, documentType])
  @@index([packageId])
  @@map("closing_package_documents")
}

// Admin verification decision per listing (cadastre + ownership/broker check)
model PropertyVerification {
  id                         String             @id @default(uuid())
  listingId                  String             @unique @map("listing_id")
  listing                    ShortTermListing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  cadastreNumber             String             @map("cadastre_number")
  verificationStatus         VerificationStatus @map("verification_status") // VERIFIED | REJECTED
  verifiedById               String?            @map("verified_by")
  verifiedAt                 DateTime?          @map("verified_at")
  notes                      String?
  requestMoreDocumentsReason String?            @map("request_more_documents_reason")
  requestMoreDocumentsById   String?            @map("request_more_documents_by")
  requestMoreDocumentsAt     DateTime?          @map("request_more_documents_at")

  @@index([verificationStatus])
  @@map("property_verifications")
}

/// Time-bound 6-digit OTP for verifying email and/or mobile (all account types).
model ContactVerificationCode {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// EMAIL | SMS
  channel        String    @map("channel") @db.VarChar(8)
  codeHash       String    @map("code_hash")
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt     DateTime? @map("consumed_at") @db.Timestamptz(6)
  failedAttempts Int       @default(0) @map("failed_attempts")
  /// E.164 when channel = SMS (must match on confirm).
  smsTargetE164  String?   @map("sms_target_e164") @db.VarChar(24)
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([userId, channel])
  @@index([expiresAt])
  @@map("contact_verification_codes")
}

// Triple verification (2): identity of the lister (gov ID + selfie)
model IdentityVerification {
  id                  String             @id @default(uuid())
  userId              String             @unique @map("user_id")
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  governmentIdFileUrl String?            @map("government_id_file")
  selfiePhotoUrl      String?            @map("selfie_photo")
  verificationStatus  VerificationStatus @default(PENDING) @map("verification_status")
  verifiedById        String?            @map("verified_by")
  verifiedAt          DateTime?          @map("verified_at")
  notes               String?
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  @@map("identity_verifications")
}

// Triple verification (3): broker license when listing_authority_type = broker
model BrokerVerification {
  id                 String             @id @default(uuid())
  userId             String             @unique @map("user_id")
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber      String             @map("license_number")
  brokerageCompany   String             @map("brokerage_company")
  verificationStatus VerificationStatus @default(PENDING) @map("verification_status")
  verifiedById       String?            @map("verified_by")
  verifiedAt         DateTime?          @map("verified_at")
  notes              String?
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  @@map("broker_verifications")
}

/// Structured service areas / specializations / languages for routing — explicit broker or admin edits only (JSON payload).
model BrokerServiceProfile {
  id        String   @id @default(cuid())
  brokerId  String   @unique @map("broker_id")
  broker    User     @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  payload   Json     @map("payload")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([brokerId])
  @@map("broker_service_profiles")
}

/// OACIQ-facing residential licence capsule (platform record; regulator-verified status remains the broker’s duty).
model LecipmBrokerLicenceProfile {
  id                       String               @id @default(cuid())
  userId                   String               @unique @map("user_id")
  user                     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName                 String?              @map("full_name") @db.VarChar(256)
  licenceNumber            String?              @map("licence_number") @db.VarChar(64)
  /// Platform product enforces residential brokerage paths only.
  licenceType              String               @default("residential") @map("licence_type") @db.VarChar(32)
  /// active | inactive | pending
  licenceStatus            String               @default("pending") @map("licence_status") @db.VarChar(24)
  neq                      String?              @db.VarChar(32)
  gst                      String?              @db.VarChar(32)
  qst                      String?              @db.VarChar(32)
  address                  String?              @db.Text
  addressLine              String?              @map("address_line") @db.VarChar(256)
  city                     String?              @db.VarChar(128)
  province                 String?              @default("QC") @db.VarChar(32)
  postalCode               String?              @map("postal_code") @db.VarChar(16)
  practiceMode             String?              @default("INDEPENDENT") @map("practice_mode") @db.VarChar(32)
  regulator                String?              @default("OACIQ") @db.VarChar(32) // NEW
  verifiedAt               DateTime?            @map("verified_at")
  mortgageLicenceCertified Boolean              @default(false) @map("mortgage_licence_certified")
  /// Broker attestation / subscription: eligible to prepare Centris-oriented listing flows (never auto-posted by LECIPM).
  hasCentrisAccess         Boolean              @default(false) @map("has_centris_access")
  /// Optional Centris member identifier — platform does not validate with Centris; broker supplies for export metadata.
  centrisMemberId          String?              @map("centris_member_id") @db.VarChar(64)
  createdAt                DateTime             @default(now()) @map("created_at")
  updatedAt                DateTime             @updatedAt @map("updated_at")
  licenceChecks            LecipmLicenceCheck[]

  @@map("lecipm_broker_licence_profiles")
}

/// Append-only licence / scope evaluation for audits (login, deal create, drafting).
model LecipmLicenceCheck {
  id          String                      @id @default(cuid())
  brokerId    String                      @map("broker_id")
  broker      User                        @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  profileId   String?                     @map("profile_id")
  profile     LecipmBrokerLicenceProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  isValid     Boolean                     @map("is_valid")
  scopeValid  Boolean                     @map("scope_valid")
  riskLevel   String?                     @map("risk_level") @db.VarChar(16)
  contextJson Json?                       @map("context_json")
  checkedAt   DateTime                    @default(now()) @map("checked_at")

  @@index([brokerId, checkedAt(sort: Desc)])
  @@map("lecipm_licence_checks")
}

// Quebec / Canada broker tax registration (BN, GST, QST) — provided by broker; format-checked only.
model BrokerTaxRegistration {
  id                 String                      @id @default(uuid())
  userId             String                      @unique @map("user_id")
  user               User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  legalName          String                      @map("legal_name")
  businessName       String?                     @map("business_name")
  businessNumberNine String                      @map("business_number_nine") // 9 digits
  gstNumber          String?                     @map("gst_number") // e.g. 123456789RT0001
  qstNumber          String?                     @map("qst_number") // required when province is QC; format 1234567890TQ0001
  businessAddress    String                      @map("business_address") @db.Text
  province           String                      @default("QC") // default Quebec
  status             BrokerTaxRegistrationStatus @default(PENDING_STAFF_REVIEW)
  adminNotes         String?                     @map("admin_notes") @db.Text
  reviewedAt         DateTime?                   @map("reviewed_at")
  reviewedByUserId   String?                     @map("reviewed_by_user_id")
  reviewedBy         User?                       @relation("BrokerTaxReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  createdAt          DateTime                    @default(now()) @map("created_at")
  updatedAt          DateTime                    @updatedAt @map("updated_at")

  @@index([status])
  @@index([province])
  @@map("broker_tax_registrations")
}

// Triple verification (4): geo-location matches cadastre address
model PropertyLocationValidation {
  id               String             @id @default(uuid())
  listingId        String             @unique @map("listing_id")
  listing          ShortTermListing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  latitude         Float              @map("latitude")
  longitude        Float              @map("longitude")
  address          String             @map("address")
  validationStatus VerificationStatus @default(PENDING) @map("validation_status") // PENDING | VERIFIED | REJECTED
  validatedById    String?            @map("validated_by")
  validatedAt      DateTime?          @map("validated_at")
  notes            String?
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  @@map("property_location_validation")
}

/// OTA / channel platforms for BNHub external listing mapping & channel manager
enum BnhubChannelPlatform {
  BOOKING_COM
  AIRBNB
  EXPEDIA
  VRBO
  /// Metasearch / Google Hotels — map when partner or feed supplies a stable property ref
  TRIVAGO
  HOTELS_COM
  GOOGLE_HOTEL
  DIRECT
  OTHER
}

enum BnhubChannelConnectionType {
  ICAL
  API
}

enum BnhubChannelConnectionStatus {
  ACTIVE
  PAUSED
  ERROR
}

enum BnhubChannelListingMapStatus {
  LINKED
  PENDING
  ERROR
}

enum BnhubChannelEventSource {
  BNHUB
  EXTERNAL
}

enum BnhubChannelEventKind {
  RESERVATION
  BLOCK
  AVAILABILITY_UPDATE
}

enum BnhubOtaSyncType {
  IMPORT
  EXPORT
}

enum BnhubOtaSyncResultStatus {
  SUCCESS
  FAILED
}

/// Per-night calendar: available, host/channel blocked, or booked (platform or external)
enum BnhubDayAvailabilityStatus {
  AVAILABLE
  BLOCKED
  BOOKED
}

/// Where the booking was originated (BNHub core vs imported channel)
enum BnhubBookingSource {
  LOCAL
  AIRBNB
  BOOKING_COM
  EXPEDIA
  OTHER
}

/// Last push/pull health for an external listing mapping
enum BnhubChannelSyncStatus {
  IDLE
  OK
  ERROR
  SYNCING
}

// Availability calendar: which dates are available; optional price override per date
model AvailabilitySlot {
  id                 String                     @id @default(uuid())
  date               DateTime
  available          Boolean                    @default(true)
  /// Preferred status for integrations; keep `available` in sync in app code
  dayStatus          BnhubDayAvailabilityStatus @default(AVAILABLE) @map("day_status")
  /// When BOOKED from a BNHub booking row — cleared on cancellation
  bookedByBookingId  String?                    @map("booked_by_booking_id")
  bookedByBooking    Booking?                   @relation(fields: [bookedByBookingId], references: [id], onDelete: SetNull)
  priceOverrideCents Int? // Special price for this date (overrides listing base)
  minStayNights      Int? // Override min stay for this date
  listingId          String
  listing            ShortTermListing           @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, date])
  @@index([listingId])
  @@index([date])
  @@index([bookedByBookingId])
}

/// Maps BNHub listing ↔ external OTA property id (Booking.com, Airbnb, Expedia, etc.)
model BnhubExternalListingMapping {
  id         String                 @id @default(cuid())
  listingId  String                 @map("listing_id")
  listing    ShortTermListing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  platform   BnhubChannelPlatform   @map("platform")
  externalId String                 @map("external_id")
  syncStatus BnhubChannelSyncStatus @default(IDLE) @map("sync_status")
  lastError  String?                @map("last_error") @db.Text
  lastSyncAt DateTime?              @map("last_sync_at")
  createdAt  DateTime               @default(now()) @map("created_at")
  updatedAt  DateTime               @updatedAt @map("updated_at")
  syncLogs   BnhubChannelSyncLog[]

  @@unique([listingId, platform])
  @@index([externalId])
  @@index([syncStatus])
  @@map("external_mapping")
}

/// Audit log for channel sync / webhook errors
model BnhubChannelSyncLog {
  id        String                       @id @default(cuid())
  mappingId String?                      @map("mapping_id")
  mapping   BnhubExternalListingMapping? @relation(fields: [mappingId], references: [id], onDelete: SetNull)
  listingId String?                      @map("listing_id")
  platform  String?
  direction String // push | pull | webhook_in
  status    String // success | error
  message   String?                      @db.Text
  payload   Json?
  createdAt DateTime                     @default(now()) @map("created_at")

  @@index([listingId])
  @@index([createdAt])
  @@map("bnhub_channel_sync_logs")
}

/// Host-owned OTA / iCal channel connection (import URL, future API keys).
model BnhubChannelConnection {
  id                   String                       @id @default(uuid()) @map("id")
  userId               String                       @map("user_id")
  user                 User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform             BnhubChannelPlatform         @map("platform")
  connectionType       BnhubChannelConnectionType   @map("connection_type")
  externalListingId    String?                      @map("external_listing_id")
  icalImportUrl        String?                      @map("ical_import_url") @db.Text
  icalExportUrl        String?                      @map("ical_export_url") @db.Text
  status               BnhubChannelConnectionStatus @default(ACTIVE) @map("status")
  lastSyncAt           DateTime?                    @map("last_sync_at")
  syncFrequencyMinutes Int                          @default(30) @map("sync_frequency_minutes")
  lastError            String?                      @map("last_error") @db.Text
  createdAt            DateTime                     @default(now()) @map("created_at")
  updatedAt            DateTime                     @updatedAt @map("updated_at")

  mappings BnhubChannelListingMapping[]
  syncLogs BnhubOtaSyncLog[]
  events   BnhubChannelCalendarEvent[]

  @@index([userId])
  @@index([platform])
  @@index([status])
  @@index([lastSyncAt])
  @@map("bnhub_channel_connections")
}

/// Links a BNHub listing to a channel connection (one external ref per pair).
model BnhubChannelListingMapping {
  id                  String                       @id @default(uuid()) @map("id")
  listingId           String                       @map("listing_id")
  listing             ShortTermListing             @relation(fields: [listingId], references: [id], onDelete: Cascade)
  channelConnectionId String                       @map("channel_connection_id")
  channelConnection   BnhubChannelConnection       @relation(fields: [channelConnectionId], references: [id], onDelete: Cascade)
  externalListingRef  String                       @map("external_listing_ref")
  mappingStatus       BnhubChannelListingMapStatus @default(LINKED) @map("mapping_status")
  createdAt           DateTime                     @default(now()) @map("created_at")

  @@unique([listingId, channelConnectionId], map: "bnhub_channel_mappings_listing_connection_key")
  @@index([channelConnectionId])
  @@index([listingId])
  @@map("bnhub_channel_mappings")
}

/// Normalized calendar events from BNHub or external iCal/API (audit + UI).
model BnhubChannelCalendarEvent {
  id                  String                  @id @default(uuid()) @map("id")
  listingId           String                  @map("listing_id")
  listing             ShortTermListing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  channelConnectionId String?                 @map("channel_connection_id")
  channelConnection   BnhubChannelConnection? @relation(fields: [channelConnectionId], references: [id], onDelete: SetNull)
  source              BnhubChannelEventSource @map("source")
  platform            BnhubChannelPlatform    @map("platform")
  externalEventId     String?                 @map("external_event_id")
  eventType           BnhubChannelEventKind   @map("event_type")
  startDate           DateTime                @map("start_date") @db.Date
  endDate             DateTime                @map("end_date") @db.Date
  guestName           String?                 @map("guest_name")
  metadataJson        Json                    @default("{}") @map("metadata_json")
  createdAt           DateTime                @default(now()) @map("created_at")

  @@index([listingId])
  @@index([channelConnectionId])
  @@index([source])
  @@index([startDate])
  @@index([platform])
  @@map("bnhub_channel_events")
}

/// Channel manager sync run log (import/export).
model BnhubOtaSyncLog {
  id           String                   @id @default(uuid()) @map("id")
  connectionId String                   @map("connection_id")
  connection   BnhubChannelConnection   @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  listingId    String?                  @map("listing_id")
  listing      ShortTermListing?        @relation(fields: [listingId], references: [id], onDelete: SetNull)
  syncType     BnhubOtaSyncType         @map("sync_type")
  status       BnhubOtaSyncResultStatus @map("status")
  message      String?                  @map("message") @db.Text
  payload      Json?                    @map("payload")
  createdAt    DateTime                 @default(now()) @map("created_at")

  @@index([connectionId])
  @@index([listingId])
  @@index([createdAt])
  @@index([status])
  @@map("bnhub_sync_logs")
}

/// AI-assisted OTA / metasearch parsing & webhook normalization (audit trail; host-owned).
model BnhubOtaAiTrace {
  id          String            @id @default(cuid())
  userId      String            @map("user_id")
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId   String?           @map("listing_id")
  listing     ShortTermListing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  traceType   String            @map("trace_type") @db.VarChar(40)
  sourceLabel String?           @map("source_label") @db.VarChar(80)
  inputDigest String            @map("input_digest") @db.VarChar(64)
  resultJson  Json              @map("result_json")
  model       String?           @map("model") @db.VarChar(80)
  createdAt   DateTime          @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@index([listingId])
  @@map("bnhub_ota_ai_traces")
}

// ---------------------------------------------------------------------------
// BNHub marketplace payments — escrow-like payout control (not regulated escrow)
// Amounts in minor units (cents) unless noted.
// ---------------------------------------------------------------------------

enum BnhubMpAccountRole {
  HOST
  PLATFORM
}

enum BnhubMpProcessor {
  STRIPE
}

enum BnhubMpOnboardingStatus {
  NOT_STARTED
  PENDING
  ACTIVE
  RESTRICTED
  REJECTED
}

enum BnhubMpVerificationState {
  UNVERIFIED
  PENDING
  VERIFIED
  RESTRICTED
}

enum BnhubMpReservationPaymentStatus {
  DRAFT
  REQUIRES_ACTION
  PROCESSING
  AUTHORIZED
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
  CANCELLED
  DISPUTED
}

enum BnhubMpCaptureMode {
  AUTOMATIC
  MANUAL
  PARTIAL_CAPTURE_READY
}

enum BnhubMpFundsFlow {
  DESTINATION_CHARGE
  SEPARATE_CHARGE_TRANSFER
  MANUAL_RELEASE
}

enum BnhubMpRiskHold {
  NONE
  HELD
  UNDER_REVIEW
  RELEASE_BLOCKED
}

enum BnhubMpPayoutStatus {
  PENDING
  SCHEDULED
  HELD
  IN_TRANSIT
  PAID
  FAILED
  REVERSED
  CANCELLED
}

enum BnhubMpHoldType {
  RISK_HOLD
  DISPUTE_HOLD
  PAYOUT_RESERVE
  SECURITY_HOLD
  COMPLIANCE_HOLD
}

enum BnhubMpHoldStatus {
  ACTIVE
  RELEASED
  EXPIRED
  CANCELLED
}

enum BnhubMpRefundType {
  FULL
  PARTIAL
  CANCELLATION
  GOODWILL
  DISPUTE_RESOLUTION
}

enum BnhubMpRefundStatus {
  DRAFT
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum BnhubMpDisputeStatus {
  OPEN
  WARNING_NEEDS_RESPONSE
  UNDER_REVIEW
  WON
  LOST
  CLOSED
}

enum BnhubMpPaymentEventActor {
  SYSTEM
  GUEST
  HOST
  ADMIN
  WEBHOOK
}

enum BnhubMpLedgerEntity {
  PAYMENT
  PAYOUT
  REFUND
  FEE
  RESERVE
  ADJUSTMENT
}

enum BnhubMpLedgerDirection {
  DEBIT
  CREDIT
}

enum BnhubMpWebhookInboxStatus {
  RECEIVED
  PROCESSED
  FAILED
  IGNORED
}

model BnhubPaymentAccount {
  id                 String                   @id @default(uuid()) @map("id")
  userId             String                   @map("user_id")
  user               User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleType           BnhubMpAccountRole       @map("role_type")
  processor          BnhubMpProcessor         @map("processor")
  processorAccountId String                   @map("processor_account_id")
  onboardingStatus   BnhubMpOnboardingStatus  @default(NOT_STARTED) @map("onboarding_status")
  payoutsEnabled     Boolean                  @default(false) @map("payouts_enabled")
  chargesEnabled     Boolean                  @default(false) @map("charges_enabled")
  requirementsJson   Json                     @default("{}") @map("requirements_json")
  verificationStatus BnhubMpVerificationState @default(UNVERIFIED) @map("verification_status")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")

  @@unique([userId, processor, roleType], map: "bnhub_payment_accounts_user_processor_role_key")
  @@index([userId])
  @@index([processorAccountId])
  @@index([onboardingStatus])
  @@map("bnhub_payment_accounts")
}

model BnhubPaymentQuote {
  id                      String           @id @default(uuid()) @map("id")
  bookingId               String?          @map("booking_id")
  booking                 Booking?         @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  listingId               String           @map("listing_id")
  listing                 ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  guestUserId             String           @map("guest_user_id")
  guest                   User             @relation("BnhubPaymentQuoteGuest", fields: [guestUserId], references: [id], onDelete: Cascade)
  hostUserId              String           @map("host_user_id")
  host                    User             @relation("BnhubPaymentQuoteHost", fields: [hostUserId], references: [id], onDelete: Cascade)
  nightlySubtotalCents    Int              @map("nightly_subtotal_cents")
  cleaningFeeCents        Int              @default(0) @map("cleaning_fee_cents")
  taxTotalCents           Int              @default(0) @map("tax_total_cents")
  serviceFeeCents         Int              @default(0) @map("service_fee_cents")
  addOnTotalCents         Int              @default(0) @map("add_on_total_cents")
  bundleTotalCents        Int              @default(0) @map("bundle_total_cents")
  membershipDiscountCents Int              @default(0) @map("membership_discount_cents")
  couponDiscountCents     Int              @default(0) @map("coupon_discount_cents")
  securityHoldCents       Int              @default(0) @map("security_hold_cents")
  grandTotalCents         Int              @map("grand_total_cents")
  currency                String           @default("USD") @map("currency")
  pricingSnapshotJson     Json             @map("pricing_snapshot_json")
  expiresAt               DateTime         @map("expires_at")
  createdAt               DateTime         @default(now()) @map("created_at")

  reservationPayments BnhubReservationPayment[]

  @@index([bookingId])
  @@index([listingId])
  @@index([guestUserId])
  @@index([hostUserId])
  @@index([expiresAt])
  @@map("bnhub_payment_quotes")
}

model BnhubReservationPayment {
  id                         String                          @id @default(uuid()) @map("id")
  bookingId                  String                          @unique @map("booking_id")
  booking                    Booking                         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  paymentQuoteId             String?                         @map("payment_quote_id")
  paymentQuote               BnhubPaymentQuote?              @relation(fields: [paymentQuoteId], references: [id], onDelete: SetNull)
  legacyPaymentId            String?                         @unique @map("legacy_payment_id")
  legacyPayment              Payment?                        @relation(fields: [legacyPaymentId], references: [id], onDelete: SetNull)
  guestUserId                String                          @map("guest_user_id")
  guest                      User                            @relation("BnhubReservationPaymentGuest", fields: [guestUserId], references: [id], onDelete: Cascade)
  hostUserId                 String                          @map("host_user_id")
  host                       User                            @relation("BnhubReservationPaymentHost", fields: [hostUserId], references: [id], onDelete: Cascade)
  listingId                  String                          @map("listing_id")
  listing                    ShortTermListing                @relation(fields: [listingId], references: [id], onDelete: Cascade)
  processor                  BnhubMpProcessor                @map("processor")
  processorPaymentIntentId   String?                         @unique @map("processor_payment_intent_id")
  processorCheckoutSessionId String?                         @unique @map("processor_checkout_session_id")
  amountAuthorizedCents      Int                             @default(0) @map("amount_authorized_cents")
  amountCapturedCents        Int                             @default(0) @map("amount_captured_cents")
  amountRefundedCents        Int                             @default(0) @map("amount_refunded_cents")
  currency                   String                          @default("USD") @map("currency")
  paymentStatus              BnhubMpReservationPaymentStatus @default(DRAFT) @map("payment_status")
  captureMode                BnhubMpCaptureMode              @default(AUTOMATIC) @map("capture_mode")
  paymentMethodType          String?                         @map("payment_method_type")
  fundsFlow                  BnhubMpFundsFlow                @default(DESTINATION_CHARGE) @map("funds_flow_type")
  riskHoldStatus             BnhubMpRiskHold                 @default(NONE) @map("risk_hold_status")
  metadataJson               Json                            @default("{}") @map("metadata_json")
  paidAt                     DateTime?                       @map("paid_at")
  idempotencyKey             String?                         @unique @map("idempotency_key")
  createdAt                  DateTime                        @default(now()) @map("created_at")
  updatedAt                  DateTime                        @updatedAt @map("updated_at")

  payouts              BnhubHostPayoutRecord[]
  holds                BnhubPaymentHold[]
  refunds              BnhubMarketplaceRefund[]
  disputes             BnhubMarketplaceDispute[]
  marketplacePayEvents BnhubMarketplacePaymentEvent[]

  @@index([guestUserId])
  @@index([hostUserId])
  @@index([listingId])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("bnhub_payments")
}

model BnhubHostPayoutRecord {
  id                   String                  @id @default(uuid()) @map("id")
  bookingId            String                  @map("booking_id")
  booking              Booking                 @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reservationPaymentId String                  @map("payment_id")
  reservationPayment   BnhubReservationPayment @relation(fields: [reservationPaymentId], references: [id], onDelete: Cascade)
  hostUserId           String                  @map("host_user_id")
  host                 User                    @relation("BnhubHostPayoutHost", fields: [hostUserId], references: [id], onDelete: Cascade)
  listingId            String                  @map("listing_id")
  listing              ShortTermListing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  processor            BnhubMpProcessor        @map("processor")
  processorTransferId  String?                 @unique @map("processor_transfer_id")
  processorPayoutId    String?                 @map("processor_payout_id")
  grossAmountCents     Int                     @map("gross_amount_cents")
  platformFeeCents     Int                     @default(0) @map("platform_fee_cents")
  reserveAmountCents   Int                     @default(0) @map("reserve_amount_cents")
  netAmountCents       Int                     @map("net_amount_cents")
  currency             String                  @default("USD") @map("currency")
  payoutStatus         BnhubMpPayoutStatus     @default(PENDING) @map("payout_status")
  releaseReason        String?                 @map("release_reason") @db.Text
  eligibleReleaseAt    DateTime?               @map("eligible_release_at")
  releasedAt           DateTime?               @map("released_at")
  metadataJson         Json                    @default("{}") @map("metadata_json")
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @updatedAt @map("updated_at")

  paymentEvents BnhubMarketplacePaymentEvent[]

  @@index([bookingId])
  @@index([reservationPaymentId])
  @@index([hostUserId])
  @@index([payoutStatus])
  @@index([eligibleReleaseAt])
  @@map("bnhub_payouts")
}

model BnhubPaymentHold {
  id                   String                   @id @default(uuid()) @map("id")
  bookingId            String                   @map("booking_id")
  booking              Booking                  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reservationPaymentId String?                  @map("payment_id")
  reservationPayment   BnhubReservationPayment? @relation(fields: [reservationPaymentId], references: [id], onDelete: SetNull)
  holdType             BnhubMpHoldType          @map("hold_type")
  holdStatus           BnhubMpHoldStatus        @default(ACTIVE) @map("hold_status")
  amountCents          Int                      @map("amount_cents")
  currency             String                   @default("USD") @map("currency")
  reason               String                   @map("reason") @db.Text
  expiresAt            DateTime?                @map("expires_at")
  releasedAt           DateTime?                @map("released_at")
  createdAt            DateTime                 @default(now()) @map("created_at")
  updatedAt            DateTime                 @updatedAt @map("updated_at")

  @@index([bookingId])
  @@index([reservationPaymentId])
  @@index([holdStatus])
  @@map("bnhub_payment_holds")
}

model BnhubMarketplaceRefund {
  id                   String                  @id @default(uuid()) @map("id")
  bookingId            String                  @map("booking_id")
  booking              Booking                 @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reservationPaymentId String                  @map("payment_id")
  reservationPayment   BnhubReservationPayment @relation(fields: [reservationPaymentId], references: [id], onDelete: Cascade)
  guestUserId          String                  @map("guest_user_id")
  guest                User                    @relation("BnhubMpRefundGuest", fields: [guestUserId], references: [id], onDelete: Cascade)
  hostUserId           String                  @map("host_user_id")
  host                 User                    @relation("BnhubMpRefundHost", fields: [hostUserId], references: [id], onDelete: Cascade)
  refundType           BnhubMpRefundType       @map("refund_type")
  amountCents          Int                     @map("amount_cents")
  currency             String                  @default("USD") @map("currency")
  refundStatus         BnhubMpRefundStatus     @default(DRAFT) @map("refund_status")
  processorRefundId    String?                 @unique @map("processor_refund_id")
  reasonCode           String                  @map("reason_code")
  summary              String?                 @map("summary") @db.Text
  initiatedBy          String                  @map("initiated_by")
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @updatedAt @map("updated_at")

  paymentEvents BnhubMarketplacePaymentEvent[]

  @@index([bookingId])
  @@index([reservationPaymentId])
  @@index([refundStatus])
  @@map("bnhub_refunds")
}

model BnhubMarketplaceDispute {
  id                   String                  @id @default(uuid()) @map("id")
  reservationPaymentId String                  @map("payment_id")
  reservationPayment   BnhubReservationPayment @relation(fields: [reservationPaymentId], references: [id], onDelete: Cascade)
  bookingId            String                  @map("booking_id")
  booking              Booking                 @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  processorDisputeId   String?                 @unique @map("processor_dispute_id")
  disputeStatus        BnhubMpDisputeStatus    @default(OPEN) @map("dispute_status")
  amountCents          Int                     @map("amount_cents")
  currency             String                  @default("USD") @map("currency")
  reasonCode           String?                 @map("reason_code")
  evidenceDueBy        DateTime?               @map("evidence_due_by")
  summary              String?                 @map("summary") @db.Text
  evidenceJson         Json                    @default("{}") @map("evidence_json")
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @updatedAt @map("updated_at")

  paymentEvents BnhubMarketplacePaymentEvent[]

  @@index([bookingId])
  @@index([disputeStatus])
  @@map("bnhub_disputes")
}

model BnhubMarketplacePaymentEvent {
  id                   String                   @id @default(uuid()) @map("id")
  reservationPaymentId String?                  @map("payment_id")
  reservationPayment   BnhubReservationPayment? @relation(fields: [reservationPaymentId], references: [id], onDelete: SetNull)
  payoutId             String?                  @map("payout_id")
  payoutRecord         BnhubHostPayoutRecord?   @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  refundId             String?                  @map("refund_id")
  refund               BnhubMarketplaceRefund?  @relation(fields: [refundId], references: [id], onDelete: SetNull)
