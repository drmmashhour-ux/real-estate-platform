// ---------------------------------------------------------------------------
// AI marketing — drafts, scheduling (no auto-post), light metrics
// ---------------------------------------------------------------------------

enum MarketingContentType {
  SOCIAL_POST
  CAPTION
  EMAIL
  GROWTH_IDEA
}

enum MarketingContentStatus {
  DRAFT
  APPROVED
  SCHEDULED
  PUBLISHED
  /// Publish pipeline in progress (claimed by worker or admin publish)
  PUBLISHING
  /// Last publish attempt failed (see marketing_publish_jobs)
  FAILED
}

/// Where admin intends to publish (execution via provider adapters; many are dry-run until OAuth).
enum MarketingPublishChannel {
  EMAIL
  X
  LINKEDIN
  INSTAGRAM
  TIKTOK
}

/// Append-only style job log for audit (row updated from RUNNING → terminal state).
enum MarketingPublishJobStatus {
  SCHEDULED
  RUNNING
  SUCCESS
  FAILED
  DRY_RUN
}

model MarketingContent {
  id          String                 @id @default(cuid())
  type        MarketingContentType
  /// Primary copy: post/caption text, flattened growth ideas, or email body mirror
  content     String                 @db.Text
  /// Structured payload: ideas[], emailKind, generation context, etc.
  contentJson Json?                  @map("content_json")
  platform    String?
  topic       String?
  tone        String?
  audience    String?
  theme       String?
  status      MarketingContentStatus @default(DRAFT)
  /// Intended publish/send time — worker picks up when due
  scheduledAt DateTime?              @map("scheduled_at")
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")
  /// "openai" | "fallback" (stored as plain string)
  aiSource    String?                @map("ai_source")

  emailSubject    String? @map("email_subject")
  emailBody       String? @map("email_body") @db.Text
  emailCta        String? @map("email_cta")
  isEmailCampaign Boolean @default(false) @map("is_email_campaign")

  createdByUserId String? @map("created_by_user_id")

  /// Publish destination (set before schedule / publish now).
  publishChannel  MarketingPublishChannel? @map("publish_channel")
  publishTargetId String?                  @map("publish_target_id")
  /// When true, providers must not call live APIs (default safe).
  publishDryRun   Boolean                  @default(true) @map("publish_dry_run")

  /// A/B parent row (variant A lives here; B/C are separate rows pointing to this id).
  parentContentId String?            @map("parent_content_id")
  parentContent   MarketingContent?  @relation("MarketingContentVariants", fields: [parentContentId], references: [id], onDelete: SetNull)
  childVariants   MarketingContent[] @relation("MarketingContentVariants")
  variantLabel    String?            @map("variant_label")
  isVariant       Boolean            @default(false) @map("is_variant")
  isWinnerVariant Boolean            @default(false) @map("is_winner_variant")

  metrics     MarketingMetric[]
  publishJobs MarketingPublishJob[]

  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([scheduledAt])
  @@index([parentContentId])
  @@map("marketing_content")
}

model MarketingPublishJob {
  id              String                    @id @default(cuid())
  contentId       String                    @map("content_id")
  content         MarketingContent          @relation(fields: [contentId], references: [id], onDelete: Cascade)
  channel         MarketingPublishChannel
  status          MarketingPublishJobStatus
  scheduledAt     DateTime?                 @map("scheduled_at")
  startedAt       DateTime?                 @map("started_at")
  finishedAt      DateTime?                 @map("finished_at")
  externalPostId  String?                   @map("external_post_id")
  /// Safe, truncated reason for admins (no stack traces).
  errorMessage    String?                   @map("error_message") @db.Text
  responseSummary String?                   @map("response_summary") @db.Text
  dryRun          Boolean                   @map("dry_run")
  createdAt       DateTime                  @default(now()) @map("created_at")

  @@index([contentId])
  @@index([createdAt])
  @@index([status])
  @@map("marketing_publish_jobs")
}

/// Manual / imported metric snapshots (append-only)
model MarketingMetric {
  id          String           @id @default(cuid())
  contentId   String           @map("content_id")
  content     MarketingContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  views       Int?
  clicks      Int?
  conversions Int?
  /// Email opens (manual / future ESP); use with views as “sent” when you log both
  opens       Int?
  notes       String?          @db.Text
  createdAt   DateTime         @default(now()) @map("created_at")

  @@index([contentId])
  @@index([createdAt])
  @@map("marketing_metrics")
}

/// LECIPM Marketing Studio v1 — Fabric.js canvas state (JSON) per user design.
model MarketingStudioProject {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String   @default("Untitled design") @db.VarChar(200)
  projectData Json     @map("project_data")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId, updatedAt])
  @@map("marketing_studio_projects")
}

/// LECIPM Marketing System v2 — user-owned blog (additive; distinct from `SeoBlogPost`).
enum MarketingBlogPostStatus {
  DRAFT
  PUBLISHED
}

model MarketingBlogPost {
  id             String                  @id @default(cuid())
  userId         String                  @map("user_id")
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String                  @db.VarChar(300)
  slug           String                  @unique @db.VarChar(200)
  content        String                  @db.Text
  coverImageUrl  String?                 @map("cover_image_url") @db.VarChar(2000)
  status         MarketingBlogPostStatus @default(DRAFT)
  tags           String[]                @default([])
  seoTitle       String?                 @map("seo_title") @db.VarChar(300)
  seoDescription String?                 @map("seo_description") @db.VarChar(500)
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")
  publishedAt    DateTime?               @map("published_at")

  @@index([userId, updatedAt])
  @@index([status, publishedAt])
  @@map("marketing_blog_posts")
}

/// Unified funnel + performance signals (Marketing System v2). No synthetic revenue — amounts are user-reported or integrated feeds only.
enum MarketingSystemEventCategory {
  FUNNEL
  PERFORMANCE
}

model MarketingSystemEvent {
  id          String                       @id @default(cuid())
  userId      String?                      @map("user_id")
  user        User?                        @relation(fields: [userId], references: [id], onDelete: SetNull)
  category    MarketingSystemEventCategory @map("category")
  eventKey    String                       @map("event_key") @db.VarChar(64)
  subjectType String?                      @map("subject_type") @db.VarChar(32)
  subjectId   String?                      @map("subject_id") @db.VarChar(64)
  amountCents Int?                         @map("amount_cents")
  sessionId   String?                      @map("session_id") @db.VarChar(128)
  meta        Json?
  createdAt   DateTime                     @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([category, eventKey, createdAt])
  @@index([subjectType, subjectId, createdAt])
  @@map("marketing_system_events")
}

// ---------------------------------------------------------------------------
// Insurance leads (partner monetization; consent stored server-side)
// ---------------------------------------------------------------------------

enum InsuranceLeadType {
  TRAVEL
  PROPERTY
  MORTGAGE
}

enum InsuranceLeadSource {
  BNBHUB
  LISTING
  CHECKOUT
  MANUAL
}

enum InsuranceLeadStatus {
  NEW
  /// Broker acknowledged outreach — does not imply a quote was issued.
  CONTACTED
  SENT
  CONVERTED
  REJECTED
}

model InsurancePartner {
  id                   String                @id @default(cuid())
  name                 String
  contactEmail         String                @map("contact_email")
  webhookUrl           String?               @map("webhook_url") @db.Text
  /// Legacy single price; used when `basePricePerLead` is null.
  fixedPricePerLead    Decimal               @default(0) @map("fixed_price_per_lead") @db.Decimal(18, 2)
  /// Preferred base payout per lead (CAD). Falls back to `fixedPricePerLead` if unset.
  basePricePerLead     Decimal?              @map("base_price_per_lead") @db.Decimal(18, 2)
  /// Extra payout when `InsuranceLead.leadScore` exceeds quality threshold.
  bonusHighQualityLead Decimal               @default(0) @map("bonus_high_quality_lead") @db.Decimal(18, 2)
  /// Optional JSON array of lead types this partner accepts, e.g. ["TRAVEL","PROPERTY"]. Null/empty = all types.
  preferredLeadTypes   Json?                 @map("preferred_lead_types")
  isActive             Boolean               @default(true) @map("is_active")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  leads                InsuranceLead[]
  revenueLogs          InsuranceRevenueLog[]

  @@index([isActive])
  @@map("insurance_partners")
}

model InsuranceLead {
  id                   String                @id @default(cuid())
  userId               String?               @map("user_id")
  user                 User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// Optional assignee for `/dashboard/insurance` broker workflow (PROPERTY leads).
  assignedBrokerUserId String?               @map("assigned_broker_user_id")
  assignedBroker       User?                 @relation("InsuranceLeadAssignedBroker", fields: [assignedBrokerUserId], references: [id], onDelete: SetNull)
  email                String
  phone                String?               @map("phone")
  fullName             String?               @map("full_name")
  leadType             InsuranceLeadType     @map("lead_type")
  listingId            String?               @map("listing_id")
  bookingId            String?               @map("booking_id")
  booking              Booking?              @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  source               InsuranceLeadSource   @map("source")
  message              String?               @db.Text
  consentGiven         Boolean               @map("consent_given")
  consentText          String                @map("consent_text") @db.Text
  status               InsuranceLeadStatus   @default(NEW)
  partnerId            String?               @map("partner_id")
  partner              InsurancePartner?     @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  estimatedValue       Decimal?              @map("estimated_value") @db.Decimal(18, 2)
  /// Quality score at last calculation (phone, booking, checkout, listing context).
  leadScore            Int                   @default(0) @map("lead_score")
  /// A/B variant id for the capture form (e.g. A = minimal, B = phone visible).
  variantId            String?               @map("variant_id")
  metadata             Json?                 @map("metadata")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  revenueLogs          InsuranceRevenueLog[]

  @@index([status])
  @@index([leadType])
  @@index([createdAt])
  @@index([userId])
  @@index([partnerId])
  @@index([assignedBrokerUserId])
  @@index([email, createdAt])
  @@map("insurance_leads")
}

enum InsuranceLeadFunnelEventType {
  LEAD_FORM_VIEWED
  LEAD_STARTED
  LEAD_SUBMITTED
  LEAD_FAILED
}

model InsuranceLeadFunnelEvent {
  id           String                       @id @default(cuid())
  eventType    InsuranceLeadFunnelEventType @map("event_type")
  /// Normalized funnel: booking | listing | payment | manual
  funnelSource String                       @map("funnel_source")
  leadType     InsuranceLeadType?           @map("lead_type")
  device       String                       @map("device")
  leadId       String?                      @map("lead_id")
  variantId    String?                      @map("variant_id")
  metadata     Json?                        @map("metadata")
  ipHash       String?                      @map("ip_hash")
  createdAt    DateTime                     @default(now()) @map("created_at")

  @@index([eventType, createdAt])
  @@index([funnelSource, createdAt])
  @@map("insurance_lead_funnel_events")
}

model InsuranceRevenueLog {
  id        String            @id @default(cuid())
  leadId    String            @map("lead_id")
  lead      InsuranceLead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  partnerId String?           @map("partner_id")
  partner   InsurancePartner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  amount    Decimal           @map("amount") @db.Decimal(18, 2)
  currency  String            @default("CAD") @map("currency")
  createdAt DateTime          @default(now()) @map("created_at")

  @@index([leadId])
  @@map("insurance_revenue_logs")
}

/// Broker professional liability (FARCIQ policy parameters — illustrative limits; bind coverage with your carrier).
model BrokerInsurance {
  id                 String   @id @default(cuid())
  brokerId           String   @map("broker_id")
  broker             User     @relation("BrokerFARCIQInsurance", fields: [brokerId], references: [id], onDelete: Cascade)
  policyNumber       String?  @map("policy_number")
  provider           String   @default("FARCIQ")
  coveragePerLoss    Int      @default(2000000) @map("coverage_per_loss")
  coveragePerYear    Int      @default(2000000) @map("coverage_per_year")
  startDate          DateTime @map("start_date")
  endDate            DateTime @map("end_date")
  status             String   @db.VarChar(24)
  deductibleLevel    Int      @map("deductible_level")
  /// Private PDF (`documents` bucket path `broker-insurance/...` or `local:...` under `private/uploads`).
  documentStorageKey String?  @map("document_storage_key") @db.VarChar(512)
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([brokerId, status])
  @@index([brokerId, endDate])
  @@map("broker_insurances")
}

/// Claim intake — store short summary only; attach sensitive documents via `privateFileId` when wired to storage.
model InsuranceClaim {
  id            String   @id @default(cuid())
  brokerId      String   @map("broker_id")
  broker        User     @relation("BrokerInsuranceClaims", fields: [brokerId], references: [id], onDelete: Cascade)
  description   String   @db.VarChar(2000)
  /// Optional `StorageFileRecord.id` for encrypted / access-controlled narrative (never paste full legal text in `description`).
