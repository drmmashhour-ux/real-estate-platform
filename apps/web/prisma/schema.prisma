// ---------------------------------------------------------------------------
// Platform fraud engine — deterministic signals, scores, cases (admin review-first).
// Complements legacy FraudSignal / FraudRiskScore / fraud_review_queue tables.
// ---------------------------------------------------------------------------
enum FraudEntityType {
  user
  listing
  booking
  payment
  message
}

enum FraudRiskLevel {
  low
  medium
  high
  critical
}

enum FraudCaseStatus {
  open
  under_review
  confirmed_fraud
  false_positive
  resolved
}

enum FraudActionType {
  allow
  monitor
  review
  challenge
  block
}

model FraudSignalEvent {
  id           String          @id @default(uuid()) @db.Uuid
  entityType   FraudEntityType
  entityId     String
  signalType   String
  signalValue  String?
  riskPoints   Int             @default(0)
  metadataJson Json            @default("{}")
  createdAt    DateTime        @default(now())

  @@index([entityType])
  @@index([entityId])
  @@index([signalType])
  @@index([createdAt])
  @@map("fraud_signal_events")
}

/// Rule-based fraud score (deterministic). Named FraudPolicyScore — distinct from ML `FraudScore` above.
model FraudPolicyScore {
  id                String          @id @default(uuid()) @db.Uuid
  entityType        FraudEntityType
  entityId          String
  score             Int             @default(0)
  riskLevel         FraudRiskLevel  @default(low)
  recommendedAction FraudActionType @default(monitor)
  reasonsJson       Json            @default("{}")
  updatedAt         DateTime        @updatedAt
  createdAt         DateTime        @default(now())

  @@unique([entityType, entityId])
  @@index([riskLevel])
  @@map("fraud_policy_scores")
}

model FraudCase {
  id               String          @id @default(uuid()) @db.Uuid
  entityType       FraudEntityType
