  @@index([watchlistId], map: "idx_portfolio_monitoring_snapshots_watchlist_id")
  @@map("portfolio_monitoring_snapshots")
}

/// Phase 4 — portfolio monitoring events.
model PortfolioMonitoringEvent {
  id          String        @id @default(cuid())
  watchlistId String        @map("watchlist_id")
  watchlist   DealWatchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
