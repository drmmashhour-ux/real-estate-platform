// ---------------------------------------------------------------------------
// Real Estate Transaction Engine
// ---------------------------------------------------------------------------

/// Client-side OACIQ disclosure gate (offer / contract / platform agreement) tied to `RealEstateTransaction`.
enum OaciqClientDisclosureFlow {
  OFFER_SUBMIT
  CONTRACT_SIGN
  AGREEMENT
}

/// Per-transaction disclosure copy + conflict flags (broker-maintained; defaults seeded on first read).
model OaciqTransactionDisclosureProfile {
  id                         String                @id @default(uuid())
  transactionId              String                @unique @map("transaction_id")
  transaction                RealEstateTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  brokerStatusBody           String                @map("broker_status_body") @db.Text
  conflictBody               String                @map("conflict_body") @db.Text
  financialInterestBody      String                @map("financial_interest_body") @db.Text
  hasBrokerConflict          Boolean               @default(false) @map("has_broker_conflict")
  hasBrokerFinancialInterest Boolean               @default(false) @map("has_broker_financial_interest")
  bundleVersion              Int                   @default(1) @map("bundle_version")
  createdAt                  DateTime              @default(now()) @map("created_at")
  updatedAt                  DateTime              @updatedAt @map("updated_at")

  @@map("oaciq_transaction_disclosure_profiles")
}

/// Recorded client acknowledgment after mandatory disclosure display (checkbox + exact mandated text).
model OaciqClientDisclosureAck {
  id                      String                    @id @default(uuid())
  transactionId           String                    @map("transaction_id")
  transaction             RealEstateTransaction     @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  userId                  String                    @map("user_id")
  user                    User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  flow                    OaciqClientDisclosureFlow @map("flow")
  ackTextExact            String                    @map("ack_text_exact") @db.VarChar(512)
  disclosureBundleVersion Int                       @map("disclosure_bundle_version")
  acknowledgedAt          DateTime                  @default(now()) @map("acknowledged_at")
  clientIp                String?                   @map("client_ip") @db.VarChar(128)
  userAgent               String?                   @map("user_agent") @db.VarChar(512)

  @@index([transactionId, userId, flow])
  @@index([acknowledgedAt])
  @@map("oaciq_client_disclosure_acks")
}

/// Broker-attested legally binding decision (OACIQ — responsibility cannot be delegated to automation).
enum OaciqBrokerDecisionType {
  PIPELINE_DEAL_CREATE
  CRM_DEAL_CREATE
  OFFER_SUBMIT
  CONTRACT_GENERATE
  LISTING_PUBLISH
  NEGOTIATION_STEP
  CONTRACT_SIGN
}

model OaciqBrokerDecisionLog {
  id                      String                  @id @default(uuid())
  brokerId                String                  @map("broker_id")
  broker                  User                    @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  decisionType            OaciqBrokerDecisionType @map("decision_type")
  approvedAt              DateTime                @default(now()) @map("approved_at")
  confirmationTextVersion String                  @default("v1_broker_decision_2026") @map("confirmation_text_version") @db.VarChar(64)
  crmDealId               String?                 @map("crm_deal_id") @db.VarChar(36)
  pipelineDealId          String?                 @map("pipeline_deal_id") @db.VarChar(36)
  realEstateTransactionId String?                 @map("real_estate_transaction_id") @db.VarChar(36)
  listingId               String?                 @map("listing_id") @db.VarChar(36)
  listingOfferId          String?                 @map("listing_offer_id") @db.VarChar(36)
  propertyOfferId         String?                 @map("property_offer_id") @db.VarChar(36)
  legalDocumentArtifactId String?                 @map("legal_document_artifact_id") @db.VarChar(36)
  negotiationStrategyId   String?                 @map("negotiation_strategy_id") @db.VarChar(36)
  metadata                Json?

  @@index([brokerId, decisionType, approvedAt(sort: Desc)])
  @@index([realEstateTransactionId, decisionType, approvedAt(sort: Desc)])
  @@index([listingId, decisionType, approvedAt(sort: Desc)])
  @@index([pipelineDealId])
  @@index([crmDealId])
  @@map("oaciq_broker_decision_logs")
}

/// Platform mapping to OACIQ obligations (alignment / assistance — not regulator approval).
enum OaciqComplianceRuleCategory {
  DISCLOSURE
  CONFLICT
  CLIENT_PROTECTION
  DOCUMENTATION
}

enum OaciqComplianceAlignmentAction {
  DEAL_CREATE
  LISTING_PUBLISH
  CONTRACT_GENERATE
}

model OaciqComplianceRule {
  id                      String                      @id @default(cuid())
  ruleKey                 String                      @unique @map("rule_key") @db.VarChar(80)
  title                   String                      @db.VarChar(256)
  description             String                      @db.Text
  category                OaciqComplianceRuleCategory
  enforcedBySystem        Boolean                     @default(true) @map("enforced_by_system")
  appliesDealCreate       Boolean                     @default(true) @map("applies_deal_create")
  appliesListingPublish   Boolean                     @default(true) @map("applies_listing_publish")
  appliesContractGenerate Boolean                     @default(true) @map("applies_contract_generate")
  active                  Boolean                     @default(true)
  createdAt               DateTime                    @default(now()) @map("created_at")
  updatedAt               DateTime                    @updatedAt @map("updated_at")

  @@index([active, category])
  @@map("oaciq_compliance_rules")
}

/// Evaluation record for OACIQ-aligned gates (pass/block + optional resolution).
model OaciqComplianceAlignmentEvent {
  id              String                         @id @default(cuid())
  brokerId        String                         @map("broker_id")
  action          OaciqComplianceAlignmentAction @map("action")
  /// PASS | BLOCK
  outcome         String                         @map("outcome") @db.VarChar(16)
  failedRuleKeys  Json?                          @map("failed_rule_keys")
  listingId       String?                        @map("listing_id") @db.VarChar(36)
  pipelineDealId  String?                        @map("pipeline_deal_id") @db.VarChar(36)
  crmDealId       String?                        @map("crm_deal_id") @db.VarChar(36)
  sdTransactionId String?                        @map("sd_transaction_id") @db.VarChar(36)
  legalArtifactId String?                        @map("legal_artifact_id") @db.VarChar(36)
  detailsJson     Json?                          @map("details_json")
  resolvedAt      DateTime?                      @map("resolved_at")
  resolutionNote  String?                        @map("resolution_note") @db.Text
  createdAt       DateTime                       @default(now()) @map("created_at")

  @@index([brokerId, createdAt(sort: Desc)])
  @@index([outcome, resolvedAt])
  @@map("oaciq_compliance_alignment_events")
}

/// Internal log of regulator outreach and responses (OACIQ, etc.) — operational memory, not legal advice.
model ComplianceRegulatorCorrespondence {
  id              String    @id @default(cuid())
  regulatorKey    String    @map("regulator_key") @db.VarChar(64)
  channel         String    @db.VarChar(32)
  status          String    @default("draft") @db.VarChar(32)
  subject         String?   @db.VarChar(512)
  outboundSummary String?   @map("outbound_summary") @db.Text
  inboundSummary  String?   @map("inbound_summary") @db.Text
  feedbackNotes   String?   @map("feedback_notes") @db.Text
  recommendations String?   @db.Text
  occurredAt      DateTime? @map("occurred_at")
  createdByUserId String?   @map("created_by_user_id")
  createdBy       User?     @relation("RegulatorCorrespondenceCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  metadata        Json?

  @@index([regulatorKey, createdAt(sort: Desc)])
  @@map("compliance_regulator_correspondence")
}

model RealEstateTransaction {
  id                        String                             @id @default(uuid())
  organizationId            String?                            @map("organization_id")
  propertyIdentityId        String                             @map("property_identity_id")
  propertyIdentity          PropertyIdentity                   @relation(fields: [propertyIdentityId], references: [id], onDelete: Restrict)
  listingId                 String?                            @map("listing_id") // Optional: ShortTermListing.id or future sale listing
  buyerId                   String                             @map("buyer_id")
  buyer                     User                               @relation("TransactionBuyer", fields: [buyerId], references: [id], onDelete: Restrict)
  sellerId                  String                             @map("seller_id")
  seller                    User                               @relation("TransactionSeller", fields: [sellerId], references: [id], onDelete: Restrict)
  brokerId                  String?                            @map("broker_id")
  broker                    User?                              @relation("TransactionBroker", fields: [brokerId], references: [id], onDelete: SetNull)
  offerPrice                Int?                               @map("offer_price") // Cents; current agreed or latest offer
  status                    String                             @map("status") // offer_submitted | negotiation | offer_accepted | deposit_required | deposit_received | contract_signed | closing_in_progress | completed | cancelled
  frozenByAdmin             Boolean                            @default(false) @map("frozen_by_admin")
  createdAt                 DateTime                           @default(now()) @map("created_at")
  updatedAt                 DateTime                           @updatedAt @map("updated_at")
  offers                    PropertyOffer[]
  messages                  TransactionMessage[]
  deposits                  TransactionDeposit[]
  documents                 TransactionDocument[]
  steps                     TransactionStep[]
  events                    TransactionEvent[]
  closingPackages           ClosingPackage[]
  timeline                  TransactionTimeline?
  oaciqDisclosureProfile    OaciqTransactionDisclosureProfile?
  oaciqClientDisclosureAcks OaciqClientDisclosureAck[]

  @@index([propertyIdentityId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([brokerId])
  @@index([status])
  @@map("real_estate_transactions")
}

model PropertyOffer {
  id             String                 @id @default(uuid())
  transactionId  String                 @map("transaction_id")
  transaction    RealEstateTransaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  buyerId        String                 @map("buyer_id")
  buyer          User                   @relation(fields: [buyerId], references: [id], onDelete: Restrict)
  offerPrice     Int                    @map("offer_price") // Cents
  conditions     Json? // e.g. inspection, financing
  expirationDate DateTime?              @map("expiration_date")
  status         String                 @map("status") // pending | accepted | rejected | countered | expired
  createdAt      DateTime               @default(now()) @map("created_at")
  counterOffers  PropertyCounterOffer[]

  @@index([transactionId])
  @@index([buyerId])
  @@index([status])
  @@map("property_offers")
}

model PropertyCounterOffer {
  id           String        @id @default(uuid())
  offerId      String        @map("offer_id")
  offer        PropertyOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  counterPrice Int           @map("counter_price") // Cents
  notes        String?
  createdById  String        @map("created_by")
  createdBy    User          @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime      @default(now()) @map("created_at")

  @@index([offerId])
  @@map("property_counter_offers")
}

model TransactionMessage {
  id            String                @id @default(uuid())
  transactionId String                @map("transaction_id")
  transaction   RealEstateTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  senderId      String                @map("sender_id")
  sender        User                  @relation(fields: [senderId], references: [id], onDelete: Restrict)
  message       String
  createdAt     DateTime              @default(now()) @map("created_at")

  @@index([transactionId])
  @@index([senderId])
  @@map("transaction_messages")
}

model TransactionDeposit {
  id              String                @id @default(uuid())
  transactionId   String                @map("transaction_id")
  transaction     RealEstateTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  amount          Int                   @map("amount") // Cents
  paymentProvider String                @map("payment_provider")
  paymentStatus   String                @map("payment_status") // pending | paid | refunded
  externalRef     String?               @map("external_ref")
  createdAt       DateTime              @default(now()) @map("created_at")

  @@index([transactionId])
  @@index([paymentStatus])
  @@map("transaction_deposits")
}

model TransactionDocument {
  id                 String                  @id @default(uuid())
  transactionId      String                  @map("transaction_id")
  transaction        RealEstateTransaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  documentType       String                  @map("document_type") // purchase_agreement | broker_agreement | inspection_conditions | etc.
  fileUrl            String                  @map("file_url")
  originalFileUrl    String?                 @map("original_file_url")
  redactedFileUrl    String?                 @map("redacted_file_url")
  sensitivityLevel   PrivacySensitivityLevel @default(CONFIDENTIAL) @map("sensitivity_level")
  version            String                  @default("1.0")
  isImmutable        Boolean                 @default(false) @map("is_immutable")
  signedByBuyer      Boolean                 @default(false) @map("signed_by_buyer")
  signedBySeller     Boolean                 @default(false) @map("signed_by_seller")
  signedByBroker     Boolean                 @default(false) @map("signed_by_broker")
  signedAt           DateTime?               @map("signed_at")
  allowedRoles       Json?                   @map("allowed_roles") // string[]
  allowedDepartments Json?                   @map("allowed_departments") // string[]
  needToKnow         Boolean                 @default(true) @map("need_to_know")
  dataCategory       PrivacyDataCategory?    @map("data_category")
  createdAt          DateTime                @default(now()) @map("created_at")

  @@index([transactionId])
  @@index([documentType])
  @@map("transaction_documents")
}

model TransactionStep {
  id            String                @id @default(uuid())
  transactionId String                @map("transaction_id")
  transaction   RealEstateTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  stepName      String                @map("step_name") // inspection | financing_approval | legal_review | final_payment | ownership_transfer
  status        String                @map("status") // pending | completed
  completedById String?               @map("completed_by")
  completedAt   DateTime?             @map("completed_at")
  createdAt     DateTime              @default(now()) @map("created_at")

  @@index([transactionId])
  @@map("transaction_steps")
}

model TransactionEvent {
  id            String                @id @default(uuid())
  transactionId String                @map("transaction_id")
  transaction   RealEstateTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  eventType     String                @map("event_type")
  eventData     Json?                 @map("event_data")
  createdById   String?               @map("created_by")
  createdAt     DateTime              @default(now()) @map("created_at")

  @@index([transactionId])
  @@index([eventType])
  @@map("transaction_events")
}

// ---------------------------------------------------------------------------
// Transaction Timeline Engine – lifecycle stages and steps
// ---------------------------------------------------------------------------
model TransactionTimeline {
  id                 String                     @id @default(uuid())
  transactionId      String                     @unique @map("transaction_id")
  transaction        RealEstateTransaction      @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  propertyIdentityId String                     @map("property_identity_id")
  listingId          String?                    @map("listing_id")
  buyerId            String                     @map("buyer_id")
  sellerId           String                     @map("seller_id")
  brokerId           String?                    @map("broker_id")
  currentStage       String                     @map("current_stage") // listing_live | offer_submitted | negotiation | offer_accepted | deposit_pending | deposit_received | inspection_* | financing_* | legal_documents_prepared | notary_review | closing_scheduled | closing_completed | cancelled
  status             String                     @default("active") // active | blocked | completed | cancelled
  nextRequiredAction String?                    @map("next_required_action")
  cancelledReason    String?                    @map("cancelled_reason")
  cancelledAt        DateTime?                  @map("cancelled_at")
  createdAt          DateTime                   @default(now()) @map("created_at")
  updatedAt          DateTime                   @updatedAt @map("updated_at")
  steps              TransactionTimelineStep[]
  events             TransactionTimelineEvent[]

  @@index([currentStage])
  @@index([status])
  @@index([buyerId])
  @@index([sellerId])
  @@index([brokerId])
  @@map("transaction_timelines")
}

model TransactionTimelineStep {
  id                String              @id @default(uuid())
  timelineId        String              @map("timeline_id")
  timeline          TransactionTimeline @relation(fields: [timelineId], references: [id], onDelete: Cascade)
  stepCode          String              @map("step_code") // e.g. offer_submit | deposit_pay | inspection_complete
  stepName          String              @map("step_name")
  stageName         String              @map("stage_name")
  status            String              @default("pending") // pending | in_progress | completed | blocked | cancelled | overdue
  assignedToRole    String?             @map("assigned_to_role") // buyer | seller | broker | admin | notary | compliance | system
  assignedToUserId  String?             @map("assigned_to_user_id")
  dueDate           DateTime?           @map("due_date")
  completedAt       DateTime?           @map("completed_at")
  completedByUserId String?             @map("completed_by_user_id")
  notes             String?
  metadata          Json? // inspection result, financing status, etc.
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  @@index([timelineId])
  @@index([status])
  @@index([dueDate])
  @@index([assignedToRole])
  @@map("transaction_timeline_steps")
}

model TransactionTimelineEvent {
  id         String              @id @default(uuid())
  timelineId String              @map("timeline_id")
  timeline   TransactionTimeline @relation(fields: [timelineId], references: [id], onDelete: Cascade)
  eventType  String              @map("event_type") // timeline_created | offer_submitted | counter_offer_sent | deposit_received | inspection_completed | financing_approved | documents_generated | notary_assigned | closing_completed | transaction_cancelled | stage_changed | step_completed | step_blocked
  eventData  Json?               @map("event_data")
  createdBy  String?             @map("created_by")
  createdAt  DateTime            @default(now()) @map("created_at")

  @@index([timelineId])
  @@index([eventType])
  @@index([createdAt])
  @@map("transaction_timeline_events")
}

model PropertyIdentityLink {
  id                 String           @id @default(uuid())
  propertyIdentityId String           @map("property_identity_id")
  propertyIdentity   PropertyIdentity @relation(fields: [propertyIdentityId], references: [id], onDelete: Cascade)
  listingId          String           @map("listing_id")
  listingType        String           @map("listing_type") // sale | long_term_rental | short_term_rental
  linkedByUserId     String           @map("linked_by_user_id")
  linkStatus         String           @map("link_status") // pending | active | rejected | archived
  createdAt          DateTime         @default(now()) @map("created_at")

  @@unique([listingId, listingType])
  @@index([propertyIdentityId])
  @@index([linkStatus])
  @@map("property_identity_links")
}

model PropertyIdentityVerification {
  id                 String           @id @default(uuid())
  propertyIdentityId String           @map("property_identity_id")
  propertyIdentity   PropertyIdentity @relation(fields: [propertyIdentityId], references: [id], onDelete: Cascade)
  verificationType   String           @map("verification_type") // cadastre_check | land_registry_document | identity_match | broker_license_check | broker_authorization_check | geo_validation | anti_fraud_check
  verificationStatus String           @map("verification_status") // pending | verified | rejected
  verifiedBy         String?          @map("verified_by")
  verifiedAt         DateTime?        @map("verified_at")
  notes              String?
  createdAt          DateTime         @default(now()) @map("created_at")

  @@index([propertyIdentityId])
  @@index([verificationType])
  @@map("property_identity_verifications")
}

model PropertyIdentityOwner {
  id                 String           @id @default(uuid())
  propertyIdentityId String           @map("property_identity_id")
  propertyIdentity   PropertyIdentity @relation(fields: [propertyIdentityId], references: [id], onDelete: Cascade)
  ownerName          String           @map("owner_name")
  ownerSource        String           @map("owner_source") // land_registry_extract | manual_admin_review | broker_authorization
  isCurrent          Boolean          @default(true) @map("is_current")
  createdAt          DateTime         @default(now()) @map("created_at")

  @@index([propertyIdentityId])
  @@map("property_identity_owners")
}

model PropertyIdentityRisk {
  id                 String           @id @default(uuid())
  propertyIdentityId String           @map("property_identity_id")
  propertyIdentity   PropertyIdentity @relation(fields: [propertyIdentityId], references: [id], onDelete: Cascade)
  riskScore          Int              @map("risk_score") // 0-100
  riskLevel          String           @map("risk_level") // low | medium | high
  riskReasons        Json?            @map("risk_reasons")
  lastEvaluatedAt    DateTime         @map("last_evaluated_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@index([propertyIdentityId])
  @@index([riskLevel])
  @@map("property_identity_risk")
}

model PropertyIdentityEvent {
  id                 String           @id @default(uuid())
  propertyIdentityId String           @map("property_identity_id")
  propertyIdentity   PropertyIdentity @relation(fields: [propertyIdentityId], references: [id], onDelete: Cascade)
  eventType          String           @map("event_type") // identity_created | listing_linked | listing_rejected | verification_completed | fraud_flag_added | ownership_changed | manual_review_requested
  eventData          Json?            @map("event_data")
  createdBy          String?          @map("created_by")
  createdAt          DateTime         @default(now()) @map("created_at")

  @@index([propertyIdentityId])
  @@index([eventType])
  @@map("property_identity_events")
}

// ---------------------------------------------------------------------------
// Global Real Estate Identity Network
// ---------------------------------------------------------------------------
model OwnerIdentity {
  id                 String                       @id @default(uuid())
  legalName          String                       @map("legal_name")
  normalizedName     String                       @map("normalized_name")
  verificationStatus String                       @default("PENDING") @map("verification_status") // PENDING | VERIFIED | REJECTED
  primarySource      String?                      @map("primary_source") // land_register_extract | manual_admin | broker_authorization | legal_document
  status             String                       @default("ACTIVE") // ACTIVE | FROZEN | MERGED
  createdAt          DateTime                     @default(now()) @map("created_at")
  updatedAt          DateTime                     @updatedAt @map("updated_at")
  ownershipHistory   OwnershipHistory[]
  brokerAuthHistory  BrokerAuthorizationHistory[]
  listingAuthorities ListingAuthority[]

  @@index([normalizedName])
  @@index([verificationStatus])
  @@map("owner_identities")
}

model BrokerIdentity {
  id                         String                       @id @default(uuid())
  legalName                  String                       @map("legal_name")
  normalizedName             String                       @map("normalized_name")
  licenseNumber              String                       @map("license_number")
  brokerageName              String                       @map("brokerage_name")
  regulatorRef               String?                      @map("regulator_ref") // e.g. OACIQ number
  verificationStatus         String                       @default("PENDING") @map("verification_status")
  status                     String                       @default("ACTIVE")
  createdAt                  DateTime                     @default(now()) @map("created_at")
  updatedAt                  DateTime                     @updatedAt @map("updated_at")
  brokerAuthorizationHistory BrokerAuthorizationHistory[]
  listingAuthorities         ListingAuthority[]

  @@index([licenseNumber])
  @@index([normalizedName])
  @@map("broker_identities")
}

model OrganizationIdentity {
  id                 String             @id @default(uuid())
  legalName          String             @map("legal_name")
  normalizedName     String             @map("normalized_name")
  organizationType   String             @map("organization_type") // brokerage | property_management | legal_entity
  verificationStatus String             @default("PENDING") @map("verification_status")
  status             String             @default("ACTIVE")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  listingAuthorities ListingAuthority[]

  @@index([normalizedName])
  @@map("organization_identities")
}

model ListingAuthority {
  id                     String                @id @default(uuid())
  propertyIdentityId     String                @map("property_identity_id")
  propertyIdentity       PropertyIdentity      @relation(fields: [propertyIdentityId], references: [id], onDelete: Cascade)
  authorityType          String                @map("authority_type") // owner_self_listed | verified_broker_authorized | delegated_manager_authorized | other_platform_approved
  ownerIdentityId        String?               @map("owner_identity_id")
  ownerIdentity          OwnerIdentity?        @relation(fields: [ownerIdentityId], references: [id], onDelete: SetNull)
  brokerIdentityId       String?               @map("broker_identity_id")
  brokerIdentity         BrokerIdentity?       @relation(fields: [brokerIdentityId], references: [id], onDelete: SetNull)
  organizationIdentityId String?               @map("organization_identity_id")
  organizationIdentity   OrganizationIdentity? @relation(fields: [organizationIdentityId], references: [id], onDelete: SetNull)
  documentReference      String?               @map("document_reference")
  startDate              DateTime              @map("start_date")
  endDate                DateTime?             @map("end_date")
  status                 String                @default("ACTIVE") // ACTIVE | EXPIRED | REVOKED
  verificationStatus     String                @default("PENDING") @map("verification_status")
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")

  @@index([propertyIdentityId])
  @@index([ownerIdentityId])
  @@index([brokerIdentityId])
  @@index([status])
  @@map("listing_authorities")
}

model IdentityLink {
  id           String   @id @default(uuid())
  identityType String   @map("identity_type") // OWNER | BROKER
  identityId   String   @map("identity_id")
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkStatus   String   @default("ACTIVE") @map("link_status") // ACTIVE | REVOKED
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([identityType, identityId, userId])
  @@index([userId])
  @@index([identityType, identityId])
  @@map("identity_links")
}

model OwnershipHistory {
  id                 String           @id @default(uuid())
  propertyIdentityId String           @map("property_identity_id")
  propertyIdentity   PropertyIdentity @relation(fields: [propertyIdentityId], references: [id], onDelete: Cascade)
  ownerIdentityId    String           @map("owner_identity_id")
  ownerIdentity      OwnerIdentity    @relation(fields: [ownerIdentityId], references: [id], onDelete: Cascade)
