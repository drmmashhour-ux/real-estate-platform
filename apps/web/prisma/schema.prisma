}

/// Phase 4 — enterprise portfolio monitoring snapshot per watchlist.
model PortfolioMonitoringSnapshot {
  id          String        @id @default(cuid())
  watchlistId String        @map("watchlist_id")
  watchlist   DealWatchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
