  guest                   User             @relation("BnhubPaymentQuoteGuest", fields: [guestUserId], references: [id], onDelete: Cascade)
  hostUserId              String           @map("host_user_id")
  host                    User             @relation("BnhubPaymentQuoteHost", fields: [hostUserId], references: [id], onDelete: Cascade)
  nightlySubtotalCents    Int              @map("nightly_subtotal_cents")
  cleaningFeeCents        Int              @default(0) @map("cleaning_fee_cents")
  taxTotalCents           Int              @default(0) @map("tax_total_cents")
  serviceFeeCents         Int              @default(0) @map("service_fee_cents")
  addOnTotalCents         Int              @default(0) @map("add_on_total_cents")
  bundleTotalCents        Int              @default(0) @map("bundle_total_cents")
  membershipDiscountCents Int              @default(0) @map("membership_discount_cents")
  couponDiscountCents     Int              @default(0) @map("coupon_discount_cents")
  securityHoldCents       Int              @default(0) @map("security_hold_cents")
  grandTotalCents         Int              @map("grand_total_cents")
  currency                String           @default("USD") @map("currency")
