// =============================================================================
// ANTI-FAILURE: Policy Engine and Rules Enforcement
// =============================================================================

enum PolicyRuleType {
  ELIGIBILITY // Who can do what
  VISIBILITY // Listing/search visibility
  RELEASE_CONDITION // Payout/reward release
  VERIFICATION // Verification requirements by risk
  AUTO_BLOCK // Auto-block conditions
  CANCELLATION // Cancellation policy
  REVIEW_ELIGIBILITY
  REFERRAL_REWARD
}

enum PolicyEffect {
  ALLOW
  DENY
  HOLD
  REQUIRE_ACTION
}

model PolicyRule {
  id            String         @id @default(uuid())
  key           String         @unique
  name          String
  description   String?
  ruleType      PolicyRuleType
  scope         String         @default("GLOBAL") // GLOBAL | REGION
  scopeValue    String?
  conditions    Json // e.g. { "minVerification": "VERIFIED", "maxFraudScore": 0.5 }
  effect        PolicyEffect
  effectPayload Json? // e.g. { "holdReasonCode": "VERIFY_IDENTITY" }
  version       Int            @default(1)
  active        Boolean        @default(true)
  updatedBy     String?
  updatedAt     DateTime       @updatedAt
  createdAt     DateTime       @default(now())

  @@index([key])
  @@index([ruleType])
  @@index([active])
}

model PolicyDecisionLog {
  id          String   @id @default(uuid())
  ruleKey     String
  entityType  String
  entityId    String
  decision    String // ALLOWED | DENIED | HELD
  reasonCode  String?
  context     Json? // Input context used for evaluation
  evaluatedAt DateTime @default(now())

  @@index([ruleKey])
  @@index([entityType, entityId])
  @@index([evaluatedAt])
}

// =============================================================================
// REVENUE, GROWTH & MARKET EXPANSION LAYER
// =============================================================================

// ---------------------------------------------------------------------------
// Subscription and Billing
// ---------------------------------------------------------------------------
enum SubscriptionPlanModule {
  BROKER_CRM
  HOST_PRO
  OWNER_ANALYTICS
  INVESTOR_ANALYTICS
  ENTERPRISE
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

model SubscriptionPlan {
  id            String                 @id @default(uuid())
  name          String
  slug          String                 @unique
  module        SubscriptionPlanModule
  billingCycle  BillingCycle
  amountCents   Int
  currency      String                 @default("USD")
  trialDays     Int                    @default(0)
  features      Json? // Entitlements: { "maxListings": 10, "analytics": true }
  active        Boolean                @default(true)
  marketId      String?                @map("market_id") // optional: market-specific plan
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  subscriptions PlanSubscription[]

  @@index([module])
  @@index([active])
  @@index([marketId])
}

/// Legacy plan-linked subscription (SubscriptionPlan). PostgreSQL enum name unchanged (`SubscriptionStatus`).
enum PlanSubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  EXPIRED

  @@map("SubscriptionStatus")
}

model PlanSubscription {
  id                 String                 @id @default(uuid())
  userId             String
  planId             String
  plan               SubscriptionPlan       @relation(fields: [planId], references: [id], onDelete: Restrict)
  status             PlanSubscriptionStatus @default(TRIALING)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean                @default(false)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  invoices           Invoice[]
  billingEvents      PlanBillingEvent[]

  @@index([userId])
  @@index([planId])
  @@index([status])
  @@map("Subscription")
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

model Invoice {
  id             String           @id @default(uuid())
  subscriptionId String
  subscription   PlanSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amountCents    Int
  status         InvoiceStatus    @default(OPEN)
  dueDate        DateTime
  paidAt         DateTime?
  invoiceNumber  String?          @unique
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
}

model PlanBillingEvent {
  id             String            @id @default(uuid())
  subscriptionId String?
  userId         String?
  eventType      String // SUBSCRIPTION_CREATED | PAYMENT_SUCCEEDED | PAYMENT_FAILED | INVOICE_PAID | REFUND
  amountCents    Int?
  metadata       Json?
  createdAt      DateTime          @default(now())
  subscription   PlanSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([subscriptionId])
  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("BillingEvent")
}

// ---------------------------------------------------------------------------
// LECIPM — Stripe workspace subscription + billing audit + Copilot persistence
// ---------------------------------------------------------------------------
enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  unpaid
  incomplete
  incomplete_expired
  paused

  @@map("subscription_status")
}

enum BillingEventType {
  checkout_completed
  subscription_created
  subscription_updated
  subscription_deleted
  invoice_payment_failed
  invoice_paid

  @@map("billing_event_type")
}

enum CopilotMessageRole {
  user
  assistant
  system
  tool

  @@map("copilot_message_role")
}

enum CopilotIntent {
  find_deals
  analyze_property
  improve_listing
  why_not_selling
  portfolio_summary
  pricing_help
  risk_check
  unknown

  @@map("copilot_intent")
}

enum CopilotRunStatus {
  queued
  completed
  failed

  @@map("copilot_run_status")
}

/// Stripe-backed workspace subscription (mirrored from webhooks). Distinct from `PlanSubscription` (plan catalog).
model Subscription {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String? @map("workspace_id") @db.Uuid
  userId      String? @map("user_id")
  user        User?   @relation("WorkspaceSubscriptionUser", fields: [userId], references: [id], onDelete: SetNull)

  stripeCustomerId     String? @map("stripe_customer_id")
  stripeSubscriptionId String? @unique @map("stripe_subscription_id")
  stripePriceId        String? @map("stripe_price_id")

  planCode           String             @map("plan_code")
  /// Monthly recurring revenue in cents, derived from Stripe price at last sync (null if unknown).
  mrrCents           Int?               @map("mrr_cents")
  status             SubscriptionStatus
  currentPeriodStart DateTime?          @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd   DateTime?          @map("current_period_end") @db.Timestamptz(6)
  cancelAtPeriodEnd  Boolean            @default(false) @map("cancel_at_period_end")

  metadata Json? @db.JsonB

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  billingEvents BillingEvent[]

  @@index([workspaceId], map: "idx_subscriptions_workspace_id")
  @@index([userId], map: "idx_subscriptions_user_id")
  @@index([status], map: "idx_subscriptions_status")
  @@index([planCode], map: "idx_subscriptions_plan_code")
  @@map("subscriptions")
}

model BillingEvent {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionId String? @map("subscription_id") @db.Uuid
  workspaceId    String? @map("workspace_id") @db.Uuid
  userId         String? @map("user_id")

  eventType     BillingEventType @map("event_type")
  stripeEventId String?          @unique @map("stripe_event_id")
  payload       Json?            @db.JsonB

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([subscriptionId], map: "idx_billing_events_subscription_id")
  @@index([workspaceId], map: "idx_billing_events_workspace_id")
  @@index([userId], map: "idx_billing_events_user_id")
  @@index([eventType], map: "idx_billing_events_event_type")
  @@map("billing_events")
}

model CopilotConversation {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String         @map("user_id")
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String?        @map("workspace_id") @db.Uuid
  title       String?
  lastIntent  CopilotIntent? @map("last_intent")
  metadata    Json?          @db.JsonB

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  messages CopilotMessage[]
  runs     CopilotRun[]

  @@index([userId], map: "idx_copilot_conversations_user_id")
  @@index([workspaceId], map: "idx_copilot_conversations_workspace_id")
  @@map("copilot_conversations")
}

model CopilotMessage {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String              @map("conversation_id") @db.Uuid
  conversation   CopilotConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           CopilotMessageRole
  content        String              @db.Text
  intent         CopilotIntent?      @map("intent")
  metadata       Json?               @db.JsonB

