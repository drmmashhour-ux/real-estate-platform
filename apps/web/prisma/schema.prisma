/**
 * Recorded when a user accepts Terms, Privacy, or optional Marketing at signup or re-consent.
 */
model UserConsent {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// TERMS | PRIVACY | MARKETING
  type       String
  acceptedAt DateTime @default(now())

  @@index([userId])
  @@index([userId, type])
}

// --- Regulatory traceability (Québec / Canada — additive; distinct from signup `UserConsent`). ---

enum LecipmRegulatoryConsentType {
  DATA_USAGE
  AI_DECISIONING
  MARKETING
  FINANCIAL_SIMULATION
}

enum LecipmRegulatoryAuditEntityType {
  DEAL
  FUND
  LISTING
  AI_DECISION
}

enum LecipmRiskDisclosureContext {
  DEAL
  FUND
  ESG
  AI_RECOMMENDATION
}

model LecipmRegulatoryConsent {
  id          String                      @id @default(cuid())
