  photoVerified     Boolean           @default(false) @map("photo_verified")
  contentReviewed   Boolean           @default(false) @map("content_reviewed")
  verificationLevel VerificationLevel @default(basic) @map("verification_level")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  @@index([verificationLevel])
  @@map("listing_verifications")
}

