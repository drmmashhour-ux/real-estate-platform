  reason     String?
  updatedBy  String?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@index([key])
  @@index([enabled])
}

enum OperationalControlType {
  KILL_SWITCH // Disable a flow (e.g. instant_booking)
  PAYOUT_HOLD // Hold payouts for target
  LISTING_FREEZE // Freeze listing visibility or creation
  BOOKING_RESTRICTION // Restrict new bookings
  MODERATION_LEVEL // Stricter moderation
  REGIONAL_LOCK // Region-specific lock
}

model OperationalControl {
  id          String                 @id @default(uuid())
  controlType OperationalControlType
  targetType  String // GLOBAL | REGION | USER | LISTING_CATEGORY | MARKET
  targetId    String? // region code, userId, category slug, etc.
  payload     Json? // e.g. { "flow": "instant_booking" }, { "holdReason": "..." }
  active      Boolean                @default(true)
  reason      String?
  reasonCode  String?
  createdBy   String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  expiresAt   DateTime?

  @@index([controlType])
  @@index([targetType, targetId])
  @@index([active])
}

model ControlActionAuditLog {
  id            String   @id @default(uuid())
  controlId     String?
  action        String // CREATED | UPDATED | DEACTIVATED | ACTIVATED
  performedBy   String?
  reasonCode    String?
  previousValue Json?
  newValue      Json?
  createdAt     DateTime @default(now())

  @@index([controlId])
  @@index([createdAt])
}

