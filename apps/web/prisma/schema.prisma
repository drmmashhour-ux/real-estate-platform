/// High-touch outreach rows for “first 10 clients” acquisition (per admin user).
model ClientAcquisitionLead {
  id            String    @id @default(cuid())
  ownerId       String    @map("owner_id")
  owner         User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name          String
  /// facebook | instagram | marketplace | other
