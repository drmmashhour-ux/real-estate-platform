// ---------------------------------------------------------------------------
// BNHub: Bookings
// ---------------------------------------------------------------------------
model Booking {
  id                           String                          @id @default(uuid())
  /**
   * Immutable internal reference (e.g. BKG-000001) for admin, finance, support — distinct from guest `confirmationCode`.
   */
  bookingCode                  String?                         @unique @map("booking_code")
  /**
   * Guest-facing confirmation code (e.g. BNH-ABC123), unique when set.
   */
  confirmationCode             String?                         @unique @map("confirmation_code")
  checkIn                      DateTime
  checkOut                     DateTime
  nights                       Int
  totalCents                   Int // Total price in cents (before fees)
  guestFeeCents                Int                             @default(0)
  hostFeeCents                 Int                             @default(0)
  status                       BookingStatus                   @default(PENDING)
  guestNotes                   String?
  /**
   * Optional guest asks (airport pickup, late check-in, etc.) — shown to host in calendar / booking UI.
   */
  specialRequest               String?                         @map("special_request")
  /**
   * Structured special requests (airport pickup, parking, shuttle, extras).
   */
  specialRequestsJson          Json?                           @map("special_requests_json")
  /// Host confirmed arrival checklist items are ready before guest check-in.
  checklistDeclaredByHostAt    DateTime?                       @map("checklist_declared_by_host_at")
  checkedInAt                  DateTime? // actual check-in time (booking-service)
  checkedOutAt                 DateTime? // actual check-out time (booking-service)
  refunded                     Boolean                         @default(false) @map("refunded")
  refundedAt                   DateTime?                       @map("refunded_at")
  createdAt                    DateTime                        @default(now())
  updatedAt                    DateTime                        @updatedAt
  guestId                      String
  guest                        User                            @relation(fields: [guestId], references: [id], onDelete: Cascade)
  listingId                    String
  listing                      ShortTermListing                @relation(fields: [listingId], references: [id], onDelete: Cascade)
  /// Origin channel — BNHub remains source of truth; external = imported or mirrored from OTA
  bookingSource                BnhubBookingSource              @default(LOCAL) @map("booking_source")
  payment                      Payment?
  review                       Review?
  bnhubHostReviewOfGuest       BnhubHostReviewOfGuest?
  disputes                     Dispute[]
  bookingIssues                BookingIssue[]
  bookingMessages              BookingMessage[]
  bookingEvents                BnhubBookingEvent[]
  checkinDetails               BnhubCheckinDetails?
  bnhubInvoice                 BnhubBookingInvoice?
  payoutHolds                  PayoutHold[]
  agreementDocuments           BnhubBookingAgreementSnapshot[]
  trustSafetyIncidents         TrustSafetyIncident[]
  contracts                    Contract[]
  platformCommissionRecords    PlatformCommissionRecord[]
  platformLegalDisputes        PlatformLegalDispute[]
  platformPayments             PlatformPayment[]
  orchestratedPayments         OrchestratedPayment[]
  /**
   * Transactional email tracking (BNHub); failures do not block booking.
   */
  guestConfirmationEmailSentAt DateTime?                       @map("guest_confirmation_email_sent_at")
  guestInvoiceEmailSentAt      DateTime?                       @map("guest_invoice_email_sent_at")
  hostBookingAlertEmailSentAt  DateTime?                       @map("host_booking_alert_email_sent_at")
  availabilitySlotsBooked      AvailabilitySlot[]
  bnhubSalesAssistConversion   BnhubSalesAssistEntry?          @relation("BnhubSalesAssistBooking")
  bnGuarantees                 BnhubBookingGuarantee[]
  bnhubBookingServices         BnhubBookingService[]
  bnhubServiceRequests         BnhubServiceRequest[]
  bnhubBookingBundles          BnhubBookingBundle[]
  bnhubConciergeSessions       BnhubConciergeSession[]
  bnhubPaymentQuotes           BnhubPaymentQuote[]
  bnhubReservationPayment      BnhubReservationPayment?
  bnhubHostPayoutRecords       BnhubHostPayoutRecord[]
  bnhubPaymentHoldsMp          BnhubPaymentHold[]
  bnhubMarketplaceRefunds      BnhubMarketplaceRefund[]
  bnhubMarketplaceDisputes     BnhubMarketplaceDispute[]
  bnhubMarketplacePayEvents    BnhubMarketplacePaymentEvent[]
  bnhubFinancialLedgerEntries  BnhubFinancialLedgerEntry[]
  bnhubTrustRiskFlagsEngine    BnhubTrustRiskFlag[]            @relation("BnhubTrustRiskFlagBooking")
  internalCrmTelemetryEvents   InternalCrmEvent[]              @relation("CrmEventBooking")
  insuranceLeads               InsuranceLead[]
  bnhubBookingChecklistItems   BnhubBookingChecklistItem[]
  bnhubTrustSimpleDisputes     BnhubTrustSimpleDispute[]
  manualPaymentSettlement      ManualPaymentSettlement         @default(NOT_APPLICABLE) @map("manual_payment_settlement")
  manualPaymentUpdatedAt       DateTime?                       @map("manual_payment_updated_at")
  manualPaymentUpdatedByUserId String?                         @map("manual_payment_updated_by_user_id")
  manualPaymentEvents          BookingManualPaymentEvent[]
  bnhubManualHostPayout        BnhubManualHostPayout?
  aiDisputeRiskLogs            AiDisputeRiskLog[]
  bnhubAutomatedHostMessages   BnhubAutomatedHostMessageLog[]
  /// Guest count for the stay (distinct from `User` account).
  guestsCount                  Int?                            @map("guests_count")
  guestContactEmail            String?                         @map("guest_contact_email")
  guestContactName             String?                         @map("guest_contact_name")
  guestContactPhone            String?                         @map("guest_contact_phone")
  cancellationReason           String?                         @map("cancellation_reason") @db.Text
  canceledAt                   DateTime?                       @map("canceled_at")
  /// When set, unpaid `PENDING` bookings past this instant are expired for overlap + checkout.
  pendingCheckoutExpiresAt     DateTime?                       @map("pending_checkout_expires_at")

  @@index([guestId])
  @@index([listingId])
  @@index([status])
  @@index([checkIn])
  @@index([bookingSource])
  @@index([pendingCheckoutExpiresAt])
}

/// BNHub / LECIPM Manager: early dispute-risk signals (detection + guidance only — no auto-resolution).
enum AiDisputeRiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum AiDisputeRiskSignalType {
  MISSING_CHECKIN_DETAILS
  MISSING_CHECKIN_COMPLETION
  GUEST_SLOW_RESPONSE
  HOST_SLOW_RESPONSE
  REPEATED_BOOKING_ISSUES
  NEGATIVE_FEEDBACK_SIGNAL
  INCOMPLETE_LISTING_SIGNAL
  HOST_ROOM_READINESS_MISSING
}

enum AiDisputePreventionAction {
  GENTLE_REMINDER
  NOTIFY_BOTH_PARTIES
  NOTIFY_ADMIN_ESCALATION
}

model AiDisputeRiskLog {
  id                    String                   @id @default(cuid())
  bookingId             String                   @map("booking_id")
  booking               Booking                  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  riskLevel             AiDisputeRiskLevel       @map("risk_level")
  signalType            AiDisputeRiskSignalType  @map("signal_type")
  summary               String                   @db.VarChar(500)
  recommendedAction     String                   @map("recommended_action") @db.Text
  preventionAction      AiDisputePreventionAction @map("prevention_action")
  messageDraftHost      String?                  @map("message_draft_host") @db.Text
  messageDraftGuest     String?                  @map("message_draft_guest") @db.Text
  /// Timeline / audit: what we recorded (never implies funds or legal outcomes).
  actionTaken           String                   @default("risk_detected") @map("action_taken") @db.VarChar(64)
  metadataJson          Json?                    @map("metadata_json")
  cooldownKey           String                   @map("cooldown_key") @db.VarChar(200)
  requiresAdminReview   Boolean                  @default(false) @map("requires_admin_review")
  adminReviewedAt       DateTime?                @map("admin_reviewed_at")
  notificationSentAt    DateTime?                @map("notification_sent_at")
  createdAt             DateTime                 @default(now()) @map("created_at")

  @@index([bookingId, createdAt])
  @@index([requiresAdminReview, createdAt])
  @@index([signalType, createdAt])
  @@map("ai_dispute_risk_logs")
}

/// Audit trail for host/admin manual payment state changes (Syria / offline launch modes).
model BookingManualPaymentEvent {
  id               String                  @id @default(cuid())
  bookingId        String                  @map("booking_id")
  booking          Booking                 @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  actorUserId      String?                 @map("actor_user_id")
  fromSettlement   ManualPaymentSettlement @map("from_settlement")
  toSettlement     ManualPaymentSettlement @map("to_settlement")
  note             String?                 @db.Text
  createdAt        DateTime                @default(now()) @map("created_at")

  @@index([bookingId, createdAt])
  @@map("booking_manual_payment_events")
}

enum BnhubGuaranteeStatus {
  ACTIVE
  CLAIMED
  RESOLVED
}

/// BNHub Trust Guarantee — active after paid confirmation; guest can claim on mismatch/issue.
model BnhubBookingGuarantee {
  id            String               @id @default(cuid())
  bookingId     String               @map("booking_id")
  booking       Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  guaranteeType String               @map("guarantee_type") // trust_backed | mismatch_protection
  status        BnhubGuaranteeStatus @default(ACTIVE)
  createdAt     DateTime             @default(now()) @map("created_at")

  @@index([bookingId])
  @@index([status])
  @@map("bn_guarantees")
}

/// Arrival trust checklist — guest confirms essentials; host can see responses.
model BnhubBookingChecklistItem {
  id         String   @id @default(cuid())
  bookingId  String   @map("booking_id")
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  itemKey    String   @map("item_key")
  label      String?
  expected   Boolean  @default(true)
  confirmed  Boolean?
  note       String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([bookingId, itemKey])
  @@index([bookingId])
  @@map("bnhub_booking_checklist_items")
}

// Guest-reported issue. Admin can set status: reviewing, approved, rejected, resolved.
model BookingIssue {
  id          String    @id @default(cuid())
  bookingId   String    @map("booking_id")
  booking     Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  issueType   String    @map("issue_type") // misrepresentation, cleanliness, access, safety, amenities, refund-request, other
  description String
  status      String    @default("open") // open | reviewing | approved | rejected | resolved
  resolvedAt  DateTime? @map("resolved_at")
  resolvedBy  String?   @map("resolved_by") // admin user id
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([bookingId])
  @@index([status])
  @@map("bnhub_booking_issues")
}

enum BnhubTrustSimpleDisputeStatus {
  OPEN
  RESOLVED
}

/// Lightweight trust dispute (checklist mismatch, payout hold) — complements full `Dispute`.
model BnhubTrustSimpleDispute {
  id         String                        @id @default(cuid())
  bookingId  String                        @map("booking_id")
  booking    Booking                       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reporterId String                        @map("reporter_id")
  reporter   User                          @relation("BnhubTrustSimpleDisputeReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  message    String                        @db.Text
  status     BnhubTrustSimpleDisputeStatus @default(OPEN)
  createdAt  DateTime                      @default(now()) @map("created_at")
  resolvedAt DateTime?                     @map("resolved_at")

  @@index([bookingId])
  @@index([status])
  @@map("bnhub_trust_simple_disputes")
}

// BNHub booking audit trail (status changes, payments, cancellations)
model BnhubBookingEvent {
  id        String   @id @default(uuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  eventType String // created | payment_pending | confirmed | declined | cancelled | completed | disputed
  actorId   String? // User id who triggered (guest, host, admin, system)
  payload   Json? // e.g. { reason, refundCents }
  createdAt DateTime @default(now())

  @@index([bookingId])
  @@index([eventType])
  @@index([createdAt])
}

// Check-in details for a booking (host can set per booking)
model BnhubCheckinDetails {
  id           String   @id @default(uuid())
  bookingId    String   @unique
  booking      Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  instructions String?
  keyInfo      String? // Key code, lockbox, etc.
  accessType   String? // self_checkin | meet_host | other
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([bookingId])
}

/**
 * BNHub invoice snapshot after successful Stripe checkout (PDF + API source of truth).
 */
model BnhubBookingInvoice {
  id                     String    @id @default(uuid())
  bookingId              String    @unique @map("booking_id")
  booking                Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  stripeSessionId        String?   @map("stripe_session_id")
  paymentIntentId        String?   @map("payment_intent_id")
  guestNameSnapshot      String?   @map("guest_name_snapshot")
  listingTitleSnapshot   String?   @map("listing_title_snapshot")
  confirmationCode       String?   @map("confirmation_code")
  totalAmountCents       Int       @map("total_amount_cents")
  platformFeeCents       Int?      @map("platform_fee_cents")
  hostPayoutCents        Int?      @map("host_payout_cents")
  stripeConnectAccountId String?   @map("stripe_connect_account_id")
  paymentStatus          String    @map("payment_status")
  issuedAt               DateTime  @default(now()) @map("issued_at")
  linkedContractId       String?   @map("linked_contract_id")
  linkedContractType     String?   @map("linked_contract_type")
  linkedContract         Contract? @relation("BnhubInvoiceLegalLink", fields: [linkedContractId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([confirmationCode])
  @@index([linkedContractId])
  @@map("bnhub_booking_invoices")
}

// Guest-host messaging per booking (MVP: booking-scoped chat)
model BookingMessage {
  id          String   @id @default(uuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body        String
  /**
   * Denormalized LEC listing code for CRM / support search.
   */
  listingCode String?  @map("listing_code")
  createdAt   DateTime @default(now())

  @@index([bookingId])
  @@index([senderId])
  @@index([listingCode])
}

// Dispute resolution (property not as described, cancellation, damage, payment)
enum DisputeStatus {
  OPEN // New, awaiting review (legacy)
  SUBMITTED // Guest submitted complaint
  UNDER_REVIEW // Platform reviewing evidence
  WAITING_FOR_HOST_RESPONSE // Host must respond within time limit
  EVIDENCE_REVIEW // Evidence under review
  RESOLVED // Resolution applied (legacy)
  RESOLVED_PARTIAL_REFUND
  RESOLVED_FULL_REFUND
  RESOLVED_RELOCATION
  REJECTED // Complaint rejected
  ESCALATED // Escalated to trust & safety
  CLOSED // No further action
}

enum DisputeClaimant {
  GUEST
  HOST
}

model Dispute {
  id                 String              @id @default(uuid())
  bookingId          String
  booking            Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  listingId          String
  listing            ShortTermListing    @relation(fields: [listingId], references: [id], onDelete: Cascade)
  claimant           DisputeClaimant
  claimantUserId     String
  description        String
  complaintCategory  String?
  evidenceUrls       Json                @default("[]") // Legacy: uploaded evidence links (prefer DisputeEvidence)
  status             DisputeStatus       @default(SUBMITTED)
  urgencyLevel       String?             @map("urgency_level") // normal | high | urgent (unsafe)
  resolutionOutcome  String?             @map("resolution_outcome")
  refundCents        Int?                @map("refund_cents")
  resolutionNotes    String?
  resolvedAt         DateTime?
  resolvedBy         String?
  hostPayoutFrozenAt DateTime?           @map("host_payout_frozen_at")
  hostRespondedAt    DateTime?           @map("host_responded_at")
  /// AI assistant: REFUND | NO_ACTION (admin tooling; not legal determination).
  aiAssistantRecommendation  String?   @map("ai_assistant_recommendation")
  aiAssistantSummary         String?   @map("ai_assistant_summary") @db.Text
  aiAssistantGeneratedAt     DateTime? @map("ai_assistant_generated_at")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  messages           DisputeMessage[]
  evidence           DisputeEvidence[]
  resolutions        DisputeResolution[]

  @@index([bookingId])
  @@index([listingId])
  @@index([status])
  @@index([urgencyLevel])
}

// Audit log for each resolution decision (one record per resolve action)
model DisputeResolution {
  id             String   @id @default(uuid())
  disputeId      String
  dispute        Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  resolutionType String   @map("resolution_type") // partial_refund | full_refund | no_action | host_suspended | etc.
  refundCents    Int?     @map("refund_cents")
  notes          String?
  resolvedBy     String
  resolvedAt     DateTime @default(now()) @map("resolved_at")

  @@index([disputeId])
  @@map("dispute_resolutions")
}

// Host accountability: warnings and penalties (repeated violations)
model HostAccountWarning {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  warningType  String   @map("warning_type") // listing_violation | complaint_pattern | cancellation | policy_breach
  message      String
  severity     String
  penaltyCents Int?     @map("penalty_cents")
  createdAt    DateTime @default(now()) @map("created_at")
  createdBy    String?  @map("created_by")

  @@index([userId])
  @@map("host_account_warnings")
}

// Host quality score and Super Host badge (computed from reviews, cancellation, response)
model HostQuality {
  id                 String   @id @default(uuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  qualityScore       Float // 0-5
  isSuperHost        Boolean  @default(false)
  cancellationRate   Float? // 0-1
  avgResponseMinutes Float?
  updatedAt          DateTime @updatedAt

  @@index([userId])
}

// Supply growth: referral program config (rewards, active)
model ReferralProgram {
  id                    String     @id @default(uuid())
  name                  String
  rewardCreditsReferrer Int        @default(500) // cents to referrer
  rewardCreditsReferee  Int        @default(500) // cents to new user
  active                Boolean    @default(true)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  referrals             Referral[]
}

// Supply growth: host referral (invite host → both get credits)
model Referral {
  id                 String           @id @default(uuid())
  programId          String?
  program            ReferralProgram? @relation(fields: [programId], references: [id], onDelete: SetNull)
  referrerId         String
  referrer           User             @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  /// Unique per row (host one-time codes or viral instance id `V…`).
  code               String           @unique
  /// Sharer’s public `User.referralCode` for analytics / `ReferralEvent.code` (viral loop).
  referralPublicCode String?          @map("referral_public_code")
  /// invited (link opened) | joined (account created) | converted (paid / qualifying action)
  status             String           @default("joined")
  rewardGiven        Boolean          @default(false) @map("reward_given")
  /// USER (default) | HOST — host→host invites for supply growth (ops: visibility boost)
  inviteKind         String?          @map("invite_kind") @db.VarChar(24)
  rewardCreditsCents Int              @default(0)
  usedByUserId       String?
  usedBy             User?            @relation("Referree", fields: [usedByUserId], references: [id], onDelete: SetNull)
  usedAt             DateTime?
  createdAt          DateTime         @default(now())

  @@index([referrerId])
  @@index([code])
  @@index([programId])
  @@index([inviteKind])
  @@index([referralPublicCode])
  @@index([status])
}

model Ambassador {
  id          String             @id @default(cuid())
  userId      String             @unique
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  isActive    Boolean            @default(true)
  commission  Float              @default(0.1)
  commissions Commission[]
  payouts     AmbassadorPayout[]
  createdAt   DateTime           @default(now())
}

model Commission {
  id           String     @id @default(cuid())
  ambassadorId String
  ambassador   Ambassador @relation(fields: [ambassadorId], references: [id], onDelete: Cascade)
  amount       Float
  sourceType   String // subscription, lead, premium
  sourceId     String
  createdAt    DateTime   @default(now())

  @@index([ambassadorId])
  @@index([sourceType])
}

model ReferralEvent {
  id        String   @id @default(cuid())
  code      String
  /// click, invite_sent, signup, activated, paid
  eventType String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([code])
  @@index([eventType])
  @@index([userId])
}

model ReferralReward {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewardType String // premium-days, credits, badge
  value      String
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([rewardType])
}

model AmbassadorPayout {
  id           String     @id @default(cuid())
  ambassadorId String
  ambassador   Ambassador @relation(fields: [ambassadorId], references: [id], onDelete: Cascade)
  amount       Float
  status       String // pending, ready, paid
  createdAt    DateTime   @default(now())

  @@index([ambassadorId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Pricing engine: stored recommendations and rules
// ---------------------------------------------------------------------------
model PricingRecommendation {
  id               String    @id @default(uuid())
  listingId        String
  recommendedCents Int
  marketAvgCents   Int
  demandLevel      String // low | medium | high
  minStayNights    Int? // suggested min stay
  factors          Json      @default("[]") // e.g. seasonality, events
  forDate          DateTime?
  createdAt        DateTime

  @@index([listingId])
  @@index([createdAt])
}

model PricingRule {
  id        String    @id @default(uuid())
  listingId String
  ruleType  String // SEASONALITY | MIN_STAY | EVENT | BASE | EARLY_BOOKING
  payload   Json // e.g. { "multiplier": 1.2 } or { "minNights": 2 }
  validFrom DateTime?
  validTo   DateTime?
  updatedAt DateTime  @updatedAt

  @@index([listingId])
}

// ---------------------------------------------------------------------------
// Search ranking: configurable weights (admin)
// ---------------------------------------------------------------------------
model SearchRankingConfig {
  id          String   @id @default(uuid())
  key         String   @unique // e.g. "verification", "reviewScore"
  weight      Float    @default(1.0)
  description String?
  updatedAt   DateTime @updatedAt

  @@index([key])
}

// ---------------------------------------------------------------------------
// Fraud detection: signals and alerts
// ---------------------------------------------------------------------------
enum FraudSignalType {
  FAKE_LISTING
  SUSPICIOUS_BOOKING
  PAYMENT_FRAUD
  ACCOUNT_TAKEOVER
  REVIEW_MANIPULATION
  REFUND_ABUSE
  SUSPICIOUS_MESSAGING
}

model FraudSignal {
  id         String          @id @default(uuid())
  entityType String // LISTING | BOOKING | USER | PAYMENT | REVIEW | MESSAGE
  entityId   String
  signalType FraudSignalType
  score      Float // 0-1 risk
  metadata   Json? // details
  createdAt  DateTime        @default(now())

  @@index([entityType, entityId])
  @@index([signalType])
  @@index([createdAt])
}

enum FraudAlertStatus {
  NEW
  REVIEWING
  RESOLVED
  DISMISSED
}

model FraudAlert {
  id         String           @id @default(uuid())
  signalIds  Json             @default("[]") // one or more FraudSignal ids
  riskScore  Float // aggregated
  status     FraudAlertStatus @default(NEW)
  assignedTo String?
  resolvedAt DateTime?
  resolvedBy String?
  notes      String?
  createdAt  DateTime
  updatedAt  DateTime         @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Listing fraud investigation and enforcement (LECIPM / BNHub)
// ---------------------------------------------------------------------------
enum InvestigationStatus {
  OPEN
  UNDER_REVIEW
  CLOSED
}

model ListingInvestigation {
  id              String              @id @default(uuid())
  listingId       String              @map("listing_id")
  listing         ShortTermListing    @relation(fields: [listingId], references: [id], onDelete: Cascade)
  fraudReason     String              @map("fraud_reason") // fake_owner | duplicate_cadastre | stolen_photos | etc.
  status          InvestigationStatus @default(OPEN)
  openedBy        String              @map("opened_by")
  openedAt        DateTime            @default(now()) @map("opened_at")
  closedAt        DateTime?           @map("closed_at")
  resolutionNotes String?             @map("resolution_notes")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([listingId])
  @@index([status])
  @@map("listing_investigations")
}

enum ListingFraudEnforcementType {
  REJECT_LISTING
  PERMANENTLY_REMOVE_LISTING
  SUSPEND_LISTING_ACCOUNT
  BAN_USER_ACCOUNT
  BLOCK_FUTURE_LISTING
  FREEZE_PAYOUTS
  FRAUD_MARKER_PROPERTY_IDENTITY
  REQUIRE_STRONGER_VERIFICATION
}

model ListingEnforcementAction {
  id         String                      @id @default(uuid())
  listingId  String                      @map("listing_id")
  userId     String                      @map("user_id") // Account acted upon (e.g. listing owner)
  user       User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  actionType ListingFraudEnforcementType @map("action_type")
  reasonCode String                      @map("reason_code")
  notes      String?
  createdBy  String
  createdAt  DateTime                    @default(now()) @map("created_at")

  @@index([listingId])
  @@index([userId])
  @@map("listing_enforcement_actions")
}

enum PayoutHoldStatus {
  PENDING // Hold requested
  ON_HOLD // Payout held
  RELEASABLE // Window passed, can release
  RELEASED
  REVERSED
  REFUNDED
}

model PayoutHold {
  id         String           @id @default(uuid())
  bookingId  String           @map("booking_id")
  booking    Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  hostId     String           @map("host_id")
  reason     String // fraud_investigation | safety_complaint | service_mismatch | dispute_escalation | escrow_window
  status     PayoutHoldStatus @default(ON_HOLD)
  createdAt  DateTime         @default(now()) @map("created_at")
  releasedAt DateTime?        @map("released_at")

  @@index([bookingId])
  @@index([hostId])
  @@index([status])
  @@map("payout_holds")
}

model HostRiskHistory {
  id        String   @id @default(uuid())
  hostId    String   @map("host_id")
  host      User     @relation(fields: [hostId], references: [id], onDelete: Cascade)
  riskType  String   @map("risk_type") // inaccurate_listing | complaints | cancellations | safety | refunds
  riskScore Float?   @map("risk_score")
  notes     String?
  createdAt DateTime

  @@index([hostId])
  @@index([riskType])
  @@map("host_risk_history")
}

// ---------------------------------------------------------------------------
// Dispute: message thread and evidence audit
// ---------------------------------------------------------------------------
model DisputeMessage {
  id         String   @id @default(uuid())
  disputeId  String
  dispute    Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  senderId   String
  body       String
  isInternal Boolean
  createdAt  DateTime @default(now())

  @@index([disputeId])
}

model DisputeEvidence {
  id           String   @id @default(uuid())
  disputeId    String
  dispute      Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  url          String
  label        String?
  evidenceType String?  @map("type") // photo | document | other
  uploadedBy   String
  createdAt    DateTime @default(now())

  @@index([disputeId])
}

// ---------------------------------------------------------------------------
// Host quality: score history for trends and audit
// ---------------------------------------------------------------------------
model HostQualityHistory {
  id               String   @id @default(uuid())
  userId           String
  qualityScore     Float
  isSuperHost      Boolean
  cancellationRate Float?
  snapshotAt       DateTime @default(now())

  @@index([userId])
  @@index([snapshotAt])
}

// ---------------------------------------------------------------------------
// Supply growth: acquisition metrics (daily snapshots)
// ---------------------------------------------------------------------------
model SupplyGrowthMetric {
  id              String   @id @default(uuid())
  date            DateTime
  newListings     Int
  newHosts        Int      @default(0)
  referralSignups Int      @default(0)
  totalListings   Int      @default(0)
  totalHosts      Int      @default(0)
  createdAt       DateTime @default(now())

  @@unique([date])
  @@index([date])
}

// ---------------------------------------------------------------------------
// BNHub: Payments (Stripe integration placeholder)
// ---------------------------------------------------------------------------
model Payment {
  id                                 String                   @id @default(uuid())
  amountCents                        Int // Total charged to guest
  guestFeeCents                      Int
  hostFeeCents                       Int
  /**
   * Host transfer amount in minor units; may be finalized at payment completion (e.g. webhook).
   */
  hostPayoutCents                    Int?
  /**
   * BNHub Stripe Connect application fee (platform commission) in minor units — set at webhook from PaymentIntent.
   */
  platformFeeCents                   Int?                     @map("platform_fee_cents")
  status                             PaymentStatus            @default(PENDING)
  stripePaymentId                    String? // PaymentIntent id (or fallback)
  /**
   * Stripe Checkout Session id (cs_...) for receipts / invoices.
   */
  stripeCheckoutSessionId            String?                  @map("stripe_checkout_session_id")
  /**
   * Stripe-hosted receipt / invoice PDF link (from Charge after Checkout).
   */
  stripeReceiptUrl                   String?                  @map("stripe_receipt_url") @db.Text
  /**
   * Checkout Session amount_total (minor units), for reconciliation.
   */
  stripeCheckoutAmountCents          Int?                     @map("stripe_checkout_amount_cents")
  /**
   * Checkout Session currency (lowercase ISO).
   */
  stripeCheckoutCurrency             String?                  @map("stripe_checkout_currency")
  /** Last Stripe refund id (re_…) for support / idempotency notes. */
  stripeLastRefundId                 String?                  @map("stripe_last_refund_id")
  /**
   * Stripe Connect destination account (acct_…) on this charge; for admin reconciliation.
   */
  stripeConnectAccountId             String?                  @map("stripe_connect_account_id")
  hostPayoutReleasedAt               DateTime?                @map("host_payout_released_at") // Escrow: release 24-48h after check-in unless held
  /**
   * Scheduled host payout (e.g. check-in + 7 days) — BNHub money layer.
   */
  scheduledHostPayoutAt              DateTime?                @map("scheduled_host_payout_at")
  payoutHoldReason                   String?                  @map("payout_hold_reason") // fraud_investigation | dispute | escrow_window
  /**
   * Linked enforceable / booking agreement referenced on payment capture.
   */
  linkedContractId                   String?                  @map("linked_contract_id")
  linkedContractType                 String?                  @map("linked_contract_type")
  linkedContract                     Contract?                @relation("PaymentLegalLink", fields: [linkedContractId], references: [id], onDelete: SetNull)
  /**
   * Canonical BNHub money breakdown (subtotal, taxes, fees, host payout) — cents only, JSON shape from `BookingMoneyBreakdown`.
   */
  moneyBreakdownJson                 Json?                    @map("money_breakdown_json")
  paidAt                             DateTime?                @map("paid_at")
  createdAt                          DateTime                 @default(now())
  updatedAt                          DateTime                 @updatedAt
  bookingId                          String                   @unique
  booking                            Booking                  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bnhubMarketplaceReservationPayment BnhubReservationPayment?

  @@index([payoutHoldReason])
  @@index([linkedContractId])
  @@index([stripePaymentId])
  @@index([status])
  @@map("payments")
}

// ---------------------------------------------------------------------------
// Multi-provider payment orchestration (Stripe + Clover) — complements BNHub `Payment` / `PlatformPayment`.
// ---------------------------------------------------------------------------
model OrchestratedPayment {
  id                 String   @id @default(cuid())
  provider           String
  providerPaymentId  String?  @map("provider_payment_id")
  userId             String   @map("user_id")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookingId          String?  @map("booking_id")
  booking            Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  paymentType        String   @map("payment_type")
  amountCents        Int      @map("amount_cents")
  currency           String   @default("cad")
  platformFeeCents   Int      @map("platform_fee_cents")
  hostAmountCents    Int      @map("host_amount_cents")
  status             String
  checkoutSessionUrl String?  @map("checkout_session_url") @db.Text
  metadata           Json?
  /** Stripe PaymentIntent id after checkout completes — reconciliation / support. */
  stripePaymentIntentId String? @map("stripe_payment_intent_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([bookingId])
  @@index([provider])
  @@index([status])
  @@index([createdAt])
  @@index([stripePaymentIntentId])
  @@map("orchestrated_payments")
}

model OrchestratedPayout {
  id          String    @id @default(cuid())
  provider    String
  providerRef String?   @map("provider_ref")
  hostId      String    @map("host_id")
  host        User      @relation("OrchestratedPayoutHost", fields: [hostId], references: [id], onDelete: Cascade)
  amountCents Int       @map("amount_cents")
  currency    String    @default("cad")
  status      String
  scheduledAt DateTime? @map("scheduled_at")
  bookingId   String?   @map("booking_id")
  payoutMethod     String    @default("stripe_connect") @map("payout_method")
  failureReason    String?   @map("failure_reason") @db.Text
  availableAt      DateTime? @map("available_at")
  paidAt           DateTime? @map("paid_at")
  stripePayoutId   String?   @map("stripe_payout_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([hostId])
  @@index([status])
  @@index([scheduledAt])
  @@index([bookingId])
  @@index([providerRef])
  @@map("orchestrated_payouts")
}

/// Admin / ops queue when Connect is unavailable or market is manual-first.
model BnhubManualHostPayout {
  id                 String    @id @default(cuid())
  bookingId          String    @unique @map("booking_id")
  booking            Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  hostUserId         String    @map("host_user_id")
  host               User      @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  amountCents        Int       @map("amount_cents")
  currency           String    @default("cad")
  /// queued | paid | cancelled
  status             String
  queueReason        String?   @map("queue_reason") @db.Text
  beneficiaryName    String?   @map("beneficiary_name")
  contactPhone       String?   @map("contact_phone")
  contactEmail       String?   @map("contact_email")
  referenceNote      String?   @map("reference_note") @db.Text
  processedByUserId  String?   @map("processed_by_user_id")
  processedAt        DateTime? @map("processed_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([hostUserId])
  @@index([status])
  @@map("bnhub_manual_host_payouts")
}

/// Cached Stripe Connect requirements for host dashboard / payout gates.
model HostStripeAccountSnapshot {
  id                   String   @id @default(cuid())
  hostUserId           String   @unique @map("host_user_id")
  host                 User     @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  stripeAccountId      String   @map("stripe_account_id")
  chargesEnabled       Boolean  @default(false) @map("charges_enabled")
  payoutsEnabled       Boolean  @default(false) @map("payouts_enabled")
  detailsSubmitted     Boolean  @default(false) @map("details_submitted")
  onboardingComplete   Boolean  @default(false) @map("onboarding_complete")
  rawRequirementsJson  Json?    @map("raw_requirements_json")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@index([stripeAccountId])
  @@map("host_stripe_account_snapshots")
}

// ---------------------------------------------------------------------------
// Platform payments (Stripe) – unified record for all payment types
// ---------------------------------------------------------------------------
model PlatformPayment {
  id                        String                    @id @default(uuid())
  userId                    String                    @map("user_id")
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId                 String?                   @map("listing_id")
  projectId                 String?                   @map("project_id")
  bookingId                 String?                   @map("booking_id")
  booking                   Booking?                  @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  dealId                    String?                   @map("deal_id")
  deal                      Deal?                     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  fsboListingId             String?                   @map("fsbo_listing_id")
  fsboListing               FsboListing?              @relation(fields: [fsboListingId], references: [id], onDelete: SetNull)
  paymentType               String                    @map("payment_type") // booking | fsbo_publish | subscription | lead_unlock | deposit | closing_fee
  amountCents               Int                       @map("amount_cents")
  currency                  String                    @default("cad")
  status                    String                    @default("pending") // pending | paid | failed  (maps to PENDING/COMPLETED concept)
  /**
   * BNHub application fee or FSBO full gross (100% platform).
   */
  platformFeeCents          Int?                      @map("platform_fee_cents")
  /**
   * BNHub host transfer portion; 0 for FSBO (no host payout).
   */
  hostPayoutCents           Int?                      @map("host_payout_cents")
  stripeSessionId           String?                   @unique @map("stripe_session_id")
  stripePaymentIntentId     String?                   @map("stripe_payment_intent_id")
  stripeFeeCents            Int?                      @map("stripe_fee_cents") // Stripe processing fee (balance transaction)
  refundedAmountCents       Int?                      @default(0) @map("refunded_amount_cents")
  metadata                  Json? // extra context
  brokerTaxSnapshot         Json?                     @map("broker_tax_snapshot") // GST/QST snapshot when broker on payment; not gov-verified
  taxCalculationJson        Json?                     @map("tax_calculation_json") // GST/QST breakdown (engine output)
  taxOverrideJson           Json?                     @map("tax_override_json") // admin-only overrides
  /**
   * Linked signed agreement (enforceable or product-specific) for monetization / disputes.
   */
  linkedContractId          String?                   @map("linked_contract_id")
  linkedContractType        String?                   @map("linked_contract_type")
  linkedContract            Contract?                 @relation("PlatformPaymentLegalLink", fields: [linkedContractId], references: [id], onDelete: SetNull)
  createdAt                 DateTime                  @default(now()) @map("created_at")
  updatedAt                 DateTime                  @updatedAt @map("updated_at")
  brokerCommissions         BrokerCommission[]
  invoices                  PlatformInvoice[]
  stripeLedgerEntries       StripeLedgerEntry[]
  partyRevenueLedgerEntries PartyRevenueLedgerEntry[]

  @@index([userId])
  @@index([bookingId])
  @@index([dealId])
  @@index([fsboListingId])
  @@index([paymentType])
  @@index([status])
  @@index([stripeSessionId])
  @@index([linkedContractId])
  @@map("platform_payments")
}

/// Paywalled buyer access to FSBO / CRM listing representative contact (Stripe `listing_contact_lead`).
enum ListingContactTargetKind {
  FSBO_LISTING
  CRM_LISTING

  @@map("listing_contact_target_kind")
}

model ListingContactLeadPurchase {
  id                      String                   @id @default(cuid())
  buyerUserId             String                   @map("buyer_user_id")
  buyer                   User                     @relation(fields: [buyerUserId], references: [id], onDelete: Cascade)
  targetKind              ListingContactTargetKind @map("target_kind")
  targetListingId         String                   @map("target_listing_id")
  status                  String                   @default("locked") @db.VarChar(24)
  priceCents              Int                      @map("price_cents")
  stripeCheckoutSessionId String?                  @unique @map("stripe_checkout_session_id")
  paidAt                  DateTime?                @map("paid_at")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")

  @@unique([buyerUserId, targetKind, targetListingId], map: "listing_contact_lead_purchase_unique_buyer_target")
  @@index([buyerUserId])
  @@index([targetListingId])
  @@map("listing_contact_lead_purchases")
}

// Commission rules by source type (defaults: booking 12% platform; sale 70% broker / 30% platform; subscription 90% platform; lead 20% broker)
model CommissionRule {
  id              String   @id @default(uuid())
  sourceType      String   @unique @map("source_type") // booking | sale | subscription | lead
  brokerPercent   Float    @default(0) @map("broker_percent")
  platformPercent Float    @default(0) @map("platform_percent")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("commission_rules")
}

model BrokerCommission {
  id                     String                   @id @default(uuid())
  paymentId              String                   @map("payment_id")
  payment                PlatformPayment          @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  brokerId               String?                  @map("broker_id") // null for platform-only (e.g. booking fee)
  broker                 User?                    @relation(fields: [brokerId], references: [id], onDelete: SetNull)
  grossAmountCents       Int                      @map("gross_amount_cents")
  brokerAmountCents      Int                      @default(0) @map("broker_amount_cents")
  platformAmountCents    Int                      @default(0) @map("platform_amount_cents")
  status                 String                   @default("pending") // pending | paid
  paidAt                 DateTime?                @map("paid_at")
  createdAt              DateTime                 @default(now()) @map("created_at")
  payoutLine             BrokerPayoutLine?
  partyRevenueLedgerLine PartyRevenueLedgerEntry?

  @@index([paymentId])
  @@index([brokerId])
  @@index([status])
  @@map("broker_commissions")
}

model BrokerPayout {
  id                   String             @id @default(uuid())
  brokerId             String             @map("broker_id")
  broker               User               @relation("BrokerPayoutBroker", fields: [brokerId], references: [id], onDelete: Cascade)
  status               BrokerPayoutStatus @default(PENDING)
  payoutMethod         String             @default("manual") @map("payout_method") // manual | other — label in UI; no auto Stripe transfer
  totalAmountCents     Int                @map("total_amount_cents")
  currency             String             @default("cad")
  approvedAt           DateTime?          @map("approved_at")
  approvedByUserId     String?            @map("approved_by_user_id")
  approvedBy           User?              @relation("BrokerPayoutApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  paidAt               DateTime?          @map("paid_at")
  recordedPaidByUserId String?            @map("recorded_paid_by_user_id")
  recordedPaidBy       User?              @relation("BrokerPayoutPaidBy", fields: [recordedPaidByUserId], references: [id], onDelete: SetNull)
  failureReason        String?            @map("failure_reason")
  notes                String?            @db.Text
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  lines                BrokerPayoutLine[]

  @@index([brokerId])
  @@index([status])
  @@map("broker_payouts")
}

model BrokerPayoutLine {
  id           String           @id @default(uuid())
  payoutId     String           @map("payout_id")
  payout       BrokerPayout     @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  commissionId String           @unique @map("commission_id")
  commission   BrokerCommission @relation(fields: [commissionId], references: [id], onDelete: Restrict)

  @@index([payoutId])
  @@map("broker_payout_lines")
}

// Deal closing workflow (listing sale: buyer, seller, broker, milestones, documents)
model Deal {
  id                             String                          @id @default(uuid())
  /**
   * Immutable deal reference for support / contracts (e.g. DEL-000001).
   */
  dealCode                       String?                         @unique @map("deal_code")
  listingId                      String?                         @map("listing_id") // ShortTermListing or sale listing
  /**
   * Denormalized LEC code when deal references a ShortTermListing.
   */
  listingCode                    String?                         @map("listing_code")
  buyerId                        String                          @map("buyer_id")
  buyer                          User                            @relation("DealBuyer", fields: [buyerId], references: [id], onDelete: Restrict)
  sellerId                       String                          @map("seller_id")
  seller                         User                            @relation("DealSeller", fields: [sellerId], references: [id], onDelete: Restrict)
  brokerId                       String?                         @map("broker_id")
  broker                         User?                           @relation("DealBroker", fields: [brokerId], references: [id], onDelete: SetNull)
  priceCents                     Int                             @map("price_cents")
  status                         String                          @default("initiated") // initiated | offer_submitted | accepted | inspection | financing | closing_scheduled | closed | cancelled
  /**
   * Broker CRM pipeline stage (UI / reminders); separate from legal deal status.
   */
  crmStage                       String?                         @map("crm_stage")
  createdAt                      DateTime                        @default(now()) @map("created_at")
  updatedAt                      DateTime                        @updatedAt @map("updated_at")
  milestones                     DealMilestone[]
  documents                      DealDocument[]
  payments                       PlatformPayment[]
  crmInteractions                CrmInteraction[]
  contracts                      Contract[]
  /**
   * Optional link to originating CRM lead (e.g. ImmoContact).
   */
  leadId                         String?                         @unique @map("lead_id")
  lead                           Lead?                           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  /**
   * LECIPM enterprise workspace (organization) — optional; null = legacy unscoped rows.
   */
  workspaceId                    String?                         @map("workspace_id") @db.Uuid
  workspace                      EnterpriseWorkspace?            @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  /**
   * Snapshot of lead origin at deal creation (reporting / disputes).
   */
  leadContactOrigin              LeadContactOrigin?              @map("lead_contact_origin")
  /**
   * Commission attribution (e.g. IMMO_CONTACT).
   */
  commissionSource               LeadContactOrigin?              @map("commission_source")
  commissionEligible             Boolean                         @default(false) @map("commission_eligible")
  /**
   * Heuristic: deal created without auto-linked Immo lead while one existed (compliance review).
   */
  possibleBypassFlag             Boolean                         @default(false) @map("possible_bypass_flag")
  platformCommissionRecords      PlatformCommissionRecord[]
  platformLegalDisputes          PlatformLegalDispute[]
  lecipmDealHistories            LecipmDealHistory[]
  workspaceDealShares            WorkspaceDealShare[]
  workspaceCollaborationMessages WorkspaceCollaborationMessage[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([brokerId])
  @@index([status])
  @@index([crmStage])
  @@index([listingCode])
  @@index([leadId])
  @@index([workspaceId])
  @@map("deals")
}

model DealMilestone {
  id          String    @id @default(uuid())
  dealId      String    @map("deal_id")
  deal        Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  name        String // e.g. "Deposit", "Inspection", "Closing"
  status      String    @default("pending") // pending | completed
  dueDate     DateTime? @map("due_date")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([dealId])
  @@map("deal_milestones")
}

model DealDocument {
  id        String   @id @default(uuid())
  dealId    String   @map("deal_id")
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  type      String // contract | amendment | inspection_report | etc.
  fileUrl   String   @map("file_url")
  status    String   @default("uploaded") // uploaded | signed
  createdAt DateTime @default(now()) @map("created_at")

  @@index([dealId])
  @@map("deal_documents")
}

// Invoices generated from platform payments (bookings, subscriptions, deals)
model PlatformInvoice {
  id                String                @id @default(uuid())
  paymentId         String                @map("payment_id")
  payment           PlatformPayment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoiceIssuer     InvoiceIssuer         @default(PLATFORM) @map("invoice_issuer")
  /**
   * Payer (PLATFORM invoice) or broker recipient (BROKER invoice).
   */
  userId            String                @map("user_id")
  user              User                  @relation("PlatformInvoiceParty", fields: [userId], references: [id], onDelete: Cascade)
  /// Unique human-facing invoice number (e.g. INV-2026-000001). Immutable once issued; tax lines are frozen at issuance.
  invoiceNumber     String                @unique @map("invoice_number")
  status            PlatformInvoiceStatus @default(ISSUED) @map("status")
  /// Product / hub attribution (mirrors `PlatformPayment.paymentType` or finer label).
  hubSource         String?               @map("hub_source")
  amountCents       Int                   @map("amount_cents")
  currency          String                @default("cad")
  pdfUrl            String?               @map("pdf_url")
  invoiceLabel      String?               @map("invoice_label") // Human-readable: Platform service invoice | Broker commission invoice
  invoiceTaxDetails Json?                 @map("invoice_tax_details") // issuer-specific; never merge both issuers in one row
  subtotalCents     Int?                  @map("subtotal_cents")
  gstCents          Int?                  @map("gst_cents")
  qstCents          Int?                  @map("qst_cents")
  totalCents        Int?                  @map("total_cents")
  invoiceLines      Json?                 @map("invoice_lines") // line items with party + tax — snapshot at issuance
  taxMode           String?               @map("tax_mode") // EXCLUSIVE | INCLUSIVE
  issuedAt          DateTime              @default(now()) @map("issued_at")
  dueAt             DateTime?             @map("due_at")
  paidAt            DateTime?             @map("paid_at")
  notes             String?               @map("notes") @db.Text
  linkedContractId  String?               @map("linked_contract_id")
  createdAt         DateTime              @default(now()) @map("created_at")

  @@unique([paymentId, invoiceIssuer])
  @@index([userId])
  @@index([paymentId])
  @@index([invoiceIssuer])
  @@index([status])
  @@map("platform_invoices")
}

// Singleton-style platform tax & registration info (admin-maintained).
model PlatformFinancialSettings {
  id                          String   @id @default("default")
  legalName                   String?  @map("legal_name")
  platformGstNumber           String?  @map("platform_gst_number")
  platformQstNumber           String?  @map("platform_qst_number")
  defaultGstRate              Decimal  @default(0.05) @map("default_gst_rate") @db.Decimal(12, 8)
  defaultQstRate              Decimal  @default(0.09975) @map("default_qst_rate") @db.Decimal(12, 8)
  applyTaxToPlatformServices  Boolean  @default(true) @map("apply_tax_platform_services")
  applyTaxToBrokerCommissions Boolean  @default(true) @map("apply_tax_broker_commissions")
  /**
   * Per payment_type: { "booking": { "taxPlatform": true, "taxBroker": true }, ... } — overrides global toggles when set.
   */
  paymentTypeTaxOverrides     Json?    @map("payment_type_tax_overrides")
  /**
   * Internal: investment / securities-adjacent hub (AMF risk) — default off.
   */
  investmentFeaturesEnabled   Boolean  @default(false) @map("investment_features_enabled")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  @@map("platform_financial_settings")
}

// Separate platform vs broker revenue — one row per party per payment slice (never mixed).
model PartyRevenueLedgerEntry {
  id                 String            @id @default(uuid())
  platformPaymentId  String            @map("platform_payment_id")
  platformPayment    PlatformPayment   @relation(fields: [platformPaymentId], references: [id], onDelete: Cascade)
  party              RevenueParty
  category           String            @map("category") // e.g. platform_booking_fee, broker_deal_commission
  amountCents        Int               @map("amount_cents")
  currency           String            @default("cad")
  brokerCommissionId String?           @unique @map("broker_commission_id")
  brokerCommission   BrokerCommission? @relation(fields: [brokerCommissionId], references: [id], onDelete: SetNull)
  brokerId           String?           @map("broker_id")
  broker             User?             @relation(fields: [brokerId], references: [id], onDelete: SetNull)
  dealId             String?           @map("deal_id")
  listingId          String?           @map("listing_id")
  metadata           Json?
  createdAt          DateTime          @default(now()) @map("created_at")

  @@index([platformPaymentId])
  @@index([party])
  @@index([brokerId])
  @@index([category])
  @@map("party_revenue_ledger_entries")
}

// Stripe financial sync — ledger per webhook event (idempotent by stripe_event_id)
model StripeLedgerEntry {
  id                String           @id @default(uuid())
  stripeEventId     String           @unique @map("stripe_event_id")
  objectType        String           @map("object_type") // checkout_session | charge | refund | payment_intent
  stripeObjectId    String           @map("stripe_object_id")
  amountCents       Int              @map("amount_cents")
  feeCents          Int              @default(0) @map("fee_cents")
  currency          String           @default("cad")
  status            String
  userId            String?          @map("user_id")
  platformPaymentId String?          @map("platform_payment_id")
  metadata          Json?
  createdAt         DateTime         @default(now()) @map("created_at")
  user              User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  platformPayment   PlatformPayment? @relation(fields: [platformPaymentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([platformPaymentId])
  @@index([createdAt])
  @@map("stripe_ledger_entries")
}

// Accountant / admin financial audit trail
model FinancialAuditLog {
  id          String   @id @default(uuid())
  actorUserId String   @map("actor_user_id")
  actor       User     @relation(fields: [actorUserId], references: [id], onDelete: Cascade)
  action      String // finance_overview_view | finance_export_csv | finance_export_pdf | tax_doc_generate | stripe_ledger_sync
  entityType  String?  @map("entity_type")
  entityId    String?  @map("entity_id")
  ipAddress   String?  @map("ip_address")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([actorUserId])
  @@index([createdAt])
  @@map("financial_audit_logs")
}

// Tax / accounting documents (invoices, receipts, slips, summaries — data for PDF/CSV export)
model TaxDocument {
  id                String    @id @default(uuid())
  documentType      String    @map("document_type") // INVOICE | RECEIPT | COMMISSION_REPORT | TAX_SUMMARY | ANNUAL_EARNINGS_SUMMARY | BROKER_COMMISSION_SUMMARY | BROKER_PAYOUT_SUMMARY | PLATFORM_REVENUE_SUMMARY | MONTHLY_PLATFORM_REPORT
  title             String
  periodYear        Int?      @map("period_year")
  periodMonth       Int?      @map("period_month")
  subjectUserId     String?   @map("subject_user_id")
  dealId            String?
  platformPaymentId String?   @map("platform_payment_id")
  summaryMarkdown   String?   @map("summary_markdown") @db.Text
  status            String    @default("active") // active | void — internal workflow only
  issueDate         DateTime? @map("issue_date")
  generatedByUserId String    @map("generated_by_user_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  subjectUser       User?     @relation("TaxDocumentSubject", fields: [subjectUserId], references: [id], onDelete: SetNull)
  generatedBy       User      @relation("TaxDocumentGeneratedBy", fields: [generatedByUserId], references: [id])

  @@index([subjectUserId])
  @@index([documentType])
  @@index([periodYear])
  @@index([status])
  @@map("tax_documents")
}

// ---------------------------------------------------------------------------
// BNHub: Reviews (property + host)
// ---------------------------------------------------------------------------
/// Guest reviews stay + host (`reviewerType` = GUEST implicitly; see `BnhubHostReviewOfGuest` for host → guest).
model Review {
  id                  String                   @id @default(uuid())
  propertyRating      Int // 1-5 overall
  hostRating          Int? // 1-5 optional
  cleanlinessRating   Int? // 1-5 BNHub category
  accuracyRating      Int?                     @map("accuracy_rating")
  communicationRating Int? // 1-5
  locationRating      Int? // 1-5
  valueRating         Int? // 1-5
  checkinRating       Int?                     @map("check_in_rating")
  comment             String?
  /// Guest post-stay checklist (kitchen, beds, amenities accurate, etc.)
  stayChecklistJson   Json?                    @map("stay_checklist_json")
  /// Whether advertised amenities matched reality (guest attestation).
  amenitiesAsAdvertised Boolean?               @map("amenities_as_advertised")
  /// AI-assisted composite 0–100 for reputation / monthly medians.
  aiCompositeScore    Float?                   @map("ai_composite_score")
  aiSummary           String?                  @map("ai_summary") @db.Text
  /// When true, review is hidden from public until moderation clears.
  moderationHeld      Boolean                  @default(false) @map("moderation_held")
  /// Heuristic 0–1; higher = more spam-like (optional moderation queue).
  spamScore           Float?                   @map("spam_score")
  createdAt           DateTime
  updatedAt           DateTime                 @updatedAt
  guestId             String
  guest               User                     @relation(fields: [guestId], references: [id], onDelete: Cascade)
  listingId           String
  listing             ShortTermListing         @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bookingId           String                   @unique
  booking             Booking                  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bnhubModeration     BnhubReviewModeration?
  bnhubAbuseReports   BnhubReviewAbuseReport[]

  @@index([listingId])
  @@index([guestId])
}

/// Host → guest post-stay evaluation (`reviewerType` = HOST implicitly). One row per `bookingId`.
model BnhubHostReviewOfGuest {
  id                       String           @id @default(uuid())
  bookingId                String           @unique @map("booking_id")
  booking                  Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  hostId                   String           @map("host_id")
  host                     User             @relation("BnhubHostReviewAuthor", fields: [hostId], references: [id], onDelete: Cascade)
  guestId                  String           @map("guest_id")
  guest                    User             @relation("BnhubHostReviewSubjectGuest", fields: [guestId], references: [id], onDelete: Cascade)
  listingId                String           @map("listing_id")
  listing                  ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  guestRespectRating       Int              @map("guest_respect_rating")
  propertyCareRating       Int?             @map("property_care_rating")
  checkoutComplianceRating Int?             @map("checkout_compliance_rating")
  quietHoursRespected      Boolean?         @map("quiet_hours_respected")
  houseRulesRespected      Boolean?         @map("house_rules_respected")
  theftOrDamageReported    Boolean          @default(false) @map("theft_or_damage_reported")
  incidentDetails          String?          @map("incident_details") @db.Text
  hostNotes                String?          @map("host_notes") @db.Text
  hostChecklistJson        Json?            @map("host_checklist_json")
  aiCompositeScore         Float?           @map("ai_composite_score")
  aiSummary                String?          @map("ai_summary") @db.Text
  createdAt                DateTime         @default(now()) @map("created_at")
  updatedAt                DateTime         @updatedAt @map("updated_at")

  @@index([guestId])
  @@index([hostId])
  @@index([listingId])
  @@map("bnhub_host_reviews_of_guest")
}

/// Monthly median AI-assisted scores + top-performer flags (rewards, listing boost).
model BnhubMonthlyReputationSnapshot {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodYearMonth String   @map("period_year_month") @db.VarChar(7)
  role            String   @map("role") @db.VarChar(16)
  city            String   @default("") @map("city") @db.VarChar(128)
  medianScore     Float    @map("median_score")
  sampleCount     Int      @map("sample_count")
  rankInScope     Int?     @map("rank_in_scope")
  topPerformer    Boolean  @default(false) @map("top_performer")
  perksJson       Json?    @map("perks_json")
  computedAt      DateTime @default(now()) @map("computed_at")

  @@unique([userId, periodYearMonth, role, city])
  @@index([periodYearMonth, role, topPerformer])
  @@map("bnhub_monthly_reputation_snapshots")
}

/// Denormalized guest-review aggregates per BNHub listing (ShortTermListing).
model PropertyRatingAggregate {
  id               String           @id @default(cuid())
  listingId        String           @unique @map("listing_id")
  listing          ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  avgRating        Float            @map("avg_rating")
  totalReviews     Int              @map("total_reviews")
  cleanlinessAvg   Float            @map("cleanliness_avg")
  accuracyAvg      Float            @map("accuracy_avg")
  communicationAvg Float            @map("communication_avg")
  locationAvg      Float            @map("location_avg")
  valueAvg         Float            @map("value_avg")
  checkinAvg       Float            @map("checkin_avg")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@map("property_rating_aggregates")
}

/// BNHub host operational + reputation score (0–100), recomputed from bookings + reviews.
model HostPerformance {
  id               String   @id @default(cuid())
  hostId           String   @unique @map("host_id")
  host             User     @relation(fields: [hostId], references: [id], onDelete: Cascade)
  responseRate     Float    @map("response_rate")
  avgResponseTime  Float    @map("avg_response_time")
  cancellationRate Float    @map("cancellation_rate")
  completionRate   Float    @map("completion_rate")
  disputeRate      Float    @map("dispute_rate")
  score            Float
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("host_performance")
}

model HostBadge {
  id         String   @id @default(cuid())
  hostId     String   @map("host_id")
  host       User     @relation("BnhubHostTrustBadges", fields: [hostId], references: [id], onDelete: Cascade)
  badgeType  String   @map("badge_type") @db.VarChar(48)
  assignedAt DateTime @default(now()) @map("assigned_at")

  @@unique([hostId, badgeType])
  @@index([hostId])
  @@map("host_badges")
}

// ---------------------------------------------------------------------------
// LECIPM + BNHub: explainable listing ranking (scores, configs, telemetry)
// listingId = canonical PK string (UUID/cuid) for ShortTermListing / FsboListing
// ---------------------------------------------------------------------------
model ListingRankingScore {
  id                           String   @id @default(cuid())
  listingType                  String   @map("listing_type") @db.VarChar(32)
  listingId                    String   @map("listing_id") @db.VarChar(40)
  city                         String?  @db.VarChar(128)
  neighborhood                 String?  @db.VarChar(128)
  totalScore                   Float    @map("total_score")
  relevanceScore               Float    @map("relevance_score")
