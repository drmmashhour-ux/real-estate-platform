/// Mandatory verification gates for seller_direct (and broker-owned FSBO rows). `VERIFIED` = approved in product copy.
model FsboListingVerification {
  id                      String             @id @default(cuid())
  fsboListingId           String             @unique @map("fsbo_listing_id")
  fsboListing             FsboListing        @relation(fields: [fsboListingId], references: [id], onDelete: Cascade)
  identityStatus          VerificationStatus @default(PENDING) @map("identity_status")
  cadasterStatus          VerificationStatus @default(PENDING) @map("cadaster_status")
  addressStatus           VerificationStatus @default(PENDING) @map("address_status")
  sellerDeclarationStatus VerificationStatus @default(PENDING) @map("seller_declaration_status")
  disclosuresStatus       VerificationStatus @default(PENDING) @map("disclosures_status")
  createdAt               DateTime           @default(now()) @map("created_at")
  updatedAt               DateTime           @updatedAt @map("updated_at")

  @@map("fsbo_listing_verifications")
}

model FsboLead {
  id                 String      @id @default(cuid())
  listingId          String      @map("listing_id")
  listing            FsboListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  name               String
  email              String
  phone              String?
  message            String?     @db.Text
  /// DIRECT_BUYER | legacy owner contact
  leadSource         String?     @map("lead_source")
  tenantId           String?     @map("tenant_id")
  tenant             Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  /// PLATFORM_ORIGIN when buyer contacted listing party via platform (commission funnel)
  dealOriginTag      String?     @map("deal_origin_tag")
  commissionEligible Boolean     @default(false) @map("commission_eligible")
  createdAt          DateTime    @default(now()) @map("created_at")

  @@index([listingId])
  @@index([tenantId])
  @@map("fsbo_leads")
}

/// Buyer asked platform to assign a broker (guided purchase / sale support).
model BuyerRequest {
  id                 String        @id @default(cuid())
  tenantId           String?       @map("tenant_id")
  tenant             Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  userId             String?       @map("user_id")
  user               User?         @relation("BuyerRequestBuyer", fields: [userId], references: [id], onDelete: SetNull)
  buyerEmail         String?       @map("buyer_email")
  buyerName          String?       @map("buyer_name")
  buyerPhone         String?       @map("buyer_phone")
  fsboListingId      String        @map("fsbo_listing_id")
  fsboListing        FsboListing   @relation(fields: [fsboListingId], references: [id], onDelete: Cascade)
  budgetMinCents     Int?          @map("budget_min_cents")
  budgetMaxCents     Int?          @map("budget_max_cents")
  timeline           String?       @db.Text
  preferences        String?       @db.Text
  leadSource         String        @default("PLATFORM_BROKER") @map("lead_source")
  assignedBrokerId   String?       @map("assigned_broker_id")
  assignedBroker     User?         @relation("BuyerRequestAssignedBroker", fields: [assignedBrokerId], references: [id], onDelete: SetNull)
  brokerClientId     String?       @unique @map("broker_client_id")
  brokerClient       BrokerClient? @relation(fields: [brokerClientId], references: [id], onDelete: SetNull)
  conversationId     String?       @unique @map("conversation_id")
  conversation       Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  commissionEligible Boolean       @default(true) @map("commission_eligible")
  dealOriginTag      String        @default("PLATFORM_MANAGED") @map("deal_origin_tag")
  createdAt          DateTime      @default(now()) @map("created_at")

  @@index([fsboListingId])
  @@index([assignedBrokerId])
  @@index([userId])
  @@index([tenantId])
  @@map("buyer_requests")
}

/// Paid buyer advisory (premium tier).
