  approvedByActorId  String?  @map("approved_by_actor_id")
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([ownerType, ownerId], map: "idx_accountability_owner")
  @@index([accountableActorId], map: "idx_accountability_accountable")
  @@index([entityType, entityId], map: "idx_accountability_entity")
  @@map("accountability_records")
}

// @domain: core
model LecipmBrokerAppraisalCase {
  id               String        @id @default(cuid())
  brokerUserId     String        @map("broker_user_id")
  subjectListingId String        @map("subject_listing_id")
  dealAnalysisId   String?       @unique @map("deal_analysis_id")
  dealAnalysis     DealAnalysis? @relation(fields: [dealAnalysisId], references: [id], onDelete: SetNull)
  title            String?
  reportNumber     String?       @unique @map("report_number")

  comparablesReviewed Boolean @default(false) @map("comparables_reviewed")
  adjustmentsReviewed Boolean @default(false) @map("adjustments_reviewed")
  assumptionsReviewed Boolean @default(false) @map("assumptions_reviewed")
  conclusionReviewed  Boolean @default(false) @map("conclusion_reviewed")
  brokerApproved      Boolean @default(false) @map("broker_approved")

  reportDraftJson      Json?     @map("report_draft_json") @db.JsonB
  reportReviewedAt     DateTime? @map("report_reviewed_at")
  valueIndicationCents Int?      @map("value_indication_cents")
  finalizedAt          DateTime? @map("finalized_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([brokerUserId], map: "idx_lecipm_broker_appraisal_broker")
  @@index([subjectListingId], map: "idx_lecipm_broker_appraisal_listing")
  @@map("lecipm_broker_appraisal_cases")
}

// @domain: core
model AccountingEntry {
  id             String                @id @default(cuid())
  entryType      String                @map("entry_type") // revenue | expense | payout | refund | tax
  category       String
  sourceType     String?               @map("source_type") // booking | fsbo | subscription | lead | mortgage | manual
  sourceId       String?               @map("source_id")
  subtotalCents  Int                   @default(0) @map("subtotal_cents")
  gstCents       Int                   @default(0) @map("gst_cents")
  qstCents       Int                   @default(0) @map("qst_cents")
  totalCents     Int                   @default(0) @map("total_cents")
  status         String // pending | completed | failed | reconciled
  notes          String?               @db.Text
  entryDate      DateTime              @map("entry_date")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  reconciliation ReconciliationRecord?

  @@index([entryType])
  @@index([category])
  @@index([entryDate])
  @@index([status])
  @@map("accounting_entries")
}

// @domain: core
model LecipmBrokerageContract {
  id        String  @id @default(cuid())
  listingId String  @unique @map("listing_id")
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  brokerId  String  @map("broker_id")
  broker    User    @relation("LecipmBrokerageContractBroker", fields: [brokerId], references: [id], onDelete: Cascade)
  agencyId  String? @map("agency_id")
  agency    Tenant? @relation(fields: [agencyId], references: [id], onDelete: SetNull)

  contractType BrokerageContractType   @map("contract_type")
  status       BrokerageContractStatus @default(draft)
  startDate    DateTime?               @map("start_date") @db.Date
  endDate      DateTime?               @map("end_date") @db.Date

  includesDistributionAuthorization Boolean @default(false) @map("includes_distribution_authorization")
  distributionScope                 Json?   @map("distribution_scope")

  formVersion OaciqMandatoryFormVersion @map("form_version")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([brokerId])
  @@index([agencyId])
  @@map("brokerage_contracts")
}

// @domain: core
model LecipmBrokerageIdentityProof {
  id           String  @id @default(cuid())
  listingId    String  @map("listing_id")
  listing      Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sellerUserId String  @map("seller_user_id")
  seller       User    @relation("LecipmBrokerageIdentityProofSeller", fields: [sellerUserId], references: [id], onDelete: Cascade)

  verifiedByBrokerId String @map("verified_by_broker_id")
  verifiedByBroker   User   @relation("LecipmBrokerageIdentityProofVerifier", fields: [verifiedByBrokerId], references: [id], onDelete: Cascade)

  verificationMethod    LecipmIdentityProofMethod @map("verification_method")
  documentType          String                    @map("document_type") @db.VarChar(64)
  documentReferenceHash String                    @map("document_reference_hash") @db.VarChar(128)

  verifiedAt DateTime @map("verified_at")

  confidential Boolean                       @default(true)
  visibleTo    LecipmIdentityProofVisibility @default(broker_only) @map("visible_to")

  attachableToTransactionDocuments Boolean @default(false) @map("attachable_to_transaction_documents")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([listingId, sellerUserId])
  @@index([verifiedByBrokerId])
  @@map("lecipm_brokerage_identity_proofs")
}

