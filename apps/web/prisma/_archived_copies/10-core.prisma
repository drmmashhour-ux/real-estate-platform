model MortgageExpert {
  id                       String                    @id @default(cuid())
  userId                   String                    @unique @map("user_id")
  user                     User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                     String
  email                    String
  phone                    String?                   @map("phone")
  photo                    String?                   @map("photo")
  company                  String?                   @map("company")
  licenseNumber            String?                   @map("license_number")
  /// Government-issued ID type for identity verification (e.g. qc_driver_license, canadian_passport).
  idDocumentType           String?                   @map("id_document_type")
  /// Stored path under /public (uploaded ID scan; access restricted to expert + admin flows).
  idDocumentPath           String?                   @map("id_document_path")
  /// profile_incomplete | pending_review | verified | rejected
  expertVerificationStatus String                    @default("profile_incomplete") @map("expert_verification_status")
  /// When the broker attested holding a valid AMF mortgage broker licence (Québec).
  ampAttestedAt            DateTime?                 @map("amp_attested_at")
  profileSubmittedAt       DateTime?                 @map("profile_submitted_at")
  title                    String?                   @map("title")
  bio                      String?                   @map("bio") @db.Text
  isActive                 Boolean                   @default(true) @map("is_active")
  /// Accepting new auto-assigned leads (subject to caps / credits).
  isAvailable              Boolean                   @default(true) @map("is_available")
  /// Default daily cap; subscription may override when active.
  maxLeadsPerDay           Int                       @default(10) @map("max_leads_per_day")
  currentLeadsToday        Int                       @default(0) @map("current_leads_today")
  /// Denormalized client review average (1–5).
  rating                   Float                     @default(5)
  reviewCount              Int                       @default(0) @map("review_count")
  totalDeals               Int                       @default(0) @map("total_deals")
  totalRevenue             Int                       @default(0) @map("total_revenue")
  /// Admin can set display/routing boost (also used if you manually curb a bad actor).
  adminRatingBoost         Float                     @default(0) @map("admin_rating_boost")
  /// Optional monetization upsells (admin / ops).
  revenuePremiumListing    Boolean                   @default(false) @map("revenue_premium_listing")
  revenueFeaturedExpert    Boolean                   @default(false) @map("revenue_featured_expert")
  revenuePremiumPlacement  Boolean                   @default(false) @map("revenue_premium_placement")
  /// Expert must accept platform commission & anti-bypass terms before dashboard access.
  acceptedTerms            Boolean                   @default(false) @map("accepted_terms")
  acceptedAt               DateTime?                 @map("accepted_at")
