  granted     Boolean
  grantedAt   DateTime                    @default(now()) @map("granted_at")
  revokedAt   DateTime?                   @map("revoked_at")

  @@unique([userId, consentType])
  @@index([userId])
  @@map("lecipm_regulatory_consents")
}

model LecipmRegulatoryAuditLog {
  id           String                          @id @default(cuid())
  userId       String?                         @map("user_id")
  entityType   LecipmRegulatoryAuditEntityType @map("entity_type")
  entityId     String                          @map("entity_id") @db.VarChar(96)
  action       String                          @db.VarChar(160)
  metadataJson Json                            @default("{}") @map("metadata_json")
  createdAt    DateTime                        @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@map("lecipm_regulatory_audit_logs")
}

model LecipmRiskDisclosure {
