  fsboListingId         String                           @map("fsbo_listing_id")
  /// Object key within private bucket (e.g. `userId/listingId/uuid.pdf`) or `local:...` for dev disk fallback.
  storagePath           String                           @map("storage_path")
  originalFileName      String                           @map("original_file_name")
  mimeType              String                           @map("mime_type")
  category              SellerSupportingDocumentCategory
  status                SellerSupportingDocumentStatus   @default(PENDING)
  /// Optional link to seller declaration section (e.g. renovations, inspection).
  declarationSectionKey String?                          @map("declaration_section_key")
  createdAt             DateTime                         @default(now()) @map("created_at")
  updatedAt             DateTime                         @updatedAt @map("updated_at")

  @@index([userId])
  @@index([fsboListingId])
  @@index([status])
  @@map("seller_documents")
}

model VerificationRuleResult {
