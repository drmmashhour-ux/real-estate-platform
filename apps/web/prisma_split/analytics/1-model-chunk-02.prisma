  clauseText         String   @map("clause_text") @db.Text
  sourceReference    String   @map("source_reference") @db.Text
  approvedByBrokerId String?  @map("approved_by_broker_id")
  active             Boolean  @default(true)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([active, jurisdiction])
  @@map("clause_templates")
}

model DraftingSource {
  id             String   @id @default(uuid())
  sourceType     String   @map("source_type") @db.VarChar(32)
  title          String
  referenceLabel String   @map("reference_label") @db.VarChar(256)
  versionLabel   String?  @map("version_label") @db.VarChar(64)
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("drafting_sources")
}

model DealExecutionAuditLog {
  id          String   @id @default(uuid())
  dealId      String   @map("deal_id")
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  actorUserId String?  @map("actor_user_id")
  actionKey   String   @map("action_key") @db.VarChar(96)
  payload     Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([dealId, createdAt])
  @@map("deal_execution_audit_logs")
}

model DealExecutionApproval {
  id           String   @id @default(uuid())
  dealId       String   @map("deal_id")
  deal         Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  approvedById String   @map("approved_by_id")
  approvedAt   DateTime @default(now()) @map("approved_at")
  snapshot     Json     @default("{}")
  notes        String?  @db.Text

  @@index([dealId])
  @@index([approvedAt])
  @@map("deal_execution_approvals")
}

model BrokerApproval {
  id                  String            @id @default(cuid())
  dealId              String            @map("deal_id")
  deal                Deal              @relation(fields: [dealId], references: [id], onDelete: Cascade)
  status              String            @default("PENDING") @db.VarChar(16)
  actionKey           String            @default("execution_prep") @map("action_key") @db.VarChar(96)
  actionPayload       Json              @default("{}") @map("action_payload")
  beforeSnapshot      Json              @default("{}") @map("before_snapshot")
  afterSnapshot       Json?             @map("after_snapshot")
  requestedByUserId   String?           @map("requested_by_user_id") @db.VarChar(36)
  decidedByUserId     String?           @map("decided_by_user_id") @db.VarChar(36)
  decidedAt           DateTime?         @map("decided_at")
  oaciqAcknowledgedAt DateTime?         @map("oaciq_acknowledged_at")
  oaciqAckTextVersion String            @default("v1_oaciq_broker_2026") @map("oaciq_ack_text_version") @db.VarChar(48)
  rejectionReason     String?           @map("rejection_reason") @db.Text
  signatureSessionId  String?           @unique @map("signature_session_id")
  signatureSession    SignatureSession? @relation(fields: [signatureSessionId], references: [id], onDelete: SetNull)
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  @@index([dealId, status])
  @@index([dealId, createdAt(sort: Desc)])
  @@map("broker_approvals")
}

model ActionPipeline {
  id                        String                     @id @default(cuid())
  type                      ActionPipelineType
  dataJson                  Json                       @map("data_json")
  aiGenerated               Boolean                    @default(true) @map("ai_generated")
  status                    ActionPipelineStatus
  dealId                    String?                    @map("deal_id")
  deal                      Deal?                      @relation(fields: [dealId], references: [id], onDelete: SetNull)
  brokerSignature           BrokerSignature?
  signatureControlAuditLogs SignatureControlAuditLog[]
  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([dealId])
  @@map("action_pipelines")
}

model BrokerSignature {
  id           String         @id @default(cuid())
  brokerId     String         @map("broker_id")
  actionId     String         @unique @map("action_id")
  action       ActionPipeline @relation(fields: [actionId], references: [id], onDelete: Cascade)
  ipAddress    String?        @map("ip_address") @db.VarChar(64)
  userAgent    String?        @map("user_agent") @db.VarChar(512)
  signedAt     DateTime       @default(now()) @map("signed_at")
  documentHash String         @map("document_hash") @db.VarChar(128)

  @@index([brokerId])
  @@map("broker_signatures")
}

model SignatureControlAuditLog {
  id               String         @id @default(cuid())
  actionPipelineId String         @map("action_pipeline_id")
  actionPipeline   ActionPipeline @relation(fields: [actionPipelineId], references: [id], onDelete: Cascade)
  dealId           String?        @map("deal_id")
  eventKey         String         @map("event_key") @db.VarChar(64)
  payload          Json           @default("{}")
  actorUserId      String?        @map("actor_user_id")
  createdAt        DateTime       @default(now()) @map("created_at")

  @@index([actionPipelineId, createdAt])
  @@map("signature_control_audit_logs")
}

model DigitalSignature {
  id            String                      @id @default(cuid())
  userId        String                      @map("user_id") @db.VarChar(36)
  documentId    String                      @map("document_id") @db.VarChar(36)
  signatureHash String                      @map("signature_hash") @db.VarChar(128)
  ipAddress     String?                     @map("ip_address") @db.VarChar(48)
  userAgent     String?                     @map("user_agent") @db.Text
  signedAt      DateTime                    @default(now()) @map("signed_at")
  metadataJson  Json?                       @map("metadata_json")

  @@index([userId, signedAt])
  @@index([documentId])
  @@map("digital_signatures")
}

model SignatureSession {
  id                    String                       @id @default(uuid())
  dealId                String                       @map("deal_id")
  deal                  Deal                         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  status                String                       @db.VarChar(32)
  provider              String                       @db.VarChar(32)
  providerSessionId     String?                      @map("provider_session_id") @db.VarChar(160)
  /// Provider envelope/document ids, signing order, last webhook payload refs (non-PII summaries).
  providerMetadata      Json                         @default("{}") @map("provider_metadata")
  documentIds           Json                         @default("[]") @map("document_ids")
  createdAt             DateTime                     @default(now()) @map("created_at")
  updatedAt             DateTime                     @updatedAt @map("updated_at")
  participants          SignatureParticipant[]
  brokerApproval        BrokerApproval?

  @@index([dealId])
  @@index([provider, status])
  @@map("signature_sessions")
}

model SignatureParticipant {
  id                  String           @id @default(uuid())
  sessionId           String           @map("session_id")
  session             SignatureSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name                String
  role                String           @db.VarChar(32)
  email               String?
  status              String           @default("pending") @db.VarChar(24)
  signedAt            DateTime?        @map("signed_at")
  providerRecipientId String?          @map("provider_recipient_id") @db.VarChar(128)

  @@index([sessionId])
  @@map("signature_participants")
}

model SignatureEnvelope {
  id                               String    @id @default(cuid())
  dealId                           String    @map("deal_id")
  deal                             Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  sourceDocumentId                 String    @map("source_document_id") @db.VarChar(36)
  /// LEGAL_ARTIFACT | CLOSING_DOCUMENT | EXTERNAL
  sourceDocumentKind               String    @map("source_document_kind") @db.VarChar(32)
  title                            String    @default("Transaction documents") @db.VarChar(512)
  /// DRAFT | APPROVED | SENT | IN_PROGRESS | COMPLETED | VOIDED
  status                           String    @default("DRAFT") @db.VarChar(24)
  documentHashSha256               String?   @map("document_hash_sha256") @db.VarChar(64)
  hashComputedAt                   DateTime? @map("hash_computed_at")
  sourceVersionLockedAt            DateTime? @map("source_version_locked_at")
  documentHashBeforeFinalizeSha256 String?   @map("document_hash_before_finalize_sha256") @db.VarChar(64)
  canonicalPdfUrl                  String?   @map("canonical_pdf_url") @db.Text
  finalPdfUrl                      String?   @map("final_pdf_url") @db.Text
  auditTrailPdfUrl                 String?   @map("audit_trail_pdf_url") @db.Text
  approvedByBrokerId               String?   @map("approved_by_broker_id") @db.VarChar(36)
  approvedAt                       DateTime? @map("approved_at")
  brokerSigningConfiguredAt        DateTime? @map("broker_signing_configured_at")
  sentAt                           DateTime? @map("sent_at")
  completedAt                      DateTime? @map("completed_at")
  createdByUserId                  String?   @map("created_by_user_id") @db.VarChar(36)
  createdAt                        DateTime  @default(now()) @map("created_at")
  updatedAt                        DateTime  @updatedAt @map("updated_at")

  participants SignatureEnvelopeParticipant[]
  events       SignatureEnvelopeEvent[]
  versions     SignedDocumentVersion[]

  @@index([dealId, status])
  @@index([dealId, createdAt(sort: Desc)])
  @@map("signature_envelopes")
}

model SignatureEnvelopeParticipant {
  id                  String            @id @default(cuid())
  envelopeId          String            @map("envelope_id")
  envelope            SignatureEnvelope @relation(fields: [envelopeId], references: [id], onDelete: Cascade)
  signerRole          String            @map("signer_role") @db.VarChar(32)
  email               String            @db.VarChar(320)
  displayName         String            @map("display_name") @db.VarChar(256)
  routingOrder        Int               @default(1) @map("routing_order")
