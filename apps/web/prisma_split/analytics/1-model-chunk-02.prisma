  subtotalCents     Int?                  @map("subtotal_cents")
  gstCents          Int?                  @map("gst_cents")
  qstCents          Int?                  @map("qst_cents")
  totalCents        Int?                  @map("total_cents")
  invoiceLines      Json?                 @map("invoice_lines") // line items with party + tax — snapshot at issuance
  taxMode           String?               @map("tax_mode") // EXCLUSIVE | INCLUSIVE
