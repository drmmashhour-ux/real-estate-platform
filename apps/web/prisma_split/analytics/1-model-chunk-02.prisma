  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([dealId])
  @@map("deal_assets")
}

model DealStateTransition {
  id          String   @id @default(uuid())
  dealId      String   @map("deal_id")
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  fromState   String   @map("from_state") @db.VarChar(48)
  toState     String   @map("to_state") @db.VarChar(48)
  reason      String?  @db.Text
  metadata    Json     @default("{}")
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([dealId, createdAt])
  @@map("deal_state_transitions")
}

model SuggestionDecisionLog {
  id                 String   @id @default(uuid())
  dealId             String   @map("deal_id")
  deal               Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  documentId         String?  @map("document_id")
  suggestionType     String   @map("suggestion_type") @db.VarChar(64)
  suggestionPayload  Json     @map("suggestion_payload")
  action             String   @db.VarChar(24)
  actorId            String   @map("actor_id")
  sourceReferences   Json?    @map("source_references")
