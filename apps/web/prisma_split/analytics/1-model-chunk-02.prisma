model TrustLedgerEntry {
  id              String        @id @default(cuid())
  ownerType       String        @map("owner_type")
  ownerId         String        @map("owner_id")
  trustDepositId  String?       @map("trust_deposit_id")
  trustDeposit    TrustDeposit? @relation(fields: [trustDepositId], references: [id], onDelete: SetNull)
  listingId       String?       @map("listing_id")
  dealId          String?       @map("deal_id")
  entryType       String        @map("entry_type")
  direction       String
  amountCents     Int           @map("amount_cents")
  currency        String        @default("CAD")
  referenceNumber String?       @map("reference_number")
  notes           String?       @db.Text
  createdById     String?       @map("created_by_id")
  createdAt       DateTime      @default(now()) @map("created_at")

  @@index([ownerType, ownerId], map: "idx_trust_ledger_owner")
  @@index([trustDepositId], map: "idx_trust_ledger_deposit")
  @@map("trust_ledger_entries")
}

model TrustReconciliationRun {
  id                 String   @id @default(cuid())
  runNumber          String   @unique @map("run_number")
  ownerType          String   @map("owner_type")
  ownerId            String   @map("owner_id")
  status             String
  totalDepositsCents Int      @map("total_deposits_cents")
  totalLedgerCents   Int      @map("total_ledger_cents")
  differenceCents    Int      @map("difference_cents")
  details            Json?    @db.JsonB
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([ownerType, ownerId], map: "idx_trust_recon_owner")
  @@map("trust_reconciliation_runs")
}

model AiAutopilotProposal {
  id             String   @id @default(cuid())
  ownerType      String   @map("owner_type")
  ownerId        String   @map("owner_id")
  moduleKey      String   @map("module_key")
  proposalType   String   @map("proposal_type")
  entityType     String?  @map("entity_type")
  entityId       String?  @map("entity_id")
  content        Json     @db.JsonB
  rationale      String?  @db.Text
  sourceSummary  Json?    @map("source_summary") @db.JsonB
  requiresReview Boolean  @default(true) @map("requires_review")
  reviewed       Boolean  @default(false)
  approved       Boolean  @default(false)
  reviewedById   String?  @map("reviewed_by_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([ownerType, ownerId], map: "idx_ai_autopilot_owner")
  @@map("ai_autopilot_proposals")
}

model CashReceiptForm {
  id            String @id @default(cuid())
  receiptNumber String @unique @map("receipt_number")

  ownerType String @map("owner_type") // agency | solo_broker | platform
  ownerId   String @map("owner_id")

  payerUserId  String? @map("payer_user_id")
  payerName    String? @map("payer_name")
  payerContact String? @map("payer_contact")

  listingId  String? @map("listing_id")
  offerId    String? @map("offer_id")
  contractId String? @map("contract_id")
  dealId     String? @map("deal_id")
  bookingId  String? @map("booking_id")

  brokerId String? @map("broker_id")
  agencyId String? @map("agency_id")

  amountCents      Int     @map("amount_cents")
  currency         String  @default("CAD")
  paymentMethod    String  @map("payment_method") // cash | cheque | bank_transfer | card | other
  receivedForType  String  @map("received_for_type") // trust_deposit | brokerage_fee | platform_fee | rent | other
  receivedForLabel String? @map("received_for_label")

  fundsDestinationType String  @map("funds_destination_type") // trust | operating | platform_revenue | pending_review
  externalReference    String? @map("external_reference")
  notes                String? @db.Text

  receivedAt DateTime @map("received_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  /// Legacy regulator payload (prefer structured columns).
  payload Json? @db.JsonB

  ledgerEntries FinancialLedgerEntry[]
  registerLinks FinancialRegisterLink[]

  @@index([ownerType, ownerId], map: "idx_cash_receipt_owner")
  @@index([listingId], map: "idx_cash_receipt_listing")
  @@index([brokerId], map: "idx_cash_receipt_broker")
  @@index([receivedAt], map: "idx_cash_receipt_received_at")
  @@map("cash_receipt_forms")
}

model FinancialLedgerEntry {
  id        String @id @default(cuid())
  ownerType String @map("owner_type")
  ownerId   String @map("owner_id")

  entryNumber   String @unique @map("entry_number")
  entryType     String @map("entry_type") // receipt | deposit_to_trust | deposit_to_operating | release | refund | fee | reversal | adjustment
  accountBucket String @map("account_bucket")
  direction     String // debit | credit | memo

  amountCents Int    @map("amount_cents")
  currency    String @default("CAD")

  cashReceiptFormId String? @map("cash_receipt_form_id")
  trustDepositId    String? @map("trust_deposit_id")
  relatedEntryId    String? @map("related_entry_id")

  listingId  String? @map("listing_id")
  offerId    String? @map("offer_id")
  contractId String? @map("contract_id")
  dealId     String? @map("deal_id")

  effectiveDate DateTime @map("effective_date")
  description   String   @db.Text
  createdById   String?  @map("created_by_id")
  approvedById  String?  @map("approved_by_id")
  locked        Boolean  @default(false)

  createdAt DateTime @default(now()) @map("created_at")

  cashReceiptForm CashReceiptForm?        @relation(fields: [cashReceiptFormId], references: [id], onDelete: SetNull)
  trustDeposit    TrustDeposit?           @relation(fields: [trustDepositId], references: [id], onDelete: SetNull)
  relatedEntry    FinancialLedgerEntry?   @relation("FinancialLedgerReversal", fields: [relatedEntryId], references: [id], onDelete: SetNull)
  reversalOf      FinancialLedgerEntry[]  @relation("FinancialLedgerReversal")
  registerLinks   FinancialRegisterLink[]

  @@index([ownerType, ownerId], map: "idx_fin_ledger_owner")
  @@index([cashReceiptFormId], map: "idx_fin_ledger_cash_receipt")
  @@index([trustDepositId], map: "idx_fin_ledger_trust_deposit")
  @@index([effectiveDate], map: "idx_fin_ledger_effective_date")
  @@map("financial_ledger_entries")
}

model FinancialRegister {
  id        String @id @default(cuid())
  ownerType String @map("owner_type")
  ownerId   String @map("owner_id")

  registerType String   @map("register_type")
  registerDate DateTime @map("register_date")
  periodKey    String   @map("period_key")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  links FinancialRegisterLink[]

  @@unique([ownerType, ownerId, registerType, periodKey], map: "uq_financial_register_period")
  @@index([ownerType, ownerId], map: "idx_financial_register_owner")
  @@map("financial_registers")
}

model FinancialRegisterLink {
  id                  String  @id @default(cuid())
  financialRegisterId String  @map("financial_register_id")
  cashReceiptFormId   String? @map("cash_receipt_form_id")
  ledgerEntryId       String? @map("ledger_entry_id")
  trustDepositId      String? @map("trust_deposit_id")

  createdAt DateTime @default(now()) @map("created_at")

  financialRegister FinancialRegister     @relation(fields: [financialRegisterId], references: [id], onDelete: Cascade)
  cashReceiptForm   CashReceiptForm?      @relation(fields: [cashReceiptFormId], references: [id], onDelete: SetNull)
  ledgerEntry       FinancialLedgerEntry? @relation(fields: [ledgerEntryId], references: [id], onDelete: SetNull)
  trustDeposit      TrustDeposit?         @relation(fields: [trustDepositId], references: [id], onDelete: SetNull)

  @@index([financialRegisterId], map: "idx_fin_reg_link_register")
  @@index([cashReceiptFormId], map: "idx_fin_reg_link_receipt")
  @@index([ledgerEntryId], map: "idx_fin_reg_link_ledger")
  @@map("financial_register_links")
}

model FinancialComplianceEvent {
  id        String @id @default(cuid())
  ownerType String @map("owner_type")
  ownerId   String @map("owner_id")

  eventType  String @map("event_type")
  entityType String @map("entity_type")
  entityId   String @map("entity_id")

  performedById String? @map("performed_by_id")
  aiAssisted    Boolean @default(false) @map("ai_assisted")
  details       Json?   @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")

  @@index([ownerType, ownerId], map: "idx_fin_compliance_owner")
  @@index([entityType, entityId], map: "idx_fin_compliance_entity")
  @@index([eventType], map: "idx_fin_compliance_event_type")
  @@map("financial_compliance_events")
}

model DealAsset {
