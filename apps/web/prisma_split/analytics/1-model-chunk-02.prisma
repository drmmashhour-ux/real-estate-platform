model DealMilestone {
  id          String    @id @default(uuid())
  dealId      String    @map("deal_id")
  deal        Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  name        String // e.g. "Deposit", "Inspection", "Closing"
  status      String    @default("pending") // pending | completed
  dueDate     DateTime? @map("due_date")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([dealId])
  @@map("deal_milestones")
}

model DealDocument {
  id                             String                          @id @default(uuid())
  dealId                         String                          @map("deal_id")
  deal                           Deal                            @relation(fields: [dealId], references: [id], onDelete: Cascade)
  type                           String // contract | amendment | inspection_report | etc.
  /// Nullable when row is structured-draft-only until broker uploads official PDF.
  fileUrl                        String?                         @map("file_url")
  status                         String                          @default("uploaded") // uploaded | signed (legacy); see workflowStatus for execution pipeline
  createdAt                      DateTime                        @default(now()) @map("created_at")
  templateKey                    String?                         @map("template_key") @db.VarChar(160)
  versionLabel                   String?                         @map("version_label") @db.VarChar(64)
  sourceType                     String?                         @map("source_type") @db.VarChar(32)
  structuredData                 Json?                           @map("structured_data")
  renderedOutput                 Json?                           @map("rendered_output")
  /// draft | broker_review | approved | exported | signed | archived — assists broker review gates
  workflowStatus                 String?                         @map("workflow_status") @db.VarChar(24)
  fulfillingRequestItems         DealRequestItem[]
  documentVersions               DealDocumentVersion[]
  lecipmProductionGuardArtifacts LecipmProductionGuardArtifact[]
  crmDealInvestorSubscriptions   CrmDealInvestorSubscription[]
  privateInvestorPacketDocuments PrivateInvestorPacketDocument[]

  @@index([dealId])
  @@index([workflowStatus])
  @@map("deal_documents")
}

model DealParty {
  id                     String        @id @default(uuid())
  dealId                 String        @map("deal_id")
  deal                   Deal          @relation(fields: [dealId], references: [id], onDelete: Cascade)
  role                   DealPartyRole
  fullName               String        @map("full_name")
  email                  String?
  phone                  String?
  address                String?       @db.Text
  representativeCapacity String?       @map("representative_capacity") @db.Text
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  @@index([dealId])
  @@map("deal_parties")
}

model DealDocumentVersion {
  id             String                    @id @default(uuid())
  dealDocumentId String                    @map("deal_document_id")
  dealDocument   DealDocument              @relation(fields: [dealDocumentId], references: [id], onDelete: Cascade)
  versionNumber  Int                       @map("version_number")
  source         DealDocumentVersionSource
  changesSummary Json                      @default("{}") @map("changes_summary")
  /// Optional structured snapshot at version time (specimen / draft assistance — not operative execution).
  snapshot       Json?                     @map("snapshot")
  createdById    String?                   @map("created_by_id")
  createdAt      DateTime                  @default(now()) @map("created_at")

  @@unique([dealDocumentId, versionNumber])
  @@index([dealDocumentId])
  @@map("deal_document_versions")
}

model DealCopilotSuggestion {
  id                   String    @id @default(uuid())
  dealId               String    @map("deal_id")
  deal                 Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  suggestionType       String    @map("suggestion_type") @db.VarChar(64)
  title                String
  summary              String    @db.Text
  confidence           Float     @default(0.5)
  severity             String    @db.VarChar(16)
  reasons              Json      @default("[]")
  recommendedAction    String?   @map("recommended_action") @db.Text
  linkedDocumentId     String?   @map("linked_document_id")
  linkedFields         Json?     @map("linked_fields")
  brokerReviewRequired Boolean   @default(true) @map("broker_review_required")
  status               String    @default("pending") @db.VarChar(24)
  sourceAttribution    Json?     @map("source_attribution")
  createdAt            DateTime  @default(now()) @map("created_at")
  resolvedAt           DateTime? @map("resolved_at")
  resolvedById         String?   @map("resolved_by_id")

  @@index([dealId, status])
  @@map("deal_copilot_suggestions")
}

model ClauseTemplate {
  id                 String   @id @default(uuid())
  title              String
  category           String   @db.VarChar(64)
  jurisdiction       String   @default("QC") @db.VarChar(16)
  transactionType    String   @map("transaction_type") @db.VarChar(64)
