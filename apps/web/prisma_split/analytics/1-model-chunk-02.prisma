  suspendedAt      DateTime?
  bannedAt         DateTime?
  linkedAccountIds Json      @default("[]") // suspected or confirmed
  notes            String?
  updatedAt        DateTime
  createdAt        DateTime  @default(now())

  @@index([userId])
}

model PrivilegedAdminAction {
  id         String   @id @default(uuid())
  adminId    String
  actionType String // PAYOUT_RELEASE | SUSPENSION | BAN | IMPERSONATION | EVIDENCE_ACCESS | LEGAL_EXPORT
  entityType String?
  entityId   String?
  reasonCode String?
  reasonText String?
  approvalId String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([actionType])
  @@index([createdAt])
}

model ApprovalRequest {
  id          String                @id @default(uuid())
  requestType String // PAYOUT_RELEASE | ACCOUNT_SUSPENSION | BAN | CRISIS_ACTION
  requestedBy String
  targetType  String?
  targetId    String?
  reasonCode  String?
  payload     Json?
  status      ApprovalRequestStatus @default(PENDING)
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNotes String?
  createdAt   DateTime
  updatedAt   DateTime              @updatedAt

  @@index([status])
  @@index([requestedBy])
  @@index([createdAt])
}

model FinancialRiskFlag {
  id          String    @id @default(uuid())
  entityType  String // PAYOUT | PAYMENT | REFUND | BOOKING
  entityId    String
  flagType    String // SUSPICIOUS_PAYOUT | REFUND_ABUSE | CHARGEBACK_RISK | ANOMALY
  severity    String // LOW | MEDIUM | HIGH
  status      String    @default("OPEN") // OPEN | UNDER_REVIEW | CLEARED | CONFIRMED
  amountCents Int?
  payload     Json?
  createdBy   String?
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime  @default(now())

  @@index([entityType, entityId])
  @@index([flagType])
  @@index([status])
}

model UserSafetyProfile {
  id                   String   @id @default(uuid())
  userId               String   @unique @map("user_id")
  hostRiskScore        Float?   @map("host_risk_score") // 0-1
  guestRiskScore       Float?   @map("guest_risk_score") // 0-1
  warningCount         Int      @default(0) @map("warning_count")
  suspensionCount      Int      @default(0) @map("suspension_count")
  seriousIncidentCount Int      @default(0) @map("serious_incident_count")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("user_safety_profiles")
}

model DefenseMetricsSnapshot {
  id                 String   @id @default(uuid())
  date               DateTime
  marketId           String?
  incidentCount      Int      @default(0)
  disputeCount       Int      @default(0)
  disputeRate        Float?
  fraudLossCents     Int      @default(0)
  abuseSignalsCount  Int      @default(0)
  suspensionCount    Int      @default(0)
  appealCount        Int      @default(0)
  appealApprovalRate Float?
  payoutHoldCount    Int      @default(0)
  complianceFailures Int      @default(0)
  data               Json? // extended breakdown
  createdAt          DateTime @default(now())

  @@index([date])
  @@index([marketId])
}

model CoOwnershipAdvisoryLog {
  id                String   @id @default(cuid())
  listingId         String   @map("listing_id")
  brokerId          String   @map("broker_id")
  advisoryType      String   @map("advisory_type") // e.g. "INSURANCE_GAP", "CERTIFICATE_MISSING"
  advisoryDelivered Boolean  @default(true) @map("advisory_delivered")
  timestamp         DateTime @default(now())

  @@index([listingId])
  @@index([brokerId])
  @@map("listing_coownership_advisory_logs")
}

model CoOwnershipAuditLog {
  id          String   @id @default(cuid())
  listingId   String   @map("listing_id")
  actorId     String?  @map("actor_id")
  event       String // e.g. "CHECKLIST_UPDATE", "ENFORCEMENT_BLOCK", "OVERRIDE"
  reason      String?  @db.Text
  beforeValue Json?    @map("before_value")
  afterValue  Json?    @map("after_value")
  timestamp   DateTime @default(now())

  @@index([listingId])
  @@map("listing_coownership_audit_logs")
}

model ChecklistItem {
  id                String                        @id @default(cuid())
  listingId         String                        @map("listing_id")
  category          ChecklistItemCategory         @default(COOWNERSHIP)
  key               String
  label             String
  description       String?
  status            ComplianceChecklistItemStatus @default(PENDING)
  required          Boolean                       @default(true)
  priority          ChecklistPriority             @default(MEDIUM)
  source            String?                       @db.VarChar(48)
  completedAt       DateTime?                     @map("completed_at")
  completedByUserId String?                       @map("completed_by_user_id")

  // Hardening extensions (Part 1, 3, 10)
  verificationLevel     ComplianceVerificationLevel @default(DECLARED) @map("verification_level")
  verifiedAt            DateTime?                   @map("verified_at")
  verifiedByUserId      String?                     @map("verified_by_user_id")
  supportingDocumentIds Json?                       @map("supporting_document_ids")
  validUntil            DateTime?                   @map("valid_until")
  isExpired             Boolean                     @default(false) @map("is_expired")

  isOverridden       Boolean @default(false) @map("is_overridden")
  overrideReason     String? @map("override_reason") @db.Text
  overriddenByUserId String? @map("overridden_by_user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([listingId, key], map: "uq_checklist_item_listing_key")
  @@index([listingId], map: "idx_checklist_item_listing_id")
  @@map("listing_coownership_checklist_items")
}

model OfferDraft {
  id                    String                       @id @default(cuid())
  dealId                String                       @map("deal_id")
  deal                  Deal                         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  listingId             String?                      @map("listing_id")
  buyerId               String                       @map("buyer_id")
  generatedBy           String                       @default("AI") @map("generated_by") @db.VarChar(16)
  /// DRAFT | READY_FOR_REVIEW | APPROVED | SENT
  status                String                       @default("DRAFT") @map("status") @db.VarChar(24)
  purchasePrice         Float                        @map("purchase_price")
  depositAmount         Float?                       @map("deposit_amount")
  financingDeadline     DateTime?                    @map("financing_deadline")
  inspectionDeadline    DateTime?                    @map("inspection_deadline")
  occupancyDate         DateTime?                    @map("occupancy_date")
  includedItemsJson     Json                         @default("[]") @map("included_items_json")
  excludedItemsJson     Json                         @default("[]") @map("excluded_items_json")
  specialConditionsJson Json                         @default("[]") @map("special_conditions_json")
  /// Price ladder + selected band + per-field traceability (sources: listing, negotiation_ai, clause_library, broker_default).
  rationaleJson         Json                         @map("rationale_json")
  priceBandsJson        Json?                        @map("price_bands_json")
  clauseWarningsJson    Json                         @default("[]") @map("clause_warnings_json")
  financingClauseText   String?                      @map("financing_clause_text") @db.Text
  inspectionClauseText  String?                      @map("inspection_clause_text") @db.Text
  occupancyClauseText   String?                      @map("occupancy_clause_text") @db.Text
  promiseArtifactId     String?                      @unique @map("promise_artifact_id")
  approvedAt            DateTime?                    @map("approved_at")
  approvedByBrokerId    String?                      @map("approved_by_broker_id")
  sentAt                DateTime?                    @map("sent_at")
  sentByBrokerId        String?                      @map("sent_by_broker_id")
  offerSnapshotJson     Json?                        @map("offer_snapshot_json")
  createdAt             DateTime                     @default(now()) @map("created_at")
  updatedAt             DateTime                     @updatedAt @map("updated_at")
  auditLogs             OfferDraftAuditLog[]

  @@index([dealId, createdAt(sort: Desc)])
  @@index([dealId, status])
  @@map("offer_drafts")
}

model OfferDraftAuditLog {
  id           String     @id @default(cuid())
  offerDraftId String     @map("offer_draft_id")
  offerDraft   OfferDraft @relation(fields: [offerDraftId], references: [id], onDelete: Cascade)
  dealId       String     @map("deal_id")
  deal         Deal       @relation(fields: [dealId], references: [id], onDelete: Cascade)
  actorUserId  String?    @map("actor_user_id")
  action       String     @db.VarChar(48)
  metadata     Json       @default("{}") @db.JsonB
  createdAt    DateTime   @default(now()) @map("created_at")

  @@index([dealId, createdAt])
  @@index([offerDraftId])
  @@index([action])
  @@map("offer_draft_audit_logs")
}

model DealPlaybook {
  id               String   @id @default(cuid())
  dealId           String   @unique @map("deal_id")
  deal             Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  /// Current step key (e.g. offer_generation_ai).
  currentStep      String   @map("current_step") @db.VarChar(48)
  completedSteps   Json     @default("[]") @map("completed_steps")
  nextAction       String   @map("next_action") @db.Text
  progressPercent  Float    @default(0) @map("progress_percent")
  trackingSnapshot Json     @default("{}") @map("tracking_snapshot")
  updatedAt        DateTime @updatedAt @map("updated_at")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([dealId])
  @@map("deal_playbooks")
}

model ActionRisk {
  id        String   @id @default(cuid())
  /// Logical action key, e.g. `offer_draft_approve:{dealId}:{draftId}` or `signature_session:{dealId}`.
  actionId  String   @map("action_id") @db.VarChar(200)
  riskScore Int      @map("risk_score")
  /// LOW | MEDIUM | HIGH
  riskLevel String   @map("risk_level") @db.VarChar(16)
  /// Structured flags + embedded warnings/blockers snapshot for replay.
  flagsJson Json     @default("{}") @map("flags_json")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([actionId, createdAt(sort: Desc)])
  @@map("action_risks")
}

model LecipmDeclarationDisclosure {
  id            String                          @id @default(cuid())
  listingId     String                          @map("listing_id")
  declarationId String                          @unique @map("declaration_id")

  disclosedToBuyer    Boolean                      @default(false) @map("disclosed_to_buyer")
  disclosureTimestamp DateTime?                    @map("disclosure_timestamp")
  disclosureMethod    DeclarationDisclosureMethod? @map("disclosure_method")

  buyerAcknowledgedAt DateTime? @map("buyer_acknowledged_at")
  buyerUserId         String?   @map("buyer_user_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([listingId])
  @@map("declaration_disclosures")
}

model EsgProfile {
  id                  String           @id @default(cuid())
  listingId           String           @unique @map("listing_id")
  energyScore         Float?           @map("energy_score")
  carbonScore         Float?           @map("carbon_score")
  sustainabilityScore Float?           @map("sustainability_score")
  certification       String?          @db.VarChar(32)
  solar               Boolean          @default(false)
  renovation          Boolean          @default(false)
  /// Penalizes composite when true (high embodied carbon assumptions).
  highCarbonMaterials Boolean          @default(false) @map("high_carbon_materials")
  compositeScore      Float?           @map("composite_score")
  grade               String?          @db.VarChar(1)
  /// 0–100 coverage from verified document evidence ingestion.
  dataCoveragePercent Float?           @default(0) @map("data_coverage_percent")
  /// Aggregate confidence from evidence pipeline (0–100).
  evidenceConfidence  Float?           @map("evidence_confidence")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  postCloseAssets     PostCloseAsset[]

  @@map("esg_profiles")
}

model EsgDocument {
  id                       String             @id @default(cuid())
  listingId                String             @map("listing_id")
  uploadedByUserId         String?            @map("uploaded_by_user_id")
  fileName                 String             @map("file_name") @db.VarChar(512)
  filePath                 String             @map("file_path") @db.VarChar(1024)
  mimeType                 String?            @map("mime_type") @db.VarChar(128)
  fileSizeBytes            Int?               @map("file_size_bytes")
  documentType             String?            @map("document_type") @db.VarChar(48)
  classificationConfidence Float?             @map("classification_confidence")
  processingStatus         String             @default("PENDING") @map("processing_status") @db.VarChar(24)
  extractedSummary         String?            @map("extracted_summary") @db.Text
  processingVersion        String?            @map("processing_version") @db.VarChar(24)
  extractionRulesVersion   String?            @map("extraction_rules_version") @db.VarChar(24)
  createdAt                DateTime           @default(now()) @map("created_at")
  updatedAt                DateTime           @updatedAt @map("updated_at")
  fields                   EsgDocumentField[]
  audits                   EsgDocumentAudit[]
  evidenceLinks            EsgEvidenceLink[]
  evidenceAnchors          EsgEvidence[]      @relation("EsgEvidenceSourceDocument")

  @@index([listingId, processingStatus])
  @@index([listingId, createdAt(sort: Desc)])
  @@map("esg_documents")
}

model EsgDocumentField {
  id               String            @id @default(cuid())
  documentId       String            @map("document_id")
  document         EsgDocument       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  fieldName        String            @map("field_name") @db.VarChar(128)
  fieldValueText   String            @map("field_value_text") @db.Text
  fieldValueNumber Float?            @map("field_value_number")
  unit             String?           @db.VarChar(32)
  extractionMethod String            @map("extraction_method") @db.VarChar(24)
  verification     String            @db.VarChar(16)
  confidence       Float?
  sourcePage       Int?              @map("source_page")
  note             String?           @db.Text
  createdAt        DateTime          @default(now()) @map("created_at")
  evidenceLinks    EsgEvidenceLink[]

  @@index([documentId, fieldName])
  @@map("esg_document_fields")
}

model EsgEvidence {
  id           String            @id @default(cuid())
  listingId    String            @map("listing_id")
  fieldKey     String            @map("field_key") @db.VarChar(128)
  valueText    String?           @map("value_text") @db.Text
  valueNumber  Float?            @map("value_number")
  unit         String?           @db.VarChar(32)
  verification String            @db.VarChar(16)
  confidence   Float?
  documentId   String?           @map("document_id")
  document     EsgDocument?      @relation("EsgEvidenceSourceDocument", fields: [documentId], references: [id], onDelete: SetNull)
  sourcePage   Int?              @map("source_page")
  snippetText  String?           @map("snippet_text") @db.Text
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  links        EsgEvidenceLink[]

  @@index([listingId, fieldKey])
  @@map("esg_evidence")
}

model EsgEvidenceLink {
  id              String            @id @default(cuid())
  evidenceId      String            @map("evidence_id")
  evidence        EsgEvidence       @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  documentId      String            @map("document_id")
  document        EsgDocument       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentFieldId String?           @map("document_field_id")
  documentField   EsgDocumentField? @relation(fields: [documentFieldId], references: [id], onDelete: SetNull)
  snippetText     String?           @map("snippet_text") @db.Text
  sourcePage      Int?              @map("source_page")
  createdAt       DateTime          @default(now()) @map("created_at")

  @@index([documentId])
  @@index([evidenceId])
  @@map("esg_evidence_links")
}
