   * Per payment_type: { "booking": { "taxPlatform": true, "taxBroker": true }, ... } — overrides global toggles when set.
   */
  paymentTypeTaxOverrides         Json?    @map("payment_type_tax_overrides")
  /**
   * Internal: investment / securities-adjacent hub (AMF risk) — default off.
   */
  investmentFeaturesEnabled       Boolean  @default(false) @map("investment_features_enabled")
  /// Revenue control: when true, broker CRM may require paid lead unlock (see `Lead` + unlock checkout).
  revenueMonetizationEnabled      Boolean  @default(false) @map("revenue_monetization_enabled")
  /// CAD cents — floor for dynamic lead unlock price (optional; pricing engine falls back to `PRICING.leadPriceCents`).
  revenueLeadUnlockMinCents       Int?     @map("revenue_lead_unlock_min_cents")
  revenueLeadUnlockMaxCents       Int?     @map("revenue_lead_unlock_max_cents")
  /// Optional admin override for default lead unlock anchor (CAD cents), e.g. 4900 — see `PRICING_CONFIG.canada.lead.default`.
  revenueLeadDefaultPriceCents    Int?     @map("revenue_lead_default_price_cents")
  /// Default BNHub listing boost (featured placement) — CAD cents; duration in days.
  revenueListingBoostPriceCents   Int?     @map("revenue_listing_boost_price_cents")
  revenueListingBoostDurationDays Int?     @map("revenue_listing_boost_duration_days")
  /**
   * Optional override for BNHub host/platform fee on lodging (percent, e.g. 3 = 3%).
   * When null, `lib/bnhub/booking-pricing` uses code constants.
   */
  bnhubHostFeePercentOverride     Decimal? @map("bnhub_host_fee_percent_override") @db.Decimal(6, 3)
  updatedAt                       DateTime @updatedAt @map("updated_at")

  @@map("platform_financial_settings")
}

