model EsgDocumentAudit {
  id           String      @id @default(cuid())
  documentId   String      @map("document_id")
  document     EsgDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  action       String      @db.VarChar(32)
  status       String      @db.VarChar(16)
  message      String      @db.Text
  metadataJson Json?       @map("metadata_json")
  createdAt    DateTime    @default(now()) @map("created_at")

  @@index([documentId, createdAt])
  @@map("esg_document_audits")
}

model EsgEvent {
  id          String   @id @default(cuid())
  listingId   String   @map("listing_id")
  type        String   @db.VarChar(24)
  message     String   @db.Text
  scoreImpact Float    @map("score_impact")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([listingId, createdAt(sort: Desc)])
  @@map("esg_events")
}

model EsgAction {
  id                         String                  @id @default(cuid())
  listingId                  String                  @map("listing_id")
  title                      String                  @db.VarChar(256)
  description                String                  @db.Text
  category                   String                  @db.VarChar(24)
  actionType                 String                  @map("action_type") @db.VarChar(24)
  priority                   String                  @db.VarChar(16)
  status                     String                  @default("OPEN") @db.VarChar(16)
  reasonCode                 String                  @map("reason_code") @db.VarChar(64)
  reasonText                 String?                 @map("reason_text") @db.Text
  estimatedScoreImpact       Float?                  @map("estimated_score_impact")
  estimatedCarbonImpact      Float?                  @map("estimated_carbon_impact")
  estimatedConfidenceImpact  Float?                  @map("estimated_confidence_impact")
  estimatedCostBand          String?                 @map("estimated_cost_band") @db.VarChar(16)
  estimatedEffortBand        String?                 @map("estimated_effort_band") @db.VarChar(16)
  estimatedTimelineBand      String?                 @map("estimated_timeline_band") @db.VarChar(16)
  paybackBand                String?                 @map("payback_band") @db.VarChar(16)
  ownerType                  String?                 @map("owner_type") @db.VarChar(16)
  assigneeUserId             String?                 @map("assignee_user_id")
  blockersJson               Json?                   @map("blockers_json")
  dependenciesJson           Json?                   @map("dependencies_json")
  evidenceNeededJson         Json?                   @map("evidence_needed_json")
  implementationNotes        String?                 @map("implementation_notes") @db.Text
  generatedFromVersion       String?                 @map("generated_from_version") @db.VarChar(24)
  createdAt                  DateTime                @default(now()) @map("created_at")
  updatedAt                  DateTime                @updatedAt @map("updated_at")
  completedAt                DateTime?               @map("completed_at")
  activities                 EsgActionActivity[]
  esgRetrofitActionLinks     EsgRetrofitAction[]
  esgOptimizationSourceLinks EsgOptimizationAction[] @relation("EsgOptimizationSourceAction")
  esgOutcomeEvents           EsgOutcomeEvent[]

  @@index([listingId, status])
  @@index([listingId, reasonCode])
  @@index([assigneeUserId])
  @@map("esg_actions")
}

model EsgActionSnapshot {
  id                String   @id @default(cuid())
  listingId         String   @map("listing_id")
  generatedAt       DateTime @default(now()) @map("generated_at")
  generationVersion String   @map("generation_version") @db.VarChar(24)
  totalActions      Int      @map("total_actions")
  criticalCount     Int      @map("critical_count")
  highCount         Int      @map("high_count")
  mediumCount       Int      @map("medium_count")
  lowCount          Int      @map("low_count")
  actionsJson       Json     @map("actions_json")

  @@index([listingId, generatedAt(sort: Desc)])
  @@map("esg_action_snapshots")
}

model EsgPortfolioActionSummary {
  id                          String   @id @default(cuid())
  ownerId                     String   @map("owner_id")
  totalAssets                 Int      @map("total_assets")
  totalOpenActions            Int      @map("total_open_actions")
  criticalActions             Int      @map("critical_actions")
  quickWins                   Int      @map("quick_wins")
  capexActions                Int      @map("capex_actions")
  averagePotentialScoreUplift Float?   @map("average_potential_score_uplift")
  summaryJson                 Json     @map("summary_json")
  createdAt                   DateTime @default(now()) @map("created_at")

  @@index([ownerId, createdAt(sort: Desc)])
  @@map("esg_portfolio_action_summaries")
}

model EsgActionActivity {
  id           String    @id @default(cuid())
  actionId     String    @map("action_id")
  action       EsgAction @relation(fields: [actionId], references: [id], onDelete: Cascade)
  actorUserId  String?   @map("actor_user_id")
  eventType    String    @map("event_type") @db.VarChar(24)
  note         String?   @db.Text
  metadataJson Json?     @map("metadata_json")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([actionId, createdAt(sort: Desc)])
  @@map("esg_action_activities")
}

model EsgRetrofitPlan {
  id                            String               @id @default(cuid())
  listingId                     String               @map("listing_id")
  planName                      String               @map("plan_name") @db.VarChar(128)
  strategyType                  String               @map("strategy_type") @db.VarChar(24)
  summaryText                   String?              @map("summary_text") @db.Text
  totalEstimatedCostBand        String?              @map("total_estimated_cost_band") @db.VarChar(32)
  totalEstimatedImpactBand      String?              @map("total_estimated_impact_band") @db.VarChar(32)
  totalTimelineBand             String?              @map("total_timeline_band") @db.VarChar(32)
  expectedScoreBand             String?              @map("expected_score_band") @db.VarChar(32)
  expectedCarbonReductionBand   String?              @map("expected_carbon_reduction_band") @db.VarChar(32)
  expectedConfidenceImprovement String?              @map("expected_confidence_improvement") @db.VarChar(32)
  assumptionsJson               Json?                @map("assumptions_json")
  planVersion                   String?              @map("plan_version") @db.VarChar(24)
  createdAt                     DateTime             @default(now()) @map("created_at")
  updatedAt                     DateTime             @updatedAt @map("updated_at")
  retrofitActions               EsgRetrofitAction[]
  financingOptions              EsgFinancingOption[] @relation("EsgFinancingForPlan")

  @@index([listingId, strategyType])
  @@index([listingId, updatedAt(sort: Desc)])
  @@map("esg_retrofit_plans")
}

model EsgRetrofitAction {
  id               String          @id @default(cuid())
  planId           String          @map("plan_id")
  plan             EsgRetrofitPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  actionId         String?         @map("action_id")
  esgAction        EsgAction?      @relation(fields: [actionId], references: [id], onDelete: SetNull)
  title            String          @db.VarChar(256)
  category         String          @db.VarChar(24)
  phase            Int
  costBand         String?         @map("cost_band") @db.VarChar(16)
  impactBand       String?         @map("impact_band") @db.VarChar(24)
  timelineBand     String?         @map("timeline_band") @db.VarChar(24)
  paybackBand      String?         @map("payback_band") @db.VarChar(16)
  dependenciesJson Json?           @map("dependencies_json")
  notes            String?         @db.Text
  createdAt        DateTime        @default(now()) @map("created_at")

  @@index([planId, phase])
  @@map("esg_retrofit_actions")
}

model EsgFinancingOption {
  id                    String           @id @default(cuid())
  listingId             String?          @map("listing_id")
  planId                String?          @map("plan_id")
  plan                  EsgRetrofitPlan? @relation("EsgFinancingForPlan", fields: [planId], references: [id], onDelete: Cascade)
  financingType         String           @map("financing_type") @db.VarChar(32)
  name                  String           @db.VarChar(256)
  provider              String?          @db.VarChar(128)
  eligibilityCriteria   String?          @map("eligibility_criteria") @db.Text
  applicableActionsJson Json?            @map("applicable_actions_json")
  costCoverageBand      String?          @map("cost_coverage_band") @db.VarChar(24)
  benefitType           String           @map("benefit_type") @db.VarChar(24)
  priority              String?          @db.VarChar(16)
  notes                 String?          @db.Text
  reasoning             String?          @db.Text
  createdAt             DateTime         @default(now()) @map("created_at")

  @@index([listingId])
  @@index([planId])
  @@map("esg_financing_options")
}

model EsgRetrofitScenario {
  id                  String   @id @default(cuid())
  listingId           String   @map("listing_id")
  scenarioName        String   @map("scenario_name") @db.VarChar(128)
  selectedActionsJson Json     @map("selected_actions_json")
  totalCostBand       String?  @map("total_cost_band") @db.VarChar(32)
  totalImpactBand     String?  @map("total_impact_band") @db.VarChar(32)
  timelineBand        String?  @map("timeline_band") @db.VarChar(32)
  expectedScoreBand   String?  @map("expected_score_band") @db.VarChar(32)
  expectedCarbonBand  String?  @map("expected_carbon_band") @db.VarChar(32)
  financingFit        String?  @map("financing_fit") @db.VarChar(32)
  assumptionsJson     Json?    @map("assumptions_json")
  risksJson           Json?    @map("risks_json")
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([listingId, createdAt(sort: Desc)])
  @@map("esg_retrofit_scenarios")
}

model EsgOptimizationPlan {
  id                     String                  @id @default(cuid())
  listingId              String                  @map("listing_id")
  status                 String                  @default("DRAFT") @db.VarChar(24)
  optimizerVersion       String                  @map("optimizer_version") @db.VarChar(24)
  strategyType           String?                 @map("strategy_type") @db.VarChar(32)
  objectiveMode          String?                 @map("objective_mode") @db.VarChar(32)
  confidenceLevel        String?                 @map("confidence_level") @db.VarChar(24)
  headlineRecommendation String?                 @map("headline_recommendation") @db.Text
  executiveSummary       String?                 @map("executive_summary") @db.Text
  currentScore           Float?                  @map("current_score")
  currentGrade           String?                 @map("current_grade") @db.VarChar(8)
  targetBand             String?                 @map("target_band") @db.VarChar(48)
  expectedReadinessShift String?                 @map("expected_readiness_shift") @db.VarChar(256)
  planJson               Json                    @map("plan_json")
  rationaleJson          Json                    @map("rationale_json")
  assumptionsJson        Json                    @map("assumptions_json")
  policyVersion          String?                 @map("policy_version") @db.VarChar(24)
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  activatedAt            DateTime?               @map("activated_at")
  completedAt            DateTime?               @map("completed_at")
  optimizationActions    EsgOptimizationAction[]
  optimizationRuns       EsgOptimizationRun[]

  @@index([listingId, status])
  @@index([listingId, updatedAt(sort: Desc)])
  @@map("esg_optimization_plans")
}

model EsgOptimizationAction {
  id                           String              @id @default(cuid())
  planId                       String              @map("plan_id")
  plan                         EsgOptimizationPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  listingId                    String              @map("listing_id")
  sourceActionId               String?             @map("source_action_id")
  sourceAction                 EsgAction?          @relation("EsgOptimizationSourceAction", fields: [sourceActionId], references: [id], onDelete: SetNull)
  rank                         Int
  title                        String              @db.VarChar(256)
  actionType                   String              @map("action_type") @db.VarChar(24)
  category                     String              @db.VarChar(24)
  priority                     String              @db.VarChar(16)
  expectedValueScore           Float?              @map("expected_value_score")
  expectedScoreImpactBand      String?             @map("expected_score_impact_band") @db.VarChar(48)
  expectedConfidenceImpactBand String?             @map("expected_confidence_impact_band") @db.VarChar(48)
  expectedCarbonImpactBand     String?             @map("expected_carbon_impact_band") @db.VarChar(48)
  expectedReadinessImpactBand  String?             @map("expected_readiness_impact_band") @db.VarChar(48)
  costBand                     String?             @map("cost_band") @db.VarChar(16)
  effortBand                   String?             @map("effort_band") @db.VarChar(16)
  timelineBand                 String?             @map("timeline_band") @db.VarChar(24)
  paybackBand                  String?             @map("payback_band") @db.VarChar(16)
  requiresApproval             Boolean             @default(true) @map("requires_approval")
  decisionStatus               String              @default("PENDING") @map("decision_status") @db.VarChar(16)
  explanation                  String?             @db.Text
  createdAt                    DateTime            @default(now()) @map("created_at")
  updatedAt                    DateTime            @updatedAt @map("updated_at")
  outcomeEvents                EsgOutcomeEvent[]

  @@index([planId, rank])
  @@index([listingId])
  @@map("esg_optimization_actions")
}

model EsgOptimizationRun {
  id                 String               @id @default(cuid())
  listingId          String               @map("listing_id")
  planId             String?              @map("plan_id")
  plan               EsgOptimizationPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  runType            String               @map("run_type") @db.VarChar(16)
  optimizerVersion   String               @map("optimizer_version") @db.VarChar(24)
  inputSnapshotJson  Json                 @map("input_snapshot_json")
  outputSnapshotJson Json                 @map("output_snapshot_json")
  selectedStrategy   String?              @map("selected_strategy") @db.VarChar(32)
  objectiveMode      String?              @map("objective_mode") @db.VarChar(32)
  status             String               @db.VarChar(16)
  createdAt          DateTime             @default(now()) @map("created_at")

  @@index([listingId, createdAt(sort: Desc)])
  @@map("esg_optimization_runs")
}

model EsgOutcomeEvent {
  id                   String                 @id @default(cuid())
  listingId            String                 @map("listing_id")
  actionId             String?                @map("action_id")
  esgAction            EsgAction?             @relation(fields: [actionId], references: [id], onDelete: SetNull)
  optimizationActionId String?                @map("optimization_action_id")
  optimizationAction   EsgOptimizationAction? @relation(fields: [optimizationActionId], references: [id], onDelete: SetNull)
  eventType            String                 @map("event_type") @db.VarChar(32)
  outcomeCategory      String?                @map("outcome_category") @db.VarChar(16)
  beforeJson           Json?                  @map("before_json")
  afterJson            Json?                  @map("after_json")
  deltaJson            Json?                  @map("delta_json")
  note                 String?                @db.Text
  createdAt            DateTime               @default(now()) @map("created_at")

  @@index([listingId, createdAt(sort: Desc)])
  @@map("esg_outcome_events")
}

model EsgOptimizationPolicy {
  id                      String   @id @default(cuid())
  ownerId                 String?  @map("owner_id")
  listingId               String?  @map("listing_id")
  autonomyMode            String   @default("SAFE_APPROVAL") @map("autonomy_mode") @db.VarChar(24)
  allowEvidenceActions    Boolean  @default(true) @map("allow_evidence_actions")
  allowDisclosureActions  Boolean  @default(true) @map("allow_disclosure_actions")
  allowOperationalActions Boolean  @default(true) @map("allow_operational_actions")
  allowCapexActions       Boolean  @default(false) @map("allow_capex_actions")
  primaryObjective        String   @default("BALANCED") @map("primary_objective") @db.VarChar(32)
  riskTolerance           String   @default("MEDIUM") @map("risk_tolerance") @db.VarChar(16)
  budgetMode              String?  @map("budget_mode") @db.VarChar(24)
  preferredStrategy       String?  @map("preferred_strategy") @db.VarChar(32)
  calibrationJson         Json?    @map("calibration_json")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@index([ownerId])
  @@index([listingId])
  @@map("esg_optimization_policies")
}

model BrokerListingAccess {
  id          String   @id @default(cuid())
  listingId   String   @map("listing_id")
  brokerId    String   @map("broker_id")
  role        String   @default("viewer") // owner | collaborator | viewer
  grantedById String?  @map("granted_by_id")
  grantedAt   DateTime @default(now()) @map("granted_at")

  @@unique([listingId, brokerId])
  @@index([brokerId])
  @@index([listingId])
  @@map("broker_listing_access")
}

model InvestorMemo {
  id                      String                                  @id @default(cuid())
  listingId               String                                  @map("listing_id")
  generatedForUserId      String?                                 @map("generated_for_user_id")
  version                 String                                  @db.VarChar(24)
  status                  String                                  @default("GENERATED") @db.VarChar(24)
  title                   String                                  @db.VarChar(512)
  memoType                String                                  @map("memo_type") @db.VarChar(32)
  headlineDecision        String?                                 @map("headline_decision") @db.Text
  recommendation          String?                                 @db.VarChar(48)
  confidenceLevel         String?                                 @map("confidence_level") @db.VarChar(24)
  payloadJson             Json                                    @map("payload_json")
  pdfPath                 String?                                 @map("pdf_path") @db.Text
  decisionLogs            InvestorDecisionLog[]
  pipelineDealsLatestMemo InvestmentPipelineDeal[]                @relation("PipelineDealLatestMemo")
  committeeSubmissions    InvestmentPipelineCommitteeSubmission[] @relation("CommitteeSubmissionMemo")
  createdAt               DateTime                                @default(now())
  updatedAt               DateTime                                @updatedAt

  @@index([listingId, createdAt(sort: Desc)])
  @@map("investor_memos")
}

model InvestorIcPack {
  id                    String                                  @id @default(cuid())
  listingId             String                                  @map("listing_id")
  generatedForUserId    String?                                 @map("generated_for_user_id")
  version               String                                  @db.VarChar(24)
  status                String                                  @default("GENERATED") @db.VarChar(24)
  title                 String                                  @db.VarChar(512)
  decisionStage         String?                                 @map("decision_stage") @db.VarChar(32)
  recommendation        String?                                 @db.VarChar(48)
  confidenceLevel       String?                                 @map("confidence_level") @db.VarChar(24)
  payloadJson           Json                                    @map("payload_json")
  pdfPath               String?                                 @map("pdf_path") @db.Text
  decisionLogs          InvestorDecisionLog[]
  pipelineDealsLatestIc InvestmentPipelineDeal[]                @relation("PipelineDealLatestIcPack")
  committeeSubmissions  InvestmentPipelineCommitteeSubmission[] @relation("CommitteeSubmissionIcPack")
  createdAt             DateTime                                @default(now())
  updatedAt             DateTime                                @updatedAt

  @@index([listingId, createdAt(sort: Desc)])
  @@map("investor_ic_packs")
}

model InvestorDecisionLog {
  id               String          @id @default(cuid())
  listingId        String          @map("listing_id")
  memoId           String?         @map("memo_id")
  memo             InvestorMemo?   @relation(fields: [memoId], references: [id], onDelete: SetNull)
  icPackId         String?         @map("ic_pack_id")
  icPack           InvestorIcPack? @relation(fields: [icPackId], references: [id], onDelete: SetNull)
  recommendation   String?         @db.VarChar(48)
  confidenceLevel  String?         @map("confidence_level") @db.VarChar(24)
  rationaleSummary String?         @map("rationale_summary") @db.Text
  createdAt        DateTime        @default(now())

  @@index([listingId, createdAt(sort: Desc)])
  @@map("investor_decision_logs")
}

model InvestmentPipelineDeal {
  id                     String          @id @default(cuid())
  listingId              String?         @map("listing_id")
  title                  String          @db.VarChar(512)
  status                 String          @default("ACTIVE") @db.VarChar(24)
  pipelineStage          String          @default("SOURCED") @map("pipeline_stage") @db.VarChar(32)
  priority               String?         @db.VarChar(16)
  ownerUserId            String?         @map("owner_user_id")
  sponsorUserId          String?         @map("sponsor_user_id")
  committeeRequired      Boolean         @default(true) @map("committee_required")
  headlineRecommendation String?         @map("headline_recommendation") @db.Text
  confidenceLevel        String?         @map("confidence_level") @db.VarChar(24)
  decisionStatus         String?         @map("decision_status") @db.VarChar(24)
  latestMemoId           String?         @map("latest_memo_id")
  latestMemo             InvestorMemo?   @relation("PipelineDealLatestMemo", fields: [latestMemoId], references: [id], onDelete: SetNull)
  latestIcPackId         String?         @map("latest_ic_pack_id")
  latestIcPack           InvestorIcPack? @relation("PipelineDealLatestIcPack", fields: [latestIcPackId], references: [id], onDelete: SetNull)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  closedAt               DateTime?       @map("closed_at")

  // Underwriting & Investment Intelligence
  underwritingScore          Float?    @map("underwriting_score")
  underwritingLabel          String?   @map("underwriting_label") @db.VarChar(24) // WEAK, MODERATE, STRONG
  underwritingRecommendation String?   @map("underwriting_recommendation") @db.VarChar(32) // BUY, BUY_WITH_RETROFIT_PLAN, HOLD, AVOID
  underwritingConfidence     String?   @map("underwriting_confidence") @db.VarChar(16) // low, medium, high
  underwritingSummaryJson    Json?     @map("underwriting_summary_json")
  underwritingRisksJson      Json?     @map("underwriting_risks_json")
  underwritingUpsideJson     Json?     @map("underwriting_upside_json")
  underwritingUpdatedAt      DateTime? @map("underwriting_updated_at")

  stageHistories        InvestmentPipelineDealStageHistory[]
  committeeSubmissions  InvestmentPipelineCommitteeSubmission[]
  committeeDecisions    InvestmentPipelineCommitteeDecision[]
  conditions            InvestmentPipelineCondition[]
  diligenceTasks        InvestmentPipelineDiligenceTask[]
  followUps             InvestmentPipelineFollowUp[]
  audits                InvestmentPipelineDecisionAudit[]
  capitalStack          InvestmentPipelineCapitalStack?
  lenderPackages        InvestmentPipelineLenderPackage[]
  pipelineLenders       InvestmentPipelineLender[]
  financingOffers       InvestmentPipelineFinancingOffer[]
  financingConditions   InvestmentPipelineFinancingCondition[]
  financingCovenants    InvestmentPipelineCovenant[]
  closingChecklistItems InvestmentPipelineClosingChecklistItem[]
  capitalAudits         InvestmentPipelineCapitalAudit[]
  underwritingSnapshots DealUnderwritingSnapshot[]

  @@index([listingId])
  @@index([pipelineStage])
  @@index([status])
  @@index([ownerUserId])
  @@map("investment_pipeline_deals")
}

model InvestmentPipelineDealStageHistory {
  id              String                 @id @default(cuid())
  dealId          String                 @map("deal_id")
  deal            InvestmentPipelineDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  fromStage       String?                @map("from_stage") @db.VarChar(32)
  toStage         String                 @map("to_stage") @db.VarChar(32)
  changedByUserId String?                @map("changed_by_user_id")
  reason          String?                @db.Text
  createdAt       DateTime               @default(now())

  @@index([dealId, createdAt(sort: Desc)])
  @@map("investment_pipeline_deal_stage_histories")
}

model InvestmentPipelineCommitteeSubmission {
  id                String                 @id @default(cuid())
  dealId            String                 @map("deal_id")
  deal              InvestmentPipelineDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  submittedByUserId String?                @map("submitted_by_user_id")
  memoId            String?                @map("memo_id")
  memo              InvestorMemo?          @relation("CommitteeSubmissionMemo", fields: [memoId], references: [id], onDelete: SetNull)
  icPackId          String?                @map("ic_pack_id")
  icPack            InvestorIcPack?        @relation("CommitteeSubmissionIcPack", fields: [icPackId], references: [id], onDelete: SetNull)
  submissionStatus  String                 @default("SUBMITTED") @map("submission_status") @db.VarChar(24)
  meetingDate       DateTime?              @map("meeting_date")
  summaryText       String?                @map("summary_text") @db.Text
  createdAt         DateTime               @default(now())

  decisions InvestmentPipelineCommitteeDecision[]

  @@index([dealId, createdAt(sort: Desc)])
  @@map("investment_pipeline_committee_submissions")
}

model InvestmentPipelineCommitteeDecision {
  id              String                                 @id @default(cuid())
  dealId          String                                 @map("deal_id")
  deal            InvestmentPipelineDeal                 @relation(fields: [dealId], references: [id], onDelete: Cascade)
  submissionId    String?                                @map("submission_id")
  submission      InvestmentPipelineCommitteeSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  decidedByUserId String?                                @map("decided_by_user_id")
  recommendation  String                                 @db.VarChar(24)
  rationale       String                                 @db.Text
  confidenceLevel String?                                @map("confidence_level") @db.VarChar(24)
  decisionJson    Json                                   @map("decision_json")
  createdAt       DateTime                               @default(now())

  @@index([dealId, createdAt(sort: Desc)])
  @@map("investment_pipeline_committee_decisions")
}

model InvestmentPipelineCondition {
  id                   String                 @id @default(cuid())
  dealId               String                 @map("deal_id")
