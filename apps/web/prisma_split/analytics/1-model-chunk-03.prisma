model Lead {
  id                            String                         @id @default(cuid())
  name                          String
  email                         String
  phone                         String
  message                       String
  listingId                     String? // listing or project context
  /**
   * When inquiry originates from FSBO Buyer Hub — links to `FsboListing`.
   */
  fsboListingId                 String?                        @map("fsbo_listing_id")
  /**
   * BNHub short-term listing when the CRM lead is tied to a stay (distinct from broker CRM `listingId`).
   */
  shortTermListingId            String?                        @map("short_term_listing_id")
  /**
   * Denormalized LEC code when lead is tied to a ShortTermListing.
   */
  listingCode                   String?                        @map("listing_code")
  projectId                     String?
  status                        String
  /**
   * Combined / form + behavior AI score 0–100 (rule-based; not ML).
   */
  score                         Int
  /**
   * Traffic / marketing attribution (URL ?source= / UTM, or "direct").
   */
  source                        String?
  /**
   * Campaign name from ?campaign= or utm_campaign.
   */
  campaign                      String?
  /**
   * Medium from ?medium= or utm_medium (e.g. cpc, social).
   */
  medium                        String?
  utmTerm                       String?                        @map("utm_term") @db.VarChar(256)
  utmContent                    String?                        @map("utm_content") @db.VarChar(256)
  /**
   * Single acquisition tag (e.g. broker_interest) — distinct from marketing `source`.
   */
  growthTag                     String?                        @map("growth_tag") @db.VarChar(64)
  referrerUrl                   String?                        @map("referrer_url") @db.Text
  /**
   * Capture channel: listing, contact, ai_chat, form, ad, referral, other, mortgage_inquiry
   */
  leadSource                    String?                        @map("lead_source")
  /**
   * Distribution attribution: LECIPM (platform) vs CENTRIS (syndicated) when known.
   */
  distributionChannel           String?                        @map("distribution_channel") @db.VarChar(32)
  /**
   * Funnel label: mortgage | null for legacy CRM rows
   */
  leadType                      String?                        @map("lead_type")
  assignedExpertId              String?                        @map("assigned_expert_id")
  /**
   * mortgage marketplace: open = unclaimed pool; null = normal flow
   */
  mortgageMarketplaceStatus     String?                        @map("mortgage_marketplace_status")
  /**
   * Mortgage form payload: amount, timeline, propertyType, etc.
   */
  mortgageInquiry               Json?                          @map("mortgage_inquiry")
  /**
   * Last known AI tier snapshot: hot | warm | cold
   */
  aiTier                        String?                        @map("ai_tier")
  /**
   * Linked platform user for behavior scoring when known.
   */
  userId                        String?                        @map("user_id")
  /**
   * Structured explainability: { formReasons[], behaviorPoints, mergedScore }.
   */
  aiExplanation                 Json?                          @map("ai_explanation")
  /**
   * Autopilot leads layer (optional; gated; does not replace legacy `score` / CRM priority fields).
   */
  aiScore                       Float?                         @map("lead_ai_score")
  aiPriority                    String?                        @map("lead_ai_priority") @db.VarChar(16)
  aiTags                        Json?                          @map("lead_ai_tags")
  aiLastUpdated                 DateTime?                      @map("lead_ai_last_updated")
  aiExecutionVersion            String?                        @map("lead_ai_execution_version") @db.VarChar(16)
  contactUnlockedAt             DateTime?                      @map("contact_unlocked_at")
  /// Broker/user who paid to unlock contact (Stripe `lead_unlock`); distinct from `introducedByBrokerId`.
  contactUnlockedByUserId       String?                        @map("contact_unlocked_by_user_id")
  introducedByBrokerId          String?                        @map("introduced_by_broker_id")
  lastFollowUpByBrokerId        String?                        @map("last_follow_up_by_broker_id")
  lastFollowUpAt                DateTime?                      @map("last_follow_up_at")
  createdAt                     DateTime                       @default(now())
  updatedAt                     DateTime                       @updatedAt @map("updated_at")
  leadStatus                    String                         @default("NEW") @map("lead_status")
  purchasedByBrokerId           String?                        @map("purchased_by_broker_id")
  /**
   * Sales pipeline: new | contacted | qualified | meeting | negotiation | won | lost (legacy: follow_up)
   */
  pipelineStatus                String                         @default("new") @map("pipeline_status")
  /**
   * Duplicate of stage label for reporting / future split from legacy status strings
   */
  pipelineStage                 String                         @default("new") @map("pipeline_stage")
  optedOutOfFollowUp            Boolean                        @default(false) @map("opted_out_of_follow_up")
  /**
   * Denormalized deal value (e.g. from evaluation estimate), dollars CAD.
   */
  dealValue                     Int?                           @map("deal_value")
  /**
   * Revenue optimization: estimated opportunity value (CAD), often from purchase price.
   */
  estimatedValue                Int?                           @map("estimated_value")
  /**
   * Heuristic 0–1 close probability from tiering model.
   */
  conversionProbability         Float?                         @map("conversion_probability")
  /**
   * How estimated value / tier was derived (mortgage_form, ai_rule, admin).
   * Note: traffic attribution remains in `source` / UTM fields.
   */
  valueSource                   String?                        @map("value_source")
  /**
   * HIGH | MEDIUM | LOW — monetization & expert routing tier.
   */
  revenueTier                   String?                        @map("revenue_tier")
  /**
   * Credits charged when this lead is assigned (auto-assign or marketplace claim).
   */
  mortgageCreditCost            Int                            @default(1) @map("mortgage_credit_cost")
  /**
   * Dynamic internal price for this lead (cents CAD) — reporting / future billing.
   */
  dynamicLeadPriceCents         Int?                           @map("dynamic_lead_price_cents")
  /**
   * Per-service platform commission at close (0–1). Mortgage leads default 0.30.
   */
  serviceCommissionRate         Float?                         @map("service_commission_rate")
  /**
   * When assigned to a mortgage expert (auto or claim).
   */
  mortgageAssignedAt            DateTime?                      @map("mortgage_assigned_at")
  /**
   * After first SLA nudge for uncontacted assigned leads.
   */
  mortgageSlaReminderAt         DateTime?                      @map("mortgage_sla_reminder_at")
  /**
   * Mortgage funnel A/B variant (e.g. A | B).
   */
  revenueAbVariant              String?                        @map("revenue_ab_variant")
  /**
   * Client-indicated city/region for demand pricing & city reports.
   */
  purchaseRegion                String?                        @map("purchase_region")
  /**
   * Estimated broker commission in dollars (dealValue × configurable rate).
   */
  commissionEstimate            Int?                           @map("commission_estimate")
  /**
   * Last time broker contacted this lead (outreach / follow-up logged).
   */
  lastContactedAt               DateTime?                      @map("last_contacted_at")
  /**
   * First outbound contact (broker / automation).
   */
  firstContactAt                DateTime?                      @map("first_contact_at")
  /**
   * Mirror of last touch for closing analytics (kept in sync with lastContactedAt on PATCH).
   */
  lastContactAt                 DateTime?                      @map("last_contact_at")
  qualifiedAt                   DateTime?                      @map("qualified_at")
  meetingScheduledAt            DateTime?                      @map("meeting_scheduled_at")
  closingAt                     DateTime?                      @map("closing_at")
  wonAt                         DateTime?                      @map("won_at")
  lostAt                        DateTime?                      @map("lost_at")
  /**
   * price | timing | no_response | competitor | other
   */
  lostReason                    String?                        @map("lost_reason")
  /**
   * interested | needs_follow_up | ready_to_close
   */
  postMeetingOutcome            String?                        @map("post_meeting_outcome")
  dealOutcomeNotes              String?                        @map("deal_outcome_notes") @db.Text
  /**
   * Optional duplicate of final sale for reporting
   */
  finalDealValue                Int?                           @map("final_deal_value")
  /**
   * Next broker action / touch (widgets; mirrors nextFollowUpAt when set by automation).
   */
  nextActionAt                  DateTime?                      @map("next_action_at")
  /**
   * Broker CRM: next reminder / follow-up touchpoint.
   */
  nextFollowUpAt                DateTime?                      @map("next_follow_up_at")
  /**
   * pending | snoozed | dismissed | completed
   */
  reminderStatus                String?                        @map("reminder_status")
  /**
   * Scheduled client meeting.
   */
  meetingAt                     DateTime?                      @map("meeting_at")
  meetingCompleted              Boolean                        @default(false) @map("meeting_completed")
  /**
   * When marked won: final sale price & commission (dollars).
   */
  finalSalePrice                Int?                           @map("final_sale_price")
  finalCommission               Int?                           @map("final_commission")
  dealClosedAt                  DateTime?                      @map("deal_closed_at")
  /**
   * Strong engagement: call/WhatsApp click, repeat visits, etc.
   */
  highIntent                    Boolean                        @default(false) @map("high_intent")
  /**
   * Direct-message lifecycle: none | sent | replied
   */
  dmStatus                      String                         @default("none") @map("dm_status")
  /**
   * Daily execution / outreach coaching: contacted | replied | follow_up_sent | demo_booked
   */
  outreachCoachingStage         String?                        @map("outreach_coaching_stage")
  lastDmAt                      DateTime?                      @map("last_dm_at")
  /**
   * Rule-based engagement points (CTA clicks, automation).
   */
  engagementScore               Int                            @default(0) @map("engagement_score")
  /**
   * LECIPM elite CRM — composite 0–100 (Trust + Deal + urgency + legacy score).
   */
  lecipmLeadScore               Int?                           @map("lecipm_lead_score")
  lecipmDealQualityScore        Int?                           @map("lecipm_deal_quality_score")
  lecipmTrustScore              Int?                           @map("lecipm_trust_score")
  lecipmUrgencyScore            Int?                           @map("lecipm_urgency_score")
  /**
   * Elite pipeline: new_lead | contacted | qualified | visit_scheduled | offer_made | closed
   */
  lecipmCrmStage                String?                        @default("new_lead") @map("lecipm_crm_stage")
  /**
   * Action-driven CRM execution layer (0–100 sub-scores; refreshed from telemetry + behavior).
   */
  intentScore                   Int                            @default(0) @map("crm_intent_score")
  urgencyScore                  Int                            @default(0) @map("crm_urgency_score")
  trustScore                    Int                            @default(0) @map("crm_trust_score")
  frictionScore                 Int                            @default(0) @map("crm_friction_score")
  lastActivityAt                DateTime?                      @map("crm_last_activity_at")
  nextBestAction                String?                        @map("crm_next_best_action")
  priorityScore                 Int                            @default(0) @map("crm_priority_score")
  /**
   * Real-time close pipeline: browsing | viewing_property | inquiry_sent | broker_connected | booking_started | negotiation | closed | lost
   */
  executionStage                String                         @default("browsing") @map("crm_execution_stage")
  lecipmScoresComputedAt        DateTime?                      @map("lecipm_scores_computed_at")
  /**
   * Denormalized: HOT | WARM | COLD (synced with score + engagement).
   */
  scoreLevel                    String?                        @map("score_level")
  /**
   * Eval drip: none | drip_scheduled | followup_24h_sent | followup_72h_sent
   */
  evaluationEmailStatus         String                         @default("none") @map("evaluation_email_status")
  lastAutomationEmailAt         DateTime?                      @map("last_automation_email_at")
  /// Launch / manual sales: `contacted` (UI), `lastContactDate`, `notes` — see `/dashboard/admin/sales`.
  launchSalesContacted          Boolean                        @default(false) @map("launch_sales_contacted")
  launchLastContactDate         DateTime?                      @map("launch_last_contact_date")
  launchNotes                   String?                        @map("launch_notes") @db.Text
  automationTasks               LeadAutomationTask[]
  leadTasks                     LeadTask[]
  followUps                     LeadFollowUp[]
  crmInteractions               CrmInteraction[]
  retentionTouches              ClientRetentionTouchpoint[]
  leadContactConsents           LeadContactConsent[]
  leadCommMessages              LeadCommMessage[]
  leadTimelineEvents            LeadTimelineEvent[]
  leadFollowUpJobs              LeadFollowUpJob[]
  mortgageDeal                  MortgageDeal?
  crmConversation               CrmConversation?
  offerDocuments                OfferDocument[]
  brokerTransactionRecords      BrokerTransactionRecord[]
  /**
   * Platform messaging thread (buyer ↔ broker) opened from Immo contact.
   */
  contactOrigin                 LeadContactOrigin?             @map("contact_origin")
  /**
   * Commission attribution (mirrors contactOrigin for ImmoContact flows).
   */
  commissionSource              LeadContactOrigin?             @map("commission_source")
  /**
   * First platform touch timestamp (ImmoContact session).
   */
  firstPlatformContactAt        DateTime?                      @map("first_platform_contact_at")
  commissionEligible            Boolean                        @default(false) @map("commission_eligible")
  platformConversationId        String?                        @unique @map("platform_conversation_id")
  platformConversation          Conversation?                  @relation("LeadPlatformConversation", fields: [platformConversationId], references: [id], onDelete: SetNull)
  contactAuditEvents            LeadContactAuditEvent[]
  internalCrmTelemetryEvents    InternalCrmEvent[]
  deal                          Deal?
  dealRooms                     DealRoom[]
  platformCommissionRecords     PlatformCommissionRecord[]
  platformLegalDisputes         PlatformLegalDispute[]
  marketplaceListing            LeadMarketplaceListing?
  /**
   * Enterprise workspace (organization) scope — optional; null = not attributed to a team.
   */
  workspaceId                   String?                        @map("workspace_id") @db.Uuid
  playbookExecutions            PlaybookExecution[]
  revenueOpportunities          RevenueOpportunity[]
  leadPricingOverrides          LeadPricingOverride[]
  leadPricingResultObservations LeadPricingResultObservation[]
  brokerBillingLead             BrokerLead?
  salesAssignment               SalesAssignment?
  lecipmVisitRequests           LecipmVisitRequest[]           @relation("LeadLecipmVisitRequests")
  /// Optional 1:1 link to broker inquiry CRM row (same listing / visitor).
  /// Auditable lead-routing recommendations (not auto-assignment to broker without product rules).
  leadRoutingDecisions          LeadRoutingDecision[]

  @@index([listingId])
  @@index([fsboListingId])
  @@index([listingCode])
  @@index([projectId])
  @@index([status])
  @@index([introducedByBrokerId])
