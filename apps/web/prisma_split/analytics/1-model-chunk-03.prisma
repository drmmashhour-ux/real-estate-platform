  runComparisonsAsPeer ValidationRunComparison[] @relation("ValidationRunComparisonPeer")

  @@index([createdAt])
  @@index([status])
  @@index([validationRunKind])
  @@index([comparisonTargetRunId])
  @@index([appliedTuningProfileId])
