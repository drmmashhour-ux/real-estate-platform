model LecipmAcquisitionContact {
  id                  String                    @id @default(cuid())
  type                String                    @db.VarChar(24)
  name                String                    @db.VarChar(512)
  email               String?                   @db.VarChar(320)
  phone               String?                   @db.VarChar(48)
  source              String                    @default("manual") @db.VarChar(24)
  /// Part 1 CRM status: CONTACTED | INTERESTED | ONBOARDED | LOST
  relationshipStatus  String                    @default("CONTACTED") @map("relationship_status") @db.VarChar(24)
  /// Part 2 pipeline / kanban: NEW | CONTACTED | FOLLOW_UP | DEMO_SCHEDULED | CONVERTED | LOST
  pipelineStage       String                    @default("NEW") @map("pipeline_stage") @db.VarChar(32)
  notesJson           Json                      @default("[]") @map("notes_json")
  assignedAdminId     String?                   @map("assigned_admin_id") @db.VarChar(36)
  linkedUserId        String?                   @map("linked_user_id") @db.VarChar(36)
  leadsGenerated      Int                       @default(0) @map("leads_generated")
  revenueCents        Int                       @default(0) @map("revenue_cents")
  firstContactedAt    DateTime?                 @map("first_contacted_at")
  convertedAt         DateTime?                 @map("converted_at")
  /// Milliseconds from createdAt to onboarded milestone (when known).
  timeToOnboardMs     Int?                      @map("time_to_onboard_ms")
  invites             LecipmAcquisitionInvite[]
  salesScriptCallLogs SalesScriptCallLog[]
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")

  @@index([type, pipelineStage])
  @@index([assignedAdminId])
  @@index([pipelineStage])
  @@index([relationshipStatus])
  @@index([createdAt(sort: Desc)])
  @@map("lecipm_acquisition_contacts")
}

