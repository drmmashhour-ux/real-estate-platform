  id            String    @id @default(cuid())
  userId        String?   @map("user_id")
  formKey       String    @map("form_key")
  title         String
  locale        String    @default("fr")
  status        String    @default("DRAFT")
  contextJson   Json      @map("context_json")
  resultJson    Json?     @map("result_json")
  canProceed    Boolean   @default(false) @map("can_proceed")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  integrityHash String?   @map("integrity_hash")
  finalizedAt   DateTime? @map("finalized_at")

  @@index([userId])
  @@index([formKey])
  @@index([status])
  @@map("turbo_drafts")
}

model TurboDraftAcknowledgement {
  id         String   @id @default(cuid())
  draftId    String   @map("draft_id")
  userId     String?  @map("user_id")
  noticeKey  String   @map("notice_key")
  version    String?
  acceptedAt DateTime @default(now()) @map("accepted_at")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")

  @@unique([draftId, noticeKey, userId])
  @@index([draftId])
  @@index([userId])
  @@map("turbo_draft_acknowledgements")
}

model TurboDraftAuditLog {
  id          String   @id @default(cuid())
  draftId     String?  @map("draft_id")
  userId      String?  @map("user_id")
  eventKey    String   @map("event_key")
  severity    String
  payloadJson Json?    @map("payload_json")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([draftId])
  @@index([userId])
  @@index([eventKey])
  @@map("turbo_draft_audit_logs")
}

model TrustHubScore {
  id         String   @id @default(cuid())
  draftId    String   @map("draft_id")
  userId     String?  @map("user_id")
  score      Int
  status     String
  resultJson Json     @map("result_json")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([draftId])
  @@index([userId])
  @@map("trust_hub_scores")
}

model TrustHubBadge {
  id        String   @id @default(cuid())
  draftId   String   @map("draft_id")
  userId    String?  @map("user_id")
  badgeKey  String   @map("badge_key")
  labelFr   String   @map("label_fr")
  proofJson Json?    @map("proof_json")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([draftId, badgeKey])
  @@index([draftId])
  @@map("trust_hub_badges")
}

model BrokerAssistRequest {
  id        String   @id @default(cuid())
  draftId   String   @map("draft_id")
  userId    String?  @map("user_id")
  dealId    String?  @map("deal_id")
  status    String   @default("REQUESTED")
  reasonFr  String?  @map("reason_fr")
  riskJson  Json?    @map("risk_json")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([draftId])
  @@index([userId])
  @@index([status])
  @@map("broker_assist_requests")
}

model BrokerOnboardingLead {
  id             String    @id @default(cuid())
  name           String
  phone          String?
  email          String?
  city           String?
  source         String? // facebook / instagram / google / linkedin
  status         String    @default("new") // contacted, demo_booked, demo_done, trial_started, first_deal, paid, rejected
  lastContactAt  DateTime? @map("last_contact_at")
  nextFollowUpAt DateTime? @map("next_follow_up_at")
  nextAction     String?   @map("next_action")
  notes          String?   @db.Text
  ownerUserId    String?   @map("owner_user_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([ownerUserId])
  @@map("broker_onboarding_leads")
}

model DemoView {
  id        String   @id @default(cuid())
  draftId   String?  @map("draft_id")
  userId    String?  @map("user_id")
  leadId    String?  @map("lead_id")
  ref       String?
  userAgent String?  @map("user_agent")
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([leadId])
  @@map("demo_views")
}

model FieldTeamCandidate {
  id              String   @id @default(cuid())
  name            String
  email           String
  phone           String?
  status          String   @default("applied")
  notes           String?  @db.Text
  /// JSON rubric: { clarity, confidence, listening, discipline } (typically 1–5).
  interviewScores Json?    @map("interview_scores")
  linkedUserId    String?  @map("linked_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([email])
  @@index([linkedUserId])
  @@map("field_team_candidates")
}

model FieldSpecialistPerformance {
  id               String   @id @default(cuid())
  userId           String   @unique @map("user_id")
  demosCompleted   Int      @default(0) @map("demos_completed")
  brokersActivated Int      @default(0) @map("brokers_activated")
  callsMade        Int      @default(0) @map("calls_made")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("field_specialist_performance")
}

model DemoBooking {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  city        String?
  experience  String?
  status      String   @default("scheduled") // scheduled, completed, no_show, cancelled
  refId       String?  @map("ref_id")
  scheduledAt DateTime @default(now()) @map("scheduled_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([email])
  @@map("demo_bookings")
}

model BrokerActivation {
  id             String   @id @default(cuid())
  brokerId       String   @unique @map("broker_id")
  createdDraft   Boolean  @default(false) @map("created_draft")
  usedAI         Boolean  @default(false) @map("used_ai")
  completedDraft Boolean  @default(false) @map("completed_draft")
  firstPayment   Boolean  @default(false) @map("first_payment")
  assistMode     Boolean  @default(false) @map("assist_mode")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([brokerId])
  @@map("broker_activations")
}

model ExecutiveReport {
  id           String                @id @default(cuid())
  createdAt    DateTime              @default(now()) @map("created_at")
  periodKey    String                @map("period_key") @db.VarChar(32)
  generatedAt  DateTime              @default(now()) @map("generated_at")
  reportJson   Json                  @map("report_json") @db.JsonB
  summaryText  String                @map("summary_text") @db.Text
  status       ExecutiveReportStatus @default(GENERATED)
  errorMessage String?               @map("error_message") @db.Text

  @@index([periodKey, generatedAt(sort: Desc)])
  @@map("executive_reports")
}

model ExecutiveReportSchedule {
  id             String                           @id @default(cuid())
  createdAt      DateTime                         @default(now()) @map("created_at")
  frequency      ExecutiveReportScheduleFrequency
  recipientsJson Json                             @map("recipients_json") @db.JsonB
  lastRunAt      DateTime?                        @map("last_run_at") @db.Timestamptz(6)
  isActive       Boolean                          @default(true) @map("is_active")

  @@index([isActive])
  @@map("executive_report_schedules")
}

model SystemAuditLog {
  id          String   @id @default(cuid())
  userId      String?  @map("user_id")
  action      String // DRAFT_CREATE | NOTICE_ACK | AI_CORRECT | AUTOPILOT_ACT | SIGN_ATTEMPT | SIGN_BLOCK
  entityType  String   @map("entity_type") // DRAFT | DEAL | LEAD | NOTICE
  entityId    String?  @map("entity_id")
  payloadJson Json?    @map("payload_json") @db.JsonB
  traceId     String?  @map("trace_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@map("system_audit_logs")
}

model DocumentHash {
  id         String   @id @default(cuid())
  entityType String   @map("entity_type") // DRAFT_PDF | DEAL_PDF
  entityId   String   @map("entity_id")
  hash       String // SHA-256
  version    Int      @default(1)
  metadata   Json?    @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([entityType, entityId, version])
  @@map("document_hashes")
}
