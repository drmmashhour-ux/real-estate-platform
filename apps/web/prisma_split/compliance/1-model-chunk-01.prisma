  @@index([fsboListingId])
  @@index([status])
  @@map("seller_documents")
}

model VerificationRuleResult {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caseId      String   @map("case_id") @db.Uuid
  ruleCode    String   @map("rule_code")
  ruleVersion String   @default("1") @map("rule_version")
  passed      Boolean  @default(false)
  scoreDelta  Int      @default(0) @map("score_delta")
  confidence  Decimal? @db.Decimal(5, 4)
  details     Json?    @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)


  @@index([caseId], map: "idx_verification_rule_results_case_id")
  @@index([ruleCode], map: "idx_verification_rule_results_rule_code")
  @@map("verification_rule_results")
}

model SellerDisclosure {
  id               String           @id @default(cuid())
  listingId        String           @unique @map("listing_id")
  structuralIssues String?          @map("structural_issues") @db.Text
  waterDamage      String?          @map("water_damage") @db.Text
  renovations      String?          @map("renovations") @db.Text
  defects          String?          @map("defects") @db.Text
  /**
   * Structured Seller Declaration form (property) — see `SellerDeclarationFormData` in app code.
   */
  formData         Json?            @map("form_data")
  completedAt      DateTime?        @map("completed_at") // Set when seller submits declaration
  declinedAt       DateTime?        @map("declined_at") // Set when seller refuses; listing cannot publish
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@map("seller_disclosures")
}

model OaciqComplianceSection {
  id               String    @id @default(cuid())
  sectionKey       String    @unique @map("section_key") @db.VarChar(128)
  sectionTitleFr   String    @map("section_title_fr") @db.VarChar(500)
  sectionTitleEn   String?   @map("section_title_en") @db.VarChar(500)
  /// Official excerpt or controlled summary (for traceability — not legal advice).
  sourceExcerpt    String?   @map("source_excerpt") @db.Text
  /// rule_engine.{sectionKey}: requiredActions, forbiddenActions, conditionalChecks
  ruleEngineJson   Json      @map("rule_engine_json")
  /// AI_CHECKLIST / AI_WARNINGS / AI_BLOCKS + metadata
  aiBehaviorJson   Json      @map("ai_behavior_json")
  clauseFr         String    @map("clause_fr") @db.Text
  clauseEn         String?   @map("clause_en") @db.Text
  defaultRiskLevel String    @default("MEDIUM") @map("default_risk_level") @db.VarChar(16)
  active           Boolean   @default(true)
  effectiveFrom    DateTime? @map("effective_from") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  evaluations OaciqComplianceEvaluationLog[]

  @@index([active, sectionKey], map: "idx_oaciq_compliance_sections_active_key")
  @@map("oaciq_compliance_sections")
}

model OaciqComplianceEvaluationLog {
  id                  String                 @id @default(cuid())
  sectionId           String                 @map("section_id")
  section             OaciqComplianceSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  brokerUserId        String                 @map("broker_user_id")
  dealId              String?                @map("deal_id") @db.VarChar(128)
  listingId           String?                @map("listing_id") @db.VarChar(128)
  /// pass | warn | block
  outcome             String                 @map("outcome") @db.VarChar(16)
  complianceRiskScore String                 @map("compliance_risk_score") @db.VarChar(16)
  contextJson         Json?                  @map("context_json")
  triggeredRulesJson  Json?                  @map("triggered_rules_json")
  blockedActionsJson  Json?                  @map("blocked_actions_json")
  createdAt           DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([brokerUserId, createdAt(sort: Desc)], map: "idx_oaciq_eval_logs_broker_created")
  @@index([sectionId, createdAt(sort: Desc)], map: "idx_oaciq_eval_logs_section_created")
  @@map("oaciq_compliance_evaluation_logs")
}

model OaciqConflictCheck {
  id              String  @id @default(cuid())
  /// Acting residential broker (solo book).
  brokerId        String  @map("broker_id") @db.VarChar(36)
  /// CRM / capital pipeline deal (cuid).
  pipelineDealId  String? @map("pipeline_deal_id") @db.VarChar(36)
  /// Execution `Deal` (uuid) — closing room / signatures.
  executionDealId String? @map("execution_deal_id") @db.VarChar(36)
  listingId       String? @map("listing_id") @db.VarChar(36)

  hasConflict      Boolean @map("has_conflict")
  conflictType     String  @map("conflict_type") @db.VarChar(64)
  disclosureStatus String  @map("disclosure_status") @db.VarChar(24)
  riskLevel        String  @map("risk_level") @db.VarChar(16)

  clientRepresentationContractSigned Boolean @default(false) @map("client_representation_contract_signed")
  brokerPersonalInvolvement          Boolean @default(false) @map("broker_personal_involvement")
  brokerFinancialInterest            Boolean @default(false) @map("broker_financial_interest")
  relatedPartyInvolvement            Boolean @default(false) @map("related_party_involvement")
  benefitOutsideCommission           Boolean @default(false) @map("benefit_outside_commission")
  dualRoleWithoutFramework           Boolean @default(false) @map("dual_role_without_framework")

  brokerConfirmedDeclaration             Boolean   @default(false) @map("broker_confirmed_declaration")
  brokerConfirmedAt                      DateTime? @map("broker_confirmed_at")
  /// High-risk: disclosure does not erase conflict — broker must acknowledge persisting duty / documentation.
  highRiskAcknowledgedPersistingConflict Boolean   @default(false) @map("high_risk_ack_persisting")
  highRiskReleasedAt                     DateTime? @map("high_risk_released_at")

  checklistJson Json? @map("checklist_json") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  disclosures OaciqConflictDisclosureLog[]

  @@index([brokerId, pipelineDealId], map: "idx_oaciq_conflict_broker_pipeline")
  @@index([brokerId, executionDealId], map: "idx_oaciq_conflict_broker_execution")
  @@index([brokerId, listingId], map: "idx_oaciq_conflict_broker_listing")
  @@map("oaciq_conflict_checks")
}

model OaciqConflictDisclosureLog {
  id              String             @id @default(cuid())
  conflictCheckId String             @map("conflict_check_id") @db.VarChar(36)
  conflictCheck   OaciqConflictCheck @relation(fields: [conflictCheckId], references: [id], onDelete: Cascade)

  pipelineDealId         String? @map("pipeline_deal_id") @db.VarChar(36)
  executionDealId        String? @map("execution_deal_id") @db.VarChar(36)
  disclosureText         String  @map("disclosure_text") @db.Text
  signedByClient         Boolean @default(false) @map("signed_by_client")
  locale                 String? @db.VarChar(8)
  includesStandardClause Boolean @default(false) @map("includes_standard_clause")

  createdByBrokerId String   @map("created_by_broker_id") @db.VarChar(36)
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([conflictCheckId, createdAt(sort: Desc)], map: "idx_oaciq_disclosure_check_created")
  @@map("oaciq_conflict_disclosure_logs")
}

