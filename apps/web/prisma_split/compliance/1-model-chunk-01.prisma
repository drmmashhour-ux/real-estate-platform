  reasonCode String                @map("reason_code")
  notes      String?
  createdBy  String
  createdAt  DateTime              @default(now()) @map("created_at")
  metadata   Json?

  @@index([incidentId])
  @@index([actionType])
  @@map("trust_safety_actions")
}

model TrustSafetyAppeal {
  id             String                  @id @default(uuid())
  incidentId     String                  @map("incident_id")
  incident       TrustSafetyIncident     @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  actionId       String?                 @map("action_id") // TrustSafetyAction.id
  submittedBy    String                  @map("submitted_by")
  appealReason   String                  @map("appeal_reason")
  status         TrustSafetyAppealStatus @default(PENDING)
  reviewedBy     String?                 @map("reviewed_by")
  resolvedAt     DateTime?               @map("resolved_at")
  resolutionNote String?                 @map("resolution_note")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")

  @@index([incidentId])
  @@index([submittedBy])
  @@index([status])
  @@map("trust_safety_appeals")
}

model TrustSafetyIncidentResponse {
  id           String              @id @default(uuid())
  incidentId   String              @map("incident_id")
  incident     TrustSafetyIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  respondentId String              @map("respondent_id")
  body         String
  createdAt    DateTime

  @@index([incidentId])
  @@map("trust_safety_incident_responses")
}

model LecipmCrmOaciqSellerDeclaration {
  id        String  @id @default(cuid())
  listingId String  @map("listing_id")
  sellerId  String  @map("seller_id")

  formVersion OaciqMandatoryFormVersion @map("form_version")

  completed Boolean @default(false)
  signed    Boolean @default(false)
  refused   Boolean @default(false)

  refusalReason String? @map("refusal_reason") @db.Text

  submittedAt DateTime? @map("submitted_at")
  signedAt    DateTime? @map("signed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")


  @@unique([listingId, sellerId])
  @@index([listingId])
  @@map("lecipm_crm_oaciq_seller_declarations")
}

model ComplianceFormLog {
  id                String                   @id @default(cuid())
  entityType        ComplianceFormEntityType @map("entity_type")
  entityId          String                   @map("entity_id")
  action            ComplianceFormAction     @map("action")
  performedByUserId String?                  @map("performed_by_user_id")
  aiAssisted        Boolean                  @default(false) @map("ai_assisted")
  notes             String?                  @db.Text
  createdAt         DateTime                 @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("compliance_form_logs")
}

model OaciqFormTemplate {
  id                  String          @id @default(uuid())
  formFamily          OaciqFormFamily @map("form_family")
  versionLabel        String?         @map("version_label") @db.VarChar(64)
  /// Storage key for the uploaded specimen PDF (S3/local) — optional when schema is registry-only.
  sourcePdfKey        String?         @map("source_pdf_key") @db.VarChar(512)
  /// Full schema: sections, fields, extraction metadata (no invented fields — only extractor + registry merge).
  schema              Json            @default("{}")
  extractedFieldCount Int             @default(0) @map("extracted_field_count")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  fields    OaciqFormField[]
  instances LecipmFormInstance[]

  @@index([formFamily])
  @@map("oaciq_form_templates")
}

model OaciqFormField {
  id         String            @id @default(uuid())
  templateId String            @map("template_id")
  template   OaciqFormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fieldKey   String            @map("field_key") @db.VarChar(200)
  label      String            @db.Text
  fieldType  OaciqPdfFieldKind @map("field_type")
  section    String?           @db.VarChar(200)
  page       Int?
  required   Boolean?
  metadata   Json              @default("{}")

  @@index([templateId])
  @@index([fieldKey])
  @@map("oaciq_form_fields")
}

model LecipmFormInstance {
  id              String                   @id @default(uuid())
  templateId      String                   @map("template_id")
  template        OaciqFormTemplate        @relation(fields: [templateId], references: [id], onDelete: Restrict)
  dealId          String                   @map("deal_id")
  status          LecipmFormInstanceStatus @default(draft)
  data            Json                     @default("{}")
  version         Int                      @default(1)
  createdByUserId String?                  @map("created_by_user_id")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")

  versions LecipmFormVersion[]

  @@index([dealId])
  @@index([templateId])
  @@index([status])
  @@map("lecipm_form_instances")
}

model LecipmFormVersion {
  id             String             @id @default(uuid())
  formInstanceId String             @map("form_instance_id")
  formInstance   LecipmFormInstance @relation(fields: [formInstanceId], references: [id], onDelete: Cascade)
  version        Int
  data           Json               @default("{}")
  createdAt      DateTime           @default(now()) @map("created_at")

  @@index([formInstanceId])
  @@map("lecipm_form_versions")
}

model SellerDisclosureProfile {
  id                     String    @id @default(cuid())
  sellerUserId           String    @unique @map("seller_user_id")
  misrepresentationScore Float     @default(0) @map("misrepresentation_score")
  recurringPatternCount  Int       @default(0) @map("recurring_pattern_count")
  signals                Json      @default("{}")
  lastEvaluatedAt        DateTime? @map("last_evaluated_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  @@index([misrepresentationScore])
  @@map("seller_disclosure_profiles")
}

model ComplianceFinanceAccount {
  id        String         @id @default(cuid())
  name      String         @db.VarChar(256)
  domain    FinAdminDomain @map("domain")
  type      FinAccountType @map("type")
  currency  String         @default("CAD") @db.VarChar(8)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  ledgerEntries ComplianceFinanceLedgerEntry[]

  @@index([domain, type])
  @@map("compliance_finance_accounts")
}

model ComplianceFinanceLedgerEntry {
  id                 String                         @id @default(cuid())
  accountId          String                         @map("account_id")
  account            ComplianceFinanceAccount       @relation(fields: [accountId], references: [id], onDelete: Restrict)
  domain             FinAdminDomain                 @map("domain")
  entryType          FinLedgerEntryType             @map("entry_type")
  referenceType      String                         @map("reference_type") @db.VarChar(64)
  referenceId        String?                        @map("reference_id") @db.VarChar(64)
  amount             Decimal                        @map("amount") @db.Decimal(18, 2)
  taxExclusiveAmount Decimal?                       @map("tax_exclusive_amount") @db.Decimal(18, 2)
  gstAmount          Decimal?                       @map("gst_amount") @db.Decimal(18, 2)
  qstAmount          Decimal?                       @map("qst_amount") @db.Decimal(18, 2)
  effectiveDate      DateTime                       @map("effective_date")
  counterpartyId     String?                        @map("counterparty_id")
  counterparty       ComplianceFinanceCounterparty? @relation(fields: [counterpartyId], references: [id], onDelete: SetNull)
  notesJson          Json?                          @map("notes_json")
  createdAt          DateTime                       @default(now()) @map("created_at")

  @@index([domain, effectiveDate])
  @@index([entryType, effectiveDate])
  @@index([referenceType, referenceId])
  @@map("compliance_finance_ledger_entries")
}

model ComplianceFinanceCounterparty {
  id            String              @id @default(cuid())
  name          String              @db.VarChar(512)
  type          FinCounterpartyKind @map("type")
  taxNumberJson Json?               @map("tax_number_json")
  createdAt     DateTime            @default(now()) @map("created_at")

  ledgerEntries ComplianceFinanceLedgerEntry[]

  @@map("compliance_finance_counterparties")
}

model LecipmRegulatoryState {
  id     String @id @default(cuid())
  userId String @unique @map("user_id") @db.VarChar(36)

  isLicensedBroker    Boolean @default(false) @map("is_licensed_broker")
  brokerMode          String  @default("INDEPENDENT") @map("broker_mode") @db.VarChar(24) // INDEPENDENT | AGENCY
  canOperateBrokerage Boolean @default(false) @map("can_operate_brokerage")
  canOperateFund      Boolean @default(false) @map("can_operate_fund")
  fundMode            String  @default("SIMULATION") @map("fund_mode") @db.VarChar(24) // SIMULATION | PRIVATE | REGISTERED

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("lecipm_regulatory_states")
}
