model ShortTermListing {
  id                                  String                            @id @default(uuid())
  /**
   * Human-readable immutable public id: LST-XXXXXX (new) or legacy LEC-#####.
   */
  listingCode                         String                            @unique @map("listing_code")
  title                               String
  /// Optional French UI copy; falls back to `title` when absent.
  titleFr                             String?                           @map("title_fr")
  subtitle                            String?
  subtitleFr                          String?                           @map("subtitle_fr")
  description                         String?
  /// Optional French description; falls back to `description` when absent.
  descriptionFr                       String?                           @map("description_fr") @db.Text
  /// Optional Arabic copy; falls back to English fields when absent.
  titleAr                             String?                           @map("title_ar")
  descriptionAr                       String?                           @map("description_ar") @db.Text
  propertyType                        String? // e.g. House, Apartment, Villa
  roomType                            String? // e.g. Entire place, Private room
  category                            String? // e.g. Vacation rental
  address                             String
  city                                String
  region                              String? // State / region
  country                             String                            @default("US")
  latitude                            Float?
  longitude                           Float?
  nightPriceCents                     Int // Base nightly price in cents
  /// When false, nightly pricing suggestion jobs skip this listing (never auto-updates `nightPriceCents`).
  pricingSuggestionsEnabled           Boolean                           @default(true) @map("pricing_suggestions_enabled")
  /// Optional floor for suggested nightly rate (major currency units; base remains `nightPriceCents`).
  pricingMinNightDollars              Float?                            @map("pricing_min_night_dollars")
  /// Optional cap for suggested nightly rate (major currency units).
  pricingMaxNightDollars              Float?                            @map("pricing_max_night_dollars")
  /// OFF | MANUAL | AUTO_APPROVE_SAFE | FULL_AUTOPILOT — controls auto-approval / safe auto-apply.
  pricingMode                         String                            @default("MANUAL") @map("pricing_mode") @db.VarChar(32)
  /// Max fractional change for AUTO_APPROVE_SAFE (e.g. 0.25 = 25%). Null = no cap in engine (still risky).
  autoApplyMaxChange                  Float?                            @map("auto_apply_max_change")
  currency                            String                            @default("USD")
  maxGuests                           Int                               @default(4)
  bedrooms                            Int? // Optional alias for beds
  beds                                Int
  baths                               Float
  photos                              Json                              @default("[]") // Legacy URLs; prefer BnhubListingPhoto for order/cover
  amenities                           Json                              @default("[]")
  houseRules                          String?
  /// Optional structured rules checklist (e.g. JSON array of { key, label, allowed }); complements `houseRules` text.
  listingRulesStructured              Json?                             @map("listing_rules_structured")
  checkInInstructions                 String?
  checkInTime                         String? // e.g. "15:00"
  checkOutTime                        String? // e.g. "11:00"
  cancellationPolicy                  String? // flexible | moderate | strict
  cleaningFeeCents                    Int                               @default(0)
  securityDepositCents                Int                               @default(0)
  instantBookEnabled                  Boolean                           @default(false)
  /// When true, guests must have approved government ID (`IdentityVerification`) before booking.
  requireGuestIdentityVerification    Boolean                           @default(false) @map("require_guest_identity_verification")
  /// Denormalized guest-review average (1–5) for cards / mobile.
  bnhubListingRatingAverage           Float?                            @map("bnhub_listing_rating_average")
  bnhubListingReviewCount             Int                               @default(0) @map("bnhub_listing_review_count")
  /// Completed paid stays for this listing.
  bnhubListingCompletedStays          Int                               @default(0) @map("bnhub_listing_completed_stays")
  /// Platform-verified host/listing (cadastre + identity path complete).
  bnhubListingHostVerified            Boolean                           @default(false) @map("bnhub_listing_host_verified")
  /// Heuristic “top host” badge for discovery UI.
  bnhubListingTopHostBadge            Boolean                           @default(false) @map("bnhub_listing_top_host_badge")
  /// Optional cached 0–100 AI discovery score; search API computes live scores for map/cards regardless.
  aiDiscoveryScore                    Int?                              @map("ai_discovery_score")
  minStayNights                       Int? // null = no minimum
  maxStayNights                       Int?
  listingStatus                       ListingStatus                     @default(DRAFT)
  verificationStatus                  VerificationStatus                @default(PENDING)
  listingAuthorityType                ListingAuthorityType? // Required when submitting for verification
  listingVerificationStatus           ListingVerificationStatus         @default(DRAFT)
  rejectionReason                     String?
  cadastreNumber                      String?
  municipality                        String? // Required with cadastre for Québec
  province                            String? // e.g. QC
  verificationDocUrl                  String? // Legacy; prefer property_documents
  verifiedAt                          DateTime?
  submittedForVerificationAt          DateTime?
  // Broker-only fields (when listingAuthorityType = BROKER)
  brokerLicenseNumber                 String?
  brokerageName                       String?
  safetyFeatures                      Json                              @default("[]") // e.g. Smoke detector, First aid
  accessibilityFeatures               Json                              @default("[]") // e.g. Step-free access
  parkingDetails                      String?
  neighborhoodDetails                 String?
  /// quiet | moderate | lively — environment signal for guests
  noiseLevel                          String?                           @map("noise_level")
  familyFriendly                      Boolean                           @default(false) @map("family_friendly")
  kidsAllowed                         Boolean                           @default(true) @map("kids_allowed")
  partyAllowed                        Boolean                           @default(false) @map("party_allowed")
  smokingAllowed                      Boolean                           @default(false) @map("smoking_allowed")
  petsAllowed                         Boolean                           @default(false) @map("pets_allowed")
  /// JSON string[] e.g. ["dog","cat","other"]
  allowedPetTypes                     Json                              @default("[]") @map("allowed_pet_types")
  maxPetWeightKg                      Float?                            @map("max_pet_weight_kg")
  petRules                            String?                           @map("pet_rules") @db.Text
  /// Added to BNHub search review signal for monthly top-host winners (0–0.12). Reset by admin monthly job.
  reputationRankBoost                 Float                             @default(0) @map("reputation_rank_boost")
  /// JSON string[] e.g. ["waterfront","downtown","near_attractions"]
  experienceTags                      Json                              @default("[]") @map("experience_tags")
  /// JSON string[] e.g. ["airport_pickup","parking","shuttle"]
  servicesOffered                     Json                              @default("[]") @map("services_offered")
  conditionOfProperty                 String?                           @map("condition_of_property") // Mandatory disclosure: overall condition
  knownIssues                         String?                           @map("known_issues") @db.Text // Mandatory disclosure: known issues (e.g. "None" or description)
  /// Host attestation timestamp: legal right to offer the stay (audit via ListingVerificationLog).
  legalRentRightAttestedAt            DateTime?                         @map("legal_rent_right_attested_at")
  /// Version of attestation copy the host agreed to; bump to require re-attestation.
