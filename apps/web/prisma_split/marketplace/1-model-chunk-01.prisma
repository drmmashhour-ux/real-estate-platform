  updatedAt                 DateTime  @updatedAt @map("updated_at")

  @@unique([listingType, listingId])
  @@index([listingType, city])
  @@index([listingType, totalScore])
  @@index([city, neighborhood])
  @@map("listing_ranking_scores")
}

