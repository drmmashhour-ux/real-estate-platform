model MarketSnapshot {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  regionSlug         String   @map("region_slug")
  propertyType       String   @map("property_type")
  mode               String   @default("investor")
  analysisWindowDays Int      @map("analysis_window_days")
  snapshotDate       DateTime @map("snapshot_date") @db.Date
  medianPriceCents   BigInt?  @map("median_price_cents")
  medianPricePerSqft Decimal? @map("median_price_per_sqft") @db.Decimal(18, 2)
  activeListingCount Int      @default(0) @map("active_listing_count")
  newListingCount    Int      @default(0) @map("new_listing_count")
  confidenceLevel    String   @map("confidence_level")
  directionLabel     String?  @map("direction_label")
  metadata           Json?    @db.JsonB
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([regionSlug, propertyType, mode, analysisWindowDays, snapshotDate], map: "uq_market_snapshots_region_window_date")
  @@index([regionSlug, snapshotDate], map: "idx_market_snapshots_region_date")
  @@map("market_snapshots")
}

model RentalListing {
  id            String              @id @default(uuid())
  listingCode   String              @unique @map("listing_code")
  landlordId    String              @map("landlord_id")
  title         String
  description   String              @db.Text
  priceMonthly  Int                 @map("price_monthly")
  depositAmount Int                 @map("deposit_amount")
  address       String
  city          String?
  status        RentalListingStatus @default(DRAFT)
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  applications  RentalApplication[]
  leases        RentalLease[]

  @@index([landlordId])
  @@index([status])
  @@map("rental_listings")
}

model RentalApplication {
  id              String                  @id @default(uuid())
  listingId       String                  @map("listing_id")
  listing         RentalListing           @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tenantId        String                  @map("tenant_id")
  message         String                  @db.Text
  status          RentalApplicationStatus @default(PENDING)
  legalAcceptedAt DateTime?               @map("legal_accepted_at")
  documentsJson   Json?                   @map("documents_json")
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")
  lease           RentalLease?

  @@index([listingId])
  @@index([tenantId])
  @@index([status])
  @@map("rental_applications")
}

model RentalLease {
  id            String             @id @default(uuid())
  listingId     String             @map("listing_id")
  listing       RentalListing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tenantId      String             @map("tenant_id")
  landlordId    String             @map("landlord_id")
  applicationId String?            @unique @map("application_id")
  application   RentalApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  startDate     DateTime           @map("start_date")
  endDate       DateTime           @map("end_date")
  monthlyRent   Int                @map("monthly_rent")
  deposit       Int
  status        RentalLeaseStatus  @default(PENDING_SIGNATURE)
  signedAt      DateTime?          @map("signed_at")
  contractText  String             @map("contract_text") @db.Text
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  payments      RentPayment[]

  @@index([tenantId])
  @@index([landlordId])
  @@index([listingId])
  @@map("rental_leases")
}

model RentPayment {
  id        String            @id @default(uuid())
  leaseId   String            @map("lease_id")
  lease     RentalLease       @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  amount    Int
  dueDate   DateTime          @map("due_date")
  status    RentPaymentStatus @default(PENDING)
  paidAt    DateTime?         @map("paid_at")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  @@index([leaseId])
  @@index([dueDate])
  @@index([status])
  @@map("rent_payments")
}

model ImmoContactLog {
  id             String               @id @default(cuid())
  userId         String?              @map("user_id")
  /// Counterparty or subject of the action (e.g. listing owner when guest contacts host).
  targetUserId   String?              @map("target_user_id")
  /// Broker attributed to this touch when applicable.
  brokerId       String?              @map("broker_id")
  listingId      String?              @map("listing_id")
  listingKind    String?              @map("listing_kind")
  /// buyer | seller | bnhub_guest | bnhub_host | broker | mortgage | admin | system — denormalized hub surface.
  hub            String?              @map("hub")
  /// Same as `eventType` in API responses — semantic event category (immutable after insert).
  contactType    ImmoContactEventType @map("contact_type")
  /// Audit payload (UTC timestamps inside JSON are ISO strings).
  metadata       Json?                @map("metadata")
  createdAt      DateTime             @default(now()) @map("created_at")
  /// Canonical event instant for audit ordering (UTC); defaults to insert time.
  actionAt       DateTime             @default(now()) @map("action_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  /// Admin-only annotation; core event fields remain immutable.
  adminNote      String?              @map("admin_note") @db.Text
  adminNotedAt   DateTime?            @map("admin_noted_at")
  adminNotedById String?              @map("admin_noted_by_id")

  @@index([userId])
  @@index([targetUserId])
  @@index([brokerId])
  @@index([listingId])
  @@index([hub])
  @@index([contactType])
  @@index([createdAt])
  @@index([actionAt])
  @@map("immo_contact_logs")
}

model FsboListing {
  id                             String                           @id @default(cuid())
  /// Public tracking code LST-XXXXXX (unique across platform with BNHub + CRM).
  listingCode                    String?                          @unique @map("listing_code")
  ownerId                        String                           @map("owner_id")
  /// Multi-tenant scope when the brokerage or platform org publishes the row.
  tenantId                       String?                          @map("tenant_id")
  /// Same physical listing table for DIY sellers vs broker-managed inventory.
  listingOwnerType               FsboListingOwnerType             @default(SELLER) @map("listing_owner_type")
  title                          String
  /// Optional French UI copy; falls back to `title` when absent.
  titleFr                        String?                          @map("title_fr")
  description                    String                           @db.Text
  /// Optional French description; falls back to `description` when absent.
  descriptionFr                  String?                          @map("description_fr") @db.Text
  /// Optional Arabic title (future); falls back to `title` when absent.
  titleAr                        String?                          @map("title_ar")
  /// Optional Arabic description; falls back to `description` when absent.
  descriptionAr                  String?                          @map("description_ar") @db.Text
  priceCents                     Int                              @map("price_cents")
  address                        String
  city                           String
  country                        String                           @default("CA")
  marketCountryId                String?                          @map("market_country_id")
  marketCityId                   String?                          @map("market_city_id")
  listingCurrency                String?                          @map("listing_currency") @db.VarChar(8)
  region                         String?
  bedrooms                       Int?
  bathrooms                      Int?
  surfaceSqft                    Int?                             @map("surface_sqft")
  images                         String[]
  /// Primary hero image; auto-synced to first gallery image for now (manual override later).
  coverImage                     String?                          @map("cover_image")
  /// Per-photo tagging (same order/length as `images`). Each item must be one of:
  /// EXTERIOR | INTERIOR | STREET_VIEW | OTHER
  photoTagsJson                  Json?                            @map("photo_tags_json")
  /// Mismatch lifecycle (auto-set when the platform detects issues; updated on user confirmation too).
  photoVerificationStatus        FsboPhotoVerificationStatus      @default(PENDING) @map("photo_verification_status")
  /// Required checkbox before admin verification / publish.
  photoConfirmationAcceptedAt    DateTime?                        @map("photo_confirmation_accepted_at")
  status                         String                           @default("DRAFT") // DRAFT | PENDING_VERIFICATION | ACTIVE | SOLD
  moderationStatus               String                           @default("APPROVED") @map("moderation_status") // PENDING | APPROVED | REJECTED
  contactEmail                   String                           @map("contact_email")
  contactPhone                   String?                          @map("contact_phone")
  rejectReason                   String?                          @map("reject_reason") @db.Text
  createdAt                      DateTime                         @default(now()) @map("created_at")
  updatedAt                      DateTime                         @updatedAt @map("updated_at")
  /// basic | premium — chosen before publish; premium may set featuredUntil after payment.
  publishPlan                    String                           @default("basic") @map("publish_plan")
  publishPriceCents              Int?                             @map("publish_price_cents")
  paidPublishAt                  DateTime?                        @map("paid_publish_at")
  featuredUntil                  DateTime?                        @map("featured_until")
  /// Listing expiry is contract-driven for broker-managed inventory and platform-driven for owner-direct inventory.
  expiresAt                      DateTime?                        @map("expires_at")
  /// Prevent duplicate renewal reminders inside the same renewal window.
  expiryReminderSentAt           DateTime?                        @map("expiry_reminder_sent_at")
  /// Archive timestamp when the platform auto-expires a listing.
  archivedAt                     DateTime?                        @map("archived_at")
  /// Optional map coordinates; fill via geocoding when available.
  latitude                       Float?                           @map("latitude")
  longitude                      Float?                           @map("longitude")
  /// quiet | moderate | lively — environment signal (Buy / long-term rent hub)
  noiseLevel                     String?                          @map("noise_level")
  familyFriendly                 Boolean                          @default(false) @map("family_friendly")
  kidsAllowed                    Boolean                          @default(true) @map("kids_allowed")
  partyAllowed                   Boolean                          @default(false) @map("party_allowed")
  smokingAllowed                 Boolean                          @default(false) @map("smoking_allowed")
  petsAllowed                    Boolean                          @default(false) @map("pets_allowed")
  /// JSON string[] e.g. ["dog","cat","other"]
  allowedPetTypes                Json                             @default("[]") @map("allowed_pet_types")
  maxPetWeightKg                 Float?                           @map("max_pet_weight_kg")
  petRules                       String?                          @map("pet_rules") @db.Text
  /// JSON string[] e.g. ["waterfront","downtown","near_attractions"]
  experienceTags                 Json                             @default("[]") @map("experience_tags")
  /// JSON string[] e.g. ["airport_pickup","parking"]
  servicesOffered                Json                             @default("[]") @map("services_offered")
  leads                          FsboLead[]
  buyerRequests                  BuyerRequest[]
  platformPayments               PlatformPayment[]
  /// e.g. SINGLE_FAMILY | CONDO | TOWNHOUSE — used for public search filters
  propertyType                   String?                          @map("property_type")
  /// Quebec cadastre / lot reference (Seller Hub).
  cadastreNumber                 String?                          @map("cadastre_number")
  yearBuilt                      Int?                             @map("year_built")
  annualTaxesCents               Int?                             @map("annual_taxes_cents")
  condoFeesCents                 Int?                             @map("condo_fees_cents")
  /// Structured seller declaration (condition, defects, inclusions…).
  sellerDeclarationJson          Json?                            @map("seller_declaration_json")
  /// Last rules-based AI review (keywords, gaps); does not auto-reject listings.
  sellerDeclarationAiReviewJson  Json?                            @map("seller_declaration_ai_review_json")
  /// Latest risk (0–100, higher = riskier) and trust (0–100, higher = more trustworthy) snapshot.
  riskScore                      Int?                             @map("risk_score")
  trustScore                     Int?                             @map("trust_score")
  aiScoreReasonsJson             Json?                            @map("ai_score_reasons_json")
  sellerDeclarationCompletedAt   DateTime?                        @map("seller_declaration_completed_at")
  /// Seller confirmed accuracy of listing info before submit/publish (timestamp).
  legalAccuracyAcceptedAt        DateTime?                        @map("legal_accuracy_accepted_at")
  /// Set when listing activation email + in-app/push welcome was sent (idempotency).
  sellerActivationNotifiedAt     DateTime?                        @map("seller_activation_notified_at")
  verification                   FsboListingVerification?
  documents                      FsboListingDocument[]
  commissionCategory             ListingCommissionCategory        @default(SALE) @map("commission_category")
  commissionRate                 Float?                           @map("commission_rate")
  listingDealType                String                           @default("SALE") @map("listing_deal_type")
  /**
   * CRM `Lead` rows from Buyer Hub contact (parallel to `FsboLead`).
   */
  listingAiScores                ListingAiScore[]
  /// Optional 1:1 canonical listing row (`properties.id` bigint) for new integrations.
  canonicalListingProperty       ListingProperty?
  /// Optional 1:1 — FSBO row created from safe intake (`ListingAcquisitionLead`).
  sourcedFromAcquisitionLead     ListingAcquisitionLead?          @relation("FsboFromAcquisition")
  /// Ops workflow: draft | pending_review | approved | published | rejected (alongside `status` / moderation).
  supplyPublicationStage         String                           @default("draft") @map("supply_publication_stage")
  permissionConfirmedAt          DateTime?                        @map("permission_confirmed_at")
  permissionSourceNote           String?                          @map("permission_source_note") @db.Text
  rewrittenDescriptionReviewed   Boolean                          @default(false) @map("rewritten_description_reviewed")
  imagesApproved                 Boolean                          @default(false) @map("images_approved")
  imageSourceNote                String?                          @map("image_source_note") @db.Text
  missingApprovedImages          Boolean                          @default(false) @map("missing_approved_images")
  /// Denormalized from `listing_ranking_scores` when ranking_v1 jobs run (fast catalog sort).
  rankingTotalScoreCache         Float                            @default(0) @map("ranking_total_score_cache")
  rankingPerformanceBand         String?                          @map("ranking_performance_band") @db.VarChar(32)
  rankingCachedAt                DateTime?                        @map("ranking_cached_at")
  /// LECIPM Green Score & Optimization Program — internal model only (not Rénoclimat / municipal programs).
  lecipmGreenInternalScore       Int?                             @map("lecipm_green_internal_score")
  lecipmGreenCertifiedAt         DateTime?                        @map("lecipm_green_certified_at")
  /// none | free | premium — suggests vs full plan + badge + browse boost.
  lecipmGreenProgramTier         String                           @default("none") @map("lecipm_green_program_tier") @db.VarChar(16)
  lecipmGreenMetadataJson        Json?                            @map("lecipm_green_metadata_json")
  /// GREEN | IMPROVABLE | LOW — AI-assessed band (not a government label).
  lecipmGreenAiLabel             String?                          @map("lecipm_green_ai_label") @db.VarChar(24)
  /// AI_ESTIMATED | DOCUMENT_SUPPORTED | PROFESSIONAL_VERIFIED (reserved).
  lecipmGreenVerificationLevel   String?                          @map("lecipm_green_verification_level") @db.VarChar(32)
  /// Confidence 0–100 for the AI assessment; higher when user-supplied documents support claims.
  lecipmGreenConfidence          Int?                             @map("lecipm_green_confidence")
  /// Decision-engine snapshot (refreshed by jobs / dashboard — not an external appraisal).
  metrics                        FsboListingMetrics?
  hostPerformanceSnapshots       HostListingPerformanceSnapshot[]
  listingMarketingDrafts         ListingMarketingDraft[]
  listingMarketingSuggestions    ListingMarketingSuggestion[]
  /// Optional syndication rows (e.g. Centris) — authorized connector only; never scraped.
  externalListings               ExternalListing[]
  greenProject                   GreenProject?
  /// Marketplace DM threads opened from FSBO detail (`Conversation.fsboListingId`).

  @@index([ownerId])
  @@index([tenantId])
  @@index([city])
  @@index([city, status, moderationStatus])
  @@index([status])
  @@index([moderationStatus])
  @@index([expiresAt])
  @@index([archivedAt])
  @@index([priceCents])
  @@index([riskScore])
  @@index([supplyPublicationStage])
  @@index([updatedAt(sort: Desc)], map: "idx_fsbo_listings_updated_at_desc")
  @@index([rankingTotalScoreCache(sort: Desc)])
  @@index([marketCountryId])
  @@index([marketCityId])
  @@map("fsbo_listings")
}

model GreenProject {
  id             String      @id @default(cuid())
  fsboListingId  String      @unique @map("fsbo_listing_id")
  listing        FsboListing @relation(fields: [fsboListingId], references: [id], onDelete: Cascade)
  /// ANALYSIS | PLANNING | EXECUTION | COMPLETED
  stage          String      @default("ANALYSIS") @db.VarChar(24)
  estimatedGrant Float?      @map("estimated_grant")
  metadataJson   Json?       @map("metadata_json")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@map("green_projects")
}

model ExternalListing {
  id           String      @id @default(cuid())
  listingId    String      @map("listing_id")
  listing      FsboListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  platform     String
  externalId   String?     @map("external_id")
  status       String
  lastSyncAt   DateTime?   @map("last_sync_at")
  errorMessage String?     @map("error_message") @db.Text
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@unique([listingId, platform])
  @@index([platform, status])
  @@map("external_listings")
}

model FsboListingMetrics {
  fsboListingId             String      @id @map("fsbo_listing_id")
  listing                   FsboListing @relation(fields: [fsboListingId], references: [id], onDelete: Cascade)
  rankingScore              Float       @default(0) @map("ranking_score")
  trustScore                Float       @default(0) @map("trust_score")
  qualityScore              Float       @default(0) @map("quality_score")
  engagementScore           Float       @default(0) @map("engagement_score")
  priceCompetitivenessScore Float       @default(0) @map("price_competitiveness_score")
  conversionScore           Float       @default(0) @map("conversion_score")
  dealScore                 Float       @default(0) @map("deal_score")
  priceSuggestedCents       Int?        @map("price_suggested_cents")
  priceConfidence           Float?      @map("price_confidence")
  featuredBoostScore        Float       @default(0) @map("featured_boost_score")
  computedAt                DateTime    @default(now()) @map("computed_at")
  updatedAt                 DateTime    @updatedAt @map("updated_at")

  @@map("fsbo_listing_metrics")
}

model HostListingPerformanceSnapshot {
  id                         String      @id @default(cuid())
  userId                     String      @map("user_id")
  fsboListingId              String      @map("fsbo_listing_id")
  listing                    FsboListing @relation(fields: [fsboListingId], references: [id], onDelete: Cascade)
  views                      Int         @default(0)
  saves                      Int         @default(0)
  bookings                   Int         @default(0)
  revenueEstimateCents       Int?        @map("revenue_estimate_cents")
  missedRevenueEstimateCents Int?        @map("missed_revenue_estimate_cents")
  createdAt                  DateTime    @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([fsboListingId, createdAt])
  @@map("host_listing_performance_snapshots")
}

model ListingMarketingDraft {
  id        String                        @id @default(cuid())
  listingId String                        @map("listing_id")
  listing   FsboListing                   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  brokerId  String                        @map("broker_id")
  draftType String                        @map("draft_type") @db.VarChar(64)
  channel   ListingMarketingDraftChannel
  title     String?                       @db.VarChar(500)
  subject   String?                       @db.VarChar(500)
  body      String                        @db.Text
  status    ListingMarketingContentStatus @default(draft)
  metadata  Json                          @default("{}")
  createdAt DateTime                      @default(now()) @map("created_at")
  updatedAt DateTime                      @updatedAt @map("updated_at")

  @@index([listingId, brokerId])
  @@index([brokerId, status])
  @@map("listing_marketing_drafts")
}

model ListingMarketingSuggestion {
  id             String                        @id @default(cuid())
  listingId      String                        @map("listing_id")
  listing        FsboListing                   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  brokerId       String                        @map("broker_id")
  suggestionType String                        @map("suggestion_type") @db.VarChar(64)
  title          String                        @db.VarChar(500)
  summary        String                        @db.Text
  payload        Json                          @default("{}")
  confidence     Float                         @default(0)
  status         ListingMarketingContentStatus @default(draft)
  createdAt      DateTime                      @default(now()) @map("created_at")
  updatedAt      DateTime                      @updatedAt @map("updated_at")

  @@index([listingId, brokerId])
  @@map("listing_marketing_suggestions")
}

model BrokerGrowthGoal {
  id                          String   @id @default(cuid())
  brokerUserId                String   @unique @map("broker_user_id")
  monthlyLeadTarget           Int?     @map("monthly_lead_target")
  monthlyClosingTarget        Int?     @map("monthly_closing_target")
  responseTimeHoursTarget     Float?   @map("response_time_hours_target")
  listingConversionRateTarget Float?   @map("listing_conversion_rate_target")
  followUpDisciplineTarget    Float?   @map("follow_up_discipline_target")
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  @@map("broker_growth_goals")
}

model HostGrowthOutreachLog {
  id          String                    @id @default(cuid())
  leadId      String                    @map("lead_id")
  lead        ListingAcquisitionLead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  channel     HostGrowthOutreachChannel
  message     String                    @db.Text
  response    String?                   @db.Text
  status      HostGrowthOutreachStatus  @default(sent)
  createdById String?                   @map("created_by_id")
  createdAt   DateTime                  @default(now()) @map("created_at")

  @@index([leadId])
  @@map("host_growth_outreach_logs")
}

model ListingAcquisitionLead {
  id                       String                             @id @default(cuid())
  sourceType               ListingAcquisitionSourceType       @map("source_type")
  contactName              String                             @map("contact_name")
  contactEmail             String                             @map("contact_email")
  contactPhone             String?                            @map("contact_phone")
  city                     String
  propertyCategory         String                             @map("property_category")
  /// Internal note only (e.g. “met at open house”) — never auto-imported listing text.
  sourcePlatformText       String?                            @map("source_platform_text") @db.Text
  /// Optional external listing URL (e.g. Airbnb) — user-supplied; not verified automatically.
  sourceListingUrl         String?                            @map("source_listing_url") @db.VarChar(2048)
  permissionStatus         ListingAcquisitionPermissionStatus @default(UNKNOWN) @map("permission_status")
  intakeStatus             ListingAcquisitionIntakeStatus     @default(NEW) @map("intake_status")
  notes                    String?                            @db.Text
  assignedToUserId         String?                            @map("assigned_to_user_id")
  priceCents               Int?                               @map("price_cents")
  bedrooms                 Int?
  bathrooms                Int?
  description              String?                            @db.Text
  amenitiesText            String?                            @map("amenities_text") @db.Text
  permissionConfirmedAt    DateTime?                          @map("permission_confirmed_at")
  /// Public reference code for the client (F-000001) — distinct from marketplace LST- codes.
  intakeCode               String?                            @unique @map("intake_code")
  /// Government ID or equivalent (single file URL).
  identityDocumentUrl      String?                            @map("identity_document_url") @db.Text
  submittedImageUrls       Json                               @default("[]") @map("submitted_image_urls")
  /// PDF / scans beyond property photos (deed excerpt, municipal docs, etc.).
  submittedDocumentUrls    Json                               @default("[]") @map("submitted_document_urls")
  linkedFsboListingId      String?                            @unique @map("linked_fsbo_listing_id")
  linkedFsboListing        FsboListing?                       @relation("FsboFromAcquisition", fields: [linkedFsboListingId], references: [id], onDelete: SetNull)
  linkedShortTermListingId String?                            @unique @map("linked_short_term_listing_id")
  linkedShortTermListing   ShortTermListing?                  @relation("StayFromAcquisition", fields: [linkedShortTermListingId], references: [id], onDelete: SetNull)
  linkedCrmListingId       String?                            @unique @map("linked_crm_listing_id")
  linkedCrmListing         Listing?                           @relation("CrmListingFromAcquisition", fields: [linkedCrmListingId], references: [id], onDelete: SetNull)
  outreachLogs             HostGrowthOutreachLog[]
  createdAt                DateTime                           @default(now()) @map("created_at")
  updatedAt                DateTime                           @updatedAt @map("updated_at")

  @@index([intakeStatus])
  @@index([permissionStatus])
  @@index([city])
  @@index([sourceType])
  @@index([createdAt])
  @@map("listing_acquisition_leads")
}

model OutreachLead {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  name            String?
  email           String?   @unique
  phone           String?
  source          String // INSTAGRAM | LINKEDIN | REFERRAL | DIRECT
  status          String    @default("NEW") // NEW | CONTACTED | RESPONDED | INTERESTED | ONBOARDED | LOST
  notesJson       Json?     @map("notes_json")
  lastContactedAt DateTime? @map("last_contacted_at")
  referralSource  String?   @map("referral_source")

  // Québec/Canada broker sourcing fields
  city            String?
  agency          String?
  instagramHandle String? @map("instagram_handle")
  linkedinUrl     String? @map("linkedin_url")
  specialization  String?
  score           Int     @default(0)

  // Legacy fields for host outreach
  contact         String?
  type            String?
  notes           String? @db.Text
  market          String? @map("market")
  createdByUserId String? @map("created_by_user_id")

