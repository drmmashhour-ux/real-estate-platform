  marketingBudgetNeed                 Float?                            @map("marketing_budget_need")
  operationalRiskScore                Float?                            @map("operational_risk_score")
  manualCapitalLock                   Boolean                           @default(false) @map("manual_capital_lock")
  createdAt                           DateTime                          @default(now()) @map("created_at")
  updatedAt                           DateTime                          @updatedAt @map("updated_at")
  ownerId                             String                            @map("host_id")
  availability                        AvailabilitySlot[]
  availabilityBlocks                  AvailabilityBlock[]
  bookingNights                       BookingNight[]
  listingPhotos                       BnhubListingPhoto[]
  hostReviewsOfGuest                  BnhubHostReviewOfGuest[]
  verificationLogs                    ListingVerificationLog[]
  disputes                            Dispute[]
  propertyDocuments                   PropertyDocument[]
  propertyVerification                PropertyVerification?
