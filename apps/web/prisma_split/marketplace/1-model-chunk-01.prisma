model ListingRankingScore {
  id                        String    @id @default(cuid())
  listingType               String    @map("listing_type") @db.VarChar(32)
  listingId                 String    @map("listing_id") @db.VarChar(40)
  city                      String?   @db.VarChar(128)
  neighborhood              String?   @db.VarChar(128)
  totalScore                Float     @map("total_score")
  relevanceScore            Float     @map("relevance_score")
  trustScore                Float     @map("trust_score")
  qualityScore              Float     @map("quality_score")
  engagementScore           Float     @map("engagement_score")
  conversionScore           Float     @map("conversion_score")
  freshnessScore            Float     @map("freshness_score")
  hostScore                 Float?    @map("host_score")
  reviewScore               Float?    @map("review_score")
  priceCompetitivenessScore Float?    @map("price_competitiveness_score")
  availabilityScore         Float?    @map("availability_score")
