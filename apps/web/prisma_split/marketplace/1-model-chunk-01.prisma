  startMinute Int      @map("start_minute")
  endMinute   Int      @map("end_minute")
  isActive    Boolean  @default(true) @map("is_active")
  timezone    String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")


  @@index([brokerId])
  @@index([dayOfWeek])
  @@map("availability_rules")
}

model AvailabilityException {
  id          String   @id @default(cuid())
  brokerId    String   @map("broker_id")
  startsAt    DateTime @map("starts_at")
  endsAt      DateTime @map("ends_at")
  reason      String?
  /// false = blocked / unavailable; true = extra availability window
  isAvailable Boolean  @default(false) @map("is_available")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")


  @@index([brokerId])
  @@index([startsAt])
  @@map("availability_exceptions")
}

model ListingProperty {
  id            BigInt                    @id @default(autoincrement())
  ownerUserId   String?                   @map("owner_user_id")
  brokerUserId  String?                   @map("broker_user_id")
  fsboListingId String?                   @unique @map("fsbo_listing_id")
  fsboListing   FsboListing?              @relation(fields: [fsboListingId], references: [id], onDelete: SetNull)
  mode          String
  propertyType  String                    @map("property_type")
  title         String?
  description   String?                   @db.Text
  price         Decimal?                  @db.Decimal(12, 2)
  addressLine1  String?                   @map("address_line1")
  unitNumber    String?                   @map("unit_number")
  city          String?
  province      String?
  postalCode    String?                   @map("postal_code")
  country       String                    @default("CA")
  bedrooms      Int?
  bathrooms     Decimal?                  @db.Decimal(4, 1)
  areaSqft      Decimal?                  @map("area_sqft") @db.Decimal(10, 2)
  status        String                    @default("draft")
  planType      String                    @default("free") @map("plan_type")
  createdAt     DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  media         ListingPropertyMedia[]

  @@index([status], map: "idx_properties_status")
  @@index([ownerUserId], map: "idx_properties_owner_user_id")
  @@index([brokerUserId], map: "idx_properties_broker_user_id")
  @@index([mode, propertyType], map: "idx_properties_mode_type")
  @@index([city, price], map: "idx_properties_city_price")
  @@map("properties")
}

model ListingPropertyMedia {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listingId      BigInt          @map("listing_id")
  listing        ListingProperty @relation(fields: [listingId], references: [id], onDelete: Cascade)
  storagePath    String          @map("storage_path")
  mimeType       String          @map("mime_type")
  mediaKind      String          @map("media_kind")
  mediaTag       String?         @map("media_tag")
  position       Int             @default(0)
  fileHash       String?         @map("file_hash")
  perceptualHash String?         @map("perceptual_hash")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([listingId], map: "idx_listing_property_media_listing_id")
  @@index([fileHash], map: "idx_listing_property_media_file_hash")
  @@map("listing_property_media")
}

model BnhubRestrictedZone {
  id              String                          @id @default(uuid()) @map("id")
  name            String                          @map("name")
  /// GeoJSON polygon or similar — interpreted only by policy engine + admin tools
  boundaryGeoJson Json                            @map("boundary_geo_json")
  policyNotes     String?                         @map("policy_notes") @db.Text
  /// Optional postal / region match for non-polygon rules (admin-configured policy only).
  postalCode      String?                         @map("postal_code")
  regionCode      String?                         @map("region_code")
  policyAction    BnhubTrustRestrictedZoneAction? @map("policy_action")
  isActive        Boolean                         @default(true) @map("is_active")
  createdAt       DateTime                        @default(now()) @map("created_at")
  updatedAt       DateTime                        @updatedAt @map("updated_at")

  listingSafetyProfiles BnhubListingSafetyProfile[]

  @@index([isActive])
  @@index([postalCode])
  @@index([regionCode])
  @@map("bnhub_restricted_zones")
}

model BnhubListingSafetyProfile {
  id                            String                  @id @default(uuid()) @map("id")
  listingId                     String                  @unique @map("listing_id")
  listing                       ShortTermListing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reviewStatus                  BnhubSafetyReviewStatus @default(APPROVED) @map("review_status")
  /// Machine-readable key for mobile copy: safety_review_in_progress | listing_unavailable | additional_verification_required | approved
  publicMessageKey              String                  @default("approved") @map("public_message_key")
  bookingAllowed                Boolean                 @default(true) @map("booking_allowed")
  listingVisible                Boolean                 @default(true) @map("listing_visible")
  requiresExteriorPhoto         Boolean                 @default(false) @map("requires_exterior_photo")
  requiresHostIdMatch           Boolean                 @default(false) @map("requires_host_id_match")
  requiresManualLocationConfirm Boolean                 @default(false) @map("requires_manual_location_confirm")
  /// Internal — never return to guest mobile clients
  internalNotes                 String?                 @map("internal_notes") @db.Text
  restrictedZoneId              String?                 @map("restricted_zone_id")
  restrictedZone                BnhubRestrictedZone?    @relation(fields: [restrictedZoneId], references: [id], onDelete: SetNull)
  lastReviewedAt                DateTime?               @map("last_reviewed_at")
  reviewedByUserId              String?                 @map("reviewed_by_user_id")
  createdAt                     DateTime                @default(now()) @map("created_at")
  updatedAt                     DateTime                @updatedAt @map("updated_at")

  @@index([reviewStatus])
  @@index([listingId])
  @@map("bnhub_listing_safety_profiles")
}

model BnhubSafetyFlag {
  id              String                  @id @default(uuid()) @map("id")
  listingId       String                  @map("listing_id")
  listing         ShortTermListing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  flagType        String                  @map("flag_type")
  severity        BnhubSafetyFlagSeverity @default(LOW) @map("severity")
  status          BnhubSafetyFlagStatus   @default(OPEN) @map("status")
  summary         String                  @map("summary")
  /// Admin-only evidence; never expose on guest/public mobile APIs
  evidenceJson    Json?                   @map("evidence_json")
  createdByUserId String?                 @map("created_by_user_id")
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")

  @@index([listingId])
  @@index([status])
  @@index([severity])
  @@map("bnhub_safety_flags")
}
