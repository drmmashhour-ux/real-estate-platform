  bnhubPricingSuggestions             BnhubPricingSuggestion[]
  bnhubPricingExecutionLogs           BnhubPricingExecutionLog[]
  /// Optional 1:1 — stay created from safe intake (`ListingAcquisitionLead`).
  sourcedFromAcquisitionLead          ListingAcquisitionLead?           @relation("StayFromAcquisition")
  permissionConfirmedAt               DateTime?                         @map("permission_confirmed_at")
  permissionSourceNote                String?                           @map("permission_source_note") @db.Text
  imagesApproved                      Boolean                           @default(false) @map("images_approved")
  imageSourceNote                     String?                           @map("image_source_note") @db.Text
  missingApprovedImages               Boolean                           @default(false) @map("missing_approved_images")
  bnhubAutomatedHostMessages          BnhubAutomatedHostMessageLog[]
  /// Auto-generated TikTok/social packs + optional video + scheduler handoff
  /// LECIPM content machine — per-style rows (hook/script/caption) + vertical asset + schedules
  /// LECIPM full automation pipeline (structured packs → video → social)
  /// Denormalized from `listing_ranking_scores` when ranking jobs run (fast BNHub catalog sort).
  rankingTotalScoreCache              Float                             @default(0) @map("ranking_total_score_cache")
  rankingPerformanceBand              String?                           @map("ranking_performance_band") @db.VarChar(32)
  rankingCachedAt                     DateTime?                         @map("ranking_cached_at")
  /// Host BNHub calendar color (FullCalendar multi-listing view).
  calendarColor                       String?                           @default("#D4AF37") @map("calendar_color") @db.VarChar(16)
  /// Multi-market FKs (legacy `country` / `city` strings remain until backfill).
  marketCountryId                     String?                           @map("market_country_id")
  marketCityId                        String?                           @map("market_city_id")
  /// Optional underwriting inputs for deterministic investment overlay (major currency units; nullable if unknown).
  investmentPurchasePriceMajor        Float?                            @map("investment_purchase_price_major")
  investmentEstimatedValueMajor       Float?                            @map("investment_estimated_value_major")
  investmentOperatingCostMonthlyMajor Float?                            @map("investment_operating_cost_monthly_major")
  /// Include in bulk BNHub recommendation jobs (hosts can disable per listing).
  investmentAnalyticsActive           Boolean                           @default(true) @map("investment_analytics_active")
  /// Public stay detail views — incremented server-side on each published listing page load (real traffic).
  bnhubListingViewCount               Int                               @default(0) @map("bnhub_listing_view_count")
  /// Count of rows in `bnhub_guest_favorites` for this listing (synced on save/unsave).
  bnhubWishlistCount                  Int                               @default(0) @map("bnhub_wishlist_count")
  /// Last server-recorded public detail view.
  bnhubLastViewedAt                   DateTime?                         @map("bnhub_last_viewed_at") @db.Timestamptz(6)
  /// Optional early-access discount percent for UX copy; checkout may use `BnhubHostListingPromotion` instead.
  bnhubEarlyAccessPercentOff          Int?                              @map("bnhub_early_access_percent_off")

  @@index([city, verificationStatus])
  @@index([city, listingStatus])
  /// Order 79 — single-column price filter / sort (canonical name for ops).
  @@index([nightPriceCents], map: "idx_listing_price")
  /// Order 79 — city-only filters (complements composite city+status indexes).
  @@index([city], map: "idx_listing_city")
  /// Order 79 — sort/filter by cached guest rating average.
  @@index([bnhubListingRatingAverage], map: "idx_listing_rating")
  @@index([createdAt])
  @@index([propertyIdentityId])
  @@index([ownerId])
  @@index([verificationStatus])
  @@index([listingStatus])
  @@index([listingVerificationStatus])
  @@index([cadastreNumber])
  @@index([rankingTotalScoreCache(sort: Desc)])
  @@index([marketCountryId])
  @@index([marketCityId])
  @@map("bnhub_listings")
}

