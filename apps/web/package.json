{
  "name": "@lecipm/web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "postinstall": "prisma generate --schema=./prisma/schema.prisma",
    "dev": "next dev -H 0.0.0.0 -p 3001 --webpack",
    "dev:3000": "next dev -H 0.0.0.0 -p 3000 --webpack",
    "build": "prisma generate --schema=./prisma/schema.prisma && NODE_OPTIONS=--max-old-space-size=8192 next build --webpack",
    "ci:integrity": "npx tsx scripts/check-repo-integrity.ts",
    "integrity:check": "npx tsx scripts/check-repo-integrity.ts",
    "ci:typecheck": "NODE_OPTIONS=--max-old-space-size=8192 pnpm exec tsc --noEmit",
    "ci:build": "node -e \"try{require('fs').unlinkSync('.next/lock')}catch(e){}\" && prisma generate --schema=./prisma/schema.prisma && NODE_OPTIONS=--max-old-space-size=8192 next build --webpack",
    "ci:lint": "eslint .",
    "ci:validate:platform": "npx tsx scripts/ci-platform-validations.ts",
    "ci:all": "npx tsx scripts/ci-runner.ts",
    "prepush:check": "npx tsx scripts/prepush-check.ts",
    "validate:ci-system": "npx tsx scripts/validate-ci-system.ts",
    "stabilize": "npx tsx scripts/run-stabilization.ts",
    "validate:stabilization": "npx tsx scripts/validate-stabilization.ts",
    "validate:crm-upgrade": "npx tsx scripts/validate-crm-upgrade.ts",
    "start": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:platform": "npx tsx scripts/validate-platform.ts",
    "validate:flows": "npx tsx scripts/validate-core-flows.ts",
    "validate:auth": "npx tsx scripts/validate-auth-user-behavior.ts",
    "test:e2e": "playwright test",
    "test:e2e:api-flows": "tsx scripts/e2e-scenarios.ts",
    "test:e2e:scenarios": "playwright test e2e/scenarios/run-all.spec.ts",
    "test:e2e:launch": "playwright test e2e/launch.spec.ts",
    "test:e2e:production": "pnpm run build && PLAYWRIGHT_PRODUCTION=1 playwright test",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "seed": "prisma db seed",
    "db:seed": "prisma db seed",
    "seed:test": "npx tsx scripts/seed-test-data.ts",
    "test:e2e:checklist": "npx tsx scripts/test-e2e-checklist.ts",
    "seed:qa-blockers": "npx tsx scripts/seed-qa-blockers.ts",
    "seed:simulation": "npx tsx prisma/seed-simulation.ts",
    "seed:trustgraph": "npx tsx prisma/seed-trustgraph-demo.ts",
    "seed:calibration": "npx tsx prisma/seed-calibration-study.ts",
    "stripe:verify": "npx tsx scripts/stripe-verify.ts",
    "verify:stripe-connect": "npx tsx scripts/verify-stripe-connect-platform.ts",
    "validate:bnhub-stripe": "npx tsx scripts/validate-bnhub-stripe-e2e.ts",
    "test:bnhub:api": "npx tsx scripts/bnhub-api-smoke.ts",
    "validate:bnhub:db": "npx tsx scripts/bnhub-db-validate.ts",
    "validate:bnhub:readiness": "npx tsx scripts/bnhub-readiness.ts",
    "validate:soft-launch-status": "npx tsx scripts/soft-launch-status-cli.ts",
    "smoke:orchestrated": "npx tsx scripts/smoke-orchestrated-tables.ts",
    "screenshots:export": "npx tsx scripts/export-screenshots.ts",
    "screenshots:optimize": "node scripts/optimize-marketing-screenshots.mjs",
    "brand:export": "node scripts/export-brand-logos.cjs",
    "assets:generate": "node scripts/generate-brand-png-assets.mjs",
    "client:test-user": "npx tsx scripts/create-client-test-user.ts",
    "seed:prelaunch-users": "npx tsx scripts/seed-prelaunch-test-users.ts",
    "demo:reset": "npx tsx scripts/reset-demo.ts",
    "demo:full": "npx tsx scripts/generate-full-demo-data.ts",
    "demo:seed": "npx tsx scripts/generate-full-demo-data.ts",
    "seed:demo": "npx tsx scripts/seed-demo-data.ts",
    "seed:demo:investor": "npx tsx scripts/seed-demo-mode.ts",
    "validate:demo": "DEMO_MODE_ENABLED=1 npx tsx scripts/validate-demo-mode.ts",
    "ai:daily-content": "npx tsx scripts/daily-launch-content.ts",
    "backup:db": "npx tsx scripts/backup-db.ts",
    "export:audit-log": "npx tsx scripts/export-audit-log.ts",
    "test:system-validation": "TEST_MODE=true npx tsx scripts/run-system-validation.ts",
    "validate:monopoly": "npx tsx scripts/validate-monopoly-mode.ts",
    "validate:growth-engine": "npx tsx scripts/validate-growth-engine.ts",
    "validate:messaging-system": "npx tsx scripts/validate-messaging-system.ts",
    "validate:ai-auto-reply": "npx tsx scripts/validate-ai-auto-reply.ts",
    "validate:ai-learning": "npx tsx scripts/validate-ai-learning.ts",
    "validate:executive-control": "npx tsx scripts/validate-executive-control.ts",
    "growth:seed": "npx tsx scripts/growth-seed.ts",
    "validate:review-system": "npx tsx scripts/validate-review-system.ts",
    "validate:ranking-system": "npx tsx scripts/validate-ranking-system.ts",
    "validate:fraud": "npx tsx scripts/validate-fraud-detection.ts",
    "realtime:socket": "node realtime/socket-booking-server.cjs",
    "inspect:executive-daily": "npx tsx scripts/inspect-executive-daily-recommendations.ts",
    "ai:autopilot": "npx tsx scripts/run-ai-autopilot.ts",
    "ai:update-profiles": "npx tsx scripts/update-user-profiles.ts",
    "ai:run": "npx tsx scripts/run-unified-ai.ts",
    "ai:run:host": "npx tsx scripts/run-unified-ai.ts --host"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed-runner.ts"
  },
  "dependencies": {
    "@lecipm/api-client": "workspace:*",
    "@lecipm/ui": "workspace:*",
    "@prisma/client": "^6",
    "@react-google-maps/api": "^2.20.8",
    "@react-pdf/renderer": "^4.3.2",
    "@supabase/supabase-js": "^2.99.3",
    "axios": "^1.13.6",
    "canvas-confetti": "^1.9.4",
    "date-fns": "^4.1.0",
    "dictionary-en": "^4.0.0",
    "dictionary-fr": "^3.0.0",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.38.0",
    "franc": "^6.2.0",
    "ioredis": "^5.10.1",
    "jspdf": "^4.2.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "next": "16.1.6",
    "next-pwa": "^5.6.0",
    "nspell": "^2.1.5",
    "openai": "^6.32.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "posthog-js": "^1.363.5",
    "posthog-node": "^5.28.5",
    "pptxgenjs": "^3.12.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-leaflet": "^5.0.0",
    "recharts": "^2.15.4",
    "resend": "^6.9.4",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "stripe": "^14.25.0",
    "uuid": "^9.0.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "autoprefixer": "^10.4.27",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "playwright": "^1.59.1",
    "postcss": "^8.5.6",
    "prisma": "^6",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vitest": "^2.1.0"
  }
}
