# =============================================================================
# Production environment — copy to .env.production locally OR set in Vercel.
# Never commit real secrets. Use Vercel → Project → Settings → Environment Variables.
# =============================================================================
#
# If DATABASE_URL is missing/wrong on Vercel, the ROOT LAYOUT cannot run Prisma
# (launch flags + locale/market) → entire site may return 503 including / and /listings.
# See docs/deployment/APP_LECIPM_503.md
#
# =============================================================================

# --- Required ---
# PostgreSQL — Vercel/serverless: use Supabase *transaction pooler* (often :6543), not direct :5432.
# Full guide: docs/deployment/VERCEL_SUPABASE_DATABASE_URL.md
# Example shape (replace host/user/pass):
# DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"
DATABASE_URL="postgresql://user:password@host:6543/postgres?sslmode=require"

# Public site URL (used in emails, redirects, absolute links, metadata)
NEXT_PUBLIC_APP_URL="https://app.lecipm.com"

# --- Auth note (web-app) ---
# Sessions use httpOnly cookie `lecipm_guest_id` (user id). No NextAuth in this app.
# If you add JWT/signed cookies later, set e.g. SESSION_SIGNING_SECRET here.

# --- Stripe (payments, BNHub Connect + Checkout) ---
# Same account, all live mode. Connect must be enabled (Dashboard → Connect) for BNHub host payouts.
# Webhook: Live endpoint → /api/stripe/webhook → copy signing secret here.
STRIPE_SECRET_KEY="sk_live_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
# After deploy, optional sanity check from a machine with these env vars: pnpm run verify:stripe-connect (in apps/web)

# --- Optional: Supabase (FSBO media, etc.) ---
# NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
# SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# --- Email (Resend / Sendgrid — see lib/email) ---
# RESEND_API_KEY="re_xxx"
# EMAIL_FROM="LECIPM <bookings@your-domain.com>"

# --- AI (if used) ---
# OPENAI_API_KEY="sk-..."

# --- Public marketing contact ---
# NEXT_PUBLIC_CONTACT_EMAIL="contact@lecipm.com"
# NEXT_PUBLIC_CONTACT_PHONE="+1 844 441 5444"

# --- Analytics ---
# NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# BNHub platform fee (decimal, default 0.15)
# BNHUB_COMMISSION_RATE=0.15

# Optional Expo push access token for BNHub mobile guest notifications.
# EXPO_ACCESS_TOKEN="your_expo_access_token"
