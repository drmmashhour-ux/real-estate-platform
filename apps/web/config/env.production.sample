# Copy to Vercel Project → Environment Variables (Production) and/or a local
# .env.production (never commit secrets; .env* is gitignored).
#
# Database: use Supabase **pooler** (PgBouncer) URL for Prisma at runtime; add sslmode.
# Migrations: use ONE `pnpm exec prisma migrate deploy` from apps/web (merged schema
# in prisma/ + prisma.config.ts) — not per split schema (single migration history on one Postgres).

# --- Postgres (pooled) ---
DATABASE_URL=postgresql://USER:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true

# Optional: direct (non-pooler) for CI/migrate when required
# DIRECT_URL=postgresql://USER:PASSWORD@db.***.supabase.co:5432/postgres?sslmode=require

# --- App URL ---
NEXT_PUBLIC_APP_URL=https://your-domain.com

# --- Supabase (public + server) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Stripe (start with test keys; swap to sk_live_ when ready) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- OpenAI (server-only) ---
# OPENAI_API_KEY=sk-...
