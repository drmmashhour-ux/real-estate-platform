# Staging (fake values only). Never use production credentials.
# Host: set on Vercel (staging) or in CI — not written to .env.local by resolve-env-db.
#
APP_ID=lecipm
APP_ENV=staging
INVESTOR_DEMO_MODE=false
#
# Required for staging: remote database with sslmode=require
STAGING_DATABASE_URL=postgresql://user:password@db.staging.example.com:5432/lecipm_staging?sslmode=require
#
# Runtime: Prisma / Next read DATABASE_URL (set STAGING_DATABASE_URL in dashboard as DATABASE_URL, or use resolve-env-db on a runner that exports the value; local files are not auto-written for APP_ENV=staging)
DATABASE_URL=postgresql://user:password@db.staging.example.com:5432/lecipm_staging?sslmode=require
#
# Local-only: allow a loopback staging DSN in emergencies (not for hosted staging)
# ALLOW_LOCAL_STAGING_DB=true
