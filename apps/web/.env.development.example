# Local / development (fake values only)
# Copy patterns into .env or .env.local; never commit real secrets.
#
# Identity & logical environment
APP_ID=lecipm
APP_ENV=development
INVESTOR_DEMO_MODE=false
#
# Optional: dedicated dev DSN; resolve-env-db prefers this when APP_ENV=development
# DEV_DATABASE_URL=postgresql://dev:dev@localhost:5432/lecipm_dev
#
# Final URL Prisma uses (local Postgres is allowed)
DATABASE_URL=postgresql://user:password@localhost:5432/lecipm_dev
#
# Staging / prod pool URLs (for reference; not used when APP_ENV=development)
# STAGING_DATABASE_URL=postgresql://user:password@db.staging.example.com:5432/lecipm_staging?sslmode=require
# PRODUCTION_DATABASE_URL=postgresql://user:password@db.prod.example.com:5432/lecipm?sslmode=require
