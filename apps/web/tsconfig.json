{
  "extends": "../../packages/config/tsconfig.nextapp.json",
  "compilerOptions": {
    "target": "ES2020",
    "skipLibCheck": true,
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "noEmit": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@/design/*": ["./src/design/*"],
      "@/modules/*": ["./modules/*"],
      "@/components/*": ["./components/*"],
      "@/hooks/*": ["./hooks/*"],
      "@/types/*": ["./types/*"],
      "@/config/*": ["./config/*"],
      "@/design-system": ["./design-system/index.ts"],
      "@/design-system/*": ["./design-system/*"],
      "@ui/*": ["../../packages/ui/src/*"],
      "@utils/*": ["../../packages/utils/src/*"],
      "@shared-types/*": ["../../packages/types/src/*"],
      "@api/*": ["../../packages/api-client/src/*"],
      "@repo/db": ["../../packages/db/src/index.ts"],
      "@repo/tenant": ["../../packages/tenant/src/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/__tests__/**",
    "scripts/**"
  ]
}
