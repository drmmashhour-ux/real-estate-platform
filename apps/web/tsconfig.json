{
  "extends": "../../packages/config/tsconfig.nextapp.json",
  "compilerOptions": {
    "target": "ES2020",
    "skipLibCheck": true,
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "noEmit": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@/src/*": ["./src/*"],
      "@/design/*": ["./src/design/*"],
      "@/modules/*": ["./modules/*"],
      "@/components/*": ["./components/*"],
      "@/hooks/*": ["./hooks/*"],
      "@/types/*": ["./types/*"],
      "@/config/*": ["./config/*"],
      "@/design-system": ["./design-system/index.ts"],
      "@/design-system/*": ["./design-system/*"],
      "@ui/*": ["../../packages/ui/src/*"],
      "@utils/*": ["../../packages/utils/src/*"],
      "@shared-types/*": ["../../packages/types/src/*"],
      "@lecipm/api": ["../../packages/api/internal/index.ts"],
      "@lecipm/core": ["../../packages/core/index.ts"],
      "@api/*": ["../../packages/api-client/src/*"],
      "@repo/db": ["../../packages/db/src/index.ts"],
      "@repo/db/*": ["../../packages/db/src/*"],
      "@repo/tenant": ["../../packages/tenant/src/index.ts"],
      "@repo/ai": ["../../packages/ai/src/index.ts"],
      "@repo/ai/*": ["../../packages/ai/src/*"],
      "@repo/market": ["../../packages/market/src/index.ts"],
      "@repo/market/*": ["../../packages/market/src/*"],
      "@repo/workflows": ["../../packages/workflows/src/index.ts"],
      "@repo/workflows/*": ["../../packages/workflows/src/*"],
      "@repo/appraisal": ["../../packages/appraisal/src/index.ts"],
      "@repo/appraisal/*": ["../../packages/appraisal/src/*"],
      "@repo/finance": ["../../packages/finance/src/index.ts"],
      "@repo/finance/*": ["../../packages/finance/src/*"],
      "@repo/compliance": ["../../packages/compliance/src/index.ts"],
      "@repo/compliance/*": ["../../packages/compliance/src/*"],
      "@repo/ui": ["../../packages/ui/src/index.ts"],
      "@repo/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/__tests__/**",
    "scripts/**"
  ]
}
