{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm build:web",
  "env": {
    "HUSKY": "0",
    "NEXT_TELEMETRY_DISABLED": "1",
    "NODE_OPTIONS": "--max-old-space-size=8192"
  },
  "crons": [
    {
      "path": "/api/cron/reset-demo",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/auto-close-worker",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/investor-metrics-daily",
      "schedule": "15 5 * * *"
    },
    {
      "path": "/api/cron/growth-seo-daily",
      "schedule": "40 4 * * *"
    },
    {
      "path": "/api/cron/ai-marketing-engine-daily",
      "schedule": "50 4 * * *"
    }
  ]
}
