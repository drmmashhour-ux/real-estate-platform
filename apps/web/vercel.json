{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm build:web",
  "env": {
    "ENABLE_EXPERIMENTAL_COREPACK": "1",
    "CI": "1",
    "NPM_CONFIG_PRODUCTION": "false",
    "HUSKY": "0",
    "NEXT_TELEMETRY_DISABLED": "1",
    "NODE_OPTIONS": "--max-old-space-size=8192"
  },
  "crons": [
    {
      "path": "/api/cron/reset-demo",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/auto-close-worker",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/investor-metrics-daily",
      "schedule": "15 5 * * *"
    },
    {
      "path": "/api/cron/bnhub-investor-report-archive",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron/growth-seo-daily",
      "schedule": "40 4 * * *"
    },
    {
      "path": "/api/cron/ai-marketing-engine-daily",
      "schedule": "50 4 * * *"
    },
    {
      "path": "/api/cron/marketing-publish-due",
      "schedule": "45 4 * * *"
    },
    {
      "path": "/api/pricing/generate",
      "schedule": "35 6 * * *"
    },
    {
      "path": "/api/cron/autonomy-run-due",
      "schedule": "30 */4 * * *"
    },
    {
      "path": "/api/cron/autonomy-learning-run",
      "schedule": "15 9 * * *"
    }
  ]
}
