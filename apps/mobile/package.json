{
  "name": "@lecipm/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "prebuild": "expo prebuild",
    "assets:generate": "node scripts/generate-store-assets.mjs",
    "app-icon:export": "node scripts/export-app-icon-platforms.mjs",
    "store-screenshots:generate": "node scripts/generate-store-screenshots.mjs",
    "eas:configure": "eas build:configure",
    "eas:build:preview:ios": "eas build --profile preview --platform ios",
    "eas:build:preview:android": "eas build --profile preview --platform android",
    "eas:build:production:ios": "eas build --profile production --platform ios",
    "eas:build:production:android": "eas build --profile production --platform android",
    "eas:submit:ios": "eas submit --platform ios --profile production",
    "eas:submit:android": "eas submit --platform android --profile production"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@supabase/supabase-js": "^2.99.3",
    "@tanstack/react-query": "^5.96.1",
    "axios": "^1.13.6",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-localization": "^55.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "^55.0.15",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "~9.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-calendars": "^1.1314.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "^4.1.7",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.4",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/node": "^22.19.3",
    "@types/react": "19.2.14",
    "eas-cli": "^16.28.0",
    "sharp": "^0.34.4",
    "typescript": "^5.9.3"
  },
  "expo": {
    "install": {
      "exclude": [
        "@types/react",
        "@types/react-dom"
      ]
    }
  }
}
