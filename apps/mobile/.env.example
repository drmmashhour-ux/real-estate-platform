# Point to your Next.js web-app (LAN IP for physical device, e.g. http://192.168.1.10:3000)
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Supabase (anon key only — never service role in the app)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: Mapbox when switching from react-native-maps (@rnmapbox/maps + prebuild)
# EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk...
