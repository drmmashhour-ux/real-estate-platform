# iOS Simulator: localhost is OK if the web app runs on your Mac.
# Physical phone: localhost cannot reach your Mac — use https://lecipm.com or http://YOUR_LAN_IP:3000
# Android emulator: the app maps localhost -> 10.0.2.2 automatically in dev.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
# Production / device testing without LAN:
# EXPO_PUBLIC_API_BASE_URL=https://lecipm.com

# Supabase (anon key only — never service role in the app)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: Mapbox when switching from react-native-maps (@rnmapbox/maps + prebuild)
# EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk...
