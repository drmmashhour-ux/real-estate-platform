# Copy to `.env` in this folder (never commit `.env`):
#   cp .env.example .env
#
# Expo only exposes variables that start with EXPO_PUBLIC_ (must be UPPERCASE).
# Do not use lowercase names like expo_public_supabase_anon_key — they will not load.

# iOS Simulator: localhost is OK if the web app runs on your Mac.
# Physical phone: use https://lecipm.com or http://YOUR_LAN_IP:3000
# Android emulator: localhost is mapped to 10.0.2.2 automatically in dev.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# --- Supabase (browser-safe anon key only; never service role in the app) ---
# Same project as apps/web if you share auth: Dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: Mapbox when switching from react-native-maps (@rnmapbox/maps + prebuild)
# EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk...
