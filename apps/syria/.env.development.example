# Syria (Darlink) — development (placeholders only)
#
APP_ID=syria
APP_ENV=development
INVESTOR_DEMO_MODE=false
# Local demo seed against Docker while STAGING_DATABASE_URL is set in .env:
# ALLOW_INVESTOR_DEMO_LOCAL_DB=true
#
# Optional dev DSN; resolve-env-db prefers this when APP_ENV=development
# DEV_DATABASE_URL=postgresql://dev:dev@localhost:5432/sybnb_dev
#
# Isolated from LECIPM: URL must not contain the token `lecipm`
DATABASE_URL=postgresql://user:password@localhost:5432/sybnb_dev
#
# STAGING_DATABASE_URL=postgresql://user:password@db.staging.example.com:5432/syria_sybnb_staging?sslmode=require
# PRODUCTION_DATABASE_URL=postgresql://user:password@db.prod.example.com:5432/syria_sybnb?sslmode=require
