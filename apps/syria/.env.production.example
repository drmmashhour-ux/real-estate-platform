# ---------------------------------------------------------------------------
# Hadiah Link / SYBNB (apps/syria) — production template
# DO NOT use Canada LECIPM (`apps/web`) databases or Vercel env imports here.
# Copy to a local, secret `.env.production` (gitignored) or set vars in Vercel only.
# ---------------------------------------------------------------------------

APP_ID=syria
APP_ENV=production
INVESTOR_DEMO_MODE=false
DARLINK_PLATFORM_ENABLED=true
SYRIA_PLATFORM_ENABLED=true
APP_CONTEXT=darlink
APP_NAME=syria
NODE_ENV=production

# --- Database (isolated) --------------------------------------------------
# Provisioning: create a NEW Postgres/Neon/Supabase DB for Syria only.
# SYRIA_DATABASE_URL: operator-facing name for the DSN (Terraform / docs).
# Prisma and Next read DATABASE_URL — set both to the same Syria DSN, or set only DATABASE_URL.
# NEVER reuse the LECIPM/Canada `DATABASE_URL` or any DSN that contains a Canada-only `lecipm` token.
SYRIA_DATABASE_URL=postgresql://USER:PASS@db.example.com:5432/syria_sybnb_prod?sslmode=require
DATABASE_URL=postgresql://USER:PASS@db.example.com:5432/syria_sybnb_prod?sslmode=require

# --- Auth (unique per Vercel project) --------------------------------------
# Use a new random secret; do not copy from `apps/web`.
# AUTH_SECRET=

# --- Isolation: session / cookies (see src/lib/auth.ts) ----------------------
# Default cookie name: syria_user_id. Override only if you rotate and need a new name.
# SYRIA_AUTH_SESSION_COOKIE=syria_user_id

# --- SYBNB / payments (ship safe) ------------------------------------------
SYBNB_PAYMENTS_ENABLED=false
SYBNB_PRODUCTION_LOCK_MODE=true
SYBNB_PAYMENT_PROVIDER=manual
SYBNB_INSTANT_BOOK_ENABLED=false

# --- Cron (SYBNB auto-complete) --------------------------------------------
# CRON_SECRET=generate-a-long-random-string

# --- Domains (set in Vercel → Domains) --------------------------------------
# Option A: syria.lecipm.com  |  Option B: sybnb.com (future)
# No shared cookies with Canada: different hostname = browser isolates auth cookies by default.

# Optional: maps
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
