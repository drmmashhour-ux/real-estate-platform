# Same Postgres as the monorepo — Syria uses isolated `syria_*` tables.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/lecipm"

# Deployment identity — Darlink (Syria app) only. Required in production (see src/lib/guard.ts).
APP_CONTEXT=darlink

# Maps (Maps JavaScript API + Geocoding for optional reverse lookup when dropping a pin)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Feature flags (safe defaults)
# Darlink product lane — set to false only to disable the branded Syria app shell messaging (rare).
DARLINK_PLATFORM_ENABLED=true

SYRIA_PLATFORM_ENABLED=true
# Locale: default Arabic — URL prefix `/ar/` or `/en/` (next-intl). Optional cookie `DARLINK_LOCALE=ar|en`.
# Server-side resolvers also accept `?lang=ar|en` or `?locale=ar|en` (e.g. deep links) — primary UX is the path prefix + LocaleToggle.
BNHUB_ENABLED=true
AUTO_PAYOUT_ENABLED=false

# Darlink marketplace autonomy OS — defaults OFF / approval-first (see apps/syria/docs/darlink-full-autonomous-marketplace.md)
# DARLINK_AUTONOMY_ENABLED=false
# DARLINK_AUTONOMY_APPROVALS_ENABLED=true
# DARLINK_AUTONOMY_AUTO_EXECUTE_ENABLED=false
# DARLINK_AUTONOMY_OPTIMIZATION_ENABLED=false

# Auth: comma-separated emails allowed to elevate to ADMIN when using "Staff admin" on login
SYRIA_ADMIN_EMAILS="admin@syria.local"

# FI / F1: POST /api/payments/confirm|reject with Authorization: Bearer <secret> (optional if you use admin session)
# If set, overrides SYRIA_PAYMENT_ADMIN_SECRET for the same check.
FI_ADMIN_SECRET=
SYRIA_PAYMENT_ADMIN_SECRET=

# Admin phone for “Make Featured” (owners contact you here). Digits, 09…, or 963…
HADIAH_MONETIZATION_PHONE=
# Legacy alias
# SYRIA_MONETIZATION_ADMIN_PHONE=

# Monetization (SYP defaults)
SYRIA_LISTING_FEE_AMOUNT=50000
# F1 baseline (bucket 0); listing quick-post uses same unless overridden
SYRIA_FEATURED_FEE_AMOUNT=50000
SYRIA_PREMIUM_FEE_AMOUNT=120000
# F1 promotion length after admin confirms (days)
SYRIA_FEATURED_DURATION_DAYS=7
# F1 A/B: ab = hash(listingId)%2 | low = always 50k/120k | high = always 70k/150k
SYRIA_F1_PRICING_MODE=ab
SYRIA_BNHUB_COMMISSION_RATE=0.12
SYRIA_DEFAULT_CURRENCY=SYP

# Monorepo global multi-region flags (read in shared packages / web admin intelligence; safe off)
# FEATURE_GLOBAL_MULTI_REGION_V1=
# FEATURE_GLOBAL_DASHBOARD_V1=
# FEATURE_REGION_ADAPTERS_V1=
# FEATURE_REGION_AWARE_AUTONOMY_V1=
# FEATURE_GLOBAL_DOMINATION_V1=
