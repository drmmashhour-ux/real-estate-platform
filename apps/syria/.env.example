# --- Investor demo (optional; OFF by default; no real payments) ---
# INVESTOR_DEMO_MODE=false
# DEMO_DATA_ENABLED=false
# DEMO_PAYMENTS_MODE=stub
# DEMO_EMAILS_DISABLED=true
# Vercel-only (never on user production): INVESTOR_DEMO_IN_PRODUCTION=true
# Seed/reset in NODE_ENV=production: INVESTOR_DEMO_ALLOW_SEED_IN_PRODUCTION=true (rare; dev DB only)

APP_ID=syria
INVESTOR_DEMO_MODE=false
# DR.BRAIN admin dashboard: simulated KPIs/charts/tickets only — never writes prod tickets or alerts
DRBRAIN_INVESTOR_DEMO_MODE=false
# Multi-env: APP_ENV=development|staging|production
# See .env.development.example, .env.staging.example, .env.production.example and docs/env-deployment.md
# pnpm env:check | pnpm dev:safe
#
# Isolation: use a DEDICATED database name (e.g. sybnb_dev) for Darlink. URLs containing `lecipm` are rejected.
# Optional: same DSN for ops docs; Prisma uses DATABASE_URL (see .env.production.example).
# SYRIA_DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/sybnb_dev"
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/sybnb_dev"
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/sybnb_dev"

# Deployment identity — Darlink (Syria app) only. Required in production (see src/lib/guard.ts).
APP_CONTEXT=darlink
# Vercel (sybnb-syria): production requires APP_NAME=syria
# APP_NAME=syria
# Dev-only: allow DATABASE_URL with `lecipm` DB name token if you use a single local Postgres: APP_DB_ISOLATION_RELAXED=1

# Maps (Maps JavaScript API + Geocoding for optional reverse lookup when dropping a pin)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ORDER SYBNB-129 — next/image JPEG/WebP quality for listing thumbnails on browse/detail (20–100; default 45)
# NEXT_PUBLIC_LISTING_IMAGE_QUALITY=45

# ORDER SYBNB-87 — listing photos via Cloudinary (HTTPS URLs stored in DB; `/api/listings/upload-image`).
# Dev: omit to fall back to compressed data URLs (small payloads only with SYBNB-83).
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# Optional folder prefix (default: sybnb/syria — ORDER SYBNB-103; never reuse Canada-era sybnb/listings on Syria prod)
# CLOUDINARY_LISTINGS_FOLDER=sybnb/syria

# Feature flags (safe defaults)
# Darlink product lane — set to false only to disable the branded Syria app shell messaging (rare).
DARLINK_PLATFORM_ENABLED=true

SYRIA_PLATFORM_ENABLED=true
# Locale: default Arabic — URL prefix `/ar/` or `/en/` (next-intl). Optional cookie `DARLINK_LOCALE=ar|en`.
# Server-side resolvers also accept `?lang=ar|en` or `?locale=ar|en` (e.g. deep links) — primary UX is the path prefix + LocaleToggle.
BNHUB_ENABLED=true
AUTO_PAYOUT_ENABLED=false

# Darlink marketplace autonomy OS — defaults OFF / approval-first (see apps/syria/docs/darlink-full-autonomous-marketplace.md)
# DARLINK_AUTONOMY_ENABLED=false
# DARLINK_AUTONOMY_APPROVALS_ENABLED=true
# DARLINK_AUTONOMY_AUTO_EXECUTE_ENABLED=false
# DARLINK_AUTONOMY_OPTIMIZATION_ENABLED=false

# Auth: comma-separated emails allowed to elevate to ADMIN when using "Staff admin" on login
SYRIA_ADMIN_EMAILS="admin@syria.local"

# FI / F1: POST /api/payments/confirm|reject with Authorization: Bearer <secret> (optional if you use admin session)
# If set, overrides SYRIA_PAYMENT_ADMIN_SECRET for the same check.
FI_ADMIN_SECRET=
SYRIA_PAYMENT_ADMIN_SECRET=

# Admin phone for “Make Featured” (owners contact you here). Digits, 09…, or 963…
HADIAH_MONETIZATION_PHONE=
# Legacy alias
# SYRIA_MONETIZATION_ADMIN_PHONE=

# Monetization (SYP defaults)
SYRIA_LISTING_FEE_AMOUNT=50000
# F1 baseline (bucket 0); listing quick-post uses same unless overridden
SYRIA_FEATURED_FEE_AMOUNT=50000
SYRIA_PREMIUM_FEE_AMOUNT=120000
# F1 promotion length after admin confirms (days)
SYRIA_FEATURED_DURATION_DAYS=7
# F1 A/B: ab = hash(listingId)%2 | low = always 50k/120k | high = always 70k/150k
SYRIA_F1_PRICING_MODE=ab
SYRIA_BNHUB_COMMISSION_RATE=0.12
SYRIA_DEFAULT_CURRENCY=SYP

# ORDER SYBNB-FINAL — pre-launch lock: keep synthetic rows OFF (`SYBNB_TEST_MODE=false`); card rails OFF until checklist passes (`SYBNB_PAYMENTS_ENABLED=false`).
# SYBNB — short-stay hub (default: no live card payments for Syria; manual-first)
# SYBNB-4: payment layer (checkout is flag-gated; no Stripe until enabled)
SYBNB_PAYMENTS_ENABLED=false
# SYBNB-6: instant book off by default; enable only with product + legal sign-off
SYBNB_INSTANT_BOOK_ENABLED=false
# ORDER SYBNB-108 — tag synthetic rows + enable guest flows without polluting prod data
# SYBNB_TEST_MODE=true
SYBNB_PAYMENT_PROVIDER=manual
# | stripe (requires SYBNB_PAYMENTS_ENABLED + host/listing/booking + compliance)
# | sham_cash_placeholder
# SYBNB_AUTO_APPROVE_STAYS=false
# Optional: when strict, `SYBNB_COMPLIANCE_MOCK=fail` blocks payment intent API
# SYBNB_COMPLIANCE_MODE=relaxed
# SYBNB_COMPLIANCE_MOCK=pass
# Optional: require host phone/account verification before new stay requests
# SYBNB_REQUIRE_HOST_VERIFIED=true
# Max unreviewed user reports on a listing before blocking new bookings
# SYBNB_MAX_UNREVIEWED_REPORTS_BLOCK=5
# HMAC of raw body (optional) — set header x-sybnb-body-hmac to sha256 HMAC
# SYBNB_WEBHOOK_BODY_HMAC_SECRET=
# In production, webhook must send x-sybnb-webhook-secret unless:
# SYBNB_WEBHOOK_ALLOW_UNAUTHENTICATED=1 (dev only)
# Card risk — min reports on listing / seller to require manual review (not auto-capture)
# SYBNB_REVIEW_PAYMENT_LISTING_REPORTS_MIN=3
# SYBNB_REVIEW_PAYMENT_SELLER_REPORTS_MIN=5
# SYBNB_RECENT_CHANGE_RISK_HOURS=48

# Require idempotency keys on POST /api/sybnb/payment-intent (pair with preflight when APP_ENV=production or SYBNB_PAYMENTS_ENABLED=true)
# SYBNB_PAYMENT_IDEMPOTENCY_REQUIRED=true

# `pnpm payments:preflight` / `pnpm payments:phase0` — pre-go-live checks
# APP_ID=syria
# APP_ENV=development
# Default safe: production lock ON (omit var, or any value except "false")
# SYBNB_PRODUCTION_LOCK_MODE=true
# SYBNB_ESCROW_ENABLED=true
# SYBNB_AUTO_RELEASE_PAYOUTS=false
# Emergency kill (instantly blocks): SYBNB_PAYMENTS_KILL_SWITCH=true | SYBNB_PAYOUTS_KILL_SWITCH=true
# If SYBNB_PAYMENT_PROVIDER=stripe: Stripe **signing** secret from Dashboard or `stripe listen` (`whsec_...`)
# STRIPE_WEBHOOK_SECRET=whsec_...
# (alias) SYBNB_STRIPE_WEBHOOK_SECRET=whsec_...
#
# ORDER SYBNB-110 — Stripe Checkout (test keys only; live `sk_live_*` rejected unless SYBNB_STRIPE_ALLOW_LIVE=true)
# Requires together: SYBNB_PAYMENTS_ENABLED=true, SYBNB_PAYMENT_PROVIDER=stripe, SYBNB_PRODUCTION_LOCK_MODE=false
# STRIPE_SECRET_KEY=sk_test_...
# Publishable key — duplicate for client banner (`NEXT_PUBLIC_*`):
# STRIPE_PUBLIC_KEY=pk_test_...
# NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_...
# Approximate SYP→USD for Checkout line item (Stripe settles in USD test mode):
# SYBNB_STRIPE_SYP_PER_USD=13000
# Base URL for Checkout return URLs:
# NEXT_PUBLIC_SYRIA_APP_URL=http://localhost:3002
#
# SYBNB-5: daily job — `GET` or `POST` /api/sybnb/cron/complete-bookings with `Authorization: Bearer <secret>`
# (same as apps/web cron pattern). Vercel: add `vercel.json` `crons` and set CRON_SECRET in project env.
# CRON_SECRET=

# SYBNB-22 / SYBNB-25 — USD anchor for host/agent copy (manual settlement); SYBNB-25 starts ~$5/listing
# NEXT_PUBLIC_SYBNB_FEATURED_USD_MIN=5
# NEXT_PUBLIC_SYBNB_FEATURED_USD_MAX=5
# SYBNB-25 — max boosted (featured/premium) slots on stay browse page 1 (clamped 3–20; default 5)
# SYBNB_FEATURED_MAX_PER_PAGE=5
# NEXT_PUBLIC_SYBNB_FEATURED_MAX_PER_PAGE=5
# Optional override for the canned WhatsApp outreach (Arabic)
# NEXT_PUBLIC_SYBNB_FEATURED_OUTREACH_AR=

# SYBNB-21 / SYBNB-24 — WhatsApp group invites (`/sybnb/agents`): Core (ops) + Agents (field)
# NEXT_PUBLIC_SYBNB_CORE_WHATSAPP_GROUP_URL=https://chat.whatsapp.com/XXXXXXXX
# NEXT_PUBLIC_SYBNB_AGENTS_WHATSAPP_GROUP_URL=https://chat.whatsapp.com/YYYYYYYY

# SYBNB-27 — Field agent incentive copy (USD band for `/sybnb/agents` + admin dashboard)
# NEXT_PUBLIC_SYBNB_AGENT_USD_LISTING_MIN=0.5
# NEXT_PUBLIC_SYBNB_AGENT_USD_LISTING_MAX=1

# SYBNB-35 — booking commission accrual (same currency unit as platform fee on SyriaBooking)
# SYBNB_AGENT_COMMISSION_RATE=0.10
# SYBNB_AGENT_COMMISSION_MIN=3

# SYBNB-28 — Public Facebook Page / Instagram (brand hub `/sybnb/brand`)
# NEXT_PUBLIC_SYBNB_FACEBOOK_URL=https://www.facebook.com/your-page
# NEXT_PUBLIC_SYBNB_INSTAGRAM_URL=https://www.instagram.com/your-handle/

# FEATURE_GLOBAL_MULTI_REGION_V1=
# FEATURE_GLOBAL_DASHBOARD_V1=
# FEATURE_REGION_ADAPTERS_V1=
# FEATURE_REGION_AWARE_AUTONOMY_V1=
# FEATURE_GLOBAL_DOMINATION_V1=
