// Syria platform — isolated tables (`syria_*`). Same DATABASE_URL as rest of monorepo; no overlap with apps/web schema.
generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
  output     = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SyriaUserRole {
  USER
  HOST
  ADMIN
}

/// SYBNB: operator review for short-stay supply (trust gate before browse).
enum SyriaSybnbListingReview {
  PENDING
  APPROVED
  REJECTED
}

/// SYBNB 2.0 — request / payment / settlement lifecycle (see `SybnbBooking`).
enum SybnbBookingStatus {
  requested
  approved
  payment_pending
  paid
  confirmed
  declined
  cancelled
  completed
  refunded
  needs_review
}

enum SybnbGuestPaymentState {
  none
  pending
  paid
  failed
  refunded
  manual_required
}

enum SybnbRiskState {
  clear
  review
  blocked
}

enum SyriaPropertyType {
  SALE
  RENT
  BNHUB
}

enum SyriaPropertyStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

/// Listing marketing tier. Declared order: free < featured < premium (used with `orderBy: { plan: desc }` → premium first).
enum SyriaListingPlan {
  free
  featured
  premium
}

enum SyriaBookingStatus {
  /// Guest requested dates; host has not decided.
  PENDING
  /// Host approved; guest must pay (card) or settle manually.
  APPROVED
  /// Paid (or admin-verified manual) & reservation locked.
  CONFIRMED
  /// Stay window ended (SYBNB post-checkout).
  COMPLETED
  CANCELLED
}

enum SyriaBookingPaymentStatus {
  UNPAID
  PENDING_MANUAL
  PAID
  HELD
}

enum SyriaPayoutLedgerStatus {
  PENDING
  APPROVED
  PAID
}

enum SyriaListingPaymentPurpose {
  LISTING_FEE
  FEATURED
  PREMIUM
  BNHUB_LISTING
  OTHER
}

enum SyriaListingPaymentStatus {
  PENDING
  VERIFIED
  FAILED
}

/// Manual-friendly payment rails (no Stripe assumption).
enum SyriaPaymentMethod {
  MANUAL_TRANSFER
  CASH
  LOCAL_GATEWAY_PLACEHOLDER
}

enum SyriaPromotionZone {
  HOME
  CATEGORY
  CITY
  SEARCH_BOOST
}

enum SyriaAutonomyRecommendationStatus {
  PENDING
  DISMISSED
  ACKNOWLEDGED
}

enum SyriaMarketplaceApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUPERSEDED
}

enum SyriaMarketplaceAutonomyRunStatus {
  RUNNING
  COMPLETED
  FAILED
  BLOCKED
}

enum SyriaMarketplaceActionOutcome {
  BLOCKED
  DRY_RUN
  EXECUTED
  FAILED
  ROLLED_BACK
  SKIPPED_APPROVAL_PENDING
}

model SyriaAppUser {
  id        String        @id @default(cuid())
  email     String        @unique
  name      String?
  phone     String?
  /// S1: set when phone verified via SMS/WhatsApp OTP (soft trust).
  phoneVerifiedAt DateTime?            @map("phone_verified_at")
  /// SYBNB general trust time — set/updated with phone or ID verification.
  verifiedAt    DateTime?  @map("verified_at")
  /// "phone" | "id" — strongest verification achieved.
  verificationLevel String? @map("verification_level")
  /// SYBNB: when true, new listings are hidden from public feed (abuse; ≥5 valid reports, etc.).
  sybnbSupplyPaused Boolean @default(false) @map("sybnb_supply_paused")
  /// SYBNB: operator-facing reputation aggregate (0+).
  reputationScore  Int     @default(0) @map("reputation_score")
  /// SYBNB / trust: account-level abuse or sanctions flag (hide from book flows in UI if needed).
  flagged            Boolean @default(false)
  role      SyriaUserRole @default(USER)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  propertiesOwned       SyriaProperty[]           @relation("PropertyOwner")
  phoneOtps                 SyriaPhoneOtp[]
  listingReportsFiled   SyriaListingReport[]      @relation("ListingReportReporter")
  bookingsAsGuest       SyriaBooking[]            @relation("BookingGuest")
  payoutsReceived       SyriaPayout[]             @relation("PayoutHost")
  listingPayments       SyriaListingPayment[]
  inquiriesSubmitted    SyriaInquiry[]
  reviewedListingPayments   SyriaListingPayment[]           @relation("ListingPaymentReviewer")
  autonomyRecommendations   SyriaAutonomyRecommendation[]   @relation("AutonomyOwner")
  sybnbBookingsAsGuest  SybnbBooking[]            @relation("SybnbGuestBookings")
  sybnbBookingsAsHost   SybnbBooking[]            @relation("SybnbHostBookings")
  sybnbPaymentAudits    SybnbPaymentAudit[]
  sybnbReportsFiled     SybnbListingReport[]    @relation("SybnbListingReportReporter")

  @@map("syria_users")
}

model SyriaInquiry {
  id          String        @id @default(cuid())
  propertyId  String        @map("property_id")
  property    SyriaProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  fromUserId  String?       @map("from_user_id")
  fromUser    SyriaAppUser? @relation(fields: [fromUserId], references: [id], onDelete: SetNull)
  name        String
  phone       String
  message     String?       @db.Text
  utmSource   String?       @map("utm_source")
  utmMedium   String?       @map("utm_medium")
  utmCampaign String?       @map("utm_campaign")
  createdAt   DateTime      @default(now()) @map("created_at")

  @@index([propertyId])
  @@map("syria_inquiries")
}

model SyriaProperty {
  id               String              @id @default(cuid())
  titleAr          String              @map("title_ar")
  titleEn          String?             @map("title_en")
  descriptionAr    String              @map("description_ar") @db.Text
  descriptionEn    String?             @map("description_en") @db.Text
  price            Decimal             @db.Decimal(14, 2)
  /// Nightly rate for `category = stay` (SYBNB); optional; `price` should mirror for sort/filters.
  pricePerNight    Int?                @map("price_per_night")
  currency         String              @default("SYP")
  type             SyriaPropertyType
  /// Syrian governorate — English label from `SYRIA_STATES` (structured filter + display).
  state            String              @default("") @map("state")
  /// Canonical governorate `name_en` from `syriaLocations` (search + display).
  governorate      String?             @map("governorate")
  /// Legacy search key: English city name from catalog (kept for filters and URL).
  city             String
  /// Bilingual display: Arabic city label (optional; backfilled from catalog in new listings).
  cityAr           String?             @map("city_ar")
  /// Bilingual display: English city label (optional; often matches `city`).
  cityEn           String?             @map("city_en")
  /// Legacy: area / district (often Arabic from catalog or custom text).
  area             String?             @map("area")
  /// Bilingual district (optional; may mirror `area` for AR).
  districtAr       String?             @map("district_ar") @db.Text
  districtEn       String?             @map("district_en") @db.Text
  /// Google place name or user text when a place was used to set the pin (optional).
  placeName        String?             @map("place_name")
  addressText      String?             @map("address_text") @db.Text
  /// Free-form location notes (optional; no street / GPS required).
  addressDetails   String?             @map("address_details") @db.Text
  latitude         Float?              @map("latitude")
  longitude        Float?              @map("longitude")
  /// Data URLs or external URLs (MVP: client-compressed base64; max 5 in quick post).
  images           String[]            @default([]) @map("images")
  /// Feature keys from `SYRIA_AMENITIES` (e.g. `wifi`, `furnished`).
  amenities        String[]            @default([]) @map("amenities")
  /// Simple public view counter; incremented on published listing page load.
  views            Int                 @default(0) @map("views")
  /// Leads: taps on owner WhatsApp (listing contact), best-effort increment.
  whatsappClicks   Int                 @default(0) @map("whatsapp_clicks")
  /// Leads: taps on owner phone (tel), best-effort increment.
  phoneClicks      Int                 @default(0) @map("phone_clicks")
  /// Short-stay (BNHUB): `YYYY-MM-DD` dates that are **booked** / not available. Absent dates = available.
  availability     String[]            @default([]) @map("availability")
  /// SYBNB: admin/host trust gate; only APPROVED stay listings show in /sybnb feed.
  sybnbReview      SyriaSybnbListingReview @default(PENDING) @map("sybnb_review")
  ownerId          String              @map("owner_id")
  owner            SyriaAppUser        @relation("PropertyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  status           SyriaPropertyStatus @default(DRAFT)
  /// Marketing tier: `free` (default) and `featured` (manual admin flag or verified payment). `premium` is legacy/optional.
  /// Browse sort: plan descending → featured listings surface before free.
  plan             SyriaListingPlan    @default(free) @map("plan")
  fraudFlag        Boolean             @default(false) @map("fraud_flag")
  /// S1: ≥3 user reports — queued for admin (with status PENDING_REVIEW).
  needsReview      Boolean             @default(false) @map("needs_review")
  /// Admin/manual "Verified" — UI badge only; no auto logic.
  listingVerified  Boolean             @default(false) @map("listing_verified")
  /// SY-11: explicit trust / marketplace verification (operator-set).
  verified         Boolean             @default(false) @map("verified")
  isFeatured       Boolean             @default(false) @map("is_featured")
  featuredUntil    DateTime?           @map("featured_until")
  featuredPriority Int                 @default(0) @map("featured_priority")
  neighborhood     String?             @map("neighborhood")
  bedrooms         Int?
  bathrooms        Int?
  furnished        Boolean?
  propertyCategory String?             @map("property_category")
  /// Marketplace vertical (full Hadiah): `real_estate` | `cars` | `electronics` | …
  category         String              @default("real_estate") @map("marketplace_category")
  subcategory      String              @default("sale") @map("marketplace_subcategory")
  /// Ad Studio template: `price` | `highlight` | `clean` (optional).
  adStyle          String?             @map("ad_style")
  /// SY-22: direct owner deal (no broker) — `true` is default; boosts sort and trust UI.
  isDirect         Boolean             @default(true) @map("is_direct")
  guestsMax        Int?                @map("guests_max")
  /// SY-28: human-friendly listing code, e.g. RE-1001 (global number + category prefix).
  adCode           String              @unique @map("ad_code")
  /// SYBNB: stay subtype — stay | apartment | room | villa | chalet (optional).
  sybnbStayType    String?             @map("sybnb_stay_type")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  bookings                  SyriaBooking[]
  listingPayments           SyriaListingPayment[]
  inquiries                 SyriaInquiry[]
  featuredPlacements        SyriaFeaturedPlacement[]
  autonomyRecommendations   SyriaAutonomyRecommendation[]
  paymentRequestsF1         SyriaPaymentRequest[]   @relation("PropertyPaymentRequest")
  listingFinanceF1          SyriaListingFinance?   @relation("PropertyListingFinance")
  listingReports            SyriaListingReport[]    @relation("PropertyReports")
  sybnbImages               SybnbListingImage[]
  sybnbBookings             SybnbBooking[]
  sybnbListingReports       SybnbListingReport[]

  @@index([city])
  @@index([state])
  @@index([governorate])
  @@index([type])
  @@index([status])
  @@index([isDirect])
  @@index([category, subcategory])
  @@index([category])
  @@index([status, needsReview, createdAt])
  @@map("syria_properties")
}

/// S1: short-lived phone verification code (hashed at rest).
model SyriaPhoneOtp {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  user      SyriaAppUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String       @map("code_hash")
  expiresAt DateTime     @map("expires_at")
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("syria_phone_otp")
}

/// S1: user report on a listing (fraud, wrong price, duplicate).
model SyriaListingReport {
  id         String        @id @default(cuid())
  propertyId String        @map("property_id")
  property   SyriaProperty @relation("PropertyReports", fields: [propertyId], references: [id], onDelete: Cascade)
  reporterId String?       @map("reporter_id")
  reporter   SyriaAppUser? @relation("ListingReportReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  /// "fraud" | "wrong_price" | "duplicate"
  reason     String
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([propertyId])
  @@index([createdAt])
  @@map("syria_listing_reports")
}

/// SYBNB: ordered image URLs (optional; parallel to `images` on `SyriaProperty`).
model SybnbListingImage {
  id         String        @id @default(cuid())
  propertyId String        @map("property_id")
  property   SyriaProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  url        String
  sortOrder  Int           @default(0) @map("sort_order")
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([propertyId])
  @@map("sybnb_listing_images")
}

/// SYBNB 2.0 short-stay booking (new flow; `SyriaBooking` remains for BNHUB).
model SybnbBooking {
  id        String   @id @default(cuid())
  listingId String   @map("listing_id")
  listing   SyriaProperty @relation(fields: [listingId], references: [id], onDelete: Cascade)
  guestId   String   @map("guest_id")
  guest     SyriaAppUser  @relation("SybnbGuestBookings", fields: [guestId], references: [id], onDelete: Cascade)
  hostId    String   @map("host_id")
  host      SyriaAppUser  @relation("SybnbHostBookings", fields: [hostId], references: [id], onDelete: Cascade)

  checkIn  DateTime @map("check_in")
  checkOut DateTime @map("check_out")
  guests   Int

  nightlyPrice Int @map("nightly_price")
  nights       Int
  serviceFee   Int    @default(0) @map("service_fee")
  totalAmount  Int    @map("total_amount")
  currency     String @default("SYP")

  status        SybnbBookingStatus     @default(requested) @map("status")
  paymentStatus SybnbGuestPaymentState @default(none) @map("payment_status")

  paymentProvider   String? @map("payment_provider")
  paymentIntentId   String? @map("payment_intent_id")
  checkoutSessionId String? @map("checkout_session_id")

  riskScore  Int            @default(0) @map("risk_score")
  riskStatus SybnbRiskState @default(clear) @map("risk_status")

  manualRef String? @map("manual_ref")
  proofUrl  String? @map("proof_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  paymentAudits SybnbPaymentAudit[]

  @@index([listingId])
  @@index([guestId])
  @@index([hostId])
  @@index([status])
  @@map("sybnb_bookings")
}

/// SYBNB listing report (operator queue via `reviewed`).
model SybnbListingReport {
  id         String        @id @default(cuid())
  propertyId String        @map("property_id")
  property   SyriaProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reporterId String?       @map("reporter_id")
  reporter   SyriaAppUser?   @relation("SybnbListingReportReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  reason     String
  reviewed   Boolean       @default(false)
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([propertyId])
  @@index([reviewed])
  @@map("sybnb_listing_reports")
}

/// SYBNB payment / checkout audit (append-only).
model SybnbPaymentAudit {
  id        String  @id @default(cuid())
  bookingId String? @map("booking_id")
  booking   SybnbBooking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  actorId   String? @map("actor_id")
  actor     SyriaAppUser? @relation(fields: [actorId], references: [id], onDelete: SetNull)
  event     String
  provider  String?
  amount    Int?
  currency  String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([bookingId])
  @@index([actorId])
  @@map("sybnb_payment_audit")
}

/// Monotonic counter for `SyriaProperty.adCode` (SY-28). Single row `id = global`.
model SyriaAdCodeSequence {
  id      String @id
  /// Last assigned number; first increment after migration yields the next public code.
  nextSeq Int    @default(1000) @map("next_seq")

  @@map("syria_ad_code_sequence")
}

model SyriaBooking {
  id                   String                     @id @default(cuid())
  propertyId           String                     @map("property_id")
  property             SyriaProperty              @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  guestId              String                     @map("guest_id")
  guest                SyriaAppUser               @relation("BookingGuest", fields: [guestId], references: [id], onDelete: Cascade)
  checkIn              DateTime                   @map("check_in")
  checkOut             DateTime                   @map("check_out")
  nightsCount       Int                        @default(1) @map("nights_count")
  nightlyRate       Decimal?                   @map("nightly_rate") @db.Decimal(14, 2)
  totalPrice        Decimal                    @map("total_price") @db.Decimal(14, 2)
  platformFeeAmount Decimal?                   @map("platform_fee_amount") @db.Decimal(14, 2)
  hostNetAmount     Decimal?                   @map("host_net_amount") @db.Decimal(14, 2)
  currency             String                     @default("SYP")
  status               SyriaBookingStatus         @default(PENDING)
  guestPaymentStatus   SyriaBookingPaymentStatus  @default(UNPAID) @map("guest_payment_status")
  payoutStatus         SyriaPayoutLedgerStatus    @default(PENDING) @map("payout_status")
  fraudFlag            Boolean                    @default(false) @map("fraud_flag")
  manualPaymentRef     String?                    @map("manual_payment_ref")
  proofUrl             String?                    @map("proof_url")
  guestCount           Int?                       @map("guest_count")
  checkedInAt          DateTime?                  @map("checked_in_at")
  utmSource            String?                    @map("utm_source")
  utmMedium            String?                    @map("utm_medium")
  utmCampaign          String?                    @map("utm_campaign")
  /// SYBNB: Stripe Checkout session id (stub or live) after host approval when card payments are on.
  sybnbCheckoutSessionId String?                  @map("sybnb_checkout_session_id")
  createdAt            DateTime                   @default(now()) @map("created_at")
  updatedAt            DateTime                   @updatedAt @map("updated_at")

  payouts SyriaPayout[]

  @@index([propertyId])
  @@index([guestId])
  @@map("syria_bookings")
}

model SyriaPayout {
  id           String                  @id @default(cuid())
  bookingId    String                  @map("booking_id")
  booking      SyriaBooking            @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  hostId       String                  @map("host_id")
  host         SyriaAppUser            @relation("PayoutHost", fields: [hostId], references: [id], onDelete: Cascade)
  amount       Decimal                 @db.Decimal(14, 2)
  platformFee  Decimal                 @map("platform_fee") @db.Decimal(14, 2)
  currency     String                  @default("SYP")
  status       SyriaPayoutLedgerStatus @default(PENDING)
  approvedAt   DateTime?               @map("approved_at")
  paidAt       DateTime?               @map("paid_at")
  notes        String?                 @db.Text
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")

  @@unique([bookingId])
  @@index([hostId])
  @@index([status])
  @@map("syria_payouts")
}

model SyriaListingPayment {
  id              String                     @id @default(cuid())
  propertyId      String                     @map("property_id")
  property        SyriaProperty              @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  ownerId         String                     @map("owner_id")
  owner           SyriaAppUser               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  amount          Decimal                    @db.Decimal(14, 2)
  currency        String                     @default("SYP")
  purpose         SyriaListingPaymentPurpose
  status          SyriaListingPaymentStatus  @default(PENDING)
  referenceNumber String?                    @map("reference_number")
  proofUrl        String?                    @map("proof_url")
  paymentMethod   SyriaPaymentMethod         @default(MANUAL_TRANSFER) @map("payment_method")
  reviewedById    String?                    @map("reviewed_by")
  reviewedBy      SyriaAppUser?              @relation("ListingPaymentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt      DateTime?                  @map("reviewed_at")
  createdAt       DateTime                   @default(now()) @map("created_at")
  updatedAt       DateTime                   @updatedAt @map("updated_at")

  @@index([propertyId])
  @@index([ownerId])
  @@index([status])
  @@map("syria_listing_payments")
}

/// FI / F1 manual payment request (باقة مميز/فاخر): upgrade → WhatsApp proof → admin confirm (`PaymentRequest` shape).
model SyriaPaymentRequest {
  id         String   @id @default(uuid()) @db.Uuid
  listingId  String   @map("listing_id")
  listing    SyriaProperty @relation("PropertyPaymentRequest", fields: [listingId], references: [id], onDelete: Cascade)
  /// "featured" | "premium" (String for stable API contract).
  plan       String
  amount     Int
  currency   String   @default("SYP")
  /// pending | confirmed | rejected
  status     String   @default("pending")
  /// Legacy A/B cell — retained for old rows; new requests use `pricingTier` (view ladder).
  pricingBucket Int @default(0) @map("pricing_bucket")
  /// View ladder: 0 = under 10 views, 1 = 10–24, 2 = 25+ (see syria-f1-pricing.config).
  pricingTier   Int    @default(0) @map("pricing_tier")
  method     String?  // e.g. cash | bank | wallet
  note       String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  confirmedAt DateTime? @map("confirmed_at")

  auditLogs   SyriaPaymentAuditLog[]

  @@index([listingId, status])
  @@index([status, createdAt])
  @@map("syria_payment_requests")
}

/// S3 — append-only audit for F1 payment requests (created / confirmed / rejected).
model SyriaPaymentAuditLog {
  id        String   @id @default(cuid())
  requestId String   @map("request_id") @db.Uuid
  request   SyriaPaymentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  action    String
  adminId   String?  @map("admin_id")
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([requestId])
  @@index([createdAt])
  @@map("syria_payment_audit_log")
}

/// F1: one row per listing — counters for support / ops.
model SyriaListingFinance {
  listingId      String  @id @map("listing_id")
  listing        SyriaProperty @relation("PropertyListingFinance", fields: [listingId], references: [id], onDelete: Cascade)
  totalRequests  Int     @default(0) @map("total_requests")
  totalConfirmed Int     @default(0) @map("total_confirmed")
  lastStatus     String? @map("last_status")

  @@map("syria_listing_finance")
}

/// Paid visibility placement (zones + ordering); admin-controlled.
model SyriaFeaturedPlacement {
  id                     String           @id @default(cuid())
  propertyId             String           @map("property_id")
  property               SyriaProperty    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  zone                   SyriaPromotionZone
  priority               Int              @default(0)
  active                 Boolean          @default(true)
  startsAt               DateTime         @map("starts_at")
  endsAt                 DateTime?        @map("ends_at")
  linkedListingPaymentId String?          @map("linked_listing_payment_id")
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")

  @@index([zone, active, priority])
  @@index([propertyId])
  @@map("syria_featured_placements")
}

/// Lightweight growth / funnel events (admin aggregates only in this phase).
model SyriaGrowthEvent {
  id          String   @id @default(cuid())
  eventType   String   @map("event_type")
  payload     Json     @default("{}")
  userId      String?  @map("user_id")
  propertyId  String?  @map("property_id")
  bookingId   String?  @map("booking_id")
  inquiryId   String?  @map("inquiry_id")
  utmSource   String?  @map("utm_source")
  utmMedium   String?  @map("utm_medium")
  utmCampaign String?  @map("utm_campaign")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([eventType, createdAt])
  @@index([utmCampaign])
  @@map("syria_growth_events")
}

/// Runs of the deterministic marketplace autonomy pipeline (Syria-local only).
model SyriaMarketplaceAutonomyRun {
  id                   String                             @id @default(cuid())
  startedAt            DateTime                           @default(now()) @map("started_at")
  finishedAt           DateTime?                          @map("finished_at")
  dryRun               Boolean                            @default(true) @map("dry_run")
  autonomyModeLabel    String                             @map("autonomy_mode_label")
  governanceModeLabel  String                             @map("governance_mode_label")
  entityScope          String                             @map("entity_scope")
  entityId             String?                            @map("entity_id")
  status               SyriaMarketplaceAutonomyRunStatus  @default(RUNNING)
  signalsCount         Int                                @default(0) @map("signals_count")
  opportunitiesCount   Int                                @default(0) @map("opportunities_count")
  proposalsCount       Int                                @default(0) @map("proposals_count")
  executedCount        Int                                @default(0) @map("executed_count")
  blockedCount         Int                                @default(0) @map("blocked_count")
  summaryJson          Json?                              @map("summary_json")
  errorNotes           String?                            @db.Text @map("error_notes")

  @@index([startedAt])
  @@map("syria_marketplace_autonomy_runs")
}

model SyriaMarketplaceAutonomyApproval {
  id                String                         @id @default(cuid())
  proposalKey       String                         @unique @map("proposal_key")
  actionType        String                         @map("action_type")
  targetEntityType  String                         @map("target_entity_type")
  targetEntityId    String?                        @map("target_entity_id")
  payloadJson       Json                           @default("{}") @map("payload_json")
  policySnapshot    Json?                          @map("policy_snapshot")
  status            SyriaMarketplaceApprovalStatus @default(PENDING)
  requestedByUserId String?                        @map("requested_by_user_id")
  decidedByUserId   String?                        @map("decided_by_user_id")
  decidedAt         DateTime?                      @map("decided_at")
  notes             String?                        @db.Text
  createdAt         DateTime                       @default(now()) @map("created_at")
  updatedAt         DateTime                       @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@map("syria_marketplace_autonomy_approvals")
}

model SyriaMarketplaceAutonomyAuditLog {
  id          String   @id @default(cuid())
  runId       String?  @map("run_id")
  eventType   String   @map("event_type")
  payloadJson Json     @default("{}") @map("payload_json")
  actorUserId String?  @map("actor_user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([runId])
  @@index([eventType, createdAt])
  @@map("syria_marketplace_autonomy_audit_logs")
}

model SyriaMarketplaceAutonomyActionRecord {
  id             String                       @id @default(cuid())
  runId          String?                      @map("run_id")
  approvalId     String?                      @map("approval_id")
  actionType     String                       @map("action_type")
  targetEntityId String?                      @map("target_entity_id")
  dryRun         Boolean                      @default(true) @map("dry_run")
  outcome        SyriaMarketplaceActionOutcome @default(DRY_RUN)
  detailJson     Json?                        @map("detail_json")
  rollbackOfId   String?                      @map("rollback_of_id")
  createdAt      DateTime                     @default(now()) @map("created_at")

  @@index([runId])
  @@index([approvalId])
  @@map("syria_marketplace_autonomy_action_records")
}

model SyriaMarketplaceOutcomeFeedbackRollup {
  id          String   @id @default(cuid())
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  rollupJson  Json     @default("{}") @map("rollup_json")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([periodEnd])
  @@map("syria_marketplace_outcome_feedback_rollups")
}

/// Safe autonomy — recommendations only; no auto messaging / pricing / payout.
model SyriaAutonomyRecommendation {
  id           String                           @id @default(cuid())
  propertyId   String?                          @map("property_id")
  property     SyriaProperty?                   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  userId       String?                          @map("user_id")
  user         SyriaAppUser?                    @relation("AutonomyOwner", fields: [userId], references: [id], onDelete: SetNull)
  actionType   String                           @map("action_type")
  status       SyriaAutonomyRecommendationStatus @default(PENDING)
  payload      Json                             @default("{}")
  autonomyMode String                           @map("autonomy_mode")
  explanation  String?                          @db.Text
  resolvedAt   DateTime?                        @map("resolved_at")
  createdAt    DateTime                         @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@index([propertyId])
  @@map("syria_autonomy_recommendations")
}
