// Syria platform — isolated tables (`syria_*`). Same DATABASE_URL as rest of monorepo; no overlap with apps/web schema.
// SYBNB (app): `apps/syria/src/lib/sybnb/*` + `components/sybnb/*` + `app/api/sybnb/*`. Stay flows use `ListingReport`
// (`sybnb_listing_reports`) + `SyriaBooking`; `SybnbBooking` is reserved for future dedicated flows beyond MVP.
generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
  output     = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SyriaUserRole {
  USER
  HOST
  ADMIN
}

/// SYBNB: operator review for short-stay supply (trust gate before browse).
enum SyriaSybnbListingReview {
  PENDING
  APPROVED
  REJECTED
}

/// SYBNB 2.0 — request / payment / settlement lifecycle (see `SybnbBooking`).
/// SYBNB-1 (no card payment) uses: `requested` | `approved` | `declined` | `cancelled` | `completed` — other values reserved for later phases.
enum SybnbBookingStatus {
  requested
  approved
  payment_pending
  paid
  confirmed
  declined
  cancelled
  completed
  refunded
  needs_review
}

/// Guest-side payment. SYBNB-1: `none` (request) then `manual_required` after host approves; card states unused until checkout ships.
enum SybnbGuestPaymentState {
  none
  pending
  paid
  failed
  refunded
  manual_required
}

enum SybnbRiskState {
  clear
  review
  blocked
}

/// SYBNB-35 — field-agent commission ledger (paid from platform fee share).
enum SybnbAgentEarningStatus {
  pending
  approved
  paid
}

enum SyriaPropertyType {
  SALE
  RENT
  BNHUB
  HOTEL
}

enum SyriaPropertyStatus {
  DRAFT
  PENDING_REVIEW
  /// ORDER SYBNB-84 — ≥5 cumulative reports (trust gate); hidden from public browse feeds until cleared by ops.
  NEEDS_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

/// Listing marketing tier. `hotel_featured` = SYBNB-41 manual hotel subscription (rank ≥ premium in sort).
enum SyriaListingPlan {
  free
  featured
  premium
  hotel_featured
}

enum SyriaBookingStatus {
  /// Guest requested dates; host has not decided.
  PENDING
  /// Host approved; guest must pay (card) or settle manually.
  APPROVED
  /// Paid (or admin-verified manual) & reservation locked.
  CONFIRMED
  /// Stay window ended (SYBNB post-checkout).
  COMPLETED
  CANCELLED
}

enum SyriaBookingPaymentStatus {
  UNPAID
  PENDING_MANUAL
  PAID
  HELD
}

enum SyriaPayoutLedgerStatus {
  PENDING
  APPROVED
  PAID
}

enum SyriaListingPaymentPurpose {
  LISTING_FEE
  FEATURED
  PREMIUM
  BNHUB_LISTING
  OTHER
}

enum SyriaListingPaymentStatus {
  PENDING
  VERIFIED
  FAILED
}

/// Manual-friendly payment rails (no Stripe assumption).
enum SyriaPaymentMethod {
  MANUAL_TRANSFER
  CASH
  LOCAL_GATEWAY_PLACEHOLDER
}

enum SyriaPromotionZone {
  HOME
  CATEGORY
  CITY
  SEARCH_BOOST
}

enum SyriaAutonomyRecommendationStatus {
  PENDING
  DISMISSED
  ACKNOWLEDGED
}

enum SyriaMarketplaceApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUPERSEDED
}

enum SyriaMarketplaceAutonomyRunStatus {
  RUNNING
  COMPLETED
  FAILED
  BLOCKED
}

enum SyriaMarketplaceActionOutcome {
  BLOCKED
  DRY_RUN
  EXECUTED
  FAILED
  ROLLED_BACK
  SKIPPED_APPROVAL_PENDING
}

/// ORDER SYBNB-52 — Hotel CRM pipeline (admin-only).
enum SybnbHotelLeadStatus {
  new
  contacted
  interested
  onboarded
  active
  paying
  lost
}

model SyriaAppUser {
  id        String        @id @default(cuid())
  email     String        @unique
  name      String?
  phone     String?
  /// S1: set when phone verified via SMS/WhatsApp OTP (soft trust).
  phoneVerifiedAt DateTime?            @map("phone_verified_at")
  /// ORDER SYBNB-96 — mirror flag; kept in sync with `phoneVerifiedAt` when OTP succeeds.
  phoneVerified   Boolean              @default(false) @map("phone_verified")
  /// ORDER SYBNB-96 — pending OTP (sha256 hex of digits); cleared after verify / resend.
  phoneCode       String?              @map("phone_code")
  phoneCodeExpiry DateTime?            @map("phone_code_expiry")
  /// SYBNB general trust time — set/updated with phone or ID verification.
  verifiedAt    DateTime?  @map("verified_at")
  /// "phone" | "id" — strongest verification achieved.
  verificationLevel String? @map("verification_level")
  /// SYBNB: when true, new listings are hidden from public feed (abuse; ≥5 valid reports, etc.).
  sybnbSupplyPaused Boolean @default(false) @map("sybnb_supply_paused")
  /// ORDER SYBNB-98 — aggregate trust score (`computeReputationScoreFromAggregates` / displayed tier on listings).
  reputationScore  Int     @default(0) @map("reputation_score")
  /// SYBNB / trust: account-level abuse or sanctions flag (hide from book flows in UI if needed).
  flagged            Boolean @default(false)
  /// SYBNB: simple trust band (0–100). Stored value only — updated on lifecycle events (`src/lib/sybnb/trust-score.ts`), not recomputed in requests.
  trustScore Int @default(50) @map("trust_score")
  /// SYBNB / trust: lightweight abuse score (rules-only; no AI). Updated via `src/lib/sybnb/fraud-score.ts`.
  fraudScore Int @default(0) @map("fraud_score")
  /// Set when score crosses threshold or manual admin action — blocks new booking requests.
  fraudFlag Boolean @default(false) @map("fraud_flag")
  role      SyriaUserRole @default(USER)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  /// Investor-demo seed only: `{"demo":true,"source":"investor-demo"}` — excluded from prod metrics/alerts when set.
  demoMeta Json? @map("demo_meta")
  /// ORDER SYBNB-108 — full platform test mode synthetic users (never mixed into prod KPIs when excluded).
  isTest Boolean @default(false) @map("is_test")

  propertiesOwned       SyriaProperty[]           @relation("PropertyOwner")
  phoneOtps                 SyriaPhoneOtp[]
  listingReportsFiled   SyriaListingReport[]      @relation("ListingReportReporter")
  bookingsAsGuest       SyriaBooking[]            @relation("BookingGuest")
  payoutsReceived       SyriaPayout[]             @relation("PayoutHost")
  listingPayments       SyriaListingPayment[]
  inquiriesSubmitted    SyriaInquiry[]
  reviewedListingPayments   SyriaListingPayment[]           @relation("ListingPaymentReviewer")
  autonomyRecommendations   SyriaAutonomyRecommendation[]   @relation("AutonomyOwner")
  sybnbBookingsAsGuest  SybnbBooking[]            @relation("SybnbGuestBookings")
  sybnbBookingsAsHost   SybnbBooking[]            @relation("SybnbHostBookings")
  sybnbPaymentAudits    SybnbPaymentAudit[]
  stayReportsFiled       ListingReport[]       @relation("ListingReportStayReporter")
  sybnbAnalyticsEvents  SybnbEvent[]             @relation("SybnbAnalyticsEventActor")
  sybnbFieldAgentAttributions SyriaProperty[]   @relation("SybnbListingFieldAgent")
  sybnbAgentEarnings      SybnbAgentEarning[]      @relation("SybnbAgentEarningAgent")
  sybnbReminderDeliveries SybnbReminderLog[]       @relation("SybnbReminderRecipient")
  sybnbMessagesSent       SybnbMessage[]           @relation("SybnbMessageSender")

  @@index([isTest])
  @@map("syria_users")
}

model SyriaInquiry {
  id          String        @id @default(cuid())
  propertyId  String        @map("property_id")
  property    SyriaProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  fromUserId  String?       @map("from_user_id")
  fromUser    SyriaAppUser? @relation(fields: [fromUserId], references: [id], onDelete: SetNull)
  name        String
  phone       String?
  message     String?       @db.Text
  utmSource   String?       @map("utm_source")
  utmMedium   String?       @map("utm_medium")
  utmCampaign String?       @map("utm_campaign")
  createdAt   DateTime      @default(now()) @map("created_at")

  @@index([propertyId])
  @@index([fromUserId, createdAt])
  @@map("syria_inquiries")
}

model SyriaProperty {
  id               String              @id @default(cuid())
  titleAr          String              @map("title_ar")
  titleEn          String?             @map("title_en")
  descriptionAr    String              @map("description_ar") @db.Text
  descriptionEn    String?             @map("description_en") @db.Text
  price            Decimal             @db.Decimal(14, 2)
  /// Nightly rate for `category = stay` (SYBNB); optional; `price` should mirror for sort/filters.
  pricePerNight    Int?                @map("price_per_night")
  currency         String              @default("SYP")
  type             SyriaPropertyType
  /// Syrian governorate — English label from `SYRIA_STATES` (structured filter + display).
  state            String              @default("") @map("state")
  /// Canonical governorate `name_en` from `syriaLocations` (search + display).
  governorate      String?             @map("governorate")
  /// Legacy search key: English city name from catalog (kept for filters and URL).
  city             String
  /// Bilingual display: Arabic city label (optional; backfilled from catalog in new listings).
  cityAr           String?             @map("city_ar")
  /// Bilingual display: English city label (optional; often matches `city`).
  cityEn           String?             @map("city_en")
  /// Legacy: area / district (often Arabic from catalog or custom text).
  area             String?             @map("area")
  /// Bilingual district (optional; may mirror `area` for AR).
  districtAr       String?             @map("district_ar") @db.Text
  districtEn       String?             @map("district_en") @db.Text
  /// Google place name or user text when a place was used to set the pin (optional).
  placeName        String?             @map("place_name")
  addressText      String?             @map("address_text") @db.Text
  /// Free-form location notes (optional; no street / GPS required).
  addressDetails   String?             @map("address_details") @db.Text
  latitude         Float?              @map("latitude")
  longitude        Float?              @map("longitude")
  /// Data URLs or external URLs (MVP: client-compressed base64; max 5 in quick post).
  images           String[]            @default([]) @map("images")
  /// Feature keys from `SYRIA_AMENITIES` (e.g. `wifi`, `furnished`).
  amenities        String[]            @default([]) @map("amenities")
  /// Simple public view counter; incremented with ORDER SYBNB-126 dedupe (30m / viewer fingerprint).
  views            Int                 @default(0) @map("views")
  /// ORDER SYBNB-126 — lifetime distinct viewers (first fingerprint only).
  uniqueViews      Int                 @default(0) @map("unique_views")
  /// Leads: taps on owner WhatsApp (listing contact), best-effort increment.
  whatsappClicks   Int                 @default(0) @map("whatsapp_clicks")
  /// Leads: taps on owner phone (tel), best-effort increment.
  phoneClicks      Int                 @default(0) @map("phone_clicks")
  /// Short-stay (BNHUB): `YYYY-MM-DD` dates that are **booked** / not available. Absent dates = available.
  availability     String[]            @default([]) @map("availability")
  /// SYBNB: admin/host trust gate; only APPROVED stay listings show in /sybnb feed.
  sybnbReview      SyriaSybnbListingReview @default(PENDING) @map("sybnb_review")
  /// Listing seller — ORDER SYBNB-94: always the authenticated publisher (`SyriaAppUser.id`).
  ownerId          String              @map("owner_id")
  owner            SyriaAppUser        @relation("PropertyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  /// SYBNB-27: optional field agent credited with onboarding this stay listing (manual ops payout — not the host).
  sybnbAgentUserId String?             @map("sybnb_agent_user_id")
  sybnbAgent       SyriaAppUser?       @relation("SybnbListingFieldAgent", fields: [sybnbAgentUserId], references: [id], onDelete: SetNull)
  status           SyriaPropertyStatus @default(DRAFT)
  /// Marketing tier: `free` (default) and `featured` (manual admin flag or verified payment). `premium` is legacy/optional.
  /// Browse sort: plan descending → featured listings surface before free.
  plan             SyriaListingPlan    @default(free) @map("plan")
  fraudFlag        Boolean             @default(false) @map("fraud_flag")
  /// S1: ≥3 user reports — queued for admin (with status PENDING_REVIEW).
  needsReview      Boolean             @default(false) @map("needs_review")
  /// Admin/manual "Verified" — UI badge only; no auto logic.
  listingVerified  Boolean             @default(false) @map("listing_verified")
  /// SY-11: explicit trust / marketplace verification (operator-set).
  verified         Boolean             @default(false) @map("verified")
  isFeatured       Boolean             @default(false) @map("is_featured")
  featuredUntil    DateTime?           @map("featured_until")
  featuredPriority Int                 @default(0) @map("featured_priority")
  neighborhood     String?             @map("neighborhood")
  bedrooms         Int?
  bathrooms        Int?
  furnished        Boolean?
  propertyCategory String?             @map("property_category")
  /// Marketplace vertical (full Hadiah): `real_estate` | `cars` | `electronics` | …
  category         String              @default("real_estate") @map("marketplace_category")
  subcategory      String              @default("sale") @map("marketplace_subcategory")
  /// Ad Studio template: `price` | `highlight` | `clean` (optional).
  adStyle          String?             @map("ad_style")
  /// SY-22: direct owner deal (no broker) — `true` is default; boosts sort and trust UI.
  isDirect         Boolean             @default(true) @map("is_direct")
  guestsMax        Int?                @map("guests_max")
  /// SY-28: human-friendly listing code, e.g. RE-1001 (global number + category prefix).
  adCode           String              @unique @map("ad_code")
  /// SYBNB: stay subtype — stay | apartment | room | villa | chalet (optional).
  sybnbStayType    String?             @map("sybnb_stay_type")
  /// SYBNB-39: optional hotel identity + ops fields when `type = HOTEL`.
  hotelName           String?   @map("hotel_name") @db.Text
  roomsAvailable      Int?      @map("rooms_available")
  /// Listing-specific phone override (hotels + ORDER SYBNB-92 seller contact prefs).
  contactPhone        String?   @map("contact_phone")
  contactEmail        String?   @map("contact_email")
  allowPhone          Boolean   @default(true) @map("allow_phone")
  allowWhatsApp       Boolean   @default(true) @map("allow_whatsapp")
  allowEmail          Boolean   @default(false) @map("allow_email")
  allowMessages       Boolean   @default(true) @map("allow_messages")
  receptionAvailable  Boolean?  @map("reception_available")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  /// Investor-demo seed marker — excluded from aggregate fraud/payment metrics when set.
  demoMeta Json? @map("demo_meta")
  /// Denormalized SY8/SYBNB feed boost: location richness + verified seller + ≥1 booking. Recomputed on listing save and booking create.
  sy8FeedRankScore Int                 @default(0) @map("sy8_feed_rank_score")
  /// SYBNB-42 — Browse tier for stay search (4 = verified subscribed hotels … 0 = fraud-flagged). Recomputed with `sy8FeedRankScore`.
  sybnbBrowseTier  Int                 @default(1) @map("sybnb_browse_tier")
  /// ORDER SYBNB-65 — cached image count for ORDER BY tie-break (`score DESC`, `images DESC`, `createdAt DESC`). Synced in `recomputeSy8FeedRankForPropertyId`.
  listingPhotoCount Int                @default(0) @map("listing_photo_count")
  /// ORDER SYBNB-93 — low-tier public post without establishing a browser session (guest owner by phone).
  isAnonymous      Boolean             @default(false) @map("is_anonymous")
  /// ORDER SYBNB-93 — `bicycle` | `basic_item` | … for analytics / policy.
  postingKind      String?             @map("posting_kind")
  /// ORDER SYBNB-97 — UTC date key (`YYYY-MM-DD`) for daily phone reveal tallies.
  phoneRevealDayUtc        String?    @map("phone_reveal_day_utc")
  phoneRevealCountDay      Int        @default(0) @map("phone_reveal_count_day")
  /// ORDER SYBNB-97 — hide phone/WhatsApp until this time after abnormal reveal volume.
  phoneRevealCooldownUntil DateTime?  @map("phone_reveal_cooldown_until")
  /// ORDER SYBNB-99 — declared identity on high-value real-estate listings (owner vs mandate).
  ownerName             String?    @map("owner_name")
  ownerPhone            String?    @map("owner_phone")
  isOwner               Boolean    @default(false) @map("is_owner")
  hasMandate            Boolean    @default(false) @map("has_mandate")
  mandateDocumentUrl    String?    @map("mandate_document_url")
  ownershipVerified     Boolean    @default(false) @map("ownership_verified")
  /// ORDER SYBNB-100 — at least one proof document on file (badge + trust; URLs not public).
  proofDocumentsSubmitted Boolean  @default(false) @map("proof_documents_submitted")
  /// ORDER SYBNB-101 — admin asked seller for clearer deed/proof uploads.
  ownershipMoreDocsRequestedAt DateTime? @map("ownership_more_docs_requested_at")
  /// ORDER SYBNB-101 — internal ops note (reject / request-docs context).
  ownershipVerificationReviewNote String? @db.Text @map("ownership_verification_review_note")
  /// ORDER SYBNB-108 — synthetic listing rows when `SYBNB_TEST_MODE=true` (excluded from public feeds).
  isTest Boolean @default(false) @map("is_test")

  propertyDocuments         PropertyDocument[]
  bookings                  SyriaBooking[]
  listingPayments           SyriaListingPayment[]
  inquiries                 SyriaInquiry[]
  listingMessages           ListingMessage[]
  featuredPlacements        SyriaFeaturedPlacement[]
  autonomyRecommendations   SyriaAutonomyRecommendation[]
  paymentRequestsF1         SyriaPaymentRequest[]   @relation("PropertyPaymentRequest")
  listingFinanceF1          SyriaListingFinance?   @relation("PropertyListingFinance")
  listingReports            SyriaListingReport[]    @relation("PropertyReports")
  sybnbImages               SybnbListingImage[]
  sybnbBookings             SybnbBooking[]
  stayListingReports       ListingReport[]       @relation("ListingReportStayOnProperty")
  sybnbAnalyticsEvents      SybnbEvent[]
  listingViewVisits         SyriaListingViewVisit[]

  @@index([sybnbAgentUserId])
  @@index([city])
  @@index([state])
  @@index([governorate])
  @@index([type])
  @@index([status])
  @@index([isDirect])
  @@index([category, subcategory])
  @@index([category])
  @@index([status, needsReview, createdAt])
  @@index([sy8FeedRankScore, createdAt])
  @@index([sybnbBrowseTier, sy8FeedRankScore])
  @@index([isTest])
  @@map("syria_properties")
}

/// ORDER SYBNB-126 — dedupe raw refreshes: one counted view per viewerKey within rolling 30 minutes.
model SyriaListingViewVisit {
  id         String        @id @default(cuid())
  propertyId String        @map("property_id")
  property   SyriaProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  /// `u:<syriaAppUserId>` or `ip:<clientIp>`
  viewerKey  String        @map("viewer_key") @db.VarChar(160)
  lastSeenAt DateTime      @map("last_seen_at")

  @@unique([propertyId, viewerKey])
  @@index([propertyId])
  @@map("syria_listing_view_visits")
}

/// ORDER SYBNB-100 — property legitimacy proofs (stored privately; only badge is public).
model PropertyDocument {
  id         String        @id @default(cuid())
  propertyId String        @map("property_id")
  property   SyriaProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  /// Stable key from `PROPERTY_DOCUMENT_TYPE_KEYS` (e.g. green_record).
  type       String
  /// Cloudinary HTTPS URL — never exposed on public listing/API responses.
  url        String
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([propertyId])
  @@map("property_documents")
}

/// ORDER SYBNB-95 — lightweight guest→seller messages (no phone call required).
model ListingMessage {
  id          String        @id @default(cuid())
  listingId   String        @map("listing_id")
  listing     SyriaProperty @relation(fields: [listingId], references: [id], onDelete: Cascade)
  senderName  String?       @map("sender_name")
  senderPhone String?       @map("sender_phone")
  message     String        @db.Text
  createdAt   DateTime      @default(now()) @map("created_at")

  @@index([listingId])
  @@map("listing_messages")
}

/// S1: short-lived phone verification code (hashed at rest).
model SyriaPhoneOtp {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  user      SyriaAppUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String       @map("code_hash")
  expiresAt DateTime     @map("expires_at")
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("syria_phone_otp")
}

/// S1: user report on a listing (fraud, wrong price, duplicate).
model SyriaListingReport {
  id         String        @id @default(cuid())
  propertyId String        @map("property_id")
  property   SyriaProperty @relation("PropertyReports", fields: [propertyId], references: [id], onDelete: Cascade)
  reporterId String?       @map("reporter_id")
  reporter   SyriaAppUser? @relation("ListingReportReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  /// "fraud" | "wrong_price" | "duplicate"
  reason     String
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([propertyId])
  @@index([createdAt])
  @@map("syria_listing_reports")
}

/// SYBNB: ordered image URLs (optional; parallel to `images` on `SyriaProperty`).
model SybnbListingImage {
  id         String        @id @default(cuid())
  propertyId String        @map("property_id")
  property   SyriaProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  url        String
  sortOrder  Int           @default(0) @map("sort_order")
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([propertyId])
  @@map("sybnb_listing_images")
}

/// SYBNB 2.0 short-stay booking (new flow; `SyriaBooking` remains for BNHUB).
model SybnbBooking {
  id        String   @id @default(cuid())
  listingId String   @map("listing_id")
  listing   SyriaProperty @relation(fields: [listingId], references: [id], onDelete: Cascade)
  guestId   String   @map("guest_id")
  guest     SyriaAppUser  @relation("SybnbGuestBookings", fields: [guestId], references: [id], onDelete: Cascade)
  hostId    String   @map("host_id")
  host      SyriaAppUser  @relation("SybnbHostBookings", fields: [hostId], references: [id], onDelete: Cascade)

  checkIn  DateTime @map("check_in")
  checkOut DateTime @map("check_out")
  guests   Int

  nightlyPrice Int @map("nightly_price")
  nights       Int
  serviceFee   Int    @default(0) @map("service_fee")
  totalAmount  Int    @map("total_amount")
  currency     String @default("SYP")

  /// Optimistic locking — incremented on each successful mutation (approve/decline/confirm, lifecycle, etc.).
  version Int @default(1)

  status        SybnbBookingStatus     @default(requested) @map("status")
  paymentStatus SybnbGuestPaymentState @default(none) @map("payment_status")

  paymentProvider   String? @map("payment_provider")
  paymentIntentId   String? @map("payment_intent_id")
  checkoutSessionId String? @map("checkout_session_id")

  riskScore  Int            @default(0) @map("risk_score")
  riskStatus SybnbRiskState @default(clear) @map("risk_status")

  manualRef String? @map("manual_ref")
  proofUrl  String? @map("proof_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  /// Set when host approves the SYBNB-1 request (manual payment phase begins).
  approvedAt DateTime? @map("approved_at")
  /// Simulated escrow UX only — `none` | `simulated_pending` | `simulated_secured` | `simulated_released` (no PSP / no real funds).
  sybnbSimulatedEscrowStatus String? @map("sybnb_simulated_escrow_status")
  /// ORDER SYBNB-108 — mirrors listing/test flow for cleanup (`SYBNB_TEST_MODE`).
  isTest Boolean @default(false) @map("is_test")

  paymentAudits SybnbPaymentAudit[]
  reminderLogs  SybnbReminderLog[]
  sybnbMessages SybnbMessage[]

  @@index([listingId])
  @@index([guestId])
  @@index([hostId])
  @@index([status])
  @@index([isTest])
  @@index([approvedAt])
  @@map("sybnb_bookings")
}

/// Cron-delivered reminder log (append-only). Rate-limit enforced in application (24h per booking/type/recipient).
model SybnbReminderLog {
  id               String       @id @default(cuid())
  bookingId        String       @map("booking_id")
  booking          SybnbBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reminderType     String       @map("reminder_type")
  recipientUserId  String       @map("recipient_user_id")
  recipient        SyriaAppUser @relation("SybnbReminderRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  sentAt           DateTime     @default(now()) @map("sent_at")

  @@index([bookingId, reminderType, recipientUserId, sentAt])
  @@map("sybnb_reminder_log")
}

/// Client-generated idempotency keys for unified offline sync (`sybnb_sync_queue`).
/// Composite PK `(client_request_id, client_id)` prevents unsafe cross-device replay of the same synthetic key.
model SybnbSyncIdempotency {
  clientRequestId String @map("client_request_id") @db.VarChar(128)
  clientId        String @default("__legacy__") @map("client_id") @db.VarChar(128)
  userId          String @map("user_id")
  kind            String @db.VarChar(32)
  bookingId       String @map("booking_id")
  createdAt       DateTime @default(now()) @map("created_at")

  @@id([clientRequestId, clientId])
  @@index([userId])
  @@index([bookingId])
  @@map("sybnb_sync_idempotency")
}

/// In-platform booking chat (SYBNB 2.0). Append-only; no external delivery.
model SybnbMessage {
  id        String   @id @default(cuid())
  bookingId String   @map("booking_id")
  senderId  String   @map("sender_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  /// Advisory risk from {@link analyzeMessage} — `low` | `medium` | `high`.
  riskLevel String?  @map("risk_level")
  /// JSON string array of flags — `phone` | `email` | `link` | `external_payment`.
  riskFlags Json?    @map("risk_flags")
  /// Client UUID for offline send dedup; unique per booking + sender when set (`sybnb_messages_booking_sender_client_uidx`).
  clientId String? @map("client_id")

  booking SybnbBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender  SyriaAppUser @relation("SybnbMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([bookingId, createdAt])
  @@map("sybnb_messages")
}

/// Append-only SYBNB booking lifecycle audit (request / approve / decline). No PII in metadata.
model SybnbAuditLog {
  id        String   @id @default(cuid())
  action    String
  bookingId String?  @map("booking_id")
  userId    String?  @map("user_id")
  actorRole String?  @map("actor_role")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([bookingId])
  @@index([userId])
  @@map("sybnb_audit_log")
}

/// ORDER SYBNB-84 — Guest-submitted SYBNB report (`listing_id` = `SyriaProperty.id`).
model ListingReport {
  id         String        @id @default(cuid())
  listingId  String        @map("property_id")
  listing    SyriaProperty @relation("ListingReportStayOnProperty", fields: [listingId], references: [id], onDelete: Cascade)
  reporterId String?       @map("reporter_id")
  reporter   SyriaAppUser? @relation("ListingReportStayReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  reason     String
  reviewed   Boolean       @default(false)
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([listingId])
  @@index([reviewed])
  @@map("sybnb_listing_reports")
}

/// SYBNB payment / checkout audit (append-only).
model SybnbPaymentAudit {
