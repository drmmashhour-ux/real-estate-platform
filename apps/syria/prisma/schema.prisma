/// SYBNB-10 lightweight analytics (append-only). Emitted from server actions + `POST /api/sybnb/events` (listing views).
model SybnbEvent {
  id        String         @id @default(cuid())
  /// e.g. listing_view | booking_request | booking_approved | report_submitted
  type      String         @map("type")
  listingId String?        @map("listing_id")
  listing   SyriaProperty? @relation(fields: [listingId], references: [id], onDelete: SetNull)
