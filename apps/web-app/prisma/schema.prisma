generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Platform ecosystem roles (see docs/PLATFORM_ROLES.md)
enum PlatformRole {
  USER                 // People searching for property, experiences, or professional guidance
  LICENSED_PROFESSIONAL // Verified brokers and real estate professionals under regulatory frameworks
  OWNER_HOST           // Property owners offering rental or sale opportunities
  INVESTOR             // Participants seeking investment opportunities or partnerships
}

// Account status for fraud / trust & safety
enum AccountStatus {
  ACTIVE     // Normal
  RESTRICTED // Cannot publish listings, withdraw funds; under review
  SUSPENDED  // Temporary suspension; stricter than restricted
  BANNED     // Permanent; cannot use platform
}

// ---------------------------------------------------------------------------
// BNHub (short-term rental) enums
// ---------------------------------------------------------------------------
enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

// Property ownership verification (land register / cadastre)
enum ListingAuthorityType {
  OWNER
  BROKER
}

enum ListingVerificationStatus {
  DRAFT                // Not yet submitted for verification
  PENDING_VERIFICATION // Documents submitted, awaiting admin review
  PENDING_DOCUMENTS    // Admin requested more documents; lister can resubmit
  VERIFIED             // Ownership/broker authorization confirmed (cadastre + identity + location)
  REJECTED             // Verification failed
}

enum PropertyDocumentType {
  LAND_REGISTRY_EXTRACT
  BROKER_AUTHORIZATION
}

enum BookingStatus {
  PENDING                // Awaiting payment
  AWAITING_HOST_APPROVAL // Request sent, host must approve or decline
  CONFIRMED
  DECLINED               // Host declined
  CANCELLED_BY_GUEST
  CANCELLED_BY_HOST
  CANCELLED              // Legacy / admin cancellation
  COMPLETED
  DISPUTED
}

enum ListingStatus {
  DRAFT                 // Not visible in search
  PUBLISHED             // Live and searchable
  UNLISTED              // Temporarily hidden
  SUSPENDED             // Admin action
  UNDER_INVESTIGATION   // Fraud suspected; removed from public; admin review
  FROZEN                // Explicit freeze (same visibility as under_investigation)
  REJECTED_FOR_FRAUD   // Fraud confirmed; listing rejected
  PERMANENTLY_REMOVED  // Permanently removed for fraud
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model User {
  id                 String             @id @default(uuid())
  email              String             @unique
  passwordHash       String?            @map("password_hash") // Optional: demo users may have no password
  role               PlatformRole       @default(USER)
  accountStatus      AccountStatus      @default(ACTIVE) @map("account_status")
  name               String?
  phone              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  properties         Property[]
  shortTermListings  ShortTermListing[]
  bookingsAsGuest    Booking[]
  reviewsGiven       Review[]
  hostQuality        HostQuality?
  referralsGiven     Referral[]          @relation("Referrer")
  referralsUsed     Referral[]          @relation("Referree")
  bookingMessagesSent BookingMessage[]
  identityVerifications IdentityVerification[]
  brokerVerifications   BrokerVerification[]
  brokerActivityScores BrokerActivityScore[]
  transactionsAsBuyer   RealEstateTransaction[] @relation("TransactionBuyer")
  transactionsAsSeller  RealEstateTransaction[] @relation("TransactionSeller")
  transactionsAsBroker  RealEstateTransaction[] @relation("TransactionBroker")
  transactionMessagesSent TransactionMessage[]
  propertyOffersAsBuyer  PropertyOffer[]
  counterOffersCreated   PropertyCounterOffer[]
  hostAccountWarnings    HostAccountWarning[]
  listingEnforcementActions ListingEnforcementAction[]
  hostRiskHistory       HostRiskHistory[]
  trustSafetyIncidentsReported TrustSafetyIncident[]  @relation("IncidentReporter")
  trustSafetyIncidentsAccused  TrustSafetyIncident[]  @relation("IncidentAccused")
  userSafetyProfile     UserSafetyProfile?
  trustSafetyAppealsSubmitted TrustSafetyAppeal[]
  identityLinks               IdentityLink[]
  generatedDocuments          GeneratedDocument[]
  closingPackagesGenerated    ClosingPackage[]
}

model Property {
  id              String   @id @default(uuid())
  price           Int
  city            String
  address         String
  beds            Int
  baths           Float
  sqft            Int
  propertyType    String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  ownerId         String
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// BNHub: Short-term rental listings
// ---------------------------------------------------------------------------
model ShortTermListing {
  id                       String             @id @default(uuid())
  title                    String
  subtitle                 String?
  description              String?
  propertyType             String?            // e.g. House, Apartment, Villa
  roomType                 String?            // e.g. Entire place, Private room
  category                 String?            // e.g. Vacation rental
  address                  String
  city                     String
  region                   String?            // State / region
  country                  String             @default("US")
  latitude                 Float?
  longitude                Float?
  nightPriceCents          Int                // Base nightly price in cents
  currency                 String             @default("USD")
  maxGuests                Int                @default(4)
  bedrooms                 Int?               // Optional alias for beds
  beds                     Int
  baths                    Float
  photos                   String[]           // Legacy URLs; prefer BnhubListingPhoto for order/cover
  amenities                String[]           @default([])
  houseRules               String?
  checkInInstructions      String?            @db.Text
  checkInTime              String?            // e.g. "15:00"
  checkOutTime             String?            // e.g. "11:00"
  cancellationPolicy      String?            // flexible | moderate | strict
  cleaningFeeCents         Int                @default(0)
  securityDepositCents     Int                @default(0)
  taxRatePercent           Float?             // e.g. 10.0 for 10%
  instantBookEnabled       Boolean            @default(false)
  minStayNights            Int?               // null = no minimum
  maxStayNights            Int?
  listingStatus            ListingStatus     @default(DRAFT)
  verificationStatus      VerificationStatus @default(PENDING)
  listingAuthorityType    ListingAuthorityType? // Required when submitting for verification
  listingVerificationStatus ListingVerificationStatus @default(DRAFT)
  rejectionReason          String?
  cadastreNumber           String?
  municipality            String?            // Required with cadastre for Québec
  province                String?           // e.g. QC
  verificationDocUrl       String?           // Legacy; prefer property_documents
  verifiedAt               DateTime?
  submittedForVerificationAt DateTime?
  // Broker-only fields (when listingAuthorityType = BROKER)
  brokerLicenseNumber     String?
  brokerageName           String?
  safetyFeatures           String[]           @default([])  // e.g. Smoke detector, First aid
  accessibilityFeatures   String[]           @default([])  // e.g. Step-free access
  parkingDetails           String?
  neighborhoodDetails     String?            @db.Text
  createdAt                DateTime           @default(now()) @map("created_at")
  updatedAt                DateTime           @updatedAt @map("updated_at")
  ownerId                  String             @map("host_id")
  owner                    User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  availability             AvailabilitySlot[]
  listingPhotos            BnhubListingPhoto[]
  bookings                 Booking[]
  reviews                  Review[]
  verificationLogs         ListingVerificationLog[]
  disputes                 Dispute[]
  propertyDocuments        PropertyDocument[]
  propertyVerification     PropertyVerification?
  propertyLocationValidation PropertyLocationValidation?
  verificationMatch        VerificationMatch?
  verificationFraudAlerts  VerificationFraudAlert[]
  propertyFraudScores      PropertyFraudScore[]
  propertyFraudAlerts      PropertyFraudAlert[]
  propertyIdentityId       String?            @map("property_identity_id")
  propertyIdentity        PropertyIdentity?   @relation(fields: [propertyIdentityId], references: [id], onDelete: SetNull)
  investigations          ListingInvestigation[]
  listingSafetyProfile    ListingSafetyProfile?
  trustSafetyIncidents    TrustSafetyIncident[]

  @@index([city, verificationStatus])
  @@index([propertyIdentityId])
  @@index([ownerId])
  @@index([verificationStatus])
  @@index([listingStatus])
  @@index([city, listingStatus])
  @@index([listingVerificationStatus])
  @@index([cadastreNumber])
  @@map("bnhub_listings")
}

// BNHub listing photos: ordering and cover photo
model BnhubListingPhoto {
  id         String            @id @default(uuid())
  listingId  String
  listing    ShortTermListing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url        String
  sortOrder  Int                @default(0)
  isCover    Boolean            @default(false)
  createdAt  DateTime          @default(now())
  @@index([listingId])
}

// Audit trail for listing verification (host identity, address, photo, ownership)
model ListingVerificationLog {
  id          String   @id @default(uuid())
  listingId   String
  listing     ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  step        String   // HOST_IDENTITY | ADDRESS | PHOTO | OWNERSHIP
  status      String   // PASSED | FAILED | PENDING
  notes       String?
  createdBy   String?  // Admin/moderator user id
  createdAt   DateTime @default(now())
  @@index([listingId])
}

// Property ownership verification: uploaded land register extract / broker authorization
model PropertyDocument {
  id              String              @id @default(uuid())
  listingId       String              @map("listing_id")
  listing         ShortTermListing    @relation(fields: [listingId], references: [id], onDelete: Cascade)
  documentType    PropertyDocumentType @map("document_type")
  fileUrl         String              @map("file_url")
  cadastreNumber  String?             @map("cadastre_number") // Extracted from document (AI or manual)
  ownerName       String?             @map("owner_name")     // Extracted from document (AI or manual)
  uploadedById    String              @map("uploaded_by")
  uploadedAt      DateTime            @default(now()) @map("uploaded_at")
  documentExtractions   DocumentExtraction[]
  @@index([listingId])
  @@index([documentType])
  @@map("property_documents")
}

// AI document extraction results (cadastre, owner, address from land register PDF)
model DocumentExtraction {
  id                String   @id @default(uuid())
  documentId        String   @unique @map("document_id")
  document          PropertyDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  cadastreNumber    String?  @map("cadastre_number")
  ownerName         String?  @map("owner_name")
  propertyAddress   String?  @map("property_address")
  municipality      String?  @map("municipality")
  lotNumber         String?  @map("lot_number")
  confidenceScore   Float?   @map("confidence_score") // 0-1
  extractedAt       DateTime @default(now()) @map("extracted_at")
  rawTextSnippet    String?  @map("raw_text_snippet") @db.Text
  verificationMatch VerificationMatch?
  @@map("document_extractions")
}

enum MatchStatus {
  MATCH
  PARTIAL_MATCH
  MISMATCH
}

// Automatic matching result: extracted values vs listing
model VerificationMatch {
  id               String      @id @default(uuid())
  listingId        String      @unique @map("listing_id")
  listing          ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  documentExtractionId String   @unique @map("document_extraction_id")
  documentExtraction   DocumentExtraction @relation(fields: [documentExtractionId], references: [id], onDelete: Cascade)
  cadastreMatch    MatchStatus @map("cadastre_match")
  addressMatch     MatchStatus @map("address_match")
  ownerMatch       MatchStatus @map("owner_match")
  overallStatus    MatchStatus @map("overall_status")
  verificationScore Int        @map("verification_score") // 0-100
  checkedAt        DateTime   @default(now()) @map("checked_at")
  @@index([overallStatus])
  @@map("verification_matches")
}

// Fraud / verification alerts for admin review
model VerificationFraudAlert {
  id         String   @id @default(uuid())
  listingId  String   @map("listing_id")
  listing    ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  alertType  String   @map("alert_type") // duplicate_cadastre | owner_mismatch | address_mismatch | low_confidence
  message    String   @db.Text
  severity   String   @default("medium") // low | medium | high
  metadata   Json?    // e.g. { cadastreNumber, documentId }
  createdAt  DateTime @default(now()) @map("created_at")
  @@index([listingId])
  @@index([alertType])
  @@map("verification_fraud_alerts")
}

// Anti-fraud engine: fraud risk score per listing (0-100)
model PropertyFraudScore {
  id         String   @id @default(uuid())
  listingId  String   @map("listing_id")
  listing    ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  fraudScore Int      @map("fraud_score") // 0-100
  riskLevel  String   @map("risk_level") // low | medium | high
  reasons    Json?    // Array of { signal, points } or string[]
  createdAt  DateTime @default(now()) @map("created_at")
  @@unique([listingId])
  @@index([riskLevel])
  @@index([fraudScore])
  @@map("property_fraud_scores")
}

// Anti-fraud engine: alerts (duplicate, mismatch, suspicious broker, etc.)
model PropertyFraudAlert {
  id         String   @id @default(uuid())
  listingId  String   @map("listing_id")
  listing    ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  alertType  String   @map("alert_type")
  severity   String   @default("medium") // low | medium | high
  message    String   @db.Text
  status     String   @default("open")   // open | reviewed | dismissed
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  @@index([listingId])
  @@index([alertType])
  @@index([status])
  @@map("property_fraud_alerts")
}

// Broker activity monitoring (suspicious broker detection)
model BrokerActivityScore {
  id           String   @id @default(uuid())
  brokerId     String   @unique @map("broker_id")
  broker       User     @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  listingCount Int      @default(0) @map("listing_count")
  fraudFlags   Int      @default(0) @map("fraud_flags")
  riskScore    Int      @default(0) @map("risk_score") // 0-100
  updatedAt    DateTime @updatedAt @map("updated_at")
  @@map("broker_activity_scores")
}

// ---------------------------------------------------------------------------
// Property Digital Identity: one permanent identity per real property
// ---------------------------------------------------------------------------
model PropertyIdentity {
  id                String    @id @default(uuid())
  propertyUid       String    @unique @map("property_uid") // Deterministic from cadastre + normalized address + municipality + province
  cadastreNumber    String?   @map("cadastre_number")
  officialAddress   String    @map("official_address")   @db.Text
  normalizedAddress String   @map("normalized_address") @db.Text
  municipality      String?
  province          String?
  country           String    @default("US")
  postalCode        String?   @map("postal_code")
  latitude          Float?
  longitude         Float?
  propertyType      String?   @map("property_type")
  verificationScore Int?     @map("verification_score") // 0-100
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  links                    PropertyIdentityLink[]
  verifications            PropertyIdentityVerification[]
  owners                   PropertyIdentityOwner[]
  riskRecords              PropertyIdentityRisk[]
  events                   PropertyIdentityEvent[]
  shortTermListings        ShortTermListing[]
  realEstateTransactions   RealEstateTransaction[]
  propertyValuations      PropertyValuation[]
  listingAuthorities       ListingAuthority[]
  ownershipHistory         OwnershipHistory[]
  brokerAuthorizationHistory BrokerAuthorizationHistory[]
  marketRegionId           String?            @map("market_region_id")
  marketRegion             MarketRegion?     @relation(fields: [marketRegionId], references: [id], onDelete: SetNull)
  marketInvestmentScores   MarketInvestmentScore[]

  @@index([cadastreNumber])
  @@index([normalizedAddress])
  @@index([municipality, province])
  @@index([marketRegionId])
  @@map("property_identities")
}

// ---------------------------------------------------------------------------
// Real Estate Transaction Engine
// ---------------------------------------------------------------------------
model RealEstateTransaction {
  id                  String    @id @default(uuid())
  propertyIdentityId  String    @map("property_identity_id")
  propertyIdentity    PropertyIdentity @relation(fields: [propertyIdentityId], references: [id], onDelete: Restrict)
  listingId           String?   @map("listing_id") // Optional: ShortTermListing.id or future sale listing
  buyerId             String    @map("buyer_id")
  buyer               User      @relation("TransactionBuyer", fields: [buyerId], references: [id], onDelete: Restrict)
  sellerId            String    @map("seller_id")
  seller              User      @relation("TransactionSeller", fields: [sellerId], references: [id], onDelete: Restrict)
  brokerId            String?   @map("broker_id")
  broker              User?     @relation("TransactionBroker", fields: [brokerId], references: [id], onDelete: SetNull)
  offerPrice          Int?      @map("offer_price") // Cents; current agreed or latest offer
  status              String    @map("status") // offer_submitted | negotiation | offer_accepted | deposit_required | deposit_received | contract_signed | closing_in_progress | completed | cancelled
  frozenByAdmin       Boolean   @default(false) @map("frozen_by_admin")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  offers              PropertyOffer[]
  messages            TransactionMessage[]
  deposits            TransactionDeposit[]
  documents           TransactionDocument[]
  steps               TransactionStep[]
  events              TransactionEvent[]
  closingPackages     ClosingPackage[]
  timeline            TransactionTimeline?

  @@index([propertyIdentityId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([brokerId])
  @@index([status])
  @@map("real_estate_transactions")
}

model PropertyOffer {
  id              String    @id @default(uuid())
  transactionId   String    @map("transaction_id")
  transaction     RealEstateTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  buyerId         String    @map("buyer_id")
  buyer           User      @relation(fields: [buyerId], references: [id], onDelete: Restrict)
  offerPrice      Int       @map("offer_price") // Cents
  conditions      Json?     // e.g. inspection, financing
  expirationDate  DateTime? @map("expiration_date")
  status          String    @map("status") // pending | accepted | rejected | countered | expired
  createdAt       DateTime  @default(now()) @map("created_at")
  counterOffers   PropertyCounterOffer[]

  @@index([transactionId])
  @@index([buyerId])
  @@index([status])
  @@map("property_offers")
}

model PropertyCounterOffer {
  id          String   @id @default(uuid())
  offerId     String   @map("offer_id")
  offer       PropertyOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  counterPrice Int     @map("counter_price") // Cents
  notes       String?  @db.Text
  createdById String   @map("created_by")
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([offerId])
  @@map("property_counter_offers")
}

model TransactionMessage {
  id             String   @id @default(uuid())
  transactionId  String   @map("transaction_id")
  transaction    RealEstateTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  senderId       String   @map("sender_id")
  sender         User     @relation(fields: [senderId], references: [id], onDelete: Restrict)
  message        String   @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([transactionId])
  @@index([senderId])
  @@map("transaction_messages")
}

model TransactionDeposit {
  id               String   @id @default(uuid())
  transactionId    String   @map("transaction_id")
  transaction      RealEstateTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  amount           Int      @map("amount") // Cents
  paymentProvider  String   @map("payment_provider")
  paymentStatus    String   @map("payment_status") // pending | paid | refunded
  externalRef      String?  @map("external_ref")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([transactionId])
  @@index([paymentStatus])
  @@map("transaction_deposits")
}

model TransactionDocument {
  id               String    @id @default(uuid())
  transactionId    String    @map("transaction_id")
  transaction      RealEstateTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  documentType     String    @map("document_type") // purchase_agreement | broker_agreement | inspection_conditions | etc.
  fileUrl          String    @map("file_url")
  signedByBuyer    Boolean   @default(false) @map("signed_by_buyer")
  signedBySeller   Boolean   @default(false) @map("signed_by_seller")
  signedByBroker   Boolean   @default(false) @map("signed_by_broker")
  signedAt         DateTime? @map("signed_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([transactionId])
  @@index([documentType])
  @@map("transaction_documents")
}

model TransactionStep {
  id             String    @id @default(uuid())
  transactionId  String    @map("transaction_id")
  transaction    RealEstateTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  stepName       String    @map("step_name") // inspection | financing_approval | legal_review | final_payment | ownership_transfer
  status         String    @map("status") // pending | completed
  completedById  String?   @map("completed_by")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([transactionId])
  @@map("transaction_steps")
}

model TransactionEvent {
  id             String   @id @default(uuid())
  transactionId  String   @map("transaction_id")
  transaction    RealEstateTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  eventType      String   @map("event_type")
  eventData      Json?    @map("event_data")
  createdById    String?  @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([transactionId])
  @@index([eventType])
  @@map("transaction_events")
}

// ---------------------------------------------------------------------------
// Transaction Timeline Engine – lifecycle stages and steps
// ---------------------------------------------------------------------------
model TransactionTimeline {
  id                  String    @id @default(uuid())
  transactionId       String    @unique @map("transaction_id")
  transaction         RealEstateTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  propertyIdentityId  String    @map("property_identity_id")
  listingId           String?   @map("listing_id")
  buyerId             String    @map("buyer_id")
  sellerId            String    @map("seller_id")
  brokerId            String?   @map("broker_id")
  currentStage        String    @map("current_stage") // listing_live | offer_submitted | negotiation | offer_accepted | deposit_pending | deposit_received | inspection_* | financing_* | legal_documents_prepared | notary_review | closing_scheduled | closing_completed | cancelled
  status              String    @default("active") // active | blocked | completed | cancelled
  nextRequiredAction  String?   @map("next_required_action") @db.Text
  cancelledReason     String?   @map("cancelled_reason") @db.Text
  cancelledAt         DateTime? @map("cancelled_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  steps               TransactionTimelineStep[]
  events              TransactionTimelineEvent[]

  @@index([currentStage])
  @@index([status])
  @@index([buyerId])
  @@index([sellerId])
  @@index([brokerId])
  @@map("transaction_timelines")
}

model TransactionTimelineStep {
  id                String    @id @default(uuid())
  timelineId        String    @map("timeline_id")
  timeline          TransactionTimeline @relation(fields: [timelineId], references: [id], onDelete: Cascade)
  stepCode          String    @map("step_code") // e.g. offer_submit | deposit_pay | inspection_complete
  stepName          String    @map("step_name")
  stageName         String    @map("stage_name")
  status            String    @default("pending") // pending | in_progress | completed | blocked | cancelled | overdue
  assignedToRole    String?   @map("assigned_to_role") // buyer | seller | broker | admin | notary | compliance | system
  assignedToUserId  String?   @map("assigned_to_user_id")
  dueDate           DateTime? @map("due_date")
  completedAt       DateTime? @map("completed_at")
  completedByUserId String?   @map("completed_by_user_id")
  notes             String?   @db.Text
  metadata          Json?     // inspection result, financing status, etc.
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([timelineId])
  @@index([status])
  @@index([dueDate])
  @@index([assignedToRole])
  @@map("transaction_timeline_steps")
}

model TransactionTimelineEvent {
  id         String    @id @default(uuid())
  timelineId String    @map("timeline_id")
  timeline   TransactionTimeline @relation(fields: [timelineId], references: [id], onDelete: Cascade)
  eventType  String    @map("event_type") // timeline_created | offer_submitted | counter_offer_sent | deposit_received | inspection_completed | financing_approved | documents_generated | notary_assigned | closing_completed | transaction_cancelled | stage_changed | step_completed | step_blocked
  eventData  Json?     @map("event_data")
  createdBy  String?   @map("created_by")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([timelineId])
  @@index([eventType])
  @@index([createdAt])
  @@map("transaction_timeline_events")
}

model PropertyIdentityLink {
  id                 String   @id @default(uuid())
  propertyIdentityId String   @map("property_identity_id")
  propertyIdentity   PropertyIdentity @relation(fields: [propertyIdentityId], references: [id], onDelete: Cascade)
  listingId          String   @map("listing_id")
  listingType        String   @map("listing_type") // sale | long_term_rental | short_term_rental
  linkedByUserId     String   @map("linked_by_user_id")
  linkStatus         String   @map("link_status")  // pending | active | rejected | archived
  createdAt          DateTime @default(now()) @map("created_at")

  @@unique([listingId, listingType])
  @@index([propertyIdentityId])
  @@index([linkStatus])
  @@map("property_identity_links")
}

model PropertyIdentityVerification {
  id                  String    @id @default(uuid())
  propertyIdentityId  String    @map("property_identity_id")
  propertyIdentity    PropertyIdentity @relation(fields: [propertyIdentityId], references: [id], onDelete: Cascade)
  verificationType    String    @map("verification_type") // cadastre_check | land_registry_document | identity_match | broker_license_check | broker_authorization_check | geo_validation | anti_fraud_check
  verificationStatus  String    @map("verification_status") // pending | verified | rejected
  verifiedBy          String?   @map("verified_by")
  verifiedAt          DateTime? @map("verified_at")
  notes               String?   @db.Text
  createdAt           DateTime  @default(now()) @map("created_at")

  @@index([propertyIdentityId])
  @@index([verificationType])
  @@map("property_identity_verifications")
}

model PropertyIdentityOwner {
  id                 String   @id @default(uuid())
  propertyIdentityId  String   @map("property_identity_id")
  propertyIdentity   PropertyIdentity @relation(fields: [propertyIdentityId], references: [id], onDelete: Cascade)
  ownerName          String   @map("owner_name")
  ownerSource        String   @map("owner_source") // land_registry_extract | manual_admin_review | broker_authorization
  isCurrent          Boolean  @default(true) @map("is_current")
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([propertyIdentityId])
  @@map("property_identity_owners")
}

model PropertyIdentityRisk {
  id                 String   @id @default(uuid())
  propertyIdentityId String   @map("property_identity_id")
  propertyIdentity   PropertyIdentity @relation(fields: [propertyIdentityId], references: [id], onDelete: Cascade)
  riskScore          Int      @map("risk_score") // 0-100
  riskLevel          String   @map("risk_level") // low | medium | high
  riskReasons        Json?    @map("risk_reasons")
  lastEvaluatedAt    DateTime @map("last_evaluated_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([propertyIdentityId])
  @@index([riskLevel])
  @@map("property_identity_risk")
}

model PropertyIdentityEvent {
  id                 String   @id @default(uuid())
  propertyIdentityId String   @map("property_identity_id")
  propertyIdentity   PropertyIdentity @relation(fields: [propertyIdentityId], references: [id], onDelete: Cascade)
  eventType          String   @map("event_type") // identity_created | listing_linked | listing_rejected | verification_completed | fraud_flag_added | ownership_changed | manual_review_requested
  eventData          Json?    @map("event_data")
  createdBy          String?  @map("created_by")
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([propertyIdentityId])
  @@index([eventType])
  @@map("property_identity_events")
}

// ---------------------------------------------------------------------------
// Global Real Estate Identity Network
// ---------------------------------------------------------------------------
model OwnerIdentity {
  id                 String    @id @default(uuid())
  legalName          String    @map("legal_name")
  normalizedName     String    @map("normalized_name")
  verificationStatus String    @default("PENDING") @map("verification_status") // PENDING | VERIFIED | REJECTED
  primarySource      String?   @map("primary_source") // land_register_extract | manual_admin | broker_authorization | legal_document
  status             String    @default("ACTIVE") // ACTIVE | FROZEN | MERGED
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  ownershipHistory      OwnershipHistory[]
  brokerAuthHistory     BrokerAuthorizationHistory[]
  listingAuthorities    ListingAuthority[]
  @@index([normalizedName])
  @@index([verificationStatus])
  @@map("owner_identities")
}

model BrokerIdentity {
  id                 String    @id @default(uuid())
  legalName          String    @map("legal_name")
  normalizedName     String    @map("normalized_name")
  licenseNumber      String    @map("license_number")
  brokerageName      String    @map("brokerage_name")
  regulatorRef       String?   @map("regulator_ref") // e.g. OACIQ number
  verificationStatus String    @default("PENDING") @map("verification_status")
  status             String    @default("ACTIVE")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  brokerAuthorizationHistory BrokerAuthorizationHistory[]
  listingAuthorities        ListingAuthority[]
  @@index([licenseNumber])
  @@index([normalizedName])
  @@map("broker_identities")
}

model OrganizationIdentity {
  id                 String    @id @default(uuid())
  legalName          String    @map("legal_name")
  normalizedName     String    @map("normalized_name")
  organizationType   String    @map("organization_type") // brokerage | property_management | legal_entity
  verificationStatus String    @default("PENDING") @map("verification_status")
  status             String    @default("ACTIVE")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  listingAuthorities ListingAuthority[]
  @@index([normalizedName])
  @@map("organization_identities")
}

model ListingAuthority {
  id                    String    @id @default(uuid())
  propertyIdentityId    String    @map("property_identity_id")
  propertyIdentity      PropertyIdentity @relation(fields: [propertyIdentityId], references: [id], onDelete: Cascade)
  authorityType         String    @map("authority_type") // owner_self_listed | verified_broker_authorized | delegated_manager_authorized | other_platform_approved
  ownerIdentityId       String?   @map("owner_identity_id")
  ownerIdentity         OwnerIdentity?   @relation(fields: [ownerIdentityId], references: [id], onDelete: SetNull)
  brokerIdentityId      String?   @map("broker_identity_id")
  brokerIdentity        BrokerIdentity?  @relation(fields: [brokerIdentityId], references: [id], onDelete: SetNull)
  organizationIdentityId String?  @map("organization_identity_id")
  organizationIdentity  OrganizationIdentity? @relation(fields: [organizationIdentityId], references: [id], onDelete: SetNull)
  documentReference     String?   @map("document_reference")
  startDate             DateTime  @map("start_date")
  endDate               DateTime? @map("end_date")
  status                String    @default("ACTIVE") // ACTIVE | EXPIRED | REVOKED
  verificationStatus    String    @default("PENDING") @map("verification_status")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  @@index([propertyIdentityId])
  @@index([ownerIdentityId])
  @@index([brokerIdentityId])
  @@index([status])
  @@map("listing_authorities")
}

model IdentityLink {
  id           String   @id @default(uuid())
  identityType String   @map("identity_type") // OWNER | BROKER
  identityId   String   @map("identity_id")
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkStatus   String   @default("ACTIVE") @map("link_status") // ACTIVE | REVOKED
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  @@unique([identityType, identityId, userId])
  @@index([userId])
  @@index([identityType, identityId])
  @@map("identity_links")
}

model OwnershipHistory {
  id                  String    @id @default(uuid())
  propertyIdentityId  String    @map("property_identity_id")
  propertyIdentity    PropertyIdentity @relation(fields: [propertyIdentityId], references: [id], onDelete: Cascade)
  ownerIdentityId     String    @map("owner_identity_id")
  ownerIdentity       OwnerIdentity @relation(fields: [ownerIdentityId], references: [id], onDelete: Cascade)
  source               String    // land_register_extract | manual_admin | broker_authorization
  effectiveStartDate   DateTime  @map("effective_start_date")
  effectiveEndDate     DateTime?  @map("effective_end_date")
  verificationStatus  String    @map("verification_status")
  notes                String?   @db.Text
  createdAt            DateTime  @default(now()) @map("created_at")
  @@index([propertyIdentityId])
  @@index([ownerIdentityId])
  @@map("ownership_history")
}

model BrokerAuthorizationHistory {
  id                    String    @id @default(uuid())
  propertyIdentityId    String    @map("property_identity_id")
  propertyIdentity      PropertyIdentity @relation(fields: [propertyIdentityId], references: [id], onDelete: Cascade)
  brokerIdentityId      String    @map("broker_identity_id")
  brokerIdentity        BrokerIdentity @relation(fields: [brokerIdentityId], references: [id], onDelete: Cascade)
  ownerIdentityId       String?   @map("owner_identity_id")
  ownerIdentity         OwnerIdentity?  @relation(fields: [ownerIdentityId], references: [id], onDelete: SetNull)
  authorizationSource   String    @map("authorization_source")
  startDate             DateTime  @map("start_date")
  endDate               DateTime? @map("end_date")
  verificationStatus   String    @map("verification_status")
  createdAt             DateTime  @default(now()) @map("created_at")
  @@index([propertyIdentityId])
  @@index([brokerIdentityId])
  @@index([ownerIdentityId])
  @@map("broker_authorization_history")
}

model IdentityRiskProfile {
  id                  String    @id @default(uuid())
  identityType        String    @map("identity_type") // OWNER | BROKER | ORGANIZATION
  identityId          String    @map("identity_id")
  riskScore           Int       @map("risk_score") // 0-100
  riskLevel           String    @map("risk_level") // low | medium | high | critical
  riskReasons         Json?     @map("risk_reasons")
  investigationStatus String?   @map("investigation_status") // open | closed | pending_review
  updatedAt           DateTime  @updatedAt @map("updated_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  @@unique([identityType, identityId])
  @@index([identityType])
  @@index([riskLevel])
  @@map("identity_risk_profiles")
}

model IdentityEvent {
  id           String   @id @default(uuid())
  identityType String   @map("identity_type")
  identityId   String   @map("identity_id")
  eventType    String   @map("event_type")
  eventData    Json?    @map("event_data")
  createdBy    String?  @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  @@index([identityType, identityId])
  @@index([eventType])
  @@map("identity_events")
}

// OwnerIdentity and BrokerIdentity need optional riskProfile relation - IdentityRiskProfile has identityType+identityId so we can't have FK from IdentityRiskProfile to both. So IdentityRiskProfile is standalone (identityType, identityId). Remove riskProfile from OwnerIdentity and BrokerIdentity - we look up by identityType+identityId.
model PropertyValuation {
  id                      String    @id @default(uuid())
  propertyIdentityId      String    @map("property_identity_id")
  propertyIdentity        PropertyIdentity @relation(fields: [propertyIdentityId], references: [id], onDelete: Cascade)
  listingId               String?   @map("listing_id") // Optional: BNHub or sale listing
  valuationType           String    @map("valuation_type") // sale | long_term_rental | short_term_rental | investment
  estimatedValue          Int?      @map("estimated_value") // Cents for sale; null for rent-only
  valueMin                Int?      @map("value_min")
  valueMax                Int?      @map("value_max")
  monthlyRentEstimate     Int?      @map("monthly_rent_estimate") // Cents
  nightlyRateEstimate     Int?      @map("nightly_rate_estimate") // Cents
  annualRevenueEstimate   Int?      @map("annual_revenue_estimate") // Cents
  grossYieldEstimate      Float?    @map("gross_yield_estimate") // Percent
  investmentScore         Int?      @map("investment_score") // 0-100
  confidenceScore         Int       @map("confidence_score") // 0-100
  confidenceLabel         String    @map("confidence_label") // low | medium | high
  valuationSummary        String?   @map("valuation_summary") @db.Text
  explanation             Json?     // main_factors, positives, negatives, position_note, data_note
  comparablesSummary      Json?     @map("comparables_summary")
  riskLevel               String?   @map("risk_level") // low | medium | high (investment)
  seasonalitySummary      Json?     @map("seasonality_summary")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  @@index([propertyIdentityId])
  @@index([listingId])
  @@index([valuationType])
  @@index([confidenceLabel])
  @@map("property_valuations")
}

// ---------------------------------------------------------------------------
// Global Property Data Graph – semantic edges and market nodes
// ---------------------------------------------------------------------------
model Market {
  id           String   @id @default(uuid())
  city         String?
  municipality String?
  province     String
  country      String   @default("US")
  slug         String   @unique // e.g. "montreal-qc-ca" for city-level; "qc-ca" for province
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  @@index([province, country])
  @@index([slug])
  @@map("markets")
}

model PropertyGraphEdge {
  id             String   @id @default(uuid())
  fromEntityType String   @map("from_entity_type") // PROPERTY | USER | LISTING | MARKET | etc.
  fromEntityId   String   @map("from_entity_id")
  toEntityType   String   @map("to_entity_type")
  toEntityId     String   @map("to_entity_id")
  edgeType       String   @map("edge_type") // SIMILAR_TO | SAME_AREA | SAME_MARKET | SAME_BUILDING | OWNED_BY | LISTED_BY | etc.
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")
  @@index([fromEntityType, fromEntityId])
  @@index([toEntityType, toEntityId])
  @@index([edgeType])
  @@map("property_graph_edges")
}

// ---------------------------------------------------------------------------
// Market Intelligence Engine – regions, indexes, demand, investment
// ---------------------------------------------------------------------------
model MarketRegion {
  id              String    @id @default(uuid())
  name            String
  regionType      String    @map("region_type") // city | municipality | neighborhood | postal_area
  parentRegionId  String?   @map("parent_region_id")
  parentRegion    MarketRegion?  @relation("RegionHierarchy", fields: [parentRegionId], references: [id], onDelete: SetNull)
  childRegions    MarketRegion[] @relation("RegionHierarchy")
  country         String    @default("US")
  province        String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  propertyIdentities PropertyIdentity[]
  priceIndexRows  MarketPriceIndex[]
  rentIndexRows   MarketRentIndex[]
  bnhubIndexRows  MarketBnhubIndex[]
  demandMetrics   MarketDemandMetrics[]
  investmentScores MarketInvestmentScore[]
  marketReports   MarketReport[]

  @@index([regionType])
  @@index([parentRegionId])
  @@index([country, province])
  @@map("market_regions")
}

model MarketPriceIndex {
  id              String       @id @default(uuid())
  marketRegionId  String       @map("market_region_id")
  marketRegion    MarketRegion @relation(fields: [marketRegionId], references: [id], onDelete: Cascade)
  period          String       @map("period") // e.g. "2025-01" for monthly, "2025-W03" for weekly
  averagePrice    Int?         @map("average_price") // Cents
  medianPrice     Int?         @map("median_price") // Cents
  pricePerUnit    Int?         @map("price_per_unit") // Cents per sqm or sqft
  trendDirection  String?      @map("trend_direction") // up | down | stable
  sampleSize      Int?         @map("sample_size")
  createdAt       DateTime     @default(now()) @map("created_at")

  @@unique([marketRegionId, period])
  @@index([marketRegionId])
  @@index([period])
  @@map("market_price_index")
}

model MarketRentIndex {
  id              String       @id @default(uuid())
  marketRegionId  String       @map("market_region_id")
  marketRegion    MarketRegion @relation(fields: [marketRegionId], references: [id], onDelete: Cascade)
  period          String       @map("period")
  averageRent     Int?         @map("average_rent") // Cents per month
  medianRent      Int?         @map("median_rent")
  rentPerUnit     Int?         @map("rent_per_unit") // Cents per sqm/sqft per month
  trendDirection  String?      @map("trend_direction")
  sampleSize      Int?         @map("sample_size")
  createdAt       DateTime     @default(now()) @map("created_at")

  @@unique([marketRegionId, period])
  @@index([marketRegionId])
  @@index([period])
  @@map("market_rent_index")
}

model MarketBnhubIndex {
  id                    String       @id @default(uuid())
  marketRegionId        String       @map("market_region_id")
  marketRegion          MarketRegion @relation(fields: [marketRegionId], references: [id], onDelete: Cascade)
  period                String       @map("period")
  averageNightlyRate    Int?         @map("average_nightly_rate") // Cents
  averageOccupancy      Float?       @map("average_occupancy") // 0-1
  averageMonthlyRevenue Int?        @map("average_monthly_revenue") // Cents
  averageRating         Float?       @map("average_rating")
  sampleSize            Int?         @map("sample_size")
  createdAt              DateTime     @default(now()) @map("created_at")

  @@unique([marketRegionId, period])
  @@index([marketRegionId])
  @@index([period])
  @@map("market_bnhub_index")
}

model MarketDemandMetrics {
  id              String       @id @default(uuid())
  marketRegionId  String       @map("market_region_id")
  marketRegion    MarketRegion @relation(fields: [marketRegionId], references: [id], onDelete: Cascade)
  period          String       @map("period")
  demandScore     Float?       @map("demand_score") // 0-100 or normalized
  searchVolume    Int?         @map("search_volume")
  bookingVolume   Int?         @map("booking_volume")
  inventoryLevel  Int?         @map("inventory_level") // Listing count in region
  createdAt       DateTime     @default(now()) @map("created_at")

  @@unique([marketRegionId, period])
  @@index([marketRegionId])
  @@index([period])
  @@map("market_demand_metrics")
}

model MarketInvestmentScore {
  id                  String            @id @default(uuid())
  propertyIdentityId  String            @map("property_identity_id")
  propertyIdentity    PropertyIdentity  @relation(fields: [propertyIdentityId], references: [id], onDelete: Cascade)
  marketRegionId      String            @map("market_region_id")
  marketRegion        MarketRegion      @relation(fields: [marketRegionId], references: [id], onDelete: Cascade)
  investmentScore     Int               @map("investment_score") // 0-100
  riskLevel           String            @map("risk_level") // low | medium | high
  summary             String?           @db.Text
  createdAt           DateTime          @default(now()) @map("created_at")

  @@unique([propertyIdentityId, marketRegionId])
  @@index([propertyIdentityId])
  @@index([marketRegionId])
  @@map("market_investment_scores")
}

model MarketReport {
  id              String       @id @default(uuid())
  marketRegionId  String       @map("market_region_id")
  marketRegion    MarketRegion @relation(fields: [marketRegionId], references: [id], onDelete: Cascade)
  reportPeriod    String       @map("report_period") // e.g. "2025-01"
  reportSummary   String?      @map("report_summary") @db.Text
  reportData      Json?        @map("report_data")
  createdAt       DateTime     @default(now()) @map("created_at")

  @@unique([marketRegionId, reportPeriod])
  @@index([marketRegionId])
  @@index([reportPeriod])
  @@map("market_reports")
}

// ---------------------------------------------------------------------------
// Document Drafting – generated documents and versioning
// ---------------------------------------------------------------------------
model GeneratedDocument {
  id                  String    @id @default(uuid())
  documentType        String    @map("document_type") // offer | rental_agreement | broker_agreement | booking_confirmation | investment_report | verification_report | transaction_summary | dispute_report
  relatedEntityType   String    @map("related_entity_type") // transaction | property | listing | booking | dispute
  relatedEntityId     String    @map("related_entity_id")
  generatedById       String    @map("generated_by")
  generatedBy         User      @relation(fields: [generatedById], references: [id], onDelete: Restrict)
  filePath            String?   @map("file_path") // Storage path or URL
  format              String    @default("html") // html | pdf | docx
  status              String    @default("draft") // draft | final | signed
  versionNumber       Int       @default(1) @map("version_number")
  changeSummary       String?   @map("change_summary") @db.Text
  signatureFields     Json?     @map("signature_fields") // [{ signerRole, signerName, signerEmail }]
  contentHtml         String?   @map("content_html") @db.Text // Rendered HTML for preview/storage
  createdAt           DateTime  @default(now()) @map("created_at")

  @@index([documentType])
  @@index([relatedEntityType, relatedEntityId])
  @@index([generatedById])
  @@index([status])
  closingPackageDocuments ClosingPackageDocument[]
  @@map("generated_documents")
}

// ---------------------------------------------------------------------------
// Notary and Closing Integration
// ---------------------------------------------------------------------------
model Notary {
  id             String    @id @default(uuid())
  notaryName     String    @map("notary_name")
  notaryEmail    String    @map("notary_email")
  notaryOffice   String?   @map("notary_office")
  jurisdiction   String?   // e.g. Quebec, Ontario
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  closingPackages ClosingPackage[]

  @@index([jurisdiction])
  @@map("notaries")
}

model ClosingPackage {
  id             String    @id @default(uuid())
  transactionId  String    @map("transaction_id")
  transaction    RealEstateTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  packageStatus  String    @map("package_status") // draft | ready | notary_review | closing_scheduled | completed
  generatedById  String    @map("generated_by")
  generatedBy    User      @relation(fields: [generatedById], references: [id], onDelete: Restrict)
  notaryId       String?   @map("notary_id")
  notary         Notary?   @relation(fields: [notaryId], references: [id], onDelete: SetNull)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  documents      ClosingPackageDocument[]

  @@index([transactionId])
  @@index([packageStatus])
  @@index([notaryId])
  @@map("closing_packages")
}

model ClosingPackageDocument {
  id          String    @id @default(uuid())
  packageId   String    @map("package_id")
  package     ClosingPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  documentId  String    @map("document_id")
  document    GeneratedDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentType String   @map("document_type") // offer | property_sheet | buyer_info | seller_info | broker_details | transaction_summary | payment_summary | ownership_verification | broker_authorization
  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([packageId, documentType])
  @@index([packageId])
  @@map("closing_package_documents")
}

// Admin verification decision per listing (cadastre + ownership/broker check)
model PropertyVerification {
  id                  String   @id @default(uuid())
  listingId           String   @unique @map("listing_id")
  listing             ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  cadastreNumber      String   @map("cadastre_number")
  verificationStatus  VerificationStatus @map("verification_status") // VERIFIED | REJECTED
  verifiedById        String?  @map("verified_by")
  verifiedAt          DateTime? @map("verified_at")
  notes               String?  @db.Text
  requestMoreDocumentsReason String? @map("request_more_documents_reason")
  requestMoreDocumentsById   String? @map("request_more_documents_by")
  requestMoreDocumentsAt    DateTime? @map("request_more_documents_at")
  @@index([verificationStatus])
  @@map("property_verifications")
}

// Triple verification (2): identity of the lister (gov ID + selfie)
model IdentityVerification {
  id                 String            @id @default(uuid())
  userId             String            @unique @map("user_id")
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  governmentIdFileUrl String?           @map("government_id_file")
  selfiePhotoUrl     String?           @map("selfie_photo")
  verificationStatus VerificationStatus @default(PENDING) @map("verification_status")
  verifiedById       String?           @map("verified_by")
  verifiedAt         DateTime?         @map("verified_at")
  notes              String?           @db.Text
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  @@map("identity_verifications")
}

// Triple verification (3): broker license when listing_authority_type = broker
model BrokerVerification {
  id                 String            @id @default(uuid())
  userId             String            @unique @map("user_id")
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber      String            @map("license_number")
  brokerageCompany   String            @map("brokerage_company")
  verificationStatus VerificationStatus @default(PENDING) @map("verification_status")
  verifiedById       String?           @map("verified_by")
  verifiedAt         DateTime?         @map("verified_at")
  notes              String?           @db.Text
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  @@map("broker_verifications")
}

// Triple verification (4): geo-location matches cadastre address
model PropertyLocationValidation {
  id                String   @id @default(uuid())
  listingId         String   @unique @map("listing_id")
  listing           ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  latitude          Float    @map("latitude")
  longitude         Float    @map("longitude")
  address           String   @map("address")
  validationStatus  VerificationStatus @default(PENDING) @map("validation_status") // PENDING | VERIFIED | REJECTED
  validatedById     String?  @map("validated_by")
  validatedAt       DateTime? @map("validated_at")
  notes             String?  @db.Text
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  @@map("property_location_validation")
}

// Availability calendar: which dates are available; optional price override per date
model AvailabilitySlot {
  id                 String           @id @default(uuid())
  date               DateTime         @db.Date
  available          Boolean          @default(true)
  priceOverrideCents Int?            // Special price for this date (overrides listing base)
  minStayNights      Int?             // Override min stay for this date
  listingId          String
  listing            ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  @@unique([listingId, date])
  @@index([listingId])
  @@index([date])
}

// ---------------------------------------------------------------------------
// BNHub: Bookings
// ---------------------------------------------------------------------------
model Booking {
  id              String        @id @default(uuid())
  checkIn         DateTime      @db.Date
  checkOut        DateTime      @db.Date
  nights          Int
  totalCents      Int           // Total price in cents (before fees)
  guestFeeCents   Int           @default(0)
  hostFeeCents    Int           @default(0)
  status          BookingStatus @default(PENDING)
  guestNotes      String?
  checkedInAt     DateTime?     // actual check-in time (booking-service)
  checkedOutAt    DateTime?     // actual check-out time (booking-service)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  guestId         String
  guest           User          @relation(fields: [guestId], references: [id], onDelete: Cascade)
  listingId       String
  listing         ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  payment           Payment?
  review            Review?
  disputes          Dispute[]
  bookingMessages   BookingMessage[]
  bookingEvents     BnhubBookingEvent[]
  checkinDetails    BnhubCheckinDetails?
  payoutHolds       PayoutHold[]
  trustSafetyIncidents TrustSafetyIncident[]

  @@index([guestId])
  @@index([listingId])
  @@index([status])
  @@index([checkIn])
}

// BNHub booking audit trail (status changes, payments, cancellations)
model BnhubBookingEvent {
  id          String   @id @default(uuid())
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  eventType  String   // created | payment_pending | confirmed | declined | cancelled | completed | disputed
  actorId    String?  // User id who triggered (guest, host, admin, system)
  payload    Json?    // e.g. { reason, refundCents }
  createdAt  DateTime @default(now())
  @@index([bookingId])
  @@index([eventType])
  @@index([createdAt])
}

// Check-in details for a booking (host can set per booking)
model BnhubCheckinDetails {
  id              String   @id @default(uuid())
  bookingId       String   @unique
  booking         Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  instructions    String?  @db.Text
  keyInfo         String?  @db.Text  // Key code, lockbox, etc.
  accessType      String?  // self_checkin | meet_host | other
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([bookingId])
}

// Guest-host messaging per booking (MVP: booking-scoped chat)
model BookingMessage {
  id        String   @id @default(uuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  createdAt DateTime @default(now())
  @@index([bookingId])
  @@index([senderId])
}

// Dispute resolution (property not as described, cancellation, damage, payment)
enum DisputeStatus {
  OPEN                        // New, awaiting review (legacy)
  SUBMITTED                   // Guest submitted complaint
  UNDER_REVIEW                // Platform reviewing evidence
  WAITING_FOR_HOST_RESPONSE   // Host must respond within time limit
  EVIDENCE_REVIEW             // Evidence under review
  RESOLVED                    // Resolution applied (legacy)
  RESOLVED_PARTIAL_REFUND
  RESOLVED_FULL_REFUND
  RESOLVED_RELOCATION
  REJECTED                    // Complaint rejected
  ESCALATED                   // Escalated to trust & safety
  CLOSED                      // No further action
}

enum DisputeClaimant {
  GUEST
  HOST
}

model Dispute {
  id                  String         @id @default(uuid())
  bookingId           String
  booking             Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  listingId           String
  listing             ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  claimant            DisputeClaimant
  claimantUserId      String
  description         String         @db.Text
  complaintCategory   String?        @map("complaint_category")
  evidenceUrls        String[]       // Legacy: uploaded evidence links (prefer DisputeEvidence)
  status              DisputeStatus  @default(SUBMITTED)
  urgencyLevel        String?        @map("urgency_level") // normal | high | urgent (unsafe)
  resolutionOutcome   String?        @map("resolution_outcome")
  refundCents         Int?           @map("refund_cents")
  resolutionNotes     String?        @db.Text
  resolvedAt          DateTime?
  resolvedBy          String?
  hostPayoutFrozenAt  DateTime?      @map("host_payout_frozen_at")
  hostRespondedAt     DateTime?      @map("host_responded_at")
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  messages            DisputeMessage[]
  evidence            DisputeEvidence[]
  resolutions        DisputeResolution[]
  @@index([bookingId])
  @@index([listingId])
  @@index([status])
  @@index([urgencyLevel])
}

// Audit log for each resolution decision (one record per resolve action)
model DisputeResolution {
  id              String   @id @default(uuid())
  disputeId       String
  dispute         Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  resolutionType  String   @map("resolution_type") // partial_refund | full_refund | no_action | host_suspended | etc.
  refundCents     Int?     @map("refund_cents")
  notes           String?  @db.Text
  resolvedBy      String   @map("resolved_by")
  resolvedAt      DateTime @default(now()) @map("resolved_at")
  @@index([disputeId])
  @@map("dispute_resolutions")
}

// Host accountability: warnings and penalties (repeated violations)
model HostAccountWarning {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  warningType  String   @map("warning_type") // listing_violation | complaint_pattern | cancellation | policy_breach
  message      String   @db.Text
  severity     String   @default("warning") // warning | penalty | suspension
  penaltyCents Int?     @map("penalty_cents")
  createdAt    DateTime @default(now()) @map("created_at")
  createdBy    String?   @map("created_by")

  @@index([userId])
  @@map("host_account_warnings")
}

// Host quality score and Super Host badge (computed from reviews, cancellation, response)
model HostQuality {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  qualityScore        Float    // 0-5
  isSuperHost         Boolean  @default(false)
  cancellationRate   Float?   // 0-1
  avgResponseMinutes  Float?
  updatedAt           DateTime @updatedAt
  @@index([userId])
}

// Supply growth: referral program config (rewards, active)
model ReferralProgram {
  id                     String    @id @default(uuid())
  name                   String
  rewardCreditsReferrer  Int       @default(500)  // cents to referrer
  rewardCreditsReferee   Int       @default(500)  // cents to new user
  active                 Boolean   @default(true)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  referrals              Referral[]
}

// Supply growth: host referral (invite host → both get credits)
model Referral {
  id                String    @id @default(uuid())
  programId         String?
  program           ReferralProgram? @relation(fields: [programId], references: [id], onDelete: SetNull)
  referrerId        String
  referrer          User      @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  code              String    @unique
  rewardCreditsCents Int      @default(0)
  usedByUserId      String?
  usedBy            User?     @relation("Referree", fields: [usedByUserId], references: [id], onDelete: SetNull)
  usedAt            DateTime?
  createdAt         DateTime  @default(now())
  @@index([referrerId])
  @@index([code])
  @@index([programId])
}

// ---------------------------------------------------------------------------
// Pricing engine: stored recommendations and rules
// ---------------------------------------------------------------------------
model PricingRecommendation {
  id                  String   @id @default(uuid())
  listingId           String
  recommendedCents    Int
  marketAvgCents      Int
  demandLevel         String   // low | medium | high
  minStayNights       Int?    // suggested min stay
  factors             String[] // e.g. seasonality, events
  forDate             DateTime? @db.Date
  createdAt           DateTime @default(now())
  @@index([listingId])
  @@index([createdAt])
}

model PricingRule {
  id            String   @id @default(uuid())
  listingId     String
  ruleType      String   // SEASONALITY | MIN_STAY | EVENT | BASE
  payload       Json     // e.g. { "multiplier": 1.2 } or { "minNights": 2 }
  validFrom     DateTime? @db.Date
  validTo       DateTime? @db.Date
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([listingId])
}

// ---------------------------------------------------------------------------
// Search ranking: configurable weights (admin)
// ---------------------------------------------------------------------------
model SearchRankingConfig {
  id              String   @id @default(uuid())
  key             String   @unique  // e.g. "verification", "reviewScore"
  weight          Float    @default(1.0)
  description     String?
  updatedAt       DateTime @updatedAt
  @@index([key])
}

// ---------------------------------------------------------------------------
// Fraud detection: signals and alerts
// ---------------------------------------------------------------------------
enum FraudSignalType {
  FAKE_LISTING
  SUSPICIOUS_BOOKING
  PAYMENT_FRAUD
  ACCOUNT_TAKEOVER
  REVIEW_MANIPULATION
  REFUND_ABUSE
  SUSPICIOUS_MESSAGING
}

model FraudSignal {
  id          String         @id @default(uuid())
  entityType  String         // LISTING | BOOKING | USER | PAYMENT | REVIEW | MESSAGE
  entityId    String
  signalType  FraudSignalType
  score       Float          // 0-1 risk
  metadata    Json?          // details
  createdAt   DateTime       @default(now())
  @@index([entityType, entityId])
  @@index([signalType])
  @@index([createdAt])
}

enum FraudAlertStatus {
  NEW
  REVIEWING
  RESOLVED
  DISMISSED
}

model FraudAlert {
  id          String          @id @default(uuid())
  signalIds   String[]        // one or more FraudSignal ids
  riskScore   Float            // aggregated
  status      FraudAlertStatus @default(NEW)
  assignedTo  String?
  resolvedAt  DateTime?
  resolvedBy  String?
  notes       String?         @db.Text
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  @@index([status])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Listing fraud investigation and enforcement (LECIPM / BNHub)
// ---------------------------------------------------------------------------
enum InvestigationStatus {
  OPEN
  UNDER_REVIEW
  CLOSED
}

model ListingInvestigation {
  id               String             @id @default(uuid())
  listingId        String             @map("listing_id")
  listing          ShortTermListing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  fraudReason      String             @map("fraud_reason") // fake_owner | duplicate_cadastre | stolen_photos | etc.
  status           InvestigationStatus @default(OPEN)
  openedBy         String             @map("opened_by")
  openedAt         DateTime           @default(now()) @map("opened_at")
  closedAt         DateTime?          @map("closed_at")
  resolutionNotes  String?            @db.Text @map("resolution_notes")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  @@index([listingId])
  @@index([status])
  @@map("listing_investigations")
}

enum ListingFraudEnforcementType {
  REJECT_LISTING
  PERMANENTLY_REMOVE_LISTING
  SUSPEND_LISTING_ACCOUNT
  BAN_USER_ACCOUNT
  BLOCK_FUTURE_LISTING
  FREEZE_PAYOUTS
  FRAUD_MARKER_PROPERTY_IDENTITY
  REQUIRE_STRONGER_VERIFICATION
}

model ListingEnforcementAction {
  id          String                     @id @default(uuid())
  listingId   String                     @map("listing_id")
  userId      String                     @map("user_id") // Account acted upon (e.g. listing owner)
  user        User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  actionType  ListingFraudEnforcementType @map("action_type")
  reasonCode  String                @map("reason_code")
  notes       String?               @db.Text
  createdBy   String                @map("created_by")
  createdAt   DateTime              @default(now()) @map("created_at")
  @@index([listingId])
  @@index([userId])
  @@map("listing_enforcement_actions")
}

enum PayoutHoldStatus {
  PENDING    // Hold requested
  ON_HOLD    // Payout held
  RELEASABLE // Window passed, can release
  RELEASED
  REVERSED
  REFUNDED
}

model PayoutHold {
  id         String           @id @default(uuid())
  bookingId  String           @map("booking_id")
  booking    Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  hostId     String           @map("host_id")
  reason     String           // fraud_investigation | safety_complaint | service_mismatch | dispute_escalation | escrow_window
  status     PayoutHoldStatus @default(ON_HOLD)
  createdAt  DateTime         @default(now()) @map("created_at")
  releasedAt DateTime?        @map("released_at")
  @@index([bookingId])
  @@index([hostId])
  @@index([status])
  @@map("payout_holds")
}

model HostRiskHistory {
  id        String   @id @default(uuid())
  hostId    String   @map("host_id")
  host      User     @relation(fields: [hostId], references: [id], onDelete: Cascade)
  riskType  String   @map("risk_type") // inaccurate_listing | complaints | cancellations | safety | refunds
  riskScore Float?   @map("risk_score")
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  @@index([hostId])
  @@index([riskType])
  @@map("host_risk_history")
}

// ---------------------------------------------------------------------------
// Dispute: message thread and evidence audit
// ---------------------------------------------------------------------------
model DisputeMessage {
  id          String   @id @default(uuid())
  disputeId   String
  dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  senderId    String
  body        String   @db.Text
  isInternal  Boolean  @default(false)  // admin-only note
  createdAt   DateTime @default(now())
  @@index([disputeId])
}

model DisputeEvidence {
  id          String   @id @default(uuid())
  disputeId   String
  dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  url         String
  label       String?
  uploadedBy  String
  createdAt   DateTime @default(now())
  @@index([disputeId])
}

// ---------------------------------------------------------------------------
// Host quality: score history for trends and audit
// ---------------------------------------------------------------------------
model HostQualityHistory {
  id            String   @id @default(uuid())
  userId        String
  qualityScore  Float
  isSuperHost   Boolean
  cancellationRate Float?
  snapshotAt    DateTime @default(now())
  @@index([userId])
  @@index([snapshotAt])
}

// ---------------------------------------------------------------------------
// Supply growth: acquisition metrics (daily snapshots)
// ---------------------------------------------------------------------------
model SupplyGrowthMetric {
  id                String   @id @default(uuid())
  date              DateTime @db.Date
  newListings       Int      @default(0)
  newHosts          Int      @default(0)
  referralSignups   Int      @default(0)
  totalListings     Int      @default(0)
  totalHosts        Int      @default(0)
  createdAt         DateTime @default(now())
  @@unique([date])
  @@index([date])
}

// ---------------------------------------------------------------------------
// BNHub: Payments (Stripe integration placeholder)
// ---------------------------------------------------------------------------
model Payment {
  id                    String        @id @default(uuid())
  amountCents            Int           // Total charged to guest
  guestFeeCents         Int
  hostFeeCents          Int
  hostPayoutCents       Int
  status                 PaymentStatus @default(PENDING)
  stripePaymentId       String?       // External payment provider ID
  hostPayoutReleasedAt  DateTime?    @map("host_payout_released_at") // Escrow: release 24-48h after check-in unless held
  payoutHoldReason      String?       @map("payout_hold_reason")       // fraud_investigation | dispute | escrow_window
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  bookingId              String        @unique
  booking                Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([payoutHoldReason])
  @@map("payments")
}

// ---------------------------------------------------------------------------
// BNHub: Reviews (property + host)
// ---------------------------------------------------------------------------
model Review {
  id                 String           @id @default(uuid())
  propertyRating     Int              // 1-5 overall
  hostRating         Int?             // 1-5 optional
  cleanlinessRating  Int?             // 1-5 BNHub category
  communicationRating Int?           // 1-5
  locationRating     Int?             // 1-5
  valueRating        Int?             // 1-5
  comment            String?          @db.Text
  createdAt          DateTime        @default(now())
  guestId            String
  guest              User             @relation(fields: [guestId], references: [id], onDelete: Cascade)
  listingId          String
  listing            ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bookingId          String           @unique
  booking            Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([guestId])
}

// =============================================================================
// ANTI-FAILURE: Operational Control Layer
// =============================================================================

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  enabled     Boolean  @default(false)
  scope       String   @default("GLOBAL")  // GLOBAL | REGION
  scopeValue  String?  // e.g. region code when scope=REGION
  reason      String?
  updatedBy   String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
  @@index([key])
  @@index([enabled])
}

enum OperationalControlType {
  KILL_SWITCH           // Disable a flow (e.g. instant_booking)
  PAYOUT_HOLD           // Hold payouts for target
  LISTING_FREEZE        // Freeze listing visibility or creation
  BOOKING_RESTRICTION   // Restrict new bookings
  MODERATION_LEVEL      // Stricter moderation
  REGIONAL_LOCK         // Region-specific lock
}

model OperationalControl {
  id          String                @id @default(uuid())
  controlType OperationalControlType
  targetType  String                // GLOBAL | REGION | USER | LISTING_CATEGORY | MARKET
  targetId    String?               // region code, userId, category slug, etc.
  payload     Json?                 // e.g. { "flow": "instant_booking" }, { "holdReason": "..." }
  active      Boolean               @default(true)
  reason      String?               @db.Text
  reasonCode  String?                // For audit and automation
  createdBy   String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  expiresAt   DateTime?
  @@index([controlType])
  @@index([targetType, targetId])
  @@index([active])
}

model ControlActionAuditLog {
  id            String   @id @default(uuid())
  controlId     String?
  action        String   // CREATED | UPDATED | DEACTIVATED | ACTIVATED
  performedBy   String?
  reasonCode    String?
  previousValue Json?
  newValue      Json?
  createdAt     DateTime @default(now())
  @@index([controlId])
  @@index([createdAt])
}

// =============================================================================
// ANTI-FAILURE: Observability and Platform Health
// =============================================================================

model ServiceHealthMetric {
  id          String   @id @default(uuid())
  serviceName String
  metricName  String
  value       Float
  unit        String?  // count | ms | percent
  region      String?
  createdAt   DateTime @default(now())
  @@index([serviceName, metricName])
  @@index([createdAt])
}

enum SystemAlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model SystemAlert {
  id           String            @id @default(uuid())
  alertType    String            // FRAUD_SPIKE | PAYMENT_FAILURE | DISPUTE_SPIKE | LATENCY | ERROR_RATE
  severity     SystemAlertSeverity
  message      String            @db.Text
  threshold    Float?
  currentValue Float?
  resolvedAt   DateTime?
  resolvedBy   String?
  metadata     Json?
  createdAt    DateTime          @default(now())
  @@index([alertType])
  @@index([severity])
  @@index([resolvedAt])
  @@index([createdAt])
}

model PlatformEvent {
  id                String   @id @default(uuid())
  eventType         String   @map("event_type")
  sourceModule      String   @map("source_module")
  entityType        String?  @map("entity_type")
  entityId          String?  @map("entity_id")
  payload           Json?
  region            String?
  processingStatus  String   @default("pending") @map("processing_status") // pending | processed | failed | dead
  processedAt       DateTime? @map("processed_at")
  errorMessage      String?  @map("error_message") @db.Text
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([eventType])
  @@index([sourceModule])
  @@index([entityType, entityId])
  @@index([processingStatus])
  @@index([createdAt])
  @@map("platform_events")
}

// ---------------------------------------------------------------------------
// Autonomous AI Property Manager – recommendations, alerts, scores, decisions
// ---------------------------------------------------------------------------
model AiPropertyRecommendation {
  id                String   @id @default(uuid())
  entityType        String   @map("entity_type") // property | listing | user | portfolio
  entityId          String   @map("entity_id")
  agentType         String   @map("agent_type") // performance | pricing | occupancy | listing_quality | risk | service_quality | portfolio | investment | support | market_shift
  recommendationType String @map("recommendation_type") // price_change | listing_improvement | date_suggestion | risk_review | etc.
  title             String   @db.Text
  summary           String?  @db.Text
  details           Json?    // structured details
  confidenceScore   Int?     @map("confidence_score") // 0-100
  priority          String   @default("normal") // low | normal | high | urgent
  status            String   @default("pending") // pending | applied | dismissed
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([entityType, entityId])
  @@index([agentType])
  @@index([status])
  @@index([createdAt])
  @@map("ai_property_recommendations")
}

model AiPropertyAlert {
  id         String   @id @default(uuid())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  alertType  String   @map("alert_type") // risk_spike | quality_drop | dispute_pattern | market_shift | etc.
  severity   String   @default("medium") // low | medium | high | critical
  message    String   @db.Text
  details    Json?
  status     String   @default("open") // open | acknowledged | resolved
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([entityType, entityId])
  @@index([alertType])
  @@index([severity])
  @@index([status])
  @@map("ai_property_alerts")
}

model AiPropertyScore {
  id         String   @id @default(uuid())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  scoreType  String   @map("score_type") // performance | listing_quality | risk | service_quality | investment_attractiveness | etc.
  scoreValue Int      @map("score_value") // 0-100
  scoreLabel String?  @map("score_label") // low | medium | high
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([scoreType])
  @@index([createdAt])
  @@map("ai_property_scores")
}

model AiPropertyManagerDecision {
  id               String   @id @default(uuid())
  agentType        String   @map("agent_type")
  entityType       String   @map("entity_type")
  entityId         String   @map("entity_id")
  inputSummary     String?  @map("input_summary") @db.Text
  outputSummary    String?  @map("output_summary") @db.Text
  confidenceScore  Int?     @map("confidence_score")
  recommendedAction String? @map("recommended_action") @db.Text
  automatedAction  String?  @map("automated_action") // none | suggestion_created | alert_created | etc.
  humanOverride    Boolean  @default(false) @map("human_override")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([agentType])
  @@index([createdAt])
  @@map("ai_property_manager_decisions")
}

model OperationalIncident {
  id          String   @id @default(uuid())
  title       String
  severity    String   // LOW | MEDIUM | HIGH | CRITICAL
  status      String   @default("OPEN")  // OPEN | INVESTIGATING | RESOLVED
  description String? @db.Text
  startedAt   DateTime @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([status])
  @@index([severity])
  @@index([startedAt])
}

// =============================================================================
// ANTI-FAILURE: Policy Engine and Rules Enforcement
// =============================================================================

enum PolicyRuleType {
  ELIGIBILITY       // Who can do what
  VISIBILITY        // Listing/search visibility
  RELEASE_CONDITION // Payout/reward release
  VERIFICATION      // Verification requirements by risk
  AUTO_BLOCK        // Auto-block conditions
  CANCELLATION      // Cancellation policy
  REVIEW_ELIGIBILITY
  REFERRAL_REWARD
}

enum PolicyEffect {
  ALLOW
  DENY
  HOLD
  REQUIRE_ACTION
}

model PolicyRule {
  id          String         @id @default(uuid())
  key         String         @unique
  name        String
  description String?        @db.Text
  ruleType    PolicyRuleType
  scope       String         @default("GLOBAL")  // GLOBAL | REGION
  scopeValue  String?
  conditions  Json          // e.g. { "minVerification": "VERIFIED", "maxFraudScore": 0.5 }
  effect      PolicyEffect
  effectPayload Json?        // e.g. { "holdReasonCode": "VERIFY_IDENTITY" }
  version     Int           @default(1)
  active      Boolean        @default(true)
  updatedBy   String?
  updatedAt   DateTime       @updatedAt
  createdAt   DateTime       @default(now())
  @@index([key])
  @@index([ruleType])
  @@index([active])
}

model PolicyDecisionLog {
  id         String   @id @default(uuid())
  ruleKey   String
  entityType String
  entityId  String
  decision  String   // ALLOWED | DENIED | HELD
  reasonCode String?
  context   Json?    // Input context used for evaluation
  evaluatedAt DateTime @default(now())
  @@index([ruleKey])
  @@index([entityType, entityId])
  @@index([evaluatedAt])
}

// =============================================================================
// REVENUE, GROWTH & MARKET EXPANSION LAYER
// =============================================================================

// ---------------------------------------------------------------------------
// Subscription and Billing
// ---------------------------------------------------------------------------
enum SubscriptionPlanModule {
  BROKER_CRM
  HOST_PRO
  OWNER_ANALYTICS
  INVESTOR_ANALYTICS
  ENTERPRISE
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

model SubscriptionPlan {
  id           String                @id @default(uuid())
  name         String
  slug         String                @unique
  module       SubscriptionPlanModule
  billingCycle BillingCycle
  amountCents  Int
  trialDays    Int                   @default(0)
  features     Json?                 // Entitlements: { "maxListings": 10, "analytics": true }
  active       Boolean               @default(true)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  subscriptions Subscription[]
  @@index([module])
  @@index([active])
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  EXPIRED
}

model Subscription {
  id                 String             @id @default(uuid())
  userId             String
  planId             String
  plan               SubscriptionPlan    @relation(fields: [planId], references: [id], onDelete: Restrict)
  status             SubscriptionStatus @default(TRIALING)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  invoices           Invoice[]
  billingEvents      BillingEvent[]
  @@index([userId])
  @@index([planId])
  @@index([status])
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

model Invoice {
  id             String        @id @default(uuid())
  subscriptionId String
  subscription   Subscription   @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amountCents    Int
  status        InvoiceStatus  @default(OPEN)
  dueDate       DateTime
  paidAt        DateTime?
  invoiceNumber String?        @unique
  createdAt     DateTime       @default(now())
  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
}

model BillingEvent {
  id             String   @id @default(uuid())
  subscriptionId String?
  userId         String?
  eventType      String   // SUBSCRIPTION_CREATED | PAYMENT_SUCCEEDED | PAYMENT_FAILED | INVOICE_PAID | REFUND
  amountCents    Int?
  metadata       Json?
  createdAt      DateTime @default(now())
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  @@index([subscriptionId])
  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Promotions and Marketplace Monetization
// ---------------------------------------------------------------------------
enum PromotionPlacement {
  FEATURED
  SPONSORED
  BOOST
}

enum PromotionCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

model PromotionCampaign {
  id         String                  @id @default(uuid())
  name       String
  campaignType String                // FEATURED | SPONSORED | BOOST
  marketId   String?
  budgetCents Int?
  startAt    DateTime
  endAt      DateTime
  status     PromotionCampaignStatus @default(DRAFT)
  createdBy  String?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  market     MarketConfig?            @relation(fields: [marketId], references: [id], onDelete: SetNull)
  promotions PromotedListing[]
  @@index([marketId])
  @@index([status])
  @@index([startAt])
}

model PromotedListing {
  id          String              @id @default(uuid())
  listingId   String
  campaignId  String
  campaign    PromotionCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  startAt     DateTime
  endAt       DateTime
  placement   PromotionPlacement
  costCents   Int?
  status      String              @default("ACTIVE") // ACTIVE | PAUSED | ENDED
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  @@index([listingId])
  @@index([campaignId])
  @@index([status])
  @@index([startAt])
}

// ---------------------------------------------------------------------------
// Growth and Acquisition
// ---------------------------------------------------------------------------
enum GrowthCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

model GrowthCampaign {
  id        String               @id @default(uuid())
  name      String
  campaignType String             // REFERRAL | INVITE | ACQUISITION
  marketId  String?
  startAt   DateTime
  endAt     DateTime
  status    GrowthCampaignStatus  @default(DRAFT)
  config    Json?                 // Reward amounts, eligibility, etc.
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  market    MarketConfig?         @relation(fields: [marketId], references: [id], onDelete: SetNull)
  acquisitionSources AcquisitionSource[]
  @@index([marketId])
  @@index([status])
}

model AcquisitionSource {
  id          String           @id @default(uuid())
  userId      String?
  campaignId  String?
  growthCampaign GrowthCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  source      String           // utm_source | referral | organic
  medium      String?
  utmCampaign String?          // utm_campaign
  createdAt   DateTime         @default(now())
  @@index([userId])
  @@index([campaignId])
  @@index([source])
}

model OnboardingMilestone {
  id           String   @id @default(uuid())
  userId       String
  milestoneKey String   // PROFILE_COMPLETE | FIRST_LISTING | FIRST_BOOKING | VERIFICATION_DONE
  completedAt DateTime @default(now())
  metadata    Json?
  createdAt   DateTime @default(now())
  @@unique([userId, milestoneKey])
  @@index([userId])
  @@index([milestoneKey])
}

// ---------------------------------------------------------------------------
// Lifecycle Automation
// ---------------------------------------------------------------------------
enum LifecycleStage {
  ONBOARDING
  ACTIVE
  AT_RISK
  CHURNED
  REACTIVATED
}

model LifecycleState {
  id             String          @id @default(uuid())
  userId         String
  stage          LifecycleStage
  module         String?         // BNHUB | BROKER_CRM | OWNER | INVESTOR
  lastActivityAt DateTime?
  metadata       Json?
  updatedAt      DateTime        @updatedAt
  createdAt      DateTime        @default(now())
  @@index([userId])
  @@index([stage])
  @@index([module])
}

// ---------------------------------------------------------------------------
// Market Configuration and Multi-Market Expansion
// ---------------------------------------------------------------------------
model MarketConfig {
  id               String    @id @default(uuid())
  code             String    @unique  // e.g. NYC, LON, UAE
  name             String
  country          String
  currency         String    @default("USD")
  defaultLanguage  String    @default("en")
  active           Boolean   @default(true)
  taxRatePercent   Float?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  taxRules         MarketTaxRule[]
  policyBindings   MarketPolicyBinding[]
  promotionCampaigns PromotionCampaign[]
  growthCampaigns  GrowthCampaign[]
  revenueLedgerEntries RevenueLedgerEntry[]
  @@index([active])
  @@index([code])
}

model MarketTaxRule {
  id            String       @id @default(uuid())
  marketId      String
  market        MarketConfig @relation(fields: [marketId], references: [id], onDelete: Cascade)
  ruleType      String       // VAT | GST | PLATFORM_FEE
  ratePercent   Float
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime     @default(now())
  @@index([marketId])
}

model MarketPolicyBinding {
  id             String       @id @default(uuid())
  marketId       String
  market         MarketConfig @relation(fields: [marketId], references: [id], onDelete: Cascade)
  policyRuleKey  String
  overridePayload Json?
  active         Boolean      @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  @@index([marketId])
  @@index([policyRuleKey])
}

// ---------------------------------------------------------------------------
// Revenue Intelligence
// ---------------------------------------------------------------------------
enum RevenueLedgerType {
  BOOKING_COMMISSION
  REAL_ESTATE_COMMISSION
  SUBSCRIPTION
  PROMOTION
  REFERRAL_COST
  REFUND
  CHARGEBACK
  INCENTIVE
  PAYOUT
}

model RevenueLedgerEntry {
  id         String            @id @default(uuid())
  type       RevenueLedgerType
  entityType String            // BOOKING | SUBSCRIPTION | INVOICE | PROMOTION | REFERRAL
  entityId   String
  amountCents Int              // Positive = revenue, negative = cost/refund
  marketId   String?
  market     MarketConfig?      @relation(fields: [marketId], references: [id], onDelete: SetNull)
  module     String?           // BNHUB | BROKER_CRM | etc.
  userId     String?
  metadata   Json?
  createdAt  DateTime          @default(now())
  @@index([type])
  @@index([entityType, entityId])
  @@index([marketId])
  @@index([createdAt])
}

model RevenueReport {
  id         String   @id @default(uuid())
  reportType String   // DAILY | WEEKLY | MONTHLY | BY_MARKET | BY_MODULE
  periodStart DateTime
  periodEnd   DateTime
  marketId   String?
  data       Json     // Aggregated totals, breakdowns
  createdAt  DateTime @default(now())
  @@index([reportType])
  @@index([periodStart])
  @@index([marketId])
}

// ---------------------------------------------------------------------------
// Executive Business Metrics
// ---------------------------------------------------------------------------
model ExecutiveMetricsSnapshot {
  id                 String   @id @default(uuid())
  date               DateTime @db.Date
  marketId           String?
  gmvCents           Int      @default(0)
  netRevenueCents    Int      @default(0)
  bookingsCount     Int      @default(0)
  activeHostsCount   Int      @default(0)
  activeBrokersCount Int      @default(0)
  mrrCents           Int      @default(0)
  arrCents           Int      @default(0)
  refundRate         Float?
  disputeRate        Float?
  data               Json?    // Extended KPIs, cohort hints
  createdAt          DateTime @default(now())
  @@unique([date, marketId])
  @@index([date])
  @@index([marketId])
}

// =============================================================================
// AI OPERATING SYSTEM (AI-OS) LAYER
// =============================================================================

// ---------------------------------------------------------------------------
// AI Data Pipeline & Feature Store
// ---------------------------------------------------------------------------
model AiFeature {
  id         String   @id @default(uuid())
  entityType String   // LISTING | BOOKING | USER | MARKET | etc.
  entityId   String
  featureKey String   // e.g. listing_quality_score, user_fraud_risk
  value      Float    // numeric feature
  valueJson  Json?    // complex or vector
  source     String?  // pipeline run id or model version
  computedAt DateTime @default(now())
  @@unique([entityType, entityId, featureKey])
  @@index([entityType, featureKey])
  @@index([computedAt])
}

// ---------------------------------------------------------------------------
// Model Registry & Lifecycle
// ---------------------------------------------------------------------------
model AiModel {
  id          String   @id @default(uuid())
  key         String   @unique  // fraud_v1, pricing_v1, ranking_v1
  name        String
  description String?  @db.Text
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  versions    ModelVersion[]
  decisionLogs AiDecisionLog[]
  @@index([key])
}

model ModelVersion {
  id          String   @id @default(uuid())
  modelId     String
  model       AiModel  @relation(fields: [modelId], references: [id], onDelete: Cascade)
  version     Int      // 1, 2, 3...
  metrics     Json?    // accuracy, precision, recall, drift
  deployedAt  DateTime?
  deprecatedAt DateTime?
  createdAt   DateTime @default(now())
  @@unique([modelId, version])
  @@index([modelId])
}

// ---------------------------------------------------------------------------
// Fraud Detection AI (aggregated scores per entity)
// ---------------------------------------------------------------------------
model FraudScore {
  id          String   @id @default(uuid())
  entityType  String   // LISTING | BOOKING | USER | PAYMENT
  entityId    String
  score       Float    // 0-1 risk
  factors     Json?    // contributing signals
  modelVersion String?
  priority    String?  // HIGH | MEDIUM | LOW (investigation priority)
  createdAt   DateTime @default(now())
  @@index([entityType, entityId])
  @@index([score])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Dynamic Pricing AI (extends PricingRecommendation with model metadata)
// ---------------------------------------------------------------------------
model AiPricingRecommendation {
  id                String    @id @default(uuid())
  listingId         String
  recommendedCents  Int
  minCents          Int?
  maxCents          Int?
  demandLevel       String    // low | medium | high
  minStayNights     Int?
  factors           Json?     // explainable factors
  modelVersion      String?
  forDate           DateTime? @db.Date
  createdAt         DateTime  @default(now())
  @@index([listingId])
  @@index([forDate])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Search Ranking AI (cached scores and explanations)
// ---------------------------------------------------------------------------
model SearchRankingScore {
  id            String   @id @default(uuid())
  listingId     String
  score         Float
  factors       Json?    // breakdown: verification, reviews, conversion...
  modelVersion  String?
  computedAt    DateTime @default(now())
  @@index([listingId])
  @@index([score])
  @@index([computedAt])
}

// ---------------------------------------------------------------------------
// Demand Forecasting
// ---------------------------------------------------------------------------
model DemandForecast {
  id           String   @id @default(uuid())
  region       String   // city or market code
  propertyType String?   // optional segment
  forecastDate DateTime @db.Date
  demandLevel  Float    // 0-1 or index
  bookingsPredicted Int?
  supplyGap    Int?     // predicted shortage
  modelVersion String?
  createdAt    DateTime @default(now())
  @@index([region, forecastDate])
  @@index([forecastDate])
}

// ---------------------------------------------------------------------------
// AI Alerts (marketplace health, fraud spikes, anomalies)
// ---------------------------------------------------------------------------
enum AiAlertType {
  FRAUD_SPIKE
  DISPUTE_SPIKE
  LISTING_QUALITY_DROP
  CANCELLATION_ANOMALY
  DEMAND_CHANGE
  REGIONAL_RISK
  MODEL_DRIFT
}

model AiAlert {
  id          String      @id @default(uuid())
  alertType   AiAlertType
  severity    String      // LOW | MEDIUM | HIGH | CRITICAL
  title       String
  message     String      @db.Text
  entityType  String?
  entityId    String?
  region      String?
  payload     Json?       // metrics, recommended actions
  acknowledgedAt DateTime?
  acknowledgedBy String?
  createdAt   DateTime   @default(now())
  @@index([alertType])
  @@index([severity])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// AI Decision Log (audit trail for model-driven decisions)
// ---------------------------------------------------------------------------
model AiDecisionLog {
  id            String   @id @default(uuid())
  modelId       String
  model         AiModel  @relation(fields: [modelId], references: [id], onDelete: Restrict)
  modelVersion  String?
  entityType    String
  entityId      String
  decision      String   // ALLOW | FLAG | BLOCK | RECOMMEND
  score         Float?
  explanation   String?  @db.Text
  overrideBy    String?  // admin override
  overrideAt    DateTime?
  context       Json?
  createdAt     DateTime @default(now())
  @@index([modelId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// AI Operator – Fully Autonomous Marketplace Operator (BNHub)
// ---------------------------------------------------------------------------
model AiOperatorDecision {
  id               String   @id @default(uuid())
  agentType        String   // listing_moderation | pricing | fraud_risk | booking_integrity | demand_forecast | host_performance | support_triage | marketplace_health
  entityType       String
  entityId         String
  inputSummary     Json?
  outputSummary    Json?
  confidenceScore  Float
  recommendedAction String
  reasonCodes      String[] @default([])
  automatedAction  String?
  humanOverrideBy  String?
  humanOverrideAt  DateTime?
  humanOverrideAction String?
  humanOverrideNotes String?  @db.Text
  createdAt        DateTime @default(now())
  @@index([agentType])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model AiOperatorAlert {
  id         String   @id @default(uuid())
  alertType  String   // listing_quality | fraud_risk | booking_anomaly | marketplace_health | pricing | etc.
  severity   String   // low | medium | high | critical
  entityType String
  entityId   String
  message    String   @db.Text
  status     String   @default("open") // open | acknowledged | resolved
  metadata   Json?
  createdAt  DateTime @default(now())
  @@index([alertType])
  @@index([status])
  @@index([createdAt])
}

// =============================================================================
// PLATFORM DEFENSE LAYER
// =============================================================================

// ---------------------------------------------------------------------------
// 1. Legal Defense – policy acceptance, terms, acknowledgements
// ---------------------------------------------------------------------------
model PolicyAcceptanceRecord {
  id            String   @id @default(uuid())
  userId        String
  policyKey     String   // terms_of_service | privacy_policy | booking_terms | payout_terms | host_responsibility | guest_conduct | listing_accuracy
  policyVersion String
  acceptedAt    DateTime @default(now())
  marketId      String?  // jurisdiction / market
  entityType    String?  // BOOKING | LISTING | PAYOUT when context-specific
  entityId      String?
  ipAddress     String?
  userAgent     String?
  metadata      Json?
  @@index([userId])
  @@index([policyKey])
  @@index([acceptedAt])
  @@index([marketId])
}

model LegalEventLog {
  id          String   @id @default(uuid())
  eventType   String   // TERMS_ACCEPTED | DISCLOSURE_SHOWN | ACKNOWLEDGEMENT | POLICY_CHANGE | JURISDICTION_BINDING
  userId      String?
  entityType  String?
  entityId    String?
  marketId    String?
  payload     Json?    // version, policyKey, evidence snapshot
  reasonCode  String?
  createdAt   DateTime @default(now())
  @@index([eventType])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// 2. Evidence Preservation – chain-of-custody, access log
// ---------------------------------------------------------------------------
model EvidenceRecord {
  id            String   @id @default(uuid())
  caseType      String   // DISPUTE | FRAUD | INCIDENT | COMPLIANCE | LEGAL
  caseId        String
  classification String  // PHOTO | DOCUMENT | SCREENSHOT | LOG_EXPORT
  url           String   // storage URL or reference
  filename      String?
  mimeType      String?
  uploadedBy    String
  uploadedAt    DateTime @default(now())
  metadata      Json?
  retentionUntil DateTime?
  checksum      String?  // integrity
  @@index([caseType, caseId])
  @@index([uploadedAt])
}

model EvidenceAccessLog {
  id          String   @id @default(uuid())
  evidenceId  String
  accessedBy  String
  accessType  String   // VIEW | EXPORT | DOWNLOAD
  reasonCode  String?
  createdAt   DateTime @default(now())
  @@index([evidenceId])
  @@index([accessedBy])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// 3. Abuse Prevention – signals, offender profiles
// ---------------------------------------------------------------------------
enum AbuseSignalType {
  REPEAT_OFFENDER
  LINKED_ACCOUNT
  EVASION_AFTER_SUSPENSION
  ABUSIVE_MESSAGING
  ABUSIVE_BOOKING
  REFUND_ABUSE
  PROMOTION_ABUSE
  REFERRAL_ABUSE
  BAN_EVASION
}

model AbuseSignal {
  id          String         @id @default(uuid())
  userId      String?
  entityType  String?
  entityId    String?
  signalType  AbuseSignalType
  severity    String         // LOW | MEDIUM | HIGH
  payload     Json?          // IP, device hints, correlation ids
  createdBy   String?        // system or staff
  createdAt   DateTime       @default(now())
  @@index([userId])
  @@index([signalType])
  @@index([createdAt])
}

model OffenderProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  strikeCount     Int      @default(0)
  lastStrikeAt    DateTime?
  suspendedAt     DateTime?
  bannedAt        DateTime?
  linkedAccountIds String[] // suspected or confirmed
  notes           String?  @db.Text
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
  @@index([userId])
}

// ---------------------------------------------------------------------------
// 4. Internal Access – privileged actions, approvals
// ---------------------------------------------------------------------------
model PrivilegedAdminAction {
  id            String   @id @default(uuid())
  adminId       String
  actionType    String   // PAYOUT_RELEASE | SUSPENSION | BAN | IMPERSONATION | EVIDENCE_ACCESS | LEGAL_EXPORT
  entityType    String?
  entityId      String?
  reasonCode    String?
  reasonText    String?  @db.Text
  approvalId    String?  // when required
  metadata      Json?
  createdAt     DateTime @default(now())
  @@index([adminId])
  @@index([actionType])
  @@index([createdAt])
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model ApprovalRequest {
  id            String               @id @default(uuid())
  requestType   String               // PAYOUT_RELEASE | ACCOUNT_SUSPENSION | BAN | CRISIS_ACTION
  requestedBy   String
  targetType    String?
  targetId      String?
  reasonCode    String?
  payload       Json?
  status        ApprovalRequestStatus @default(PENDING)
  reviewedBy    String?
  reviewedAt    DateTime?
  reviewNotes   String?              @db.Text
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  @@index([status])
  @@index([requestedBy])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// 5. Crisis Response – events, action log
// ---------------------------------------------------------------------------
enum CrisisSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model CrisisEvent {
  id            String         @id @default(uuid())
  title         String
  severity      CrisisSeverity
  status        String         @default("ACTIVE")  // ACTIVE | CONTAINED | RESOLVED
  region        String?        // market or region
  startedAt     DateTime       @default(now())
  resolvedAt    DateTime?
  resolvedBy    String?
  playbookRef   String?        // reference to runbook
  summary       String?        @db.Text
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  actionLogs    CrisisActionLog[]
  @@index([status])
  @@index([severity])
  @@index([startedAt])
}

model CrisisActionLog {
  id          String      @id @default(uuid())
  crisisId    String
  crisis      CrisisEvent @relation(fields: [crisisId], references: [id], onDelete: Cascade)
  actionType  String      // BOOKING_FREEZE | PAYOUT_FREEZE | CONTENT_TAKEDOWN | ESCALATION
  targetType  String?
  targetId    String?
  performedBy String
  reasonCode  String?
  payload     Json?
  createdAt   DateTime    @default(now())
  @@index([crisisId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// 6. Regulatory Compliance – requirements, reviews
// ---------------------------------------------------------------------------
model ComplianceRequirement {
  id          String   @id @default(uuid())
  marketId    String
  requirementKey String  // TAX_REGISTRATION | LICENSING | DATA_RETENTION | DISCLOSURE
  name        String
  description String?  @db.Text
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([marketId])
  @@index([requirementKey])
}

model ComplianceReview {
  id            String   @id @default(uuid())
  requirementId String?
  entityType   String   // USER | LISTING | BOOKING
  entityId     String
  marketId     String?
  status       String   // PENDING | COMPLIANT | NON_COMPLIANT | EXCEPTION
  reviewedAt   DateTime?
  reviewedBy   String?
  notes        String?  @db.Text
  documentRefs String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@index([entityType, entityId])
  @@index([marketId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// 7. Financial Defense – risk flags, intervention log
// ---------------------------------------------------------------------------
model FinancialRiskFlag {
  id          String   @id @default(uuid())
  entityType  String   // PAYOUT | PAYMENT | REFUND | BOOKING
  entityId    String
  flagType    String   // SUSPICIOUS_PAYOUT | REFUND_ABUSE | CHARGEBACK_RISK | ANOMALY
  severity    String   // LOW | MEDIUM | HIGH
  status      String   @default("OPEN")  // OPEN | UNDER_REVIEW | CLEARED | CONFIRMED
  amountCents Int?
  payload     Json?
  createdBy   String?
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime @default(now())
  @@index([entityType, entityId])
  @@index([flagType])
  @@index([status])
}

// ---------------------------------------------------------------------------
// 8. Enforcement – actions, appeals
// ---------------------------------------------------------------------------
enum EnforcementActionType {
  WARNING
  TEMPORARY_RESTRICTION
  LISTING_FREEZE
  BOOKING_LIMITATION
  PAYOUT_HOLD
  ACCOUNT_SUSPENSION
  PERMANENT_BAN
  MARKET_SPECIFIC
}

model EnforcementAction {
  id            String                @id @default(uuid())
  userId        String
  actionType    EnforcementActionType
  severity      String                // LOW | MEDIUM | HIGH | CRITICAL
  reasonCode    String
  reasonText    String?               @db.Text
  marketId      String?
  effectiveAt   DateTime              @default(now())
  expiresAt     DateTime?
  performedBy   String?
  appealId      String?
  metadata      Json?
  createdAt     DateTime              @default(now())
  @@index([userId])
  @@index([actionType])
  @@index([effectiveAt])
  @@index([reasonCode])
}

enum AppealStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  WITHDRAWN
}

model Appeal {
  id            String        @id @default(uuid())
  enforcementId String?
  userId        String
  reasonCode    String?
  description   String        @db.Text
  status        AppealStatus  @default(PENDING)
  submittedAt   DateTime      @default(now())
  reviewedBy    String?
  reviewedAt    DateTime?
  outcomeNotes  String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  @@index([userId])
  @@index([status])
  @@index([submittedAt])
}

// ---------------------------------------------------------------------------
// Trust & Safety Engine – incidents, evidence, actions, profiles, appeals
// ---------------------------------------------------------------------------
enum TrustSafetyIncidentStatus {
  SUBMITTED
  UNDER_REVIEW
  WAITING_RESPONSE
  ESCALATED
  RESOLVED
  CLOSED
}

enum TrustSafetySeverity {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

enum TrustSafetyRiskLevel {
  LOW_RISK
  MEDIUM_RISK
  HIGH_RISK
  CRITICAL_RISK
}

model TrustSafetyIncident {
  id                String                     @id @default(uuid())
  reporterId        String                     @map("reporter_id")
  reporter          User                       @relation("IncidentReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  accusedUserId     String?                    @map("accused_user_id")
  accusedUser       User?                      @relation("IncidentAccused", fields: [accusedUserId], references: [id], onDelete: SetNull)
  listingId         String?                    @map("listing_id")
  listing           ShortTermListing?          @relation(fields: [listingId], references: [id], onDelete: SetNull)
  bookingId         String?                    @map("booking_id")
  booking           Booking?                   @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  incidentCategory  String                     @map("incident_category")
  severityLevel     TrustSafetySeverity        @default(MEDIUM) @map("severity_level")
  riskScore         Float?                     @map("risk_score") // 0-1
  riskLevel         TrustSafetyRiskLevel?      @map("risk_level")
  status            TrustSafetyIncidentStatus  @default(SUBMITTED)
  urgencyLevel      String?                    @map("urgency_level") // normal | high | urgent | emergency
  description       String                     @db.Text
  incidentTime      DateTime?                  @map("incident_time")
  createdAt         DateTime                   @default(now()) @map("created_at")
  updatedAt         DateTime                   @updatedAt @map("updated_at")
  resolvedAt        DateTime?                  @map("resolved_at")
  resolvedBy        String?                    @map("resolved_by")
  resolutionNotes   String?                    @db.Text @map("resolution_notes")
  evidence          TrustSafetyEvidence[]
  actions           TrustSafetyAction[]
  appeals           TrustSafetyAppeal[]
  responses         TrustSafetyIncidentResponse[]
  @@index([reporterId])
  @@index([accusedUserId])
  @@index([listingId])
  @@index([bookingId])
  @@index([status])
  @@index([severityLevel])
  @@index([incidentCategory])
  @@index([createdAt])
  @@map("trust_safety_incidents")
}

model TrustSafetyEvidence {
  id          String               @id @default(uuid())
  incidentId  String               @map("incident_id")
  incident    TrustSafetyIncident  @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  fileUrl     String               @map("file_url")
  fileType    String?              @map("file_type") // photo | video | screenshot | document
  label       String?
  uploadedBy  String                @map("uploaded_by")
  createdAt   DateTime             @default(now()) @map("created_at")
  @@index([incidentId])
  @@map("trust_safety_evidence")
}

enum TrustSafetyActionType {
  WARNING
  LISTING_WARNING
  BOOKING_RESTRICTION
  PAYOUT_HOLD
  LISTING_FREEZE
  ACCOUNT_SUSPENSION
  PERMANENT_LISTING_REMOVAL
  PERMANENT_ACCOUNT_BAN
  ADDITIONAL_VERIFICATION_REQUIRED
  MANUAL_REVIEW_REQUIRED
}

model TrustSafetyAction {
  id          String                 @id @default(uuid())
  incidentId  String                 @map("incident_id")
  incident    TrustSafetyIncident    @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  actionType  TrustSafetyActionType  @map("action_type")
  reasonCode  String                 @map("reason_code")
  notes       String?                @db.Text
  createdBy  String                 @map("created_by")
  createdAt   DateTime              @default(now()) @map("created_at")
  metadata    Json?
  @@index([incidentId])
  @@index([actionType])
  @@map("trust_safety_actions")
}

model UserSafetyProfile {
  id                    String   @id @default(uuid())
  userId                String   @unique @map("user_id")
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hostRiskScore         Float?   @map("host_risk_score")   // 0-1
  guestRiskScore        Float?   @map("guest_risk_score") // 0-1
  warningCount          Int      @default(0) @map("warning_count")
  suspensionCount       Int      @default(0) @map("suspension_count")
  seriousIncidentCount  Int      @default(0) @map("serious_incident_count")
  updatedAt             DateTime @updatedAt @map("updated_at")
  @@map("user_safety_profiles")
}

model ListingSafetyProfile {
  id                    String            @id @default(uuid())
  listingId             String            @unique @map("listing_id")
  listing               ShortTermListing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  safetyScore           Float?            @map("safety_score")   // 0-1, higher = safer
  complaintCount        Int               @default(0) @map("complaint_count")
  unsafeIncidentCount   Int               @default(0) @map("unsafe_incident_count")
  fraudIncidentCount    Int               @default(0) @map("fraud_incident_count")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  @@map("listing_safety_profiles")
}

enum TrustSafetyAppealStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  WITHDRAWN
}

model TrustSafetyAppeal {
  id           String                   @id @default(uuid())
  incidentId   String                   @map("incident_id")
  incident     TrustSafetyIncident      @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  actionId     String?                  @map("action_id") // TrustSafetyAction.id
  submittedBy  String                   @map("submitted_by")
  submitter    User                     @relation(fields: [submittedBy], references: [id], onDelete: Cascade)
  appealReason String                   @db.Text @map("appeal_reason")
  status       TrustSafetyAppealStatus  @default(PENDING)
  reviewedBy   String?                  @map("reviewed_by")
  resolvedAt   DateTime?                @map("resolved_at")
  resolutionNote String?                @db.Text @map("resolution_note")
  createdAt    DateTime                 @default(now()) @map("created_at")
  updatedAt    DateTime                 @updatedAt @map("updated_at")
  @@index([incidentId])
  @@index([submittedBy])
  @@index([status])
  @@map("trust_safety_appeals")
}

model TrustSafetyIncidentResponse {
  id          String               @id @default(uuid())
  incidentId  String               @map("incident_id")
  incident    TrustSafetyIncident  @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  respondentId String              @map("respondent_id")
  body        String               @db.Text
  createdAt   DateTime             @default(now()) @map("created_at")
  @@index([incidentId])
  @@map("trust_safety_incident_responses")
}

// ---------------------------------------------------------------------------
// 9. Defense Analytics – metrics snapshots
// ---------------------------------------------------------------------------
model DefenseMetricsSnapshot {
  id                  String   @id @default(uuid())
  date                DateTime @db.Date
  marketId            String?
  incidentCount       Int      @default(0)
  disputeCount        Int      @default(0)
  disputeRate         Float?
  fraudLossCents      Int      @default(0)
  abuseSignalsCount   Int      @default(0)
  suspensionCount     Int      @default(0)
  appealCount         Int      @default(0)
  appealApprovalRate  Float?
  payoutHoldCount     Int      @default(0)
  complianceFailures  Int      @default(0)
  data                Json?    // extended breakdown
  createdAt           DateTime @default(now())
  @@index([date])
  @@index([marketId])
}