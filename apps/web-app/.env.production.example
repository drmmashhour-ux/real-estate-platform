# Production environment template. Copy to .env.production and set real values.
# Never commit real secrets.

# Required
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Stripe (live keys for production)
STRIPE_SECRET_KEY=sk_live_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# BNHub platform fee on short-term bookings (default 0.15 = 15%)
# BNHUB_COMMISSION_RATE=0.15

# Transactional email (set one provider path — see lib/email/provider.ts)
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=
# RESEND_API_KEY=
# EMAIL_FROM="Mashhour <bookings@your-domain.com>"
# EMAIL_REPLY_TO=support@your-domain.com

# Public marketing (shown in footer / home; NEXT_PUBLIC_* required for client-side display)
# NEXT_PUBLIC_CONTACT_EMAIL=hello@your-domain.com
# NEXT_PUBLIC_CONTACT_PHONE="+1 (514) 555-1234"
# NEXT_PUBLIC_SOCIAL_LINKEDIN_URL=https://www.linkedin.com/company/your-org
# NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=https://www.instagram.com/your-org
# NEXT_PUBLIC_SOCIAL_X_URL=https://x.com/your-org

# Optional
# DESIGN_STUDIO_PRICE_CENTS=500
# DESIGN_STUDIO_TRIAL_DAYS=7

# Do not set demo user IDs in production
# NEXT_PUBLIC_DEMO_GUEST_ID=
# NEXT_PUBLIC_DEMO_HOST_ID=
