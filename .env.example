# =============================================================================
# Monorepo environment — NO real secrets in git (team rule)
# =============================================================================
# Each developer copies the relevant *.env.example → .env locally.
# Never commit .env, .env.local, or production keys.
#
# Pointers:
# - Web (Prisma, BNHub): apps/web/.env.example
# - Admin: apps/admin/.env.example (if present)
# - Mobile (Expo): apps/mobile/.env.example (EXPO_PUBLIC_*)
# - Services: each service may ship services/<name>/.env.example
#
# Onboarding: docs/onboarding.md
# =============================================================================
#
# Vercel / production minimum — define ALL of these in Vercel → Project → Settings → Environment Variables
# (Production + Preview as needed). Prisma reads DATABASE_URL at generate/build time.
# Full local template for @lecipm/web: apps/web/.env.example
#
DATABASE_URL=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

NEXT_PUBLIC_APP_URL=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

CRON_SECRET=

# -----------------------------------------------------------------------------
# Local monorepo default
# -----------------------------------------------------------------------------
NODE_ENV=development
