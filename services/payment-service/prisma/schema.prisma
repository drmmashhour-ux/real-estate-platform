generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Shared BNHub enums (match booking-service / web-app when sharing DB)
// ---------------------------------------------------------------------------
enum PlatformRole {
  USER
  LICENSED_PROFESSIONAL
  OWNER_HOST
  INVESTOR
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ---------------------------------------------------------------------------
// BNHub models (read/write when sharing DB with booking-service)
// ---------------------------------------------------------------------------
model User {
  id                 String             @id @default(uuid())
  email              String             @unique
  role               PlatformRole       @default(USER)
  name               String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  shortTermListings  ShortTermListing[]
  bookingsAsGuest    Booking[]
}

model ShortTermListing {
  id                  String             @id @default(uuid())
  title               String
  description         String?
  address             String
  city                String
  country             String             @default("US")
  latitude            Float?
  longitude           Float?
  nightPriceCents     Int
  beds                Int
  baths               Float
  maxGuests           Int                @default(4)
  photos              String[]
  verificationStatus  VerificationStatus @default(PENDING)
  cadastreNumber      String?
  verificationDocUrl  String?
  verifiedAt          DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  ownerId             String
  owner               User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  bookings            Booking[]

  @@index([ownerId])
}

model Booking {
  id              String        @id @default(uuid())
  checkIn         DateTime      @db.Date
  checkOut        DateTime      @db.Date
  nights          Int
  totalCents      Int
  guestFeeCents   Int           @default(0)
  hostFeeCents    Int           @default(0)
  status          BookingStatus  @default(PENDING)
  guestNotes      String?
  checkedInAt     DateTime?
  checkedOutAt    DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  guestId         String
  guest           User          @relation(fields: [guestId], references: [id], onDelete: Cascade)
  listingId       String
  listing         ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  payment         Payment?

  @@index([guestId])
  @@index([listingId])
  @@index([status])
}

model Payment {
  id               String        @id @default(uuid())
  amountCents      Int
  guestFeeCents    Int
  hostFeeCents     Int
  hostPayoutCents  Int
  status           PaymentStatus @default(PENDING)
  stripePaymentId  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  bookingId        String        @unique
  booking          Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  intent           PaymentIntent?
  transactions     Transaction[]
  payoutPayments   PayoutPayment[]

  @@index([status])
}

// ---------------------------------------------------------------------------
// Payment service: escrow intent (hold then capture)
// ---------------------------------------------------------------------------
enum IntentStatus {
  CREATED   // Intent created with provider
  HELD      // Funds held (authorized)
  CAPTURED  // Captured (booking confirmed)
  CANCELLED
  FAILED
}

model PaymentIntent {
  id                String       @id @default(uuid())
  bookingId         String
  paymentId         String       @unique
  payment           Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  amountCents       Int
  currency          String       @default("usd")
  providerIntentId  String?       // Provider's payment intent / authorization ID
  status            IntentStatus  @default(CREATED)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([bookingId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Transaction history (audit log)
// ---------------------------------------------------------------------------
enum TransactionType {
  INTENT_CREATED
  INTENT_HELD
  CAPTURED
  REFUNDED
  PAYOUT_PREPARED
  PAYOUT_SENT
}

model Transaction {
  id               String          @id @default(uuid())
  type             TransactionType
  paymentId        String?
  payment          Payment?        @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  paymentIntentId  String?
  payoutId         String?
  payout           Payout?         @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  amountCents      Int
  providerRef      String?        // Provider's transaction/refund ID
  metadata         String?        // JSON for extra data
  createdAt        DateTime       @default(now())

  @@index([paymentId])
  @@index([type])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Payout preparation (batch host payouts)
// ---------------------------------------------------------------------------
enum PayoutStatus {
  PENDING
  SENT
  FAILED
}

model Payout {
  id               String          @id @default(uuid())
  hostId           String          // Listing owner to pay
  totalCents       Int
  status           PayoutStatus    @default(PENDING)
  providerPayoutId String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  payments         PayoutPayment[]
  transactions     Transaction[]

  @@index([hostId])
  @@index([status])
}

model PayoutPayment {
  payoutId   String
  payout     Payout   @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  paymentId  String
  payment    Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([payoutId, paymentId])
  @@index([paymentId])
}
