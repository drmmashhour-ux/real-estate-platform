generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Shared BNHub enums (match booking-service / web-app when sharing DB)
// ---------------------------------------------------------------------------
enum PlatformRole {
  USER
  LICENSED_PROFESSIONAL
  OWNER_HOST
  INVESTOR
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ---------------------------------------------------------------------------
// BNHub models (read/write when sharing DB with booking-service)
// ---------------------------------------------------------------------------
model User {
  id                 String             @id @default(uuid())
  email              String             @unique
  role               PlatformRole       @default(USER)
  name               String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  shortTermListings  ShortTermListing[]
  bookingsAsGuest    Booking[]
}

model ShortTermListing {
  id                  String             @id @default(uuid())
  title               String
  description         String?
  address             String
  city                String
  country             String             @default("US")
  latitude            Float?
  longitude           Float?
  nightPriceCents     Int
  beds                Int
  baths               Float
  maxGuests           Int                @default(4)
  photos              String[]
  verificationStatus  VerificationStatus @default(PENDING)
  cadastreNumber      String?
  verificationDocUrl  String?
  verifiedAt          DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  ownerId             String
  owner               User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  bookings            Booking[]

  @@index([ownerId])
}

model Booking {
  id              String        @id @default(uuid())
  checkIn         DateTime      @db.Date
  checkOut        DateTime      @db.Date
  nights          Int
  totalCents      Int
  guestFeeCents   Int           @default(0)
  hostFeeCents    Int           @default(0)
  status          BookingStatus  @default(PENDING)
  guestNotes      String?
  checkedInAt     DateTime?
  checkedOutAt    DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  guestId         String
  guest           User          @relation(fields: [guestId], references: [id], onDelete: Cascade)
  listingId       String
  listing         ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  payment         Payment?

  @@index([guestId])
  @@index([listingId])
  @@index([status])
}

model Payment {
  id               String        @id @default(uuid())
  amountCents      Int
  guestFeeCents    Int
  hostFeeCents     Int
  hostPayoutCents  Int
  status           PaymentStatus @default(PENDING)
  stripePaymentId  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  bookingId        String        @unique
  booking          Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  intent           PaymentIntent?
  transactions     Transaction[]
  payoutPayments   PayoutPayment[]

  @@index([status])
}

// ---------------------------------------------------------------------------
// Payment service: escrow intent (hold then capture)
// ---------------------------------------------------------------------------
enum IntentStatus {
  CREATED   // Intent created with provider
  HELD      // Funds held (authorized)
  CAPTURED  // Captured (booking confirmed)
  CANCELLED
  FAILED
}

model PaymentIntent {
  id                String       @id @default(uuid())
  bookingId         String
  paymentId         String       @unique
  payment           Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  amountCents       Int
  currency          String       @default("usd")
  providerIntentId  String?       // Provider's payment intent / authorization ID
  status            IntentStatus  @default(CREATED)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([bookingId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Transaction history (audit log)
// ---------------------------------------------------------------------------
enum TransactionType {
  INTENT_CREATED
  INTENT_HELD
  CAPTURED
  REFUNDED
  PAYOUT_PREPARED
  PAYOUT_SENT
}

model Transaction {
  id               String          @id @default(uuid())
  type             TransactionType
  paymentId        String?
  payment          Payment?        @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  paymentIntentId  String?
  payoutId         String?
  payout           Payout?         @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  amountCents      Int
  providerRef      String?        // Provider's transaction/refund ID
  metadata         String?        // JSON for extra data
  createdAt        DateTime       @default(now())

  @@index([paymentId])
  @@index([type])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Payout preparation (batch host payouts)
// ---------------------------------------------------------------------------
enum PayoutStatus {
  PENDING
  SENT
  FAILED
}

model Payout {
  id               String          @id @default(uuid())
  hostId           String          // Listing owner to pay
  totalCents       Int
  status           PayoutStatus    @default(PENDING)
  providerPayoutId String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  payments         PayoutPayment[]
  transactions     Transaction[]

  @@index([hostId])
  @@index([status])
}

model PayoutPayment {
  payoutId   String
  payout     Payout   @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  paymentId  String
  payment    Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([payoutId, paymentId])
  @@index([paymentId])
}

// ---------------------------------------------------------------------------
// Syria financial foundation (architecture-only; no live payment execution)
// ---------------------------------------------------------------------------
enum SyriaFinancialTransactionStatus {
  PENDING
  AUTHORIZED
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
  DISPUTED
}

enum SyriaFinancialPayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum SyriaFinancialAuditEventType {
  PAYMENT_ATTEMPT
  PAYOUT_ATTEMPT
  VERIFICATION_CHANGE
  ADMIN_ACTION
  SUSPICIOUS_EVENT
  PROVIDER_FAILURE
  API_FAILURE
}

enum SyriaFinancialKycStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
  REQUIRES_MORE_INFO
}

enum SyriaFinancialVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum SyriaFinancialApprovalWorkflowStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
}

enum SyriaFinancialRiskSignalType {
  DUPLICATE_PAYMENT
  VELOCITY
  SUSPICIOUS_IP
  REPEATED_FAILURE
  PROVIDER_ANOMALY
}

model SyriaFinancialTransaction {
  id              String                            @id @default(uuid())
  provider        String                            @db.VarChar(64)
  amount          Int
  currency        String                            @db.VarChar(3)
  bookingId       String
  payerId         String
  merchantId      String
  status          SyriaFinancialTransactionStatus   @default(PENDING)
  idempotencyKey  String?
  retryAttempt    Int                               @default(0)
  maxRetryAttempts Int                              @default(3)
  nextRetryAt     DateTime?
  metadata        Json                              @default("{}")
  auditTrail      Json                              @default("[]")
  createdAt       DateTime                          @default(now())
  updatedAt       DateTime                          @updatedAt
  completedAt     DateTime?
  deletedAt       DateTime?

  @@unique([provider, idempotencyKey])
  @@index([bookingId])
  @@index([payerId])
  @@index([merchantId])
  @@index([status])
  @@index([createdAt])
  @@map("syria_financial_transactions")
}

model SyriaFinancialWallet {
  id              String                              @id @default(uuid())
  merchantId      String
  currency        String                              @db.VarChar(3)
  availableBalance Int                                @default(0)
  pendingBalance   Int                                @default(0)
  payoutBalance    Int                                @default(0)
  refundBalance    Int                                @default(0)
  holdBalance      Int                                @default(0)
  ledgerEntries    SyriaFinancialWalletLedgerEntry[]
  createdAt       DateTime                            @default(now())
  updatedAt       DateTime                            @updatedAt
  deletedAt       DateTime?

  @@unique([merchantId, currency])
  @@index([merchantId])
  @@map("syria_financial_wallets")
}

model SyriaFinancialWalletLedgerEntry {
  id                      String                 @id @default(uuid())
  walletId                String
  wallet                  SyriaFinancialWallet   @relation(fields: [walletId], references: [id], onDelete: Restrict)
  immutableTransactionId  String
  referenceType           String                 @db.VarChar(64)
  referenceId             String
  balanceDelta            Json                   @default("{}")
  metadata                Json                   @default("{}")
  correlationId           String
  createdAt               DateTime               @default(now())

  @@unique([walletId, immutableTransactionId])
  @@index([referenceType, referenceId])
  @@index([correlationId])
  @@index([createdAt])
  @@map("syria_financial_wallet_ledger_entries")
}

model SyriaFinancialPayout {
  id                    String                       @id @default(uuid())
  merchantId            String
  provider              String                       @db.VarChar(64)
  amount                Int
  currency              String                       @db.VarChar(3)
  destinationReference  String?
  status                SyriaFinancialPayoutStatus   @default(PENDING)
  idempotencyKey        String?
  providerPayoutId      String?
  metadata              Json                         @default("{}")
  auditTrail            Json                         @default("[]")
  correlationId         String
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  completedAt           DateTime?
  deletedAt             DateTime?

  @@unique([provider, idempotencyKey])
  @@index([merchantId])
  @@index([status])
  @@index([correlationId])
  @@map("syria_financial_payouts")
}

model SyriaFinancialProviderEvent {
  id               String    @id @default(uuid())
  provider         String    @db.VarChar(64)
  eventType        String    @db.VarChar(128)
  providerEventId  String?
  processingStatus String    @db.VarChar(64)
  metadata         Json      @default("{}")
  correlationId    String
  receivedAt       DateTime  @default(now())
  processedAt      DateTime?
  deletedAt        DateTime?

  @@unique([provider, providerEventId])
  @@index([provider])
  @@index([eventType])
  @@index([processingStatus])
  @@index([correlationId])
  @@map("syria_financial_provider_events")
}

model SyriaFinancialAuditLog {
  id             String                         @id @default(uuid())
  eventType      SyriaFinancialAuditEventType
  actorType      String                         @db.VarChar(64)
  actorId        String?
  targetType     String                         @db.VarChar(128)
  targetId       String?
  correlationId  String
  metadata       Json                           @default("{}")
  createdAt      DateTime                       @default(now())

  @@index([eventType])
  @@index([actorType, actorId])
  @@index([targetType, targetId])
  @@index([correlationId])
  @@index([createdAt])
  @@map("syria_financial_audit_logs")
}

model SyriaFinancialPaymentEvent {
  id                String    @id @default(uuid())
  provider          String    @db.VarChar(64)
  eventType         String    @db.VarChar(128)
  providerEventId   String?
  processingStatus  String    @db.VarChar(64)
  metadata          Json      @default("{}")
  correlationId     String
  receivedAt        DateTime  @default(now())
  processedAt       DateTime?
  deletedAt         DateTime?

  @@index([provider])
  @@index([eventType])
  @@index([processingStatus])
  @@index([correlationId])
  @@map("syria_financial_payment_events")
}

model SyriaFinancialMerchantProfile {
  id                             String                                  @id @default(uuid())
  merchantId                     String                                  @unique
  displayName                    String
  countryCode                    String                                  @default("SY") @db.VarChar(2)
  kycStatus                      SyriaFinancialKycStatus                 @default(NOT_STARTED)
  identityVerificationStatus     SyriaFinancialVerificationStatus        @default(UNVERIFIED)
  bankAccountVerificationStatus  SyriaFinancialVerificationStatus        @default(UNVERIFIED)
  approvalWorkflowStatus         SyriaFinancialApprovalWorkflowStatus    @default(DRAFT)
  metadata                       Json                                    @default("{}")
  documents                      SyriaFinancialMerchantDocument[]
  createdAt                      DateTime                                @default(now())
  updatedAt                      DateTime                                @updatedAt
  deletedAt                      DateTime?

  @@index([kycStatus])
  @@index([approvalWorkflowStatus])
  @@map("syria_financial_merchant_profiles")
}

model SyriaFinancialMerchantDocument {
  id              String                         @id @default(uuid())
  merchantProfileId String
  merchantProfile   SyriaFinancialMerchantProfile @relation(fields: [merchantProfileId], references: [id], onDelete: Restrict)
  documentType    String                         @db.VarChar(64)
  storageRef      String
  checksum        String?
  exposedPublicly Boolean                        @default(false)
  metadata        Json                           @default("{}")
  uploadedAt      DateTime                       @default(now())
  deletedAt       DateTime?

  @@index([merchantProfileId])
  @@index([documentType])
  @@map("syria_financial_merchant_documents")
}

model SyriaFinancialRiskSignal {
  id             String                         @id @default(uuid())
  signalType     SyriaFinancialRiskSignalType
  subjectId      String
  severity       String                         @db.VarChar(32)
  passiveOnly    Boolean                        @default(true)
  metadata       Json                           @default("{}")
  correlationId  String
  observedAt     DateTime                       @default(now())
  deletedAt      DateTime?

  @@index([signalType])
  @@index([subjectId])
  @@index([severity])
  @@index([correlationId])
  @@index([observedAt])
  @@map("syria_financial_risk_signals")
}
