generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Shared BNHub enums (match booking-service / web-app when sharing DB)
// ---------------------------------------------------------------------------
enum PlatformRole {
  USER
  LICENSED_PROFESSIONAL
  OWNER_HOST
  INVESTOR
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ---------------------------------------------------------------------------
// BNHub models (read/write when sharing DB with booking-service)
// ---------------------------------------------------------------------------
model User {
  id                 String             @id @default(uuid())
  email              String             @unique
  role               PlatformRole       @default(USER)
  name               String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  shortTermListings  ShortTermListing[]
  bookingsAsGuest    Booking[]
}

model ShortTermListing {
  id                  String             @id @default(uuid())
  title               String
  description         String?
  address             String
  city                String
  country             String             @default("US")
  latitude            Float?
  longitude           Float?
  nightPriceCents     Int
  beds                Int
  baths               Float
  maxGuests           Int                @default(4)
  photos              String[]
  verificationStatus  VerificationStatus @default(PENDING)
  cadastreNumber      String?
  verificationDocUrl  String?
  verifiedAt          DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  ownerId             String
  owner               User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  bookings            Booking[]

  @@index([ownerId])
}

model Booking {
  id              String        @id @default(uuid())
  checkIn         DateTime      @db.Date
  checkOut        DateTime      @db.Date
  nights          Int
  totalCents      Int
  guestFeeCents   Int           @default(0)
  hostFeeCents    Int           @default(0)
  status          BookingStatus  @default(PENDING)
  guestNotes      String?
  checkedInAt     DateTime?
  checkedOutAt    DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  guestId         String
  guest           User          @relation(fields: [guestId], references: [id], onDelete: Cascade)
  listingId       String
  listing         ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  payment         Payment?

  @@index([guestId])
  @@index([listingId])
  @@index([status])
}

model Payment {
  id               String        @id @default(uuid())
  amountCents      Int
  guestFeeCents    Int
  hostFeeCents     Int
  hostPayoutCents  Int
  status           PaymentStatus @default(PENDING)
  stripePaymentId  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  bookingId        String        @unique
  booking          Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  intent           PaymentIntent?
  transactions     Transaction[]
  payoutPayments   PayoutPayment[]

  @@index([status])
}

// ---------------------------------------------------------------------------
// Payment service: escrow intent (hold then capture)
// ---------------------------------------------------------------------------
enum IntentStatus {
  CREATED   // Intent created with provider
  HELD      // Funds held (authorized)
  CAPTURED  // Captured (booking confirmed)
  CANCELLED
  FAILED
}

model PaymentIntent {
  id                String       @id @default(uuid())
  bookingId         String
  paymentId         String       @unique
  payment           Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  amountCents       Int
  currency          String       @default("usd")
  providerIntentId  String?       // Provider's payment intent / authorization ID
  status            IntentStatus  @default(CREATED)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([bookingId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Transaction history (audit log)
// ---------------------------------------------------------------------------
enum TransactionType {
  INTENT_CREATED
  INTENT_HELD
  CAPTURED
  REFUNDED
  PAYOUT_PREPARED
  PAYOUT_SENT
}

model Transaction {
  id               String          @id @default(uuid())
  type             TransactionType
  paymentId        String?
  payment          Payment?        @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  paymentIntentId  String?
  payoutId         String?
  payout           Payout?         @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  amountCents      Int
  providerRef      String?        // Provider's transaction/refund ID
  metadata         String?        // JSON for extra data
  createdAt        DateTime       @default(now())

  @@index([paymentId])
  @@index([type])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Payout preparation (batch host payouts)
// ---------------------------------------------------------------------------
enum PayoutStatus {
  PENDING
  SENT
  FAILED
}

model Payout {
  id               String          @id @default(uuid())
  hostId           String          // Listing owner to pay
  totalCents       Int
  status           PayoutStatus    @default(PENDING)
  providerPayoutId String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  payments         PayoutPayment[]
  transactions     Transaction[]

  @@index([hostId])
  @@index([status])
}

model PayoutPayment {
  payoutId   String
  payout     Payout   @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  paymentId  String
  payment    Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([payoutId, paymentId])
  @@index([paymentId])
}

// ---------------------------------------------------------------------------
// Syria financial foundation: architecture-only, no live payment execution
// ---------------------------------------------------------------------------
enum SyriaFinancialProvider {
  provider_stub
  provider_qnb_stub
  provider_chamcash_stub
}

enum SyriaFinancialTransactionStatus {
  pending
  authorized
  processing
  completed
  failed
  refunded
  cancelled
  disputed
}

enum SyriaFinancialPayoutStatus {
  pending
  processing
  completed
  failed
  cancelled
}

enum SyriaMerchantKycStatus {
  not_started
  pending
  approved
  rejected
  requires_review
}

enum SyriaVerificationStatus {
  unverified
  pending
  verified
  rejected
}

enum SyriaMerchantApprovalStatus {
  draft
  submitted
  approved
  rejected
  suspended
}

enum SyriaFinancialAuditCategory {
  payment_attempt
  payout_attempt
  verification_change
  admin_action
  suspicious_event
  provider_failure
  api_failure
}

enum SyriaPaymentEventStatus {
  received
  validated
  rejected
  processed
}

enum SyriaRiskSignalType {
  duplicate_payment
  velocity
  suspicious_ip
  repeated_failure
  provider_anomaly
}

model SyriaFinancialTransaction {
  id              String                           @id @default(uuid())
  provider        SyriaFinancialProvider
  amountMinor     Int
  currency        String
  bookingId       String
  payerId         String
  merchantId      String
  status          SyriaFinancialTransactionStatus @default(pending)
  idempotencyKey  String                           @unique
  providerRef     String?
  metadata        Json
  auditTrail      Json
  createdAt       DateTime                         @default(now())
  updatedAt       DateTime                         @updatedAt
  deletedAt       DateTime?

  @@index([bookingId])
  @@index([payerId])
  @@index([merchantId])
  @@index([provider, status])
  @@index([createdAt])
  @@map("syria_financial_transactions")
}

model SyriaFinancialWallet {
  id                    String   @id @default(uuid())
  ownerId               String   @unique
  currency              String
  availableBalanceMinor Int      @default(0)
  pendingBalanceMinor   Int      @default(0)
  payoutBalanceMinor    Int      @default(0)
  refundBalanceMinor    Int      @default(0)
  holdBalanceMinor      Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  deletedAt             DateTime?
  ledgerEntries         SyriaFinancialWalletLedgerEntry[]

  @@index([ownerId])
  @@map("syria_financial_wallets")
}

model SyriaFinancialWalletLedgerEntry {
  id                 String   @id @default(uuid())
  walletId           String
  wallet             SyriaFinancialWallet @relation(fields: [walletId], references: [id], onDelete: Restrict)
  transactionId      String
  bookingId          String?
  providerReference  String?
  amountMinor        Int
  currency           String
  ledgerBucket       String
  metadata           Json
  createdAt          DateTime @default(now())

  @@index([walletId])
  @@index([transactionId])
  @@map("syria_financial_wallet_ledger_entries")
}

model SyriaFinancialPayout {
  id              String                    @id @default(uuid())
  merchantId      String
  provider        SyriaFinancialProvider
  amountMinor     Int
  currency        String
  status          SyriaFinancialPayoutStatus @default(pending)
  idempotencyKey  String                    @unique
  providerRef     String?
  metadata        Json
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  deletedAt       DateTime?

  @@index([merchantId])
  @@index([provider, status])
  @@map("syria_financial_payouts")
}

model SyriaFinancialAuditLog {
  id                    String                      @id @default(uuid())
  category              SyriaFinancialAuditCategory
  action                String
  actorType             String
  actorId               String?
  requestCorrelationId  String
  targetId              String?
  metadata              Json
  previousHash          String?
  recordHash            String?
  createdAt             DateTime                    @default(now())

  @@index([category])
  @@index([actorType, actorId])
  @@index([requestCorrelationId])
  @@index([createdAt])
  @@map("syria_financial_audit_logs")
}

model SyriaPaymentEvent {
  id               String                  @id @default(uuid())
  provider         SyriaFinancialProvider
  providerEventId  String
  eventType        String
  transactionId    String?
  correlationId    String
  status           SyriaPaymentEventStatus @default(received)
  payload          Json
  receivedAt       DateTime                @default(now())
  processedAt      DateTime?
  deletedAt        DateTime?

  @@unique([provider, providerEventId])
  @@index([transactionId])
  @@index([correlationId])
  @@map("syria_payment_events")
}

model SyriaMerchantProfile {
  id                             String                        @id @default(uuid())
  merchantId                     String                        @unique
  legalName                      String
  countryCode                    String                        @default("SY")
  kycStatus                      SyriaMerchantKycStatus        @default(not_started)
  identityVerificationStatus     SyriaVerificationStatus       @default(unverified)
  bankAccountVerificationStatus  SyriaVerificationStatus       @default(unverified)
  approvalStatus                 SyriaMerchantApprovalStatus   @default(draft)
  documentReferences             Json
  reviewNotes                    String?
  createdAt                      DateTime                      @default(now())
  updatedAt                      DateTime                      @updatedAt
  deletedAt                      DateTime?

  @@index([kycStatus])
  @@index([approvalStatus])
  @@map("syria_merchant_profiles")
}

model SyriaFinancialRiskSignal {
  id                      String                @id @default(uuid())
  type                    SyriaRiskSignalType
  severity                String
  subjectId               String
  correlationId           String
  metadata                Json
  passiveMonitoringOnly   Boolean               @default(true)
  detectedAt              DateTime              @default(now())
  resolvedAt              DateTime?
  deletedAt               DateTime?

  @@index([type])
  @@index([subjectId])
  @@index([detectedAt])
  @@map("syria_financial_risk_signals")
}

model SyriaProviderHealthSnapshot {
  id               String                 @id @default(uuid())
  provider         SyriaFinancialProvider
  status           String
  liveConnectivity Boolean                @default(false)
  details          Json
  checkedAt        DateTime               @default(now())

  @@index([provider])
  @@index([checkedAt])
  @@map("syria_provider_health_snapshots")
}
