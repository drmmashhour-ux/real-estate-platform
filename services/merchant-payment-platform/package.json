{
  "name": "@merchant-payments/platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "prisma generate --schema prisma/schema.prisma && tsc",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "test": "prisma generate --schema prisma/schema.prisma && node --import tsx --test src/__tests__/*.test.ts",
    "lint": "eslint src --ext .ts --ignore-pattern src/generated/**"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.20.0"
  }
}
