generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ListingType {
  MARKETPLACE_SALE
  MARKETPLACE_RENT
  BNHUB
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  LIVE
  SUSPENDED
  ARCHIVED
}

enum MediaType {
  PHOTO
}

model Property {
  id                   String         @id @default(uuid())
  ownerId              String         @map("owner_id")
  brokerId             String?        @map("broker_id")
  type                 ListingType
  status               ListingStatus  @default(DRAFT)
  title                String
  description          String?
  propertyType         String?        @map("property_type")
  address              String
  city                 String
  region               String?
  country              String         @default("CA")
  latitude             Float?
  longitude            Float?
  priceCents           Int?           @map("price_cents")
  currency             String         @default("CAD")
  nightlyPriceCents    Int?           @map("nightly_price_cents")
  cleaningFeeCents     Int?           @map("cleaning_fee_cents") @default(0)
  maxGuests            Int?           @map("max_guests")
  bedrooms             Int?
  beds                 Int?
  baths                Float?
  checkInTime          String?        @map("check_in_time")
  checkOutTime         String?        @map("check_out_time")
  houseRules           String?        @map("house_rules")
  minNights            Int?           @map("min_nights") @default(1)
  maxNights            Int?           @map("max_nights")
  registrationNumber   String?        @map("registration_number")
  reviewedAt           DateTime?      @map("reviewed_at")
  rejectionReason      String?        @map("rejection_reason")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  deletedAt            DateTime?      @map("deleted_at")

  images   PropertyImage[]
  amenities PropertyAmenity[]

  @@index([ownerId])
  @@index([status])
  @@index([type])
  @@index([city, country])
  @@map("properties")
}

model PropertyImage {
  id         String     @id @default(uuid())
  propertyId String     @map("property_id")
  url        String
  type       MediaType  @default(PHOTO)
  sortOrder  Int        @default(0) @map("sort_order")
  createdAt  DateTime   @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_images")
}

model PropertyAmenity {
  id          String   @id @default(uuid())
  propertyId  String   @map("property_id")
  amenityKey  String   @map("amenity_key")
  createdAt   DateTime @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, amenityKey])
  @@index([propertyId])
  @@map("property_amenities")
}
