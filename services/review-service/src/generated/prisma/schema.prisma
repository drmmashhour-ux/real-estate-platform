generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Shared BNHub models (read-only when sharing DB with web-app/booking-service)
// ---------------------------------------------------------------------------
enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  name              String?
  shortTermListings ShortTermListing[]
  bookingsAsGuest   Booking[]
  reviewsGiven      Review[]
}

model ShortTermListing {
  id       String    @id @default(uuid())
  title    String
  ownerId  String
  owner    User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  bookings Booking[]
  reviews  Review[]

  @@index([ownerId])
}

model Booking {
  id        String           @id @default(uuid())
  status    BookingStatus    @default(PENDING)
  guestId   String
  guest     User             @relation(fields: [guestId], references: [id], onDelete: Cascade)
  listingId String
  listing   ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  review    Review?

  @@index([guestId])
  @@index([listingId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Reviews with moderation
// ---------------------------------------------------------------------------
enum ReviewStatus {
  PENDING // Awaiting moderation
  APPROVED // Visible
  REJECTED // Hidden, with reason
}

model Review {
  id              String           @id @default(uuid())
  propertyRating  Int // 1-5 listing rating
  hostRating      Int? // 1-5 optional host rating
  comment         String?          @db.Text
  status          ReviewStatus     @default(PENDING)
  moderatedAt     DateTime?
  moderatorId     String?
  rejectionReason String?          @db.Text
  createdAt       DateTime         @default(now())
  guestId         String
  guest           User             @relation(fields: [guestId], references: [id], onDelete: Cascade)
  listingId       String
  listing         ShortTermListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bookingId       String           @unique
  booking         Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([guestId])
  @@index([status])
  @@index([createdAt])
}
